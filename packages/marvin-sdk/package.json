{
  "name": "@marvin/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for Marvin CMS",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts"
  },
