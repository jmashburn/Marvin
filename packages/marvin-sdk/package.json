    "publishing",
    "workspace",
    "astro",
    "nextjs",
    "nuxt"
  ],
  "author": "Marvin Project",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmashburn/Marvin.git",
    "directory": "packages/marvin-sdk"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
