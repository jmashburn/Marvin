{
  "name": "@marvin/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for Marvin CMS",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./publish": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "examples.md",
    "QUICKSTART.md"
  ],
  "keywords": [
    "marvin",
    "cms",
    "sdk",
    "typescript",
    "headless-cms",
    "publishing",
    "workspace",
    "astro",
    "nextjs",
    "nuxt"
  ],
  "author": {
    "name": "Marvin Project",
    "email": "contact@inneropen.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inneropen/marvin-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/inneropen/marvin-sdk/issues"
  },
  "homepage": "https://github.com/inneropen/marvin-sdk#readme",
  "scripts": {
    "build": "tsup src/index.ts src/types/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts src/types/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "tsup": "^8.5.1"
  }
}
