# Marvin Publishing Client Configuration
# Copy this file to .env and fill in your values

# Marvin API URL (no trailing slash)
MARVIN_API_URL=https://marvin.example.com

# Site Client Token
# Get this from Marvin: Settings > Publishing > Site Clients
MARVIN_SITE_CLIENT_TOKEN=your-site-client-token-here

# Workspace Slug
# The slug of your Marvin workspace (e.g., "mash-burn")
MARVIN_WORKSPACE_SLUG=your-workspace-slug
