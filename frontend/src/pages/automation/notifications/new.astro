---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);

let eventOptions: any[] = [];
let error: string | null = null;
let appriseReady = false;

// Check if Apprise is available
try {
  const configCheck = await fetchApi<any>('/api/admin/about/check', {}, authToken);
  appriseReady = configCheck?.apprise_ready === true;
} catch (e) {
  console.error('[notifications/new] Error checking Apprise availability:', e);
}

// Redirect if Apprise is not available
if (!appriseReady) {
  return Astro.redirect('/automation/notifications');
}

try {
  const response = await fetchApi<any>('/api/event/options', {}, authToken);
  eventOptions = response.items || [];
} catch (e) {
  console.error('[notifications/new] Error loading events:', e);
  error = e instanceof Error ? e.message : String(e);
}

// Pre-select commonly used events
const defaultEvents = [
  'core.entry_created',
  'core.entry_published',
  'core.site_deployment_failed',
  'core.site_build_failed',
  'core.backup_failed',
  'core.storage_quota_exceeded'
];
---

<AppLayout title="Create Notification" eyebrow="Automation">
  <div class="page-header">
    <div>
      <h2>Create Event Notification</h2>
      <p>Set up a new notification endpoint and subscribe to events</p>
    </div>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : (
    <div class="form-container">
      <form id="create-notification-form" class="form">
        <div class="form-section">
          <h3>Notification Details</h3>

          <label class="form-field">
            <span class="label">Name *</span>
            <input
              type="text"
              name="name"
              required
              placeholder="Slack Notifications"
              class="input"
            />
          </label>

          <label class="form-field">
            <span class="label">Apprise URL *</span>
            <input
              type="text"
              name="apprise_url"
              required
              placeholder="slack://token/channel"
              class="input"
            />
            <small class="hint">
              Apprise notification URL. See <a href="https://github.com/caronc/apprise" target="_blank" rel="noopener">Apprise docs</a> for formats.
              Examples: <code>slack://token/channel</code>, <code>mailto://user:pass@domain.com</code>
            </small>
          </label>

          <label class="form-field checkbox-field">
            <input type="checkbox" name="enabled" checked />
            <span>Enabled</span>
          </label>
        </div>

        <div class="form-section">
          <div class="section-header">
            <div>
              <h3>Event Subscriptions</h3>
              <p class="section-description">Select which events should trigger this notification</p>
            </div>
            <div class="selection-actions">
              <button type="button" id="select-all" class="link-button">Select All</button>
              <span class="separator">•</span>
              <button type="button" id="select-none" class="link-button">Clear All</button>
              <span class="separator">•</span>
              <button type="button" id="select-defaults" class="link-button">Select Defaults</button>
            </div>
          </div>

          <div class="search-field">
            <input
              type="text"
              id="event-search"
              placeholder="Search events..."
              class="input"
            />
          </div>

          <div class="events-checklist" id="events-checklist">
            {eventOptions.map((event) => {
              const optionValue = event.option || `core.${event.slug || event.name.toLowerCase().replace(/\s+/g, '_')}`;
              const isDefault = defaultEvents.includes(optionValue);
              return (
                <label
                  class="event-checkbox"
                  data-event-name={event.name.toLowerCase()}
                  data-event-description={event.description?.toLowerCase() || ''}
                >
                  <input
                    type="checkbox"
                    name="events"
                    value={optionValue}
                    checked={isDefault}
                  />
                  <div class="event-checkbox-content">
                    <span class="event-checkbox-name">{event.name}</span>
                    {event.description && (
                      <span class="event-checkbox-description">{event.description}</span>
                    )}
                  </div>
                </label>
              );
            })}
          </div>

          <div class="selection-summary">
            <span id="selection-count">6 events selected</span>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="button">Create Notification</button>
          <a href="/automation/notifications" class="button secondary">Cancel</a>
        </div>
      </form>
    </div>
  )}
</AppLayout>

<script>
  // HttpOnly cookie is automatically sent with credentials: 'include'
  const form = document.getElementById('create-notification-form');
  const checkboxes = document.querySelectorAll('input[name="events"]') as NodeListOf<HTMLInputElement>;
  const searchInput = document.getElementById('event-search') as HTMLInputElement;
  const eventCheckboxes = document.querySelectorAll('.event-checkbox');
  const selectionCount = document.getElementById('selection-count');
  const selectAllBtn = document.getElementById('select-all');
  const selectNoneBtn = document.getElementById('select-none');
  const selectDefaultsBtn = document.getElementById('select-defaults');

  // Default events to select
  const defaultEvents = [
    'core.entry_created',
    'core.entry_published',
    'core.site_deployment_failed',
    'core.site_build_failed',
    'core.backup_failed',
    'core.storage_quota_exceeded'
  ];

  // Update selection count
  function updateSelectionCount() {
    const checked = Array.from(checkboxes).filter(cb => cb.checked).length;
    if (selectionCount) {
      selectionCount.textContent = `${checked} event${checked !== 1 ? 's' : ''} selected`;
    }
  }

  // Search filter
  searchInput?.addEventListener('input', () => {
    const searchTerm = searchInput.value.toLowerCase();
    eventCheckboxes.forEach(label => {
      const name = label.getAttribute('data-event-name') || '';
      const description = label.getAttribute('data-event-description') || '';
      const matches = searchTerm === '' || name.includes(searchTerm) || description.includes(searchTerm);
      (label as HTMLElement).style.display = matches ? 'flex' : 'none';
    });
  });

  // Selection actions
  selectAllBtn?.addEventListener('click', () => {
    checkboxes.forEach(cb => cb.checked = true);
    updateSelectionCount();
  });

  selectNoneBtn?.addEventListener('click', () => {
    checkboxes.forEach(cb => cb.checked = false);
    updateSelectionCount();
  });

  selectDefaultsBtn?.addEventListener('click', () => {
    checkboxes.forEach(cb => {
      cb.checked = defaultEvents.includes(cb.value);
    });
    updateSelectionCount();
  });

  // Update count on checkbox change
  checkboxes.forEach(cb => {
    cb.addEventListener('change', updateSelectionCount);
  });

  // Form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);

    // Get all checked event options
    const selectedEvents = Array.from(checkboxes)
      .filter(cb => cb.checked)
      .map(cb => cb.value);

    const payload = {
      name: formData.get('name'),
      apprise_url: formData.get('apprise_url'),
      enabled: formData.get('enabled') === 'on',
      options: selectedEvents,
    };

    try {
      const { fetchApi } = await import('@/lib/api/client');

      await fetchApi('/api/group/notifications', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      window.location.href = '/automation/notifications?created=true';
    } catch (error) {
      alert('Failed to create notification. Please try again.');
      console.error('Error creating notification:', error);
    }
  });

  // Initial count
  updateSelectionCount();
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .page-header h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .page-header p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .form-container {
    max-width: 800px;
  }

  .form {
    display: grid;
    gap: 24px;
  }

  .form-section {
    display: grid;
    gap: 16px;
    padding: 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-section h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }

  .section-description {
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--muted);
  }

  .selection-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
  }

  .link-button {
    padding: 0;
    border: none;
    background: none;
    color: var(--accent);
    font-size: 13px;
    cursor: pointer;
    text-decoration: underline;
  }

  .link-button:hover {
    opacity: 0.8;
  }

  .separator {
    color: var(--muted);
  }

  .form-field {
    display: grid;
    gap: 6px;
  }

  .search-field {
    margin-top: 8px;
  }

  .checkbox-field {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .checkbox-field input[type="checkbox"] {
    width: auto;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
  }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .hint {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
  }

  .hint a {
    color: var(--accent);
    text-decoration: underline;
  }

  .hint code {
    font-family: ui-monospace, monospace;
    font-size: 11px;
    background: var(--panel-2);
    padding: 2px 4px;
    border-radius: 3px;
  }

  .events-checklist {
    max-height: 400px;
    overflow-y: auto;
    padding: 12px;
    background: var(--panel-2);
    border-radius: var(--radius);
    display: grid;
    gap: 8px;
  }

  .event-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    cursor: pointer;
    transition: all 0.2s;
  }

  .event-checkbox:hover {
    border-color: var(--accent);
    background: var(--panel);
  }

  .event-checkbox input[type="checkbox"] {
    margin-top: 2px;
    cursor: pointer;
  }

  .event-checkbox-content {
    display: grid;
    gap: 2px;
    flex: 1;
  }

  .event-checkbox-name {
    font-size: 14px;
    font-weight: 500;
  }

  .event-checkbox-description {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.4;
  }

  .selection-summary {
    padding: 8px 12px;
    background: var(--panel-2);
    border-radius: var(--radius);
    text-align: center;
    font-size: 13px;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 12px;
  }
</style>
