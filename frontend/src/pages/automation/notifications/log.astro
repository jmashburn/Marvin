---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { getApiUrl } from "@/lib/api/config";
import { createSdkClient } from "@/lib/sdk";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

const filter = Astro.url.searchParams.get("filter") || "all";

let logs: any[] = [];
let notifiers: any[] = [];
let error: string | null = null;

try {
  const [logsResp, notifResult] = await Promise.all([
    authToken
      ? fetch(getApiUrl("/api/group/notifications/log?limit=200").toString(), {
          headers: { Authorization: `Bearer ${authToken}` },
        }).then((r) => (r.ok ? r.json() : []))
      : Promise.resolve([]),
    sdk.notifications.list(),
  ]);
  logs = Array.isArray(logsResp) ? logsResp : [];
  notifiers = Array.isArray(notifResult) ? notifResult : ((notifResult as any)?.items ?? []);
} catch (e) {
  console.error("[notifications/log] Error:", e);
  error = e instanceof Error ? e.message : String(e);
}

const notifierMap = new Map(notifiers.map((n: any) => [n.id, n]));
const filteredLogs = filter === "all" ? logs : logs.filter((l: any) => l.status === filter);

function formatDate(isoStr: string): string {
  if (!isoStr) return "—";
  const normalized = isoStr.replace(/(\.\d{3})\d+/, "$1");
  const d = new Date(normalized);
  return Number.isNaN(d.getTime()) ? isoStr : d.toLocaleString();
}

function statusClass(status: string): string {
  return status === "success" ? "success" : status === "failed" ? "failed" : "none";
}
---

<AppLayout title="Notification Activity Log" eyebrow="Automation">
  <div class="page-header">
    <div class="breadcrumb">
      <a href="/automation/notifications">Notifications</a>
      <span>›</span>
      <span>Activity Log</span>
    </div>
    <h2>Notification Activity Log</h2>
    <p>Execution history for all event notifiers in this workspace</p>
  </div>

  <div class="filters">
    <a href="?filter=all" class:list={['filter-btn', { active: filter === 'all' }]}>All ({logs.length})</a>
    <a href="?filter=success" class:list={['filter-btn', { active: filter === 'success' }]}>Success</a>
    <a href="?filter=failed" class:list={['filter-btn', { active: filter === 'failed' }]}>Failed</a>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : filteredLogs.length === 0 ? (
    <div class="empty-state">
      <div class="empty-icon">🔔</div>
      <p class="empty-title">No notification executions yet</p>
      <p class="empty-desc">Logs appear here after notifiers fire or are tested</p>
      <a href="/automation/notifications" class="button">View Notifications</a>
    </div>
  ) : (
    <div class="table-wrap">
      <table class="log-table">
        <thead>
          <tr>
            <th></th>
            <th>Executed At</th>
            <th>Notifier</th>
            <th>Event Type</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {filteredLogs.map((log: any, i: number) => {
            const notifierId = log.notifierId ?? log.notifier_id;
            const executedAt = log.executedAt ?? log.executed_at;
            const eventType = log.eventType ?? log.event_type;
            const errorMsg = log.errorMessage ?? log.error_message;
            const payload = log.requestPayload ?? log.request_payload;
            const notifier = notifierMap.get(notifierId);
            const hasDetails = !!(errorMsg || payload);
            return (
              <>
                <tr class:list={['log-row', { 'has-details': hasDetails }]}>
                  <td class="expand-cell">
                    {hasDetails && (
                      <button class="expand-btn" data-target={`detail-${i}`}>▶</button>
                    )}
                  </td>
                  <td class="nowrap">{formatDate(executedAt)}</td>
                  <td>
                    {notifier
                      ? <a href={`/automation/notifications/${notifierId}#execution-history`} class="notifier-link">{notifier.name}</a>
                      : <span class="muted">{notifierId?.slice(0, 8)}…</span>}
                  </td>
                  <td><span class="event-type">{eventType ?? '—'}</span></td>
                  <td>
                    <span class={`status-chip status-${statusClass(log.status)}`}>{log.status}</span>
                  </td>
                </tr>
                {hasDetails && (
                  <tr class="detail-row" id={`detail-${i}`} style="display:none">
                    <td colspan="5">
                      <div class="detail-body">
                        {errorMsg && (
                          <div class="detail-section">
                            <div class="detail-label">Error</div>
                            <div class="detail-message">{errorMsg}</div>
                          </div>
                        )}
                        {payload && (
                          <div class="detail-section">
                            <div class="detail-label">Payload Sent</div>
                            <pre class="payload-json">{JSON.stringify(payload, null, 2)}</pre>
                          </div>
                        )}
                      </div>
                    </td>
                  </tr>
                )}
              </>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</AppLayout>

<script>
  document.querySelectorAll('.expand-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.target!;
      const row = document.getElementById(id);
      if (!row) return;
      const open = row.style.display !== 'none';
      row.style.display = open ? 'none' : 'table-row';
      (btn as HTMLElement).textContent = open ? '▶' : '▼';
    });
  });
</script>

<style>
  .page-header {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink); }

  .page-header h2 { margin: 0 0 8px; font-size: 24px; font-weight: 600; }
  .page-header p { margin: 0; color: var(--muted); font-size: 14px; }

  .filters { display: flex; gap: 8px; margin-bottom: 24px; }

  .filter-btn {
    padding: 6px 14px;
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line);
    background: var(--panel);
    transition: all 0.15s;
  }

  .filter-btn:hover { color: var(--ink); border-color: var(--ink); }
  .filter-btn.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .empty-state { padding: 80px 24px; text-align: center; }
  .empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.3; }
  .empty-title { margin: 0 0 8px; font-size: 18px; font-weight: 600; }
  .empty-desc { margin: 0 0 24px; color: var(--muted); font-size: 14px; }

  .table-wrap { overflow-x: auto; }

  .log-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .log-table th {
    text-align: left;
    padding: 10px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    border-bottom: 2px solid var(--line);
    white-space: nowrap;
  }

  .log-table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
    vertical-align: middle;
  }

  .log-row:hover td { background: var(--panel); }

  .expand-cell { width: 32px; padding: 10px 6px 10px 12px; }

  .expand-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    font-size: 11px;
    padding: 2px 4px;
    border-radius: 3px;
  }

  .expand-btn:hover { background: var(--line); color: var(--ink); }

  .detail-row td { padding: 0; border-bottom: 1px solid var(--line); }

  .detail-body {
    padding: 16px 16px 16px 52px;
    background: var(--panel);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail-section { display: flex; flex-direction: column; gap: 4px; }

  .detail-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--muted);
  }

  .detail-message {
    font-size: 13px;
    color: var(--color-error);
    font-family: ui-monospace, monospace;
  }

  .payload-json {
    font-size: 12px;
    font-family: ui-monospace, monospace;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 12px;
    margin: 0;
    overflow-x: auto;
    max-height: 400px;
    overflow-y: auto;
    white-space: pre;
    color: var(--ink);
  }

  .nowrap { white-space: nowrap; }
  .muted { color: var(--muted); font-size: 13px; }

  .notifier-link { color: var(--ink); text-decoration: none; font-weight: 500; }
  .notifier-link:hover { color: var(--accent); }

  .event-type {
    font-size: 12px;
    font-family: ui-monospace, monospace;
    color: var(--muted);
  }

  .status-chip {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-success { background: rgba(79, 156, 132, 0.1); color: var(--accent); }
  .status-failed { background: rgba(239, 68, 68, 0.1); color: var(--color-error); }
  .status-none { color: var(--muted); }
</style>
