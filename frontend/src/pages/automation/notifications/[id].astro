---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";
import { getApiUrl } from "@/lib/api/config";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);
const { id } = Astro.params;

let notification: any = null;
let eventOptions: any[] = [];
let history: any[] = [];
let error: string | null = null;
let appriseReady = false;

try {
  const configCheck = await sdk.adminSystem.check() as any;
  appriseReady = (configCheck as any)?.appriseReady ?? configCheck?.apprise_ready ?? false;
} catch (e) {
  console.error('[notifications/edit] Error checking Apprise availability:', e);
}

if (!appriseReady) {
  return Astro.redirect('/automation/notifications');
}

try {
  [notification, eventOptions] = await Promise.all([
    sdk.notifications.get(id!),
    sdk.events.getOptions().then((r: any) => Array.isArray(r) ? r : (r?.items ?? [])).catch(() => []),
  ]);
} catch (e) {
  console.error('[notifications/edit] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

if (notification && authToken) {
  try {
    const resp = await fetch(getApiUrl(`/api/group/notifications/${id}/logs?limit=50`).toString(), {
      headers: { 'Authorization': `Bearer ${authToken}` },
    });
    if (resp.ok) history = await resp.json();
    else console.error('[notifications/edit] Logs fetch status:', resp.status);
  } catch (e) {
    console.error('[notifications/edit] Error loading history:', e);
  }
}

function formatDate(isoStr: string): string {
  if (!isoStr) return '—';
  const normalized = isoStr.replace(/(\.\d{3})\d+/, '$1');
  const d = new Date(normalized);
  return isNaN(d.getTime()) ? isoStr : d.toLocaleString();
}

function statusClass(status: string): string {
  return status === 'success' ? 'success' : status === 'failed' ? 'failed' : 'none';
}

// Build set of currently subscribed option strings e.g. "core.invitation_created"
const subscribedSet = new Set<string>(
  (notification?.options ?? []).map((o: any) => o.option ?? o)
);

const currentAppriseUrl = notification?.appriseUrl ?? notification?.apprise_url ?? '';
---

<AppLayout title="Edit Notification" eyebrow="Automation">
  <div class="page-header">
    <div>
      <h2>Edit Event Notification</h2>
      <p>Update notification endpoint configuration</p>
    </div>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : notification ? (
    <div class="form-container">
      <form id="update-notification-form" class="form" style="max-width:700px">
        <input type="hidden" name="id" value={notification.id} />

        <div class="form-section">
          <h3>Notification Details</h3>

          <input type="hidden" name="group_id" value={notification.groupId} />

          <label class="form-field">
            <span class="label">Name</span>
            <input type="text" name="name" required value={notification.name} class="input" />
          </label>

          <div class="form-field">
            <span class="label">Notification URL</span>
            <input
              type="text"
              name="apprise_url"
              value={currentAppriseUrl}
              placeholder="slack://{{SLACK_TOKEN}}/#channel"
              class="input"
            />
            <small class="hint">
              See <a href="https://github.com/caronc/apprise" target="_blank" rel="noopener">Apprise docs</a> for URL formats.
              Use <code>&#123;&#123;SLUG&#125;&#125;</code> to embed a <a href="/workspace/settings/environment">workspace secret or variable</a> — stored as-is, resolved at send time.
            </small>
          </div>

          <label class="form-field checkbox-field">
            <input type="checkbox" name="enabled" checked={notification.enabled !== false} />
            <span>Enabled</span>
          </label>
        </div>

        <div class="form-section">
          <div class="section-header">
            <div>
              <h3>Event Subscriptions</h3>
              <p class="section-description">Select which events should trigger this notification</p>
            </div>
            <div class="selection-actions">
              <button type="button" id="select-all" class="link-button">Select All</button>
              <span class="separator">•</span>
              <button type="button" id="select-none" class="link-button">Clear All</button>
            </div>
          </div>

          <div class="search-field">
            <input type="text" id="event-search" placeholder="Search events..." class="input" />
          </div>

          <div class="events-checklist" id="events-checklist">
            {eventOptions.map((event: any) => {
              const optionValue = `core.${event.value}`;
              const isChecked = subscribedSet.has(optionValue);
              return (
                <label
                  class="event-checkbox"
                  data-event-name={event.label?.toLowerCase() ?? ''}
                  data-event-description={event.description?.toLowerCase() ?? ''}
                >
                  <input type="checkbox" name="events" value={optionValue} checked={isChecked} />
                  <div class="event-checkbox-content">
                    <span class="event-checkbox-name">{event.label}</span>
                    {event.description && (
                      <span class="event-checkbox-description">{event.description}</span>
                    )}
                  </div>
                </label>
              );
            })}
          </div>

          <div class="selection-summary">
            <span id="selection-count">Loading…</span>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="button">Save Changes</button>
          <button type="button" id="test-btn" class="button secondary" disabled={notification.enabled === false}>Test</button>
          <button type="button" id="delete-btn" class="button danger">Delete</button>
          <a href="/automation/notifications" class="button secondary">Cancel</a>
        </div>
      </form>

      <div class="history-section" id="execution-history">
        <h3>Execution History</h3>
        {history.length === 0 ? (
          <p class="no-history">No executions yet. Use the Test button to fire a test notification.</p>
        ) : (
          <div class="history-table-wrap">
            <table class="history-table">
              <thead>
                <tr>
                  <th></th>
                  <th>Executed At</th>
                  <th>Status</th>
                  <th>Event Type</th>
                </tr>
              </thead>
              <tbody>
                {history.map((exec: any, i: number) => {
                  const executedAt = exec.executedAt ?? exec.executed_at;
                  const eventType = exec.eventType ?? exec.event_type;
                  const errorMsg = exec.errorMessage ?? exec.error_message;
                  const payload = exec.requestPayload ?? exec.request_payload;
                  const hasDetails = !!(errorMsg || payload);
                  return (
                    <>
                      <tr>
                        <td class="expand-cell">
                          {hasDetails && <button class="expand-btn" data-target={`h-${i}`}>▶</button>}
                        </td>
                        <td class="nowrap">{formatDate(executedAt)}</td>
                        <td>
                          <span class={`run-status status-${statusClass(exec.status)}`}>{exec.status}</span>
                        </td>
                        <td>{eventType ?? '—'}</td>
                      </tr>
                      {hasDetails && (
                        <tr id={`h-${i}`} style="display:none">
                          <td colspan="4">
                            <div class="detail-body">
                              {errorMsg && <div class="error-msg">{errorMsg}</div>}
                              {payload && <pre class="payload-json">{JSON.stringify(payload, null, 2)}</pre>}
                            </div>
                          </td>
                        </tr>
                      )}
                    </>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  ) : null}
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';
  const sdk = createSdkClient();

  // Expand/collapse history rows
  document.querySelectorAll('.expand-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.target!;
      const row = document.getElementById(id);
      if (!row) return;
      const open = row.style.display !== 'none';
      row.style.display = open ? 'none' : 'table-row';
      (btn as HTMLElement).textContent = open ? '▶' : '▼';
    });
  });

  const form = document.getElementById('update-notification-form');
  const deleteBtn = document.getElementById('delete-btn');
  const notificationId = (document.querySelector('input[name="id"]') as HTMLInputElement)?.value;

  const checkboxes = document.querySelectorAll('input[name="events"]') as NodeListOf<HTMLInputElement>;
  const searchInput = document.getElementById('event-search') as HTMLInputElement;
  const selectionCount = document.getElementById('selection-count');
  const eventCheckboxes = document.querySelectorAll('.event-checkbox');

  function updateSelectionCount() {
    const checked = Array.from(checkboxes).filter(cb => cb.checked).length;
    if (selectionCount) selectionCount.textContent = `${checked} event${checked !== 1 ? 's' : ''} selected`;
  }

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase();
    eventCheckboxes.forEach(label => {
      const name = label.getAttribute('data-event-name') || '';
      const desc = label.getAttribute('data-event-description') || '';
      (label as HTMLElement).style.display = (!q || name.includes(q) || desc.includes(q)) ? 'flex' : 'none';
    });
  });

  document.getElementById('select-all')?.addEventListener('click', () => {
    checkboxes.forEach(cb => cb.checked = true);
    updateSelectionCount();
  });

  document.getElementById('select-none')?.addEventListener('click', () => {
    checkboxes.forEach(cb => cb.checked = false);
    updateSelectionCount();
  });

  checkboxes.forEach(cb => cb.addEventListener('change', updateSelectionCount));
  updateSelectionCount();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    const groupId = (document.querySelector('input[name="group_id"]') as HTMLInputElement)?.value;
    const selectedEvents = Array.from(checkboxes).filter(cb => cb.checked).map(cb => cb.value);
    const appriseUrlValue = (formData.get('apprise_url') as string)?.trim() || null;

    const payload: any = {
      name: formData.get('name'),
      apprise_url: appriseUrlValue,
      enabled: formData.get('enabled') === 'on',
      options: selectedEvents,
      group_id: groupId,
    };

    try {
      await sdk.notifications.update(notificationId, payload);
      window.location.href = '/automation/notifications?updated=true';
    } catch (error) {
      alert('Failed to update notification. Please try again.');
      console.error('Error updating notification:', error);
    }
  });

  document.getElementById('test-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('test-btn') as HTMLButtonElement;
    if (btn?.disabled) return;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    try {
      await sdk.notifications.test(notificationId);
      alert('Test notification sent!');
    } catch (e: any) {
      alert(`Test failed: ${e?.message || e}`);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Test';
    }
  });

  deleteBtn?.addEventListener('click', async () => {
    if (!confirm('Are you sure you want to delete this notification?')) return;
    try {
      await sdk.notifications.delete(notificationId);
      window.location.href = '/automation/notifications?deleted=true';
    } catch (error) {
      alert('Failed to delete notification. Please try again.');
      console.error('Error deleting notification:', error);
    }
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .page-header h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .page-header p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .form-container {
    max-width: 700px;
  }

  .form {
    display: grid;
    gap: 24px;
  }

  .form-section {
    display: grid;
    gap: 16px;
    padding: 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-section h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .form-field {
    display: grid;
    gap: 6px;
  }

  .checkbox-field {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .checkbox-field input[type="checkbox"] {
    width: auto;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
  }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .hint {
    font-size: 12px;
    color: var(--muted);
  }

  .hint a {
    color: var(--accent);
    text-decoration: underline;
  }

  .current-url { margin: 0; font-size: 12px; color: var(--muted); }
  .current-url code { font-family: ui-monospace, monospace; font-size: 11px; word-break: break-all; }

  .section-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; }
  .section-description { margin: 4px 0 0; font-size: 13px; color: var(--muted); }
  .selection-actions { display: flex; align-items: center; gap: 8px; font-size: 13px; }
  .link-button { padding: 0; border: none; background: none; color: var(--accent); font-size: 13px; cursor: pointer; text-decoration: underline; }
  .separator { color: var(--muted); }
  .search-field { margin-top: 4px; }

  .events-checklist {
    max-height: 400px;
    overflow-y: auto;
    padding: 12px;
    background: var(--panel-2, var(--bg));
    border-radius: var(--radius);
    display: grid;
    gap: 8px;
  }

  .event-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .event-checkbox:hover { border-color: var(--accent); }
  .event-checkbox input[type="checkbox"] { margin-top: 2px; cursor: pointer; }
  .event-checkbox-content { display: grid; gap: 2px; flex: 1; }
  .event-checkbox-name { font-size: 14px; font-weight: 500; }
  .event-checkbox-description { font-size: 12px; color: var(--muted); line-height: 1.4; }

  .selection-summary {
    padding: 8px 12px;
    background: var(--panel-2, var(--bg));
    border-radius: var(--radius);
    text-align: center;
    font-size: 13px;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 12px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .button.danger {
    background: var(--color-error);
    color: white;
  }

  .button.danger:hover {
    background: var(--color-error);
    opacity: 0.9;
  }

  .current-url {
    margin: 0 0 4px;
    font-size: 12px;
    color: var(--muted);
  }

  .current-url code {
    font-family: ui-monospace, monospace;
    font-size: 11px;
    background: var(--bg);
    padding: 1px 4px;
    border-radius: 3px;
    border: 1px solid var(--line);
    word-break: break-all;
  }

  .connected-events-section {
    margin-top: 32px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    max-width: 700px;
  }

  .sub-header-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .sub-header-row h3 { margin: 0; font-size: 16px; font-weight: 600; }
  .sub-header-row p { margin: 0; font-size: 13px; color: var(--muted); }
  .sub-header-row a { color: var(--accent); }

  .sub-options {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .sub-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
    gap: 16px;
    color: inherit;
  }

  .sub-option:last-child { border-bottom: none; }

  .sub-option-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .sub-option-name-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .sub-option-info strong { font-size: 14px; font-weight: 500; }

  .sub-url {
    font-size: 11px;
    font-family: ui-monospace, monospace;
    color: var(--muted);
  }

  .sub-option-actions { display: flex; gap: 6px; flex-shrink: 0; }

  .sub-option-connected {
    background: rgba(79, 156, 132, 0.04);
    border-left: 3px solid var(--accent);
  }

  .connected-check {
    color: var(--accent);
    font-weight: 700;
    font-size: 13px;
    flex-shrink: 0;
  }

  .no-events-row { color: var(--muted); font-size: 13px; }
  .no-events-row a { color: var(--accent); }

  .button.small { padding: 5px 12px; font-size: 12px; min-height: 28px; flex-shrink: 0; }

  .history-section {
    margin-top: 32px;
    max-width: 700px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 32px;
  }

  .history-section h3 { margin: 0 0 20px; font-size: 16px; font-weight: 600; }
  .no-history { color: var(--muted); font-size: 14px; margin: 0; }
  .history-table-wrap { overflow-x: auto; }

  .history-table { width: 100%; border-collapse: collapse; font-size: 14px; }

  .history-table th {
    text-align: left;
    padding: 8px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    border-bottom: 1px solid var(--line);
  }

  .history-table td {
    padding: 12px 16px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    line-height: 1.5;
  }

  .history-table tr:last-child td { border-bottom: none; }
  .nowrap { white-space: nowrap; }

  .run-status { font-size: 12px; font-weight: 600; text-transform: uppercase; }
  .status-success { color: var(--accent); }
  .status-failed { color: var(--color-error); }
  .status-none { color: var(--muted); }

  .expand-cell { width: 32px; padding: 12px 4px 12px 16px; }
  .expand-btn { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 11px; padding: 2px 4px; border-radius: 3px; }
  .expand-btn:hover { background: var(--line); color: var(--ink); }

  .detail-body { padding: 12px 16px 12px 52px; background: var(--panel); display: flex; flex-direction: column; gap: 8px; }

  .error-msg { font-size: 13px; color: var(--color-error); font-family: ui-monospace, monospace; }

  .payload-json {
    font-size: 12px;
    font-family: ui-monospace, monospace;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 12px;
    margin: 0;
    overflow-x: auto;
    max-height: 360px;
    overflow-y: auto;
    white-space: pre;
    color: var(--ink);
  }
</style>
