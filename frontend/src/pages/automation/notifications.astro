---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";
import { getApiUrl } from "@/lib/api/config";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

function extractScheme(url: string): string {
  const match = url.match(/^([a-z][a-z0-9+\-.]*):\/\//i);
  return match ? match[1].toLowerCase() : '';
}

let notifications: any[] = [];
let lastLogByNotifier: Record<string, any> = {};
let error: string | null = null;
let appriseReady = false;

// Check if Apprise is available
try {
  const configCheck = await sdk.adminSystem.check() as any;
  appriseReady = (configCheck as any)?.appriseReady ?? configCheck?.apprise_ready ?? false;
} catch (e) {
  console.error('[notifications] Error checking Apprise availability:', e);
}

// Only fetch notifications if Apprise is available
if (appriseReady) {
  try {
    const result = await sdk.notifications.list();
    notifications = Array.isArray(result) ? result : ((result as any)?.items ?? []);
  } catch (e) {
    console.error('[notifications] Error:', e);
    error = e instanceof Error ? e.message : String(e);
  }
}

// Fetch last execution log for each notifier
if (notifications.length && authToken) {
  await Promise.all(notifications.map(async (notif) => {
    try {
      const resp = await fetch(getApiUrl(`/group/notifications/${notif.id}/logs?limit=1`).toString(), {
        headers: { 'Authorization': `Bearer ${authToken}` },
      });
      if (resp.ok) {
        const logs = await resp.json();
        if (logs.length) lastLogByNotifier[notif.id] = logs[0];
      }
    } catch {}
  }));
}

function formatDate(isoStr: string): string {
  if (!isoStr) return '—';
  const normalized = isoStr.replace(/(\.\d{3})\d+/, '$1');
  const d = new Date(normalized);
  return isNaN(d.getTime()) ? isoStr : d.toLocaleString();
}
---

<AppLayout title="Notifications" eyebrow="Automation">
  <div class="toolbar">
    <div>
      <h2>Event Notifications</h2>
      <p>Configure notifications for workspace events</p>
    </div>
    {appriseReady && (
      <div class="toolbar-actions">
        <a href="/automation/notifications/log" class="button secondary">Activity Log</a>
        <a href="/automation/notifications/new" class="button">Create Notification</a>
      </div>
    )}
  </div>

  {!appriseReady ? (
    <div class="alert alert-warning">
      <strong>Notifications Service Not Available</strong>
      <p>The notifications service is currently disabled. Notifications require the service to be enabled in the system settings.</p>
      <p style="margin-top: 12px;">
        <strong>Need webhooks instead?</strong> Use <a href="/automation/webhooks" style="color: inherit; text-decoration: underline;">Webhooks</a> for scheduled HTTP callbacks.
      </p>
      <p style="margin-top: 12px; font-size: 13px; opacity: 0.8;">
        When the notifications service is enabled, you get access to 80+ notification services including Slack, Discord, Email, SMS, and basic webhooks via json://, xml://, or form:// URLs.
      </p>
    </div>
  ) : error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : notifications.length === 0 ? (
    <div class="empty-state">
      <div class="empty-icon">🔔</div>
      <p class="empty-title">No notifications configured</p>
      <p class="empty-description">Set up notifications to stay informed about workspace events</p>
      <a href="/automation/notifications/new" class="button">Create Notification</a>
    </div>
  ) : (
    <div class="notifications-list">
      {notifications.map((notif) => {
        const scheme = extractScheme(notif.appriseUrl ?? notif.apprise_url ?? '');
        const url = notif.appriseUrl ?? notif.apprise_url ?? '';
        const eventCount = notif.options?.length ?? 0;
        const lastLog = lastLogByNotifier[notif.id];
        const lastRunAt = lastLog ? (lastLog.executedAt ?? lastLog.executed_at) : null;
        const lastStatus = lastLog?.status ?? null;
        return (
          <div class="notification-card">
            <div class="notification-info">
              <div class="notification-header">
                <strong>{notif.name}</strong>
                {notif.enabled === false && <span class="badge-disabled">Disabled</span>}
                {scheme && <span class="badge-service">{scheme}</span>}
              </div>
              {url && <p class="notification-url">{url}</p>}
              <p class="notification-count">{eventCount} event{eventCount !== 1 ? 's' : ''} subscribed</p>
              <p class="notification-last-run">
                {lastRunAt ? (
                  <>Last run: {formatDate(lastRunAt)} · <span class={`inline-status status-${lastStatus}`}>{lastStatus}</span></>
                ) : (
                  <span class="never-run">Never run</span>
                )}
              </p>
            </div>
            <div class="notification-actions">
              <button
                type="button"
                class="button secondary small"
                data-test-id={notif.id}
                data-test-name={notif.name}
                disabled={notif.enabled === false}
              >Test</button>
              <a href={`/automation/notifications/${notif.id}`} class="button secondary small">Edit</a>
              <button type="button" class="button secondary small danger" data-delete-id={notif.id} data-delete-name={notif.name}>Delete</button>
            </div>
          </div>
        );
      })}
    </div>
  )}
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';
  const sdk = createSdkClient();

  document.querySelectorAll('[data-test-id]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.testId!;
      const name = (btn as HTMLElement).dataset.testName!;
      (btn as HTMLButtonElement).disabled = true;
      (btn as HTMLButtonElement).textContent = 'Sending…';
      try {
        await sdk.notifications.test(id);
        alert(`Test notification sent to "${name}".`);
      } catch (e: any) {
        alert(`Test failed: ${e?.message || e}`);
      } finally {
        (btn as HTMLButtonElement).disabled = false;
        (btn as HTMLButtonElement).textContent = 'Test';
      }
    });
  });

  document.querySelectorAll('[data-delete-id]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.deleteId!;
      const name = (btn as HTMLElement).dataset.deleteName!;
      if (!confirm(`Delete notification "${name}"?`)) return;
      try {
        await sdk.notifications.delete(id);
        (btn as HTMLElement).closest('.notification-card')?.remove();
      } catch (e: any) {
        alert(`Delete failed: ${e?.message || e}`);
      }
    });
  });
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar-actions { display: flex; gap: 8px; align-items: center; }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .alert {
    padding: 20px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    line-height: 1.6;
  }

  .alert strong {
    display: block;
    margin-bottom: 8px;
    font-size: 16px;
  }

  .alert p {
    margin: 0;
    font-size: 14px;
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid #fecaca;
  }

  .alert-warning {
    background: rgb(251 191 36 / 0.1);
    color: var(--warn);
    border: 1px solid var(--warn);
  }

  .empty-state {
    padding: 80px 24px;
    text-align: center;
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 16px;
    opacity: 0.3;
  }

  .empty-title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .empty-description {
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 14px;
  }

  .notifications-list {
    display: grid;
    gap: 16px;
  }

  .notification-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    padding: 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .notification-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .notification-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .notification-header strong {
    font-size: 15px;
    font-weight: 600;
  }

  .badge-disabled {
    padding: 2px 8px;
    background: rgba(128, 128, 128, 0.1);
    color: var(--muted);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .badge-service {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.4px;
    padding: 2px 8px;
    border-radius: 3px;
    background: var(--bg);
    border: 1px solid var(--line);
    color: var(--muted);
  }

  .notification-url {
    margin: 2px 0 0;
    font-size: 12px;
    font-family: ui-monospace, monospace;
    color: var(--muted);
    word-break: break-all;
  }

  .notification-count {
    margin: 2px 0 0;
    font-size: 13px;
    color: var(--muted);
  }

  .notification-actions {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
    align-items: center;
  }

  .button.small {
    padding: 6px 14px;
    font-size: 13px;
  }

  .button.secondary.danger { color: var(--color-error); border-color: var(--color-error); }
  .button.secondary.danger:hover { background: var(--color-error-bg); }
  .button:disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }

  .notification-last-run {
    margin: 2px 0 0;
    font-size: 12px;
    color: var(--muted);
  }

  .inline-status { font-weight: 600; }
  .status-success { color: var(--accent); }
  .status-failed { color: var(--color-error); }
  .never-run { font-style: italic; }
</style>
