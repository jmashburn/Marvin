---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let workspace: any = null;
let automations: any[] = [];
let options: any = { triggers: [], conditionOps: [], actionKinds: [], operations: [] };
let error: string | null = null;

try {
  workspace = await getCurrentWorkspace(authToken);
  if (workspace) {
    [automations, options] = await Promise.all([
      sdk.automations.list(),
      sdk.automations.options(),
    ]);
  }
} catch (e) {
  console.error("[workflows] Error loading:", e);
  error = e instanceof Error ? e.message : String(e);
}

// Serialize server data for the client script (read via JSON.parse, so the module script can import).
const optionsJson = JSON.stringify(options).replace(/</g, "\\u003c");
const listJson = JSON.stringify(automations).replace(/</g, "\\u003c");
const aiActionsAvailable = (options.operations ?? []).length > 0;
---

<AppLayout title="Workflows" eyebrow="Automation">
 <div class="workflows-page">
  <div class="toolbar">
    <div>
      <h2>Workflows</h2>
      <p>When something happens, run steps automatically — no code. AI steps are optional.</p>
    </div>
    <div class="toolbar-actions">
      <button id="wf-new" class="button">New workflow</button>
    </div>
  </div>

  <div class="page-container">
    {error && <div class="banner error">{error}</div>}

    {!aiActionsAvailable && (
      <div class="banner info">
        AI actions aren’t available — <a href="/workspace/settings/ai-workflow">enable AI</a> (and allow the
        <code>automation</code> source) to add steps like “generate summary”. Event, task, and webhook steps work regardless.
      </div>
    )}

    <!-- Builder (hidden until New/Edit) -->
    <section id="wf-builder" class="builder" hidden>
      <div class="builder-head">
        <h3 id="wf-builder-title">New workflow</h3>
        <button id="wf-json-toggle" type="button" class="linkish">Edit as JSON</button>
      </div>

      <div id="wf-guided">
        <div class="form-field">
          <label class="label" for="wf-name">Name</label>
          <input class="input" id="wf-name" placeholder="Summarize published bench notes" />
        </div>

        <div class="form-field">
          <label class="label" for="wf-trigger-type">Trigger</label>
          <select class="input" id="wf-trigger-type"></select>
        </div>

        <div class="form-field" id="wf-event-field">
          <label class="label" for="wf-trigger">On event</label>
          <select class="input" id="wf-trigger"></select>
          <span class="hint">The event that starts the workflow.</span>
        </div>
        <p class="hint" id="wf-manual-hint" hidden>Runs when you press <strong>Run</strong> on the workflow (or via the API). No event needed.</p>
        <p class="hint" id="wf-mcp-hint" hidden>Exposed as a named MCP tool (<code>marvin_wf_&lt;slug&gt;</code>) so external MCP hosts can run it. Also runnable via <strong>Run</strong>.</p>

        <div class="form-field" id="wf-schedule-field" hidden>
          <label class="label" for="wf-sched-n">Every</label>
          <div class="inline">
            <input class="input" id="wf-sched-n" type="number" min="1" value="1" />
            <select class="input" id="wf-sched-unit">
              <option value="60">minutes</option>
              <option value="3600">hours</option>
              <option value="86400" selected>days</option>
            </select>
          </div>
          <span class="hint">How often to run it. Adds a task to your Scheduler.</span>
        </div>

        <div class="form-field" id="wf-chained-field" hidden>
          <label class="label" for="wf-chained-target">Workflow</label>
          <select class="input" id="wf-chained-target"></select>
          <span class="hint" id="wf-chained-hint">Runs after the selected workflow completes.</span>
        </div>

        <div class="form-field" id="wf-webhook-field" hidden>
          <label class="label" for="wf-webhook-target">Incoming webhook</label>
          <select class="input" id="wf-webhook-target"></select>
          <span class="hint">Runs when this webhook receives a POST. Read the payload with <code>$event.payload.*</code>. Manage webhooks under <a href="/automation/incoming-webhooks">Incoming Webhooks</a>.</span>
        </div>

        <div class="form-field">
          <label class="label">Only if <span class="muted">(all conditions must match — optional)</span></label>
          <div id="wf-conditions" class="rows"></div>
          <button type="button" class="linkish" id="wf-add-condition">+ Add condition</button>
        </div>

        <div class="form-field">
          <label class="label">Then do <span class="muted">(steps run in order; each can use the previous step’s output)</span></label>
          <div id="wf-actions" class="rows"></div>
          <button type="button" class="linkish" id="wf-add-action">+ Add step</button>
        </div>

        <label class="check"><input type="checkbox" id="wf-enabled" /> Enabled</label>
      </div>

      <div id="wf-json-editor" hidden>
        <div class="form-field">
          <label class="label" for="wf-json">Definition (JSON)</label>
          <textarea class="input mono" id="wf-json" rows="16" spellcheck="false"></textarea>
          <span class="hint">Advanced: the raw <code>{`{ trigger, conditions, actions }`}</code> definition.</span>
        </div>
      </div>

      <div class="builder-actions">
        <button id="wf-save" class="button">Save workflow</button>
        <button id="wf-cancel" class="button secondary" type="button">Cancel</button>
        <span id="wf-status" class="status"></span>
      </div>
    </section>

    <!-- Workflow list -->
    <div id="wf-list" class="wf-list"></div>
    <div id="wf-empty" class="empty" hidden>No workflows yet. Create one to automate a repetitive step.</div>
  </div>

  <script type="application/json" id="wf-options-data" is:inline set:html={optionsJson}></script>
  <script type="application/json" id="wf-list-data" is:inline set:html={listJson}></script>
 </div>
</AppLayout>

<script>
  import {
    createAutomation,
    updateAutomation,
    deleteAutomation,
    runAutomation,
  } from "@/lib/api/automations";

  const read = (id: string) => JSON.parse(document.getElementById(id)!.textContent || "null");
  const OPTIONS = read("wf-options-data") || { triggers: [], conditionOps: [], actionKinds: [], operations: [] };
  let workflows: any[] = read("wf-list-data") || [];

  const $ = (id: string) => document.getElementById(id)!;
  const esc = (s: unknown) =>
    String(s ?? "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));

  const builder = $("wf-builder");
  const guided = $("wf-guided");
  const jsonEditor = $("wf-json-editor");
  const statusEl = $("wf-status");
  let editingId: string | null = null; // null = creating
  let jsonMode = false;

  // ── Option-driven controls ────────────────────────────────────────────────
  const prettyEvent = (e: string) => e.replace(/_/g, " ");
  const TRIGGER_TYPE_LABELS: Record<string, string> = {
    event: "Event", manual: "Manual (Run button)", schedule: "Schedule",
    chained: "After another workflow", on_error: "When a workflow fails",
    incoming_webhook: "Incoming webhook (external POST)",
    mcp: "MCP tool (external hosts)",
  };
  function webhookName(ref: string | undefined): string {
    if (!ref || ref === "any") return "any incoming webhook";
    const w = (OPTIONS.incomingWebhooks || []).find((x: any) => x.slug === ref || x.id === ref);
    return w ? w.name : ref;
  }
  function automationName(ref: string | undefined): string {
    if (!ref || ref === "any") return "any workflow";
    const a = (OPTIONS.automations || []).find((x: any) => x.slug === ref || x.id === ref);
    return a ? a.name : ref;
  }
  function humanInterval(secs: number): string {
    if (!secs) return "—";
    const [n, unit] = secs % 86400 === 0 ? [secs / 86400, "day"]
      : secs % 3600 === 0 ? [secs / 3600, "hour"]
      : [Math.max(1, Math.round(secs / 60)), "minute"];
    return `${n} ${unit}${n === 1 ? "" : "s"}`;
  }

  function fillTriggers() {
    const typeSel = $("wf-trigger-type") as HTMLSelectElement;
    typeSel.innerHTML = (OPTIONS.triggerTypes || ["event"])
      .map((t: string) => `<option value="${esc(t)}">${esc(TRIGGER_TYPE_LABELS[t] || t)}</option>`)
      .join("");
    const evSel = $("wf-trigger") as HTMLSelectElement;
    evSel.innerHTML = (OPTIONS.triggers || [])
      .map((t: string) => `<option value="${esc(t)}">${esc(prettyEvent(t))}</option>`)
      .join("");
    const chSel = $("wf-chained-target") as HTMLSelectElement;
    chSel.innerHTML = `<option value="any">Any workflow</option>` +
      (OPTIONS.automations || []).map((a: any) => `<option value="${esc(a.slug)}">${esc(a.name)}</option>`).join("");
    const whSel = $("wf-webhook-target") as HTMLSelectElement;
    whSel.innerHTML = `<option value="any">Any incoming webhook</option>` +
      (OPTIONS.incomingWebhooks || []).map((w: any) =>
        `<option value="${esc(w.slug)}">${esc(w.name)}${w.hasToken ? "" : " (no token yet)"}</option>`).join("");
  }
  function syncTriggerType() {
    const t = ($("wf-trigger-type") as HTMLSelectElement).value;
    const isChain = t === "chained" || t === "on_error";
    $("wf-event-field").toggleAttribute("hidden", t !== "event");
    $("wf-manual-hint").toggleAttribute("hidden", t !== "manual");
    $("wf-mcp-hint").toggleAttribute("hidden", t !== "mcp");
    $("wf-schedule-field").toggleAttribute("hidden", t !== "schedule");
    $("wf-chained-field").toggleAttribute("hidden", !isChain);
    $("wf-webhook-field").toggleAttribute("hidden", t !== "incoming_webhook");
    if (isChain) {
      $("wf-chained-hint").textContent = t === "on_error"
        ? "Runs when the selected workflow fails."
        : "Runs after the selected workflow completes.";
    }
  }
  const KIND_LABELS: Record<string, string> = {
    operation: "AI operation",
    emit_event: "Emit event",
    handler: "Run task",
    webhook: "Call webhook",
  };
  // Most-useful-first (backend returns kinds alphabetically). New steps default to the first
  // available — an AI operation when AI is on, otherwise the first non-AI kind.
  const KIND_ORDER = ["operation", "handler", "webhook", "emit_event"];
  const orderedKinds = (): string[] => {
    const avail = OPTIONS.actionKinds || [];
    return KIND_ORDER.filter((k) => avail.includes(k)).concat(avail.filter((k: string) => !KIND_ORDER.includes(k)));
  };
  const defaultKind = (): string =>
    (OPTIONS.operations || []).length ? "operation" : (orderedKinds().find((k) => k !== "operation") || orderedKinds()[0] || "operation");

  // ── Condition rows ────────────────────────────────────────────────────────
  function conditionRow(c: any = {}) {
    const row = document.createElement("div");
    row.className = "row cond-row";
    const ops = (OPTIONS.conditionOps || []).map((o: string) => `<option ${c.op === o ? "selected" : ""}>${esc(o)}</option>`).join("");
    row.innerHTML = `
      <input class="input c-field" list="wf-fields" placeholder="entry.entry_type" value="${esc(c.field ?? "")}" />
      <select class="input c-op">${ops}</select>
      <input class="input c-value" placeholder="value" value="${esc(c.value ?? "")}" />
      <button type="button" class="icon-btn" title="Remove">✕</button>`;
    row.querySelector(".icon-btn")!.addEventListener("click", () => row.remove());
    return row;
  }

  // ── Action rows (kind-dependent fields) ───────────────────────────────────
  function actionRow(a: any = {}) {
    const row = document.createElement("div");
    row.className = "row action-row";
    const selectedKind = a.kind || defaultKind();
    const kinds = orderedKinds()
      .map((k: string) => `<option value="${esc(k)}" ${selectedKind === k ? "selected" : ""}>${esc(KIND_LABELS[k] || k)}</option>`)
      .join("");
    row.innerHTML = `
      <div class="action-head">
        <select class="input a-kind">${kinds}</select>
        <button type="button" class="icon-btn" title="Remove step">✕</button>
      </div>
      <div class="a-fields"></div>`;
    const kindSel = row.querySelector(".a-kind") as HTMLSelectElement;
    const fields = row.querySelector(".a-fields") as HTMLElement;
    const render = () => { fields.innerHTML = ""; fields.appendChild(kindFields(kindSel.value, a)); };
    kindSel.addEventListener("change", () => render());
    row.querySelector(".icon-btn")!.addEventListener("click", () => row.remove());
    render();
    return row;
  }

  function kindFields(kind: string, a: any): HTMLElement {
    const wrap = document.createElement("div");
    if (kind === "operation") {
      const ops = (OPTIONS.operations || []);
      if (!ops.length) {
        wrap.innerHTML = `<p class="muted small">Enable AI to use AI operations here.</p>`;
        return wrap;
      }
      const optList = ops.map((o: any) => `<option value="${esc(o.op)}" ${a.op === o.op ? "selected" : ""}>${esc(o.name)}</option>`).join("");
      wrap.innerHTML = `
        <select class="input a-op">${optList}</select>
        <label class="check small"><input type="checkbox" class="a-writeback" ${a.write_back ? "checked" : ""}/> Write the result back to the entry</label>`;
    } else if (kind === "emit_event") {
      const evs = (OPTIONS.triggers || []).map((t: string) => `<option value="${esc(t)}" ${a.event === t ? "selected" : ""}>${esc(prettyEvent(t))}</option>`).join("");
      wrap.innerHTML = `<select class="input a-event">${evs}</select><span class="hint small">Re-emits this event so other workflows can react.</span>`;
    } else if (kind === "handler") {
      wrap.innerHTML = `<input class="input a-task" list="wf-handlers" placeholder="request_site_rebuild" value="${esc(a.task ?? "")}" /><span class="hint small">An internal task to run (e.g. request_site_rebuild, ai_reindex_embeddings).</span>`;
    } else if (kind === "webhook") {
      const whs = OPTIONS.webhooks || [];
      if (!whs.length) {
        wrap.innerHTML = `<p class="muted small">No webhooks configured yet — <a href="/automation/webhooks">add one</a> first.</p>`;
        return wrap;
      }
      const opts = whs.map((w: any) => `<option value="${esc(w.id)}" ${a.webhook_id === w.id ? "selected" : ""}>${esc(w.name)} · ${esc(w.method)}</option>`).join("");
      wrap.innerHTML = `<select class="input a-webhook">${opts}</select><span class="hint small">Fires one of your configured webhooks (its URL, method, headers, and payload).</span>`;
    }
    return wrap;
  }

  // ── Build / read the definition ───────────────────────────────────────────
  function readDefinition() {
    const conditions = [...document.querySelectorAll(".cond-row")].map((r) => {
      const field = (r.querySelector(".c-field") as HTMLInputElement).value.trim();
      const op = (r.querySelector(".c-op") as HTMLSelectElement).value;
      const value = (r.querySelector(".c-value") as HTMLInputElement).value;
      return field ? { field, op, value } : null;
    }).filter(Boolean);

    const actions = [...document.querySelectorAll(".action-row")].map((r) => {
      const kind = (r.querySelector(".a-kind") as HTMLSelectElement).value;
      if (kind === "operation") {
        const op = (r.querySelector(".a-op") as HTMLSelectElement | null)?.value;
        if (!op) return null;
        return { kind, op, write_back: (r.querySelector(".a-writeback") as HTMLInputElement)?.checked || false };
      }
      if (kind === "emit_event") return { kind, event: (r.querySelector(".a-event") as HTMLSelectElement).value };
      if (kind === "handler") {
        const task = (r.querySelector(".a-task") as HTMLInputElement).value.trim();
        return task ? { kind, task } : null;
      }
      if (kind === "webhook") {
        const webhookId = (r.querySelector(".a-webhook") as HTMLSelectElement | null)?.value;
        return webhookId ? { kind, webhook_id: webhookId } : null;
      }
      return null;
    }).filter(Boolean);

    const ttype = ($("wf-trigger-type") as HTMLSelectElement).value;
    let trigger: any;
    if (ttype === "event") {
      trigger = { type: "event", event: ($("wf-trigger") as HTMLSelectElement).value };
    } else if (ttype === "schedule") {
      const n = Math.max(1, parseInt(($("wf-sched-n") as HTMLInputElement).value || "1", 10));
      const unit = parseInt(($("wf-sched-unit") as HTMLSelectElement).value, 10);
      trigger = { type: "schedule", schedule_type: "interval", schedule_config: { interval_seconds: n * unit } };
    } else if (ttype === "chained" || ttype === "on_error") {
      const target = ($("wf-chained-target") as HTMLSelectElement).value;
      trigger = { type: ttype, ...(target && target !== "any" ? { automation: target } : {}) };
    } else if (ttype === "incoming_webhook") {
      const wh = ($("wf-webhook-target") as HTMLSelectElement).value;
      trigger = { type: ttype, ...(wh && wh !== "any" ? { webhook: wh } : {}) };
    } else {
      trigger = { type: ttype };
    }
    return { trigger, conditions, actions };
  }

  // ── Open / close the builder ──────────────────────────────────────────────
  function openBuilder(wf: any = null) {
    editingId = wf?.id ?? null;
    $("wf-builder-title").textContent = wf ? `Edit: ${wf.name}` : "New workflow";
    ($("wf-name") as HTMLInputElement).value = wf?.name ?? "";
    ($("wf-enabled") as HTMLInputElement).checked = wf?.enabled ?? false;
    fillTriggers();
    const def = wf?.definition ?? {};
    const trig = def.trigger ?? {};
    ($("wf-trigger-type") as HTMLSelectElement).value = trig.type || "event";
    if (trig.event) ($("wf-trigger") as HTMLSelectElement).value = trig.event;
    if (trig.type === "schedule") {
      const secs = trig.schedule_config?.interval_seconds || 86400;
      const unit = secs % 86400 === 0 ? 86400 : secs % 3600 === 0 ? 3600 : 60;
      ($("wf-sched-n") as HTMLInputElement).value = String(Math.max(1, Math.round(secs / unit)));
      ($("wf-sched-unit") as HTMLSelectElement).value = String(unit);
    }
    if (trig.type === "chained" || trig.type === "on_error") {
      ($("wf-chained-target") as HTMLSelectElement).value = trig.automation || "any";
    }
    if (trig.type === "incoming_webhook") {
      ($("wf-webhook-target") as HTMLSelectElement).value = trig.webhook || "any";
    }
    syncTriggerType();

    const condWrap = $("wf-conditions"); condWrap.innerHTML = "";
    (def.conditions ?? []).forEach((c: any) => condWrap.appendChild(conditionRow(c)));
    const actWrap = $("wf-actions"); actWrap.innerHTML = "";
    (def.actions?.length ? def.actions : [{}]).forEach((a: any) => actWrap.appendChild(actionRow(a)));

    ($("wf-json") as HTMLTextAreaElement).value = JSON.stringify(def, null, 2);
    setJsonMode(false);
    statusEl.textContent = "";
    builder.removeAttribute("hidden");
    builder.scrollIntoView({ behavior: "smooth", block: "start" });
  }
  function closeBuilder() { builder.setAttribute("hidden", ""); editingId = null; }

  function setJsonMode(on: boolean) {
    jsonMode = on;
    guided.toggleAttribute("hidden", on);
    jsonEditor.toggleAttribute("hidden", !on);
    $("wf-json-toggle").textContent = on ? "Use guided builder" : "Edit as JSON";
    // keep them in sync when switching
    if (on) ($("wf-json") as HTMLTextAreaElement).value = JSON.stringify(readDefinition(), null, 2);
  }

  // ── Save ──────────────────────────────────────────────────────────────────
  async function save() {
    const name = ($("wf-name") as HTMLInputElement).value.trim();
    if (!name) { statusEl.textContent = "Name is required."; return; }
    let definition: any;
    try {
      definition = jsonMode ? JSON.parse(($("wf-json") as HTMLTextAreaElement).value) : readDefinition();
    } catch (e: any) { statusEl.textContent = `Invalid JSON: ${e.message}`; return; }
    if (!definition.actions?.length) { statusEl.textContent = "Add at least one step."; return; }

    const enabled = ($("wf-enabled") as HTMLInputElement).checked;
    statusEl.textContent = "Saving…";
    try {
      if (editingId) await updateAutomation(editingId, { name, enabled, definition });
      else await createAutomation({ name, enabled, definition });
      location.reload();
    } catch (e: any) {
      statusEl.textContent = e?.message || "Save failed.";
    }
  }

  // ── List rendering ─────────────────────────────────────────────────────────
  const OP_SYMBOL: Record<string, string> = { eq: "=", neq: "≠", contains: "contains", exists: "exists" };
  function stepChip(a: any): string {
    const base = KIND_LABELS[a.kind] || a.kind;
    const webhookName = a.webhook_id
      ? ((OPTIONS.webhooks || []).find((w: any) => w.id === a.webhook_id)?.name ?? "webhook")
      : (a.url ? "raw url" : "");
    const detail = a.op || a.task || (a.event ? prettyEvent(a.event) : "") || webhookName;
    const text = detail ? `${base} · ${detail}` : base;
    return `<span class="chip step k-${esc(a.kind)}">${esc(text)}</span>`;
  }
  function lane(label: string, chips: string[]): string {
    if (!chips.length) return "";
    return `<div class="lane"><span class="lane-label">${label}</span><div class="chips">${chips.join("")}</div></div>`;
  }
  function summarize(wf: any): string {
    const d = wf.definition || {};
    const conds = (d.conditions || []).map(
      (c: any) => `<span class="chip cond">${esc(c.field)} <em>${esc(OP_SYMBOL[c.op] || c.op)}</em> ${esc(c.value ?? "")}</span>`,
    );
    const steps = (d.actions || []).map(stepChip);
    const t = d.trigger || {};
    const trigText = t.type === "manual" ? "run manually"
      : t.type === "mcp" ? "MCP tool"
      : t.type === "schedule" ? `every ${humanInterval(t.schedule_config?.interval_seconds)}`
      : t.type === "chained" ? `after ${automationName(t.automation)}`
      : t.type === "on_error" ? `if ${automationName(t.automation)} fails`
      : t.type === "incoming_webhook" ? `${webhookName(t.webhook)} received`
      : prettyEvent(t.event || "—");
    const trigChip = `<span class="chip trigger">${esc(trigText)}</span>`;
    return `<div class="flow">
      ${lane("When", [trigChip])}
      ${lane("If", conds)}
      ${lane("Then", steps)}
    </div>`;
  }

  function renderList() {
    const host = $("wf-list");
    $("wf-empty").toggleAttribute("hidden", workflows.length > 0);
    host.innerHTML = workflows.map((wf) => `
      <div class="wf-card ${wf.enabled ? "" : "off"}" data-id="${esc(wf.id)}">
        <div class="wf-main">
          <div class="wf-title">
            <strong>${esc(wf.name)}</strong>
            <span class="badge ${wf.enabled ? "on" : "muted"}">${wf.enabled ? "Enabled" : "Disabled"}</span>
          </div>
          ${summarize(wf)}
        </div>
        <div class="wf-actions">
          <button class="wf-btn primary js-run">Run</button>
          <button class="wf-btn js-toggle">${wf.enabled ? "Disable" : "Enable"}</button>
          <button class="wf-btn js-edit">Edit</button>
          <button class="wf-btn danger js-delete">Delete</button>
        </div>
      </div>`).join("");

    host.querySelectorAll(".wf-card").forEach((card) => {
      const id = (card as HTMLElement).dataset.id!;
      const wf = workflows.find((w) => w.id === id);
      card.querySelector(".js-run")!.addEventListener("click", async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        btn.disabled = true; const orig = btn.textContent; btn.textContent = "Running…";
        try {
          const res = await runAutomation(id);
          alert(res.ok ? "Workflow ran." : "Workflow ran with errors — check the Event Log.");
        } catch (err: any) {
          alert(err?.message || "Run failed.");
        } finally { btn.disabled = false; btn.textContent = orig; }
      });
      card.querySelector(".js-edit")!.addEventListener("click", () => openBuilder(wf));
      card.querySelector(".js-toggle")!.addEventListener("click", async () => {
        try { await updateAutomation(id, { enabled: !wf.enabled }); location.reload(); }
        catch (e: any) { alert(e?.message || "Failed to toggle."); }
      });
      card.querySelector(".js-delete")!.addEventListener("click", async () => {
        if (!confirm(`Delete workflow “${wf.name}”?`)) return;
        try { await deleteAutomation(id); location.reload(); }
        catch (e: any) { alert(e?.message || "Failed to delete."); }
      });
    });
  }

  // ── Wire up ─────────────────────────────────────────────────────────────────
  $("wf-new").addEventListener("click", () => openBuilder());
  $("wf-cancel").addEventListener("click", closeBuilder);
  $("wf-save").addEventListener("click", save);
  $("wf-trigger-type").addEventListener("change", syncTriggerType);
  $("wf-add-condition").addEventListener("click", () => $("wf-conditions").appendChild(conditionRow()));
  $("wf-add-action").addEventListener("click", () => $("wf-actions").appendChild(actionRow()));
  $("wf-json-toggle").addEventListener("click", () => setJsonMode(!jsonMode));

  // datalists for field/handler hints
  const dl = document.createElement("datalist"); dl.id = "wf-fields";
  ["entry.entry_type", "entry.status", "entry.title", "entry.slug"].forEach((f) => {
    const o = document.createElement("option"); o.value = f; dl.appendChild(o);
  });
  document.body.appendChild(dl);
  const dh = document.createElement("datalist"); dh.id = "wf-handlers";
  ["request_site_rebuild", "ai_reindex_embeddings", "publish_scheduled_entries"].forEach((f) => {
    const o = document.createElement("option"); o.value = f; dh.appendChild(o);
  });
  document.body.appendChild(dh);

  renderList();
</script>

