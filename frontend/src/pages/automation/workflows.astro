---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";
import { createSdkClient } from "@/lib/sdk";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let workspace: any = null;
let automations: any[] = [];
let options: any = { triggers: [], conditionOps: [], actionKinds: [], operations: [] };
let error: string | null = null;

try {
  workspace = await getCurrentWorkspace(authToken);
  if (workspace) {
    [automations, options] = await Promise.all([sdk.automations.list(), sdk.automations.options()]);
  }
} catch (e) {
  console.error("[workflows] Error loading:", e);
  error = e instanceof Error ? e.message : String(e);
}

// Serialize server data for the client script (read via JSON.parse, so the module script can import).
const optionsJson = JSON.stringify(options).replace(/</g, "\\u003c");
const listJson = JSON.stringify(automations).replace(/</g, "\\u003c");
const aiActionsAvailable = (options.operations ?? []).length > 0;
---

<AppLayout title="Workflows" eyebrow="Automation">
 <div class="workflows-page">
  <div class="toolbar">
    <div>
      <h2>Workflows</h2>
      <p>When something happens, run steps automatically — no code. AI steps are optional.</p>
    </div>
    <div class="toolbar-actions">
      <button id="wf-new" class="button">New workflow</button>
    </div>
  </div>

  <div class="page-container">
    {error && <div class="banner error">{error}</div>}

    {!aiActionsAvailable && (
      <div class="banner info">
        AI actions aren’t available — <a href="/workspace/settings/ai-workflow">enable AI</a> (and allow the
        <code>automation</code> source) to add steps like “generate summary”. Event, task, and webhook steps work regardless.
      </div>
    )}

    <!-- Builder (hidden until New/Edit) -->
    <section id="wf-builder" class="builder" hidden>
      <div class="builder-head">
        <h3 id="wf-builder-title">New workflow</h3>
        <button id="wf-json-toggle" type="button" class="linkish">Edit as JSON</button>
      </div>

      <div id="wf-guided">
        <div class="form-field">
          <label class="label" for="wf-name">Name</label>
          <input class="input" id="wf-name" placeholder="Summarize published bench notes" />
        </div>

        <div class="form-field">
          <label class="label" for="wf-trigger-type">Trigger</label>
          <select class="input" id="wf-trigger-type"></select>
        </div>

        <div class="form-field" id="wf-event-field">
          <label class="label" for="wf-trigger">On event</label>
          <select class="input" id="wf-trigger"></select>
          <span class="hint">The event that starts the workflow.</span>
        </div>
        <p class="hint" id="wf-manual-hint" hidden>Runs when you press <strong>Run</strong> on the workflow (or via the API). No event needed.</p>
        <p class="hint" id="wf-mcp-hint" hidden>Exposed as a named MCP tool (<code>marvin_wf_&lt;slug&gt;</code>) so external MCP hosts can run it. Also runnable via <strong>Run</strong>.</p>

        <div class="form-field" id="wf-schedule-field" hidden>
          <label class="label" for="wf-sched-n">Every</label>
          <div class="inline">
            <input class="input" id="wf-sched-n" type="number" min="1" value="1" />
            <select class="input" id="wf-sched-unit">
              <option value="60">minutes</option>
              <option value="3600">hours</option>
              <option value="86400" selected>days</option>
            </select>
          </div>
          <span class="hint">How often to run it. Adds a task to your Scheduler.</span>
        </div>

        <div class="form-field" id="wf-chained-field" hidden>
          <label class="label" for="wf-chained-target">Workflow</label>
          <select class="input" id="wf-chained-target"></select>
          <span class="hint" id="wf-chained-hint">Runs after the selected workflow completes.</span>
        </div>

        <div class="form-field" id="wf-webhook-field" hidden>
          <label class="label" for="wf-webhook-target">Incoming webhook</label>
          <select class="input" id="wf-webhook-target"></select>
          <span class="hint">Runs when this webhook receives a POST. Read the payload with <code>$event.payload.*</code>. Manage webhooks under <a href="/automation/incoming-webhooks">Incoming Webhooks</a>.</span>
        </div>

        <div class="form-field target-block">
          <label class="check"><input type="checkbox" id="wf-target-on" /> Run on a query of entries <span class="muted">(instead of the triggering entry) — runs the steps on each match</span></label>
          <div id="wf-target-body" hidden>
            <div class="target-grid">
              <label class="tf"><span>Entry type</span><input class="input" id="wf-t-type" placeholder="any — e.g. recipe" /></label>
              <label class="tf"><span>Status</span>
                <select class="input" id="wf-t-status">
                  <option value="">any</option>
                  <option value="draft">draft</option>
                  <option value="published">published</option>
                  <option value="archived">archived</option>
                  <option value="inbox">inbox</option>
                </select>
              </label>
              <label class="tf"><span>Title contains</span><input class="input" id="wf-t-text" placeholder="any" /></label>
              <label class="tf"><span>In collection</span><input class="input" id="wf-t-collection" placeholder="any — slug or name" /></label>
            </div>
            <div class="target-checks">
              <label class="check small"><input type="checkbox" id="wf-t-images" /> has images</label>
              <label class="check small"><input type="checkbox" id="wf-t-assets" /> has assets</label>
              <label class="check small"><input type="checkbox" id="wf-t-resources" /> has resources</label>
            </div>
            <div class="target-preview-row">
              <button type="button" class="button secondary sm" id="wf-preview-btn">Preview matches</button>
              <span class="hint" id="wf-preview-status"></span>
            </div>
            <div id="wf-preview-result" class="preview-result" hidden></div>
          </div>
        </div>

        <div class="form-field">
          <label class="label">Only if <span class="muted">(all conditions must match — optional)</span></label>
          <div id="wf-conditions" class="rows"></div>
          <button type="button" class="linkish" id="wf-add-condition">+ Add condition</button>
        </div>

        <div class="form-field">
          <label class="label">Then do <span class="muted">(steps run in order; each can use the previous step’s output)</span></label>
          <div id="wf-actions" class="rows"></div>
          <button type="button" class="linkish" id="wf-add-action">+ Add step</button>
        </div>

        <label class="check"><input type="checkbox" id="wf-enabled" /> Enabled</label>
      </div>

      <div id="wf-json-editor" hidden>
        <div class="form-field">
          <label class="label" for="wf-json">Definition (JSON)</label>
          <textarea class="input mono" id="wf-json" rows="16" spellcheck="false"></textarea>
          <span class="hint">Advanced: the raw <code>{`{ trigger, conditions, actions }`}</code> definition.</span>
        </div>
      </div>

      <div id="wf-warnings" class="banner warn" hidden></div>

      <div class="builder-actions">
        <button id="wf-save" class="button">Save workflow</button>
        <button id="wf-cancel" class="button secondary" type="button">Cancel</button>
        <span id="wf-status" class="status"></span>
      </div>
    </section>

    <!-- Workflow list -->
    <div id="wf-list" class="wf-list"></div>
    <div id="wf-empty" class="empty" hidden>No workflows yet. Create one to automate a repetitive step.</div>
  </div>

  <script type="application/json" id="wf-options-data" is:inline set:html={optionsJson}></script>
  <script type="application/json" id="wf-list-data" is:inline set:html={listJson}></script>
 </div>
</AppLayout>

<script>
  import {
    createAutomation,
    updateAutomation,
    deleteAutomation,
    runAutomation,
    dryRunAutomation,
    validateAutomation,
    previewAutomation,
    listAutomationExecutions,
    getAutomationExecution,
  } from "@/lib/api/automations";

  const read = (id: string) => JSON.parse(document.getElementById(id)!.textContent || "null");
  const OPTIONS = read("wf-options-data") || { triggers: [], conditionOps: [], actionKinds: [], operations: [] };
  let workflows: any[] = read("wf-list-data") || [];

  const $ = (id: string) => document.getElementById(id)!;
  const esc = (s: unknown) =>
    String(s ?? "").replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));

  const builder = $("wf-builder");
  const guided = $("wf-guided");
  const jsonEditor = $("wf-json-editor");
  const statusEl = $("wf-status");
  let editingId: string | null = null; // null = creating
  let jsonMode = false;

  // ── Option-driven controls ────────────────────────────────────────────────
  const prettyEvent = (e: string) => e.replace(/_/g, " ");
  const TRIGGER_TYPE_LABELS: Record<string, string> = {
    event: "Event", manual: "Manual (Run button)", schedule: "Schedule",
    chained: "After another workflow", on_error: "When a workflow fails",
    incoming_webhook: "Incoming webhook (external POST)",
    mcp: "MCP tool (external hosts)",
  };
  function webhookName(ref: string | undefined): string {
    if (!ref || ref === "any") return "any incoming webhook";
    const w = (OPTIONS.incomingWebhooks || []).find((x: any) => x.slug === ref || x.id === ref);
    return w ? w.name : ref;
  }
  function automationName(ref: string | undefined): string {
    if (!ref || ref === "any") return "any workflow";
    const a = (OPTIONS.automations || []).find((x: any) => x.slug === ref || x.id === ref);
    return a ? a.name : ref;
  }
  function humanInterval(secs: number): string {
    if (!secs) return "—";
    const [n, unit] = secs % 86400 === 0 ? [secs / 86400, "day"]
      : secs % 3600 === 0 ? [secs / 3600, "hour"]
      : [Math.max(1, Math.round(secs / 60)), "minute"];
    return `${n} ${unit}${n === 1 ? "" : "s"}`;
  }

  function fillTriggers() {
    const typeSel = $("wf-trigger-type") as HTMLSelectElement;
    typeSel.innerHTML = (OPTIONS.triggerTypes || ["event"])
      .map((t: string) => `<option value="${esc(t)}">${esc(TRIGGER_TYPE_LABELS[t] || t)}</option>`)
      .join("");
    const evSel = $("wf-trigger") as HTMLSelectElement;
    const groups = OPTIONS.triggerGroups as Record<string, string[]> | undefined;
    if (groups && Object.keys(groups).length) {
      // Grouped by family (Entries/Assets/Forms/…) — 26 events read better as optgroups.
      evSel.innerHTML = Object.entries(groups)
        .map(([label, evs]) => `<optgroup label="${esc(label)}">${
          evs.map((t) => `<option value="${esc(t)}">${esc(prettyEvent(t))}</option>`).join("")
        }</optgroup>`).join("");
    } else {
      evSel.innerHTML = (OPTIONS.triggers || [])
        .map((t: string) => `<option value="${esc(t)}">${esc(prettyEvent(t))}</option>`).join("");
    }
    const chSel = $("wf-chained-target") as HTMLSelectElement;
    chSel.innerHTML = `<option value="any">Any workflow</option>` +
      (OPTIONS.automations || []).map((a: any) => `<option value="${esc(a.slug)}">${esc(a.name)}</option>`).join("");
    const whSel = $("wf-webhook-target") as HTMLSelectElement;
    whSel.innerHTML = `<option value="any">Any incoming webhook</option>` +
      (OPTIONS.incomingWebhooks || []).map((w: any) =>
        `<option value="${esc(w.slug)}">${esc(w.name)}${w.hasToken ? "" : " (no token yet)"}</option>`).join("");
  }
  function syncTriggerType() {
    const t = ($("wf-trigger-type") as HTMLSelectElement).value;
    const isChain = t === "chained" || t === "on_error";
    $("wf-event-field").toggleAttribute("hidden", t !== "event");
    $("wf-manual-hint").toggleAttribute("hidden", t !== "manual");
    $("wf-mcp-hint").toggleAttribute("hidden", t !== "mcp");
    $("wf-schedule-field").toggleAttribute("hidden", t !== "schedule");
    $("wf-chained-field").toggleAttribute("hidden", !isChain);
    $("wf-webhook-field").toggleAttribute("hidden", t !== "incoming_webhook");
    if (isChain) {
      $("wf-chained-hint").textContent = t === "on_error"
        ? "Runs when the selected workflow fails."
        : "Runs after the selected workflow completes.";
    }
    populateFieldDatalist(t);
    revalidate();
  }

  // ── Live coherence check (advisory) ───────────────────────────────────────
  let revalidateTimer: any;
  function revalidate() {
    clearTimeout(revalidateTimer);
    revalidateTimer = setTimeout(runRevalidate, 350);
  }
  async function runRevalidate() {
    const banner = $("wf-warnings");
    if (jsonMode) { banner.setAttribute("hidden", ""); return; }  // JSON mode: don't fight the editor
    let def: any;
    try { def = readDefinition(); } catch { banner.setAttribute("hidden", ""); return; }
    try {
      const res = await validateAutomation(def);
      const issues = res?.issues ?? [];
      if (!issues.length) { banner.setAttribute("hidden", ""); banner.innerHTML = ""; return; }
      banner.innerHTML = `<strong>Heads up:</strong><ul>${
        issues.map((i: any) => `<li>${esc(i.message)}</li>`).join("")
      }</ul><span class="warn-note">These are warnings — you can still save.</span>`;
      banner.removeAttribute("hidden");
    } catch {
      banner.setAttribute("hidden", "");  // never block the builder on the validator
    }
  }
  const KIND_LABELS: Record<string, string> = {
    operation: "AI operation",
    entry: "Entry action",
    emit_event: "Emit event",
    handler: "Run task",
    webhook: "Call webhook",
  };
  const ENTRY_OP_LABELS: Record<string, string> = {
    publish: "Publish", unpublish: "Unpublish", archive: "Archive", restore: "Restore from archive",
    add_to_collection: "Add to collection", remove_from_collection: "Remove from collection",
  };
  const COLLECTION_OPS = new Set(["add_to_collection", "remove_from_collection"]);
  const COND_OP_LABELS: Record<string, string> = {
    eq: "equals", neq: "not equals", contains: "contains", in: "is one of",
    starts_with: "starts with", exists: "exists", changed: "changed",
    changed_from: "changed from", changed_to: "changed to",
  };
  // Most-useful-first (backend returns kinds alphabetically). New steps default to the first
  // available — an AI operation when AI is on, otherwise the first non-AI kind.
  const KIND_ORDER = ["operation", "entry", "handler", "webhook", "emit_event"];
  const orderedKinds = (): string[] => {
    const avail = OPTIONS.actionKinds || [];
    return KIND_ORDER.filter((k) => avail.includes(k)).concat(avail.filter((k: string) => !KIND_ORDER.includes(k)));
  };
  const defaultKind = (): string =>
    (OPTIONS.operations || []).length ? "operation" : (orderedKinds().find((k) => k !== "operation") || orderedKinds()[0] || "operation");

  // ── Condition rows ────────────────────────────────────────────────────────
  function conditionRow(c: any = {}) {
    const row = document.createElement("div");
    row.className = "row cond-row";
    const ops = (OPTIONS.conditionOps || []).map((o: string) => `<option value="${esc(o)}" ${c.op === o ? "selected" : ""}>${esc(COND_OP_LABELS[o] || o)}</option>`).join("");
    row.innerHTML = `
      <input class="input c-field" list="wf-fields" placeholder="entry.entry_type" value="${esc(c.field ?? "")}" />
      <select class="input c-op">${ops}</select>
      <input class="input c-value" placeholder="value" value="${esc(c.value ?? "")}" />
      <button type="button" class="icon-btn" title="Remove">✕</button>`;
    row.querySelector(".icon-btn")!.addEventListener("click", () => { row.remove(); revalidate(); });
    return row;
  }

  // ── Action rows (kind-dependent fields) ───────────────────────────────────
  function actionRow(a: any = {}) {
    const row = document.createElement("div");
    row.className = "row action-row";
    const selectedKind = a.kind || defaultKind();
    const aiOpsAvailable = (OPTIONS.operations || []).length > 0;
    const kinds = orderedKinds()
      .map((k: string) => {
        // Mark the AI-operation kind unavailable when AI/the automation source is off — unless this
        // step already is an operation (so an existing step still renders + can be fixed).
        const off = k === "operation" && !aiOpsAvailable && selectedKind !== "operation";
        const label = KIND_LABELS[k] || k;
        return `<option value="${esc(k)}" ${selectedKind === k ? "selected" : ""} ${off ? "disabled" : ""}>${esc(label)}${off ? " (needs AI)" : ""}</option>`;
      })
      .join("");
    row.innerHTML = `
      <div class="action-head">
        <select class="input a-kind">${kinds}</select>
        <button type="button" class="icon-btn" title="Remove step">✕</button>
      </div>
      <div class="a-fields"></div>`;
    const kindSel = row.querySelector(".a-kind") as HTMLSelectElement;
    const fields = row.querySelector(".a-fields") as HTMLElement;
    const render = () => { fields.innerHTML = ""; fields.appendChild(kindFields(kindSel.value, a)); };
    kindSel.addEventListener("change", () => render());
    row.querySelector(".icon-btn")!.addEventListener("click", () => { row.remove(); revalidate(); });
    render();
    return row;
  }

  function kindFields(kind: string, a: any): HTMLElement {
    const wrap = document.createElement("div");
    if (kind === "operation") {
      const ops = (OPTIONS.operations || []);
      if (!ops.length) {
        // Empty when AI is off OR the `automation` invocation source is disabled for this workspace.
        wrap.innerHTML = `<p class="muted small">AI operations aren't available here — AI is off, or the
          <strong>Automations</strong> AI source is turned off. Turn it on in
          <a href="/workspace/settings/ai-workflow">AI Settings</a>.</p>`;
        return wrap;
      }
      const optList = ops.map((o: any) => `<option value="${esc(o.op)}" ${a.op === o.op ? "selected" : ""}>${esc(o.name)}</option>`).join("");
      wrap.innerHTML = `
        <select class="input a-op">${optList}</select>
        <input class="input a-entity-slug" placeholder="Target entry by slug — e.g. $event.payload.entry_slug" value="${esc(a.entity_slug ?? "")}" />
        <span class="hint small">Which entry to run on. Leave blank to use the triggering entry; for a webhook, point at one by slug (e.g. <code>$event.payload.entry_slug</code>).</span>
        <label class="check small"><input type="checkbox" class="a-writeback" ${a.write_back ? "checked" : ""}/> Write the result back to the entry</label>`;
    } else if (kind === "entry") {
      const opList = Object.entries(ENTRY_OP_LABELS)
        .map(([op, label]) => `<option value="${esc(op)}" ${a.op === op ? "selected" : ""}>${esc(label)}</option>`).join("");
      const showColl = COLLECTION_OPS.has(a.op);
      wrap.innerHTML = `
        <select class="input a-op">${opList}</select>
        <input class="input a-entity-slug" placeholder="Target entry by slug — e.g. $event.payload.entry_slug" value="${esc(a.entity_slug ?? "")}" />
        <span class="hint small">Which entry to act on. Leave blank to use the triggering entry (or each entry a Run-on target matches); or point at one by slug (e.g. <code>$event.payload.entry_slug</code>).</span>
        <label class="a-collection-wrap tf" ${showColl ? "" : "hidden"}><span>Collection</span>
          <input class="input a-collection" placeholder="slug or name — e.g. featured" value="${esc(a.collection_slug ?? "")}" /></label>`;
      // Toggle the collection field when the op switches to/from a membership op.
      const opSel = wrap.querySelector(".a-op") as HTMLSelectElement;
      const collWrap = wrap.querySelector(".a-collection-wrap") as HTMLElement;
      opSel.addEventListener("change", () => collWrap.toggleAttribute("hidden", !COLLECTION_OPS.has(opSel.value)));
    } else if (kind === "emit_event") {
      const evs = (OPTIONS.triggers || []).map((t: string) => `<option value="${esc(t)}" ${a.event === t ? "selected" : ""}>${esc(prettyEvent(t))}</option>`).join("");
      wrap.innerHTML = `<select class="input a-event">${evs}</select><span class="hint small">Re-emits this event so other workflows can react.</span>`;
    } else if (kind === "handler") {
      wrap.innerHTML = `<input class="input a-task" list="wf-handlers" placeholder="request_site_rebuild" value="${esc(a.task ?? "")}" /><span class="hint small">An internal task to run (e.g. request_site_rebuild, ai_reindex_embeddings).</span>`;
    } else if (kind === "webhook") {
      const whs = OPTIONS.webhooks || [];
      if (!whs.length) {
        wrap.innerHTML = `<p class="muted small">No webhooks configured yet — <a href="/automation/webhooks">add one</a> first.</p>`;
        return wrap;
      }
      const opts = whs.map((w: any) => `<option value="${esc(w.id)}" ${a.webhook_id === w.id ? "selected" : ""}>${esc(w.name)} · ${esc(w.method)}</option>`).join("");
      wrap.innerHTML = `<select class="input a-webhook">${opts}</select><span class="hint small">Fires one of your configured webhooks (its URL, method, headers, and payload).</span>`;
    }
    return wrap;
  }

  // ── Build / read the definition ───────────────────────────────────────────
  function readDefinition() {
    const conditions = [...document.querySelectorAll(".cond-row")].map((r) => {
      const field = (r.querySelector(".c-field") as HTMLInputElement).value.trim();
      const op = (r.querySelector(".c-op") as HTMLSelectElement).value;
      const value = (r.querySelector(".c-value") as HTMLInputElement).value;
      return field ? { field, op, value } : null;
    }).filter(Boolean);

    const actions = [...document.querySelectorAll(".action-row")].map((r) => {
      const kind = (r.querySelector(".a-kind") as HTMLSelectElement).value;
      if (kind === "operation") {
        const op = (r.querySelector(".a-op") as HTMLSelectElement | null)?.value;
        if (!op) return null;
        const slug = (r.querySelector(".a-entity-slug") as HTMLInputElement | null)?.value.trim();
        const step: any = { kind, op, write_back: (r.querySelector(".a-writeback") as HTMLInputElement)?.checked || false };
        if (slug) step.entity_slug = slug;
        return step;
      }
      if (kind === "entry") {
        const op = (r.querySelector(".a-op") as HTMLSelectElement | null)?.value;
        if (!op) return null;
        const slug = (r.querySelector(".a-entity-slug") as HTMLInputElement | null)?.value.trim();
        const step: any = { kind, op };
        if (slug) step.entity_slug = slug;
        if (COLLECTION_OPS.has(op)) {
          const coll = (r.querySelector(".a-collection") as HTMLInputElement | null)?.value.trim();
          if (coll) step.collection_slug = coll;
        }
        return step;
      }
      if (kind === "emit_event") return { kind, event: (r.querySelector(".a-event") as HTMLSelectElement).value };
      if (kind === "handler") {
        const task = (r.querySelector(".a-task") as HTMLInputElement).value.trim();
        return task ? { kind, task } : null;
      }
      if (kind === "webhook") {
        const webhookId = (r.querySelector(".a-webhook") as HTMLSelectElement | null)?.value;
        return webhookId ? { kind, webhook_id: webhookId } : null;
      }
      return null;
    }).filter(Boolean);

    const ttype = ($("wf-trigger-type") as HTMLSelectElement).value;
    let trigger: any;
    if (ttype === "event") {
      trigger = { type: "event", event: ($("wf-trigger") as HTMLSelectElement).value };
    } else if (ttype === "schedule") {
      const n = Math.max(1, parseInt(($("wf-sched-n") as HTMLInputElement).value || "1", 10));
      const unit = parseInt(($("wf-sched-unit") as HTMLSelectElement).value, 10);
      trigger = { type: "schedule", schedule_type: "interval", schedule_config: { interval_seconds: n * unit } };
    } else if (ttype === "chained" || ttype === "on_error") {
      const target = ($("wf-chained-target") as HTMLSelectElement).value;
      trigger = { type: ttype, ...(target && target !== "any" ? { automation: target } : {}) };
    } else if (ttype === "incoming_webhook") {
      const wh = ($("wf-webhook-target") as HTMLSelectElement).value;
      trigger = { type: ttype, ...(wh && wh !== "any" ? { webhook: wh } : {}) };
    } else {
      trigger = { type: ttype };
    }
    return { trigger, ...readTarget(), conditions, actions };
  }

  // The optional "Run on" selector (FROM clause). Returns {} or { target: {...} }.
  function readTarget() {
    if (!($("wf-target-on") as HTMLInputElement).checked) return {};
    const query: any = {};
    const type = ($("wf-t-type") as HTMLInputElement).value.trim(); if (type) query.entry_type = type;
    const status = ($("wf-t-status") as HTMLSelectElement).value; if (status) query.status = status;
    const text = ($("wf-t-text") as HTMLInputElement).value.trim(); if (text) query.text = text;
    const coll = ($("wf-t-collection") as HTMLInputElement).value.trim(); if (coll) query.collection = coll;
    if (($("wf-t-images") as HTMLInputElement).checked) query.has_images = true;
    if (($("wf-t-assets") as HTMLInputElement).checked) query.has_assets = true;
    if (($("wf-t-resources") as HTMLInputElement).checked) query.has_resources = true;
    return { target: { entity: "entry", query } };
  }

  function syncTargetBody() {
    const on = ($("wf-target-on") as HTMLInputElement).checked;
    $("wf-target-body").toggleAttribute("hidden", !on);
  }

  // Dry-run the target selector: show which entries it would act on, without running anything.
  async function runPreview() {
    const status = $("wf-preview-status");
    const result = $("wf-preview-result");
    status.textContent = "Resolving…"; status.className = "hint";
    result.setAttribute("hidden", "");
    try {
      const res: any = await previewAutomation(readDefinition());
      if (res.error) { status.textContent = `Query error: ${res.error}`; status.className = "hint error"; return; }
      const total = res.total ?? 0;
      const matches = res.matches ?? [];
      const noun = (n: number) => `${n} ${n === 1 ? "entry" : "entries"}`;
      status.textContent = "";
      const cappedNote = res.capped ? ` <span class="muted">(capped — only the first are shown/run)</span>` : "";
      const chips = matches.length
        ? matches.map((m: any) => `<span class="chip">${esc(m.title || m.slug || m.id)}</span>`).join("")
        : `<span class="muted">Nothing passes the conditions.</span>`;
      result.innerHTML =
        `<div class="preview-head">Query matches <strong>${noun(total)}</strong>${cappedNote}. `
        + `After conditions, it would run on <strong>${noun(matches.length)}</strong>:</div>`
        + `<div class="preview-chips">${chips}</div>`;
      result.removeAttribute("hidden");
    } catch (e: any) {
      status.textContent = `Error: ${e?.message ?? e}`; status.className = "hint error";
    }
  }

  // ── Open / close the builder ──────────────────────────────────────────────
  function openBuilder(wf: any = null) {
    editingId = wf?.id ?? null;
    $("wf-builder-title").textContent = wf ? `Edit: ${wf.name}` : "New workflow";
    ($("wf-name") as HTMLInputElement).value = wf?.name ?? "";
    ($("wf-enabled") as HTMLInputElement).checked = wf?.enabled ?? false;
    fillTriggers();
    const def = wf?.definition ?? {};
    const trig = def.trigger ?? {};
    ($("wf-trigger-type") as HTMLSelectElement).value = trig.type || "event";
    if (trig.event) ($("wf-trigger") as HTMLSelectElement).value = trig.event;
    if (trig.type === "schedule") {
      const secs = trig.schedule_config?.interval_seconds || 86400;
      const unit = secs % 86400 === 0 ? 86400 : secs % 3600 === 0 ? 3600 : 60;
      ($("wf-sched-n") as HTMLInputElement).value = String(Math.max(1, Math.round(secs / unit)));
      ($("wf-sched-unit") as HTMLSelectElement).value = String(unit);
    }
    if (trig.type === "chained" || trig.type === "on_error") {
      ($("wf-chained-target") as HTMLSelectElement).value = trig.automation || "any";
    }
    if (trig.type === "incoming_webhook") {
      ($("wf-webhook-target") as HTMLSelectElement).value = trig.webhook || "any";
    }
    syncTriggerType();

    // Restore the "Run on" target selector.
    const tgt = def.target;
    const tq = tgt?.query ?? {};
    ($("wf-target-on") as HTMLInputElement).checked = !!tgt;
    ($("wf-t-type") as HTMLInputElement).value = tq.entry_type ?? "";
    ($("wf-t-status") as HTMLSelectElement).value = tq.status ?? "";
    ($("wf-t-text") as HTMLInputElement).value = tq.text ?? tq.query ?? "";
    ($("wf-t-collection") as HTMLInputElement).value = tq.collection ?? "";
    ($("wf-t-images") as HTMLInputElement).checked = !!tq.has_images;
    ($("wf-t-assets") as HTMLInputElement).checked = !!tq.has_assets;
    ($("wf-t-resources") as HTMLInputElement).checked = !!tq.has_resources;
    syncTargetBody();
    ($("wf-preview-result") as HTMLElement).setAttribute("hidden", "");

    const condWrap = $("wf-conditions"); condWrap.innerHTML = "";
    (def.conditions ?? []).forEach((c: any) => condWrap.appendChild(conditionRow(c)));
    const actWrap = $("wf-actions"); actWrap.innerHTML = "";
    (def.actions?.length ? def.actions : [{}]).forEach((a: any) => actWrap.appendChild(actionRow(a)));

    ($("wf-json") as HTMLTextAreaElement).value = JSON.stringify(def, null, 2);
    setJsonMode(false);
    statusEl.textContent = "";
    builder.removeAttribute("hidden");
    builder.scrollIntoView({ behavior: "smooth", block: "start" });
  }
  function closeBuilder() { builder.setAttribute("hidden", ""); editingId = null; }

  function setJsonMode(on: boolean) {
    jsonMode = on;
    guided.toggleAttribute("hidden", on);
    jsonEditor.toggleAttribute("hidden", !on);
    $("wf-json-toggle").textContent = on ? "Use guided builder" : "Edit as JSON";
    // keep them in sync when switching
    if (on) ($("wf-json") as HTMLTextAreaElement).value = JSON.stringify(readDefinition(), null, 2);
  }

  // ── Save ──────────────────────────────────────────────────────────────────
  async function save() {
    const name = ($("wf-name") as HTMLInputElement).value.trim();
    if (!name) { statusEl.textContent = "Name is required."; return; }
    let definition: any;
    try {
      definition = jsonMode ? JSON.parse(($("wf-json") as HTMLTextAreaElement).value) : readDefinition();
    } catch (e: any) { statusEl.textContent = `Invalid JSON: ${e.message}`; return; }
    if (!definition.actions?.length) { statusEl.textContent = "Add at least one step."; return; }

    const enabled = ($("wf-enabled") as HTMLInputElement).checked;
    statusEl.textContent = "Saving…";
    try {
      if (editingId) await updateAutomation(editingId, { name, enabled, definition });
      else await createAutomation({ name, enabled, definition });
      location.reload();
    } catch (e: any) {
      statusEl.textContent = e?.message || "Save failed.";
    }
  }

  // ── List rendering ─────────────────────────────────────────────────────────
  const OP_SYMBOL: Record<string, string> = {
    eq: "=", neq: "≠", contains: "contains", in: "in", starts_with: "starts", exists: "exists",
    changed: "changed", changed_from: "changed from", changed_to: "changed to",
  };
  function stepChip(a: any): string {
    const base = KIND_LABELS[a.kind] || a.kind;
    const webhookName = a.webhook_id
      ? ((OPTIONS.webhooks || []).find((w: any) => w.id === a.webhook_id)?.name ?? "webhook")
      : (a.url ? "raw url" : "");
    const detail = a.op || a.task || (a.event ? prettyEvent(a.event) : "") || webhookName;
    const text = detail ? `${base} · ${detail}` : base;
    return `<span class="chip step k-${esc(a.kind)}">${esc(text)}</span>`;
  }
  function lane(label: string, chips: string[]): string {
    if (!chips.length) return "";
    return `<div class="lane"><span class="lane-label">${label}</span><div class="chips">${chips.join("")}</div></div>`;
  }
  function summarize(wf: any): string {
    const d = wf.definition || {};
    const conds = (d.conditions || []).map(
      (c: any) => `<span class="chip cond">${esc(c.field)} <em>${esc(OP_SYMBOL[c.op] || c.op)}</em> ${esc(c.value ?? "")}</span>`,
    );
    const steps = (d.actions || []).map(stepChip);
    const t = d.trigger || {};
    const trigText = t.type === "manual" ? "run manually"
      : t.type === "mcp" ? "MCP tool"
      : t.type === "schedule" ? `every ${humanInterval(t.schedule_config?.interval_seconds)}`
      : t.type === "chained" ? `after ${automationName(t.automation)}`
      : t.type === "on_error" ? `if ${automationName(t.automation)} fails`
      : t.type === "incoming_webhook" ? `${webhookName(t.webhook)} received`
      : prettyEvent(t.event || "—");
    const trigChip = `<span class="chip trigger">${esc(trigText)}</span>`;
    const onChips = d.target ? [`<span class="chip target">${esc(targetSummary(d.target))}</span>`] : [];
    return `<div class="flow">
      ${lane("When", [trigChip])}
      ${onChips.length ? lane("On", onChips) : ""}
      ${lane("If", conds)}
      ${lane("Then", steps)}
    </div>`;
  }

  function targetSummary(t: any): string {
    const q = t?.query || {};
    const parts: string[] = [];
    if (q.entry_type) parts.push(q.entry_type);
    if (q.status) parts.push(q.status);
    if (q.collection) parts.push(`in ${q.collection}`);
    if (q.text) parts.push(`titled “${q.text}”`);
    if (q.has_images) parts.push("with images");
    else if (q.has_assets) parts.push("with assets");
    if (q.has_resources) parts.push("with resources");
    const noun = `${t?.entity || "entry"}${parts.length ? "" : " (all)"}`;
    return `${noun}${parts.length ? " " + parts.join(", ") : "s"}`;
  }

  // ── Run history ─────────────────────────────────────────────────────────────
  function runRow(r: any): string {
    const when = r.startedAt ? new Date(r.startedAt).toLocaleString() : "";
    const dur = r.durationMs != null ? ` · ${r.durationMs}ms` : "";
    const targets = (r.targetsMatched > 1 || r.capped) ? ` · ${r.targetsRun}/${r.targetsMatched}${r.capped ? "+" : ""} targets` : "";
    const steps = ` · ${r.stepsOk}✓${r.stepsFailed ? ` ${r.stepsFailed}✗` : ""}`;
    return `<div class="run-row" data-exec="${esc(r.id)}">
        <span class="run-status status-${esc(r.status)}">${esc(r.status)}</span>
        <span class="run-when">${esc(when)}</span>
        <span class="run-meta muted">${esc(r.triggerType)}${esc(targets)}${esc(steps)}${esc(dur)}</span>
      </div>
      <div class="run-detail" hidden></div>`;
  }
  function execActionRow(a: any): string {
    const ent = a.targetEntityId ? ` <span class="muted">→ ${esc(String(a.targetEntityId).slice(0, 8))}</span>` : "";
    const err = a.error ? ` <span class="run-err">${esc(a.error)}</span>` : "";
    const dur = a.durationMs != null ? ` <span class="muted">${a.durationMs}ms</span>` : "";
    return `<div class="act-row">
      <span class="status-${esc(a.status)}">${a.status === "success" ? "✓" : "✗"}</span>
      <span>${esc(a.kind)}${a.label ? ` · ${esc(a.label)}` : ""}</span>${ent}${err}${dur}
    </div>`;
  }
  async function toggleHistory(card: Element, id: string) {
    const panel = card.querySelector(".wf-history") as HTMLElement;
    if (!panel.hasAttribute("hidden")) { panel.setAttribute("hidden", ""); return; }
    panel.removeAttribute("hidden");
    panel.innerHTML = `<span class="hint">Loading runs…</span>`;
    try {
      const runs: any[] = await listAutomationExecutions(id, 15);
      panel.innerHTML = runs.length ? runs.map(runRow).join("") : `<span class="hint">No runs recorded yet.</span>`;
      panel.querySelectorAll(".run-row").forEach((rr) => {
        rr.addEventListener("click", async () => {
          const execId = (rr as HTMLElement).dataset.exec!;
          const detail = rr.nextElementSibling as HTMLElement;
          if (!detail.hasAttribute("hidden")) { detail.setAttribute("hidden", ""); return; }
          detail.removeAttribute("hidden");
          detail.innerHTML = `<span class="hint">Loading…</span>`;
          try {
            const ex: any = await getAutomationExecution(id, execId);
            const acts = ex.actions ?? [];
            // The chain id lets you trace the whole cascade this run belongs to in the event log.
            const chain = ex.correlationId
              ? `<div class="run-chain hint small">chain <code>${esc(ex.correlationId)}</code></div>` : "";
            detail.innerHTML = chain + (acts.length ? acts.map(execActionRow).join("") : `<span class="hint">No step records.</span>`);
          } catch (e: any) { detail.innerHTML = `<span class="hint error">${esc(e?.message ?? e)}</span>`; }
        });
      });
    } catch (e: any) { panel.innerHTML = `<span class="hint error">${esc(e?.message ?? e)}</span>`; }
  }

  // ── Dry run (preview the plan, execute nothing) ──────────────────────────────
  function planStepRow(s: any): string {
    const ok = s.status === "success";
    const label = s.label ? ` · ${esc(s.label)}` : "";
    const tgt = s.resolved?.entity_id ? ` <span class="muted">→ ${esc(String(s.resolved.entity_id).slice(0, 8))}</span>` : "";
    const err = s.error ? ` <span class="run-err">${esc(s.error)}</span>` : "";
    // Show the resolved preview minus the noise keys already shown as label/kind/target.
    const preview = { ...(s.resolved ?? {}) };
    ["dry_run", "kind", "entity_id"].forEach((k) => delete preview[k]);
    const body = Object.keys(preview).length ? `<pre class="plan-json">${esc(JSON.stringify(preview, null, 2))}</pre>` : "";
    return `<div class="act-row">
      <span class="status-${esc(s.status)}">${ok ? "✓" : "✗"}</span>
      <span>${esc(s.kind)}${label}</span>${tgt}${err}
    </div>${body}`;
  }
  async function showDryRun(card: Element, id: string) {
    const panel = card.querySelector(".wf-history") as HTMLElement;
    panel.removeAttribute("hidden");
    panel.innerHTML = `<span class="hint">Resolving plan…</span>`;
    try {
      const res: any = await dryRunAutomation(id);
      const plan: any[] = res.plan ?? [];
      const head = `<div class="hint">Dry run — nothing executed. ${res.ran} target(s), ${plan.length} step(s)${res.ok ? "" : " · would fail"}.</div>`;
      panel.innerHTML = head + (plan.length ? plan.map(planStepRow).join("") : `<span class="hint">No steps would run (target/conditions matched nothing).</span>`);
    } catch (e: any) { panel.innerHTML = `<span class="hint error">${esc(e?.message ?? e)}</span>`; }
  }

  function renderList() {
    const host = $("wf-list");
    $("wf-empty").toggleAttribute("hidden", workflows.length > 0);
    host.innerHTML = workflows.map((wf) => `
      <div class="wf-card ${wf.enabled ? "" : "off"}" data-id="${esc(wf.id)}">
        <div class="wf-main">
          <div class="wf-title">
            <strong>${esc(wf.name)}</strong>
            <span class="badge ${wf.enabled ? "on" : "muted"}">${wf.enabled ? "Enabled" : "Disabled"}</span>
          </div>
          ${summarize(wf)}
          <div class="wf-history" hidden></div>
        </div>
        <div class="wf-actions">
          <button class="wf-btn primary js-run" ${wf.enabled ? "" : "disabled title=\"Enable the workflow to run it\""}>Run</button>
          <button class="wf-btn js-dryrun" title="Preview the plan — resolve inputs, execute nothing">Dry run</button>
          <button class="wf-btn js-history">Runs</button>
          <button class="wf-btn js-toggle">${wf.enabled ? "Disable" : "Enable"}</button>
          <button class="wf-btn js-edit">Edit</button>
          <button class="wf-btn danger js-delete">Delete</button>
        </div>
      </div>`).join("");

    host.querySelectorAll(".wf-card").forEach((card) => {
      const id = (card as HTMLElement).dataset.id!;
      const wf = workflows.find((w) => w.id === id);
      card.querySelector(".js-run")!.addEventListener("click", async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        btn.disabled = true; const orig = btn.textContent; btn.textContent = "Running…";
        try {
          const res = await runAutomation(id);
          alert(res.ok ? "Workflow ran." : "Workflow ran with errors — check the Event Log.");
        } catch (err: any) {
          alert(err?.message || "Run failed.");
        } finally { btn.disabled = false; btn.textContent = orig; }
      });
      card.querySelector(".js-dryrun")!.addEventListener("click", async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        btn.disabled = true; const orig = btn.textContent; btn.textContent = "Resolving…";
        try { await showDryRun(card, id); }
        finally { btn.disabled = false; btn.textContent = orig; }
      });
      card.querySelector(".js-history")!.addEventListener("click", () => toggleHistory(card, id));
      card.querySelector(".js-edit")!.addEventListener("click", () => openBuilder(wf));
      card.querySelector(".js-toggle")!.addEventListener("click", async () => {
        try { await updateAutomation(id, { enabled: !wf.enabled }); location.reload(); }
        catch (e: any) { alert(e?.message || "Failed to toggle."); }
      });
      card.querySelector(".js-delete")!.addEventListener("click", async () => {
        if (!confirm(`Delete workflow “${wf.name}”?`)) return;
        try { await deleteAutomation(id); location.reload(); }
        catch (e: any) { alert(e?.message || "Failed to delete."); }
      });
    });
  }

  // ── Wire up ─────────────────────────────────────────────────────────────────
  $("wf-new").addEventListener("click", () => openBuilder());
  $("wf-cancel").addEventListener("click", closeBuilder);
  $("wf-save").addEventListener("click", save);
  $("wf-trigger-type").addEventListener("change", syncTriggerType);
  $("wf-add-condition").addEventListener("click", () => { $("wf-conditions").appendChild(conditionRow()); revalidate(); });
  $("wf-add-action").addEventListener("click", () => { $("wf-actions").appendChild(actionRow()); revalidate(); });
  $("wf-target-on").addEventListener("change", () => { syncTargetBody(); revalidate(); });
  $("wf-preview-btn").addEventListener("click", runPreview);
  // Any edit inside the builder re-runs the advisory coherence check (debounced).
  builder.addEventListener("input", revalidate);
  builder.addEventListener("change", revalidate);
  $("wf-json-toggle").addEventListener("click", () => setJsonMode(!jsonMode));

  // Condition-field datalist — repopulated per trigger so the picker offers the fields the
  // trigger's context actually exposes (entry.* for entry triggers, event.payload.* for webhooks).
  const dl = document.createElement("datalist"); dl.id = "wf-fields";
  document.body.appendChild(dl);
  function populateFieldDatalist(triggerType: string) {
    const fields = (OPTIONS.conditionFields || {})[triggerType]
      || (OPTIONS.conditionFields || {}).event || [];
    dl.innerHTML = "";
    for (const f of fields) {
      const o = document.createElement("option");
      o.value = f.field;
      o.label = f.description ? `${f.label} — ${f.description}` : f.label;
      dl.appendChild(o);
    }
  }
  populateFieldDatalist("event");
  const dh = document.createElement("datalist"); dh.id = "wf-handlers";
  // Matches the backend allowlist (AUTOMATION_ALLOWED_HANDLERS) — content/publishing/index only.
  ["request_site_rebuild", "publish_scheduled_entries", "unpublish_expired_entries",
   "ai_reindex_embeddings", "resync_smart_collections"].forEach((f) => {
    const o = document.createElement("option"); o.value = f; dh.appendChild(o);
  });
  document.body.appendChild(dh);

  renderList();
</script>

<style>
  /* Most content on this page is injected by the client script; Astro scoped styles don't reach
     JS-created nodes, so component rules are :global() (scoped to .workflows-page so they don't leak). */
  /* `.hint`/`.form-field` set display, which would override the [hidden] attribute — force it. */
  .workflows-page :global([hidden]) { display: none !important; }
  .workflows-page :global(.toolbar) { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 4px; }
  .workflows-page :global(.toolbar h2) { margin: 0; font-size: 22px; }
  .workflows-page :global(.toolbar p) { margin: 4px 0 0; color: var(--muted); font-size: 14px; max-width: 60ch; }
  .workflows-page :global(.page-container) { max-width: 900px; }

  .workflows-page :global(.banner) { padding: 11px 14px; border-radius: 10px; margin: 14px 0; font-size: 13.5px; line-height: 1.5; }
  .workflows-page :global(.banner.error) { background: color-mix(in srgb, var(--color-error) 12%, transparent); color: var(--color-error); }
  .workflows-page :global(.banner.info) { background: var(--panel); border: 1px solid var(--line); color: var(--muted); }
  .workflows-page :global(.banner a) { color: var(--accent); }
  .workflows-page :global(.banner.warn) { background: color-mix(in srgb, #d9a441 13%, transparent); border: 1px solid color-mix(in srgb, #d9a441 42%, transparent); color: var(--ink); }
  .workflows-page :global(.banner.warn[hidden]) { display: none; }
  .workflows-page :global(.banner.warn ul) { margin: 6px 0 4px; padding-left: 18px; }
  .workflows-page :global(.banner.warn li) { margin: 2px 0; }
  .workflows-page :global(.banner.warn .warn-note) { display: block; margin-top: 4px; color: var(--muted); font-size: 12.5px; }

  /* "Run on" target selector + dry-run preview */
  .workflows-page :global(.target-block) { border: 1px dashed var(--line); border-radius: 10px; padding: 12px; }
  .workflows-page :global(.target-grid) { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; margin: 12px 0 8px; }
  .workflows-page :global(.tf) { display: flex; flex-direction: column; gap: 4px; font-size: 12px; }
  .workflows-page :global(.tf > span) { color: var(--muted); }
  .workflows-page :global(.target-checks) { display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 10px; }
  .workflows-page :global(.target-preview-row) { display: flex; align-items: center; gap: 10px; }
  .workflows-page :global(.button.secondary.sm) { padding: 5px 12px; font-size: 12px; }
  .workflows-page :global(.preview-result) { margin-top: 10px; padding: 10px 12px; background: var(--panel); border: 1px solid var(--line); border-radius: 8px; }
  .workflows-page :global(.preview-result[hidden]) { display: none; }
  .workflows-page :global(.preview-head) { font-size: 13px; margin-bottom: 8px; }
  .workflows-page :global(.preview-chips) { display: flex; flex-wrap: wrap; gap: 6px; }
  .workflows-page :global(.preview-chips .chip) { padding: 2px 9px; border-radius: 999px; background: var(--bg); border: 1px solid var(--line); font-size: 12px; }
  .workflows-page :global(.hint.error) { color: var(--color-error); }
  .workflows-page :global(.chip.target) { background: color-mix(in srgb, var(--accent) 12%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent); }

  /* Run history */
  .workflows-page :global(.wf-history) { margin-top: 10px; border-top: 1px solid var(--line); padding-top: 8px; display: flex; flex-direction: column; gap: 2px; }
  .workflows-page :global(.wf-history[hidden]) { display: none; }
  .workflows-page :global(.run-row) { display: flex; align-items: center; gap: 10px; padding: 5px 6px; border-radius: 6px; cursor: pointer; font-size: 12.5px; }
  .workflows-page :global(.run-row:hover) { background: var(--panel); }
  .workflows-page :global(.run-status) { font-weight: 600; text-transform: capitalize; font-size: 11px; }
  .workflows-page :global(.status-success) { color: #3fae6b; }
  .workflows-page :global(.status-failed) { color: var(--color-error); }
  .workflows-page :global(.status-partial) { color: #d9a441; }
  .workflows-page :global(.status-running) { color: var(--muted); }
  .workflows-page :global(.run-meta) { font-size: 11.5px; }
  .workflows-page :global(.run-detail) { margin: 0 0 6px 18px; display: flex; flex-direction: column; gap: 2px; }
  .workflows-page :global(.run-detail[hidden]) { display: none; }
  .workflows-page :global(.act-row) { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--muted); font-family: var(--mono, monospace); }
  .workflows-page :global(.run-err) { color: var(--color-error); }
