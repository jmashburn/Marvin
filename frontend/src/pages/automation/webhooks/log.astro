---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

const filter = Astro.url.searchParams.get('filter') || 'all';

let logs: any[] = [];
let webhooks: any[] = [];
let error: string | null = null;

try {
  [logs, webhooks] = await Promise.all([
    sdk.webhooks.log({ limit: 200 }),
    sdk.webhooks.list(),
  ]);
} catch (e) {
  console.error('[webhooks/log] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

const webhookMap = new Map(webhooks.map((w: any) => [w.id, w]));
const filteredLogs = filter === 'all' ? logs : logs.filter((l: any) => l.status === filter);

function formatDate(isoStr: string): string {
  if (!isoStr) return '—';
  const normalized = isoStr.replace(/(\.\d{3})\d+/, '$1');
  const d = new Date(normalized);
  return isNaN(d.getTime()) ? isoStr : d.toLocaleString();
}

function statusClass(status: string): string {
  if (status === 'success') return 'success';
  if (status === 'failed') return 'failed';
  if (status === 'retrying') return 'timeout';
  return 'none';
}
---

<AppLayout title="Webhook Activity Log" eyebrow="Automation">
  <div class="page-header">
    <div class="breadcrumb">
      <a href="/automation/webhooks">Webhooks</a>
      <span>›</span>
      <span>Activity Log</span>
    </div>
    <h2>Webhook Activity Log</h2>
    <p>Execution history for all webhooks in this workspace</p>
  </div>

  <div class="filters">
    <a href="?filter=all" class:list={['filter-btn', { active: filter === 'all' }]}>All ({logs.length})</a>
    <a href="?filter=success" class:list={['filter-btn', { active: filter === 'success' }]}>Success</a>
    <a href="?filter=failed" class:list={['filter-btn', { active: filter === 'failed' }]}>Failed</a>
    <a href="?filter=retrying" class:list={['filter-btn', { active: filter === 'retrying' }]}>Retrying</a>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : filteredLogs.length === 0 ? (
    <div class="empty-state">
      <div class="empty-icon">🔗</div>
      <p class="empty-title">No webhook executions yet</p>
      <p class="empty-desc">Logs appear here after webhooks fire or are tested</p>
      <a href="/automation/webhooks" class="button">View Webhooks</a>
    </div>
  ) : (
    <div class="table-wrap">
      <table class="log-table">
        <thead>
          <tr>
            <th></th>
            <th>Executed At</th>
            <th>Webhook</th>
            <th>Status</th>
            <th>HTTP</th>
            <th>Attempt</th>
          </tr>
        </thead>
        <tbody>
          {filteredLogs.map((log: any, i: number) => {
            const webhook = webhookMap.get(log.webhook_id);
            const hasError = !!log.error_message;
            return (
              <>
                <tr class:list={['log-row', { 'has-error': hasError }]}>
                  <td class="expand-cell">
                    {hasError && (
                      <button class="expand-btn" data-target={`detail-${i}`}>▶</button>
                    )}
                  </td>
                  <td class="nowrap">{formatDate(log.executed_at)}</td>
                  <td>
                    {webhook
                      ? <a href={`/automation/webhooks/${log.webhook_id}`} class="webhook-link">{webhook.name}</a>
                      : <span class="muted">{log.webhook_id?.slice(0, 8)}…</span>}
                  </td>
                  <td>
                    <span class={`status-chip status-${statusClass(log.status)}`}>{log.status}</span>
                  </td>
                  <td>
                    {log.http_status_code
                      ? <code class={`http-code ${log.http_status_code < 300 ? 'ok' : 'err'}`}>{log.http_status_code}</code>
                      : <span class="muted">—</span>}
                  </td>
                  <td>{log.retry_attempt > 0 ? `#${log.retry_attempt + 1}` : '1'}</td>
                </tr>
                {hasError && (
                  <tr class="detail-row" id={`detail-${i}`} style="display:none">
                    <td colspan="6">
                      <div class="detail-body">
                        <div class="detail-label">Error</div>
                        <div class="detail-message">{log.error_message}</div>
                      </div>
                    </td>
                  </tr>
                )}
              </>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
</AppLayout>

<script>
  document.querySelectorAll('.expand-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.target!;
      const row = document.getElementById(id);
      if (!row) return;
      const open = row.style.display !== 'none';
      row.style.display = open ? 'none' : 'table-row';
      (btn as HTMLElement).textContent = open ? '▶' : '▼';
    });
  });
</script>

<style>
  .page-header {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink); }

  .page-header h2 { margin: 0 0 8px; font-size: 24px; font-weight: 600; }
  .page-header p { margin: 0; color: var(--muted); font-size: 14px; }

  .filters { display: flex; gap: 8px; margin-bottom: 24px; }

  .filter-btn {
    padding: 6px 14px;
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line);
    background: var(--panel);
    transition: all 0.15s;
  }

  .filter-btn:hover { color: var(--ink); border-color: var(--ink); }
  .filter-btn.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .empty-state { padding: 80px 24px; text-align: center; }
  .empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.3; }
  .empty-title { margin: 0 0 8px; font-size: 18px; font-weight: 600; }
  .empty-desc { margin: 0 0 24px; color: var(--muted); font-size: 14px; }

  .table-wrap { overflow-x: auto; }

  .log-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .log-table th {
    text-align: left;
    padding: 10px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    border-bottom: 2px solid var(--line);
    white-space: nowrap;
  }

  .log-table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
    vertical-align: middle;
  }

  .log-row:hover td { background: var(--panel); }

  .expand-cell { width: 32px; padding: 10px 6px 10px 12px; }

  .expand-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    font-size: 11px;
    padding: 2px 4px;
    border-radius: 3px;
  }

  .expand-btn:hover { background: var(--line); color: var(--ink); }

  .detail-row td { padding: 0; border-bottom: 1px solid var(--line); }

  .detail-body {
    padding: 12px 16px 12px 52px;
    background: var(--panel);
  }

  .detail-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .detail-message {
    font-size: 13px;
    color: var(--color-error);
    font-family: ui-monospace, monospace;
  }

  .nowrap { white-space: nowrap; }
  .muted { color: var(--muted); font-size: 13px; }

  .webhook-link { color: var(--ink); text-decoration: none; font-weight: 500; }
  .webhook-link:hover { color: var(--accent); }

  .status-chip {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-success { background: rgba(79, 156, 132, 0.1); color: var(--accent); }
  .status-failed { background: rgba(239, 68, 68, 0.1); color: var(--color-error); }
  .status-timeout { background: rgba(217, 119, 6, 0.1); color: #d97706; }
  .status-none { color: var(--muted); }

  .http-code {
    font-family: ui-monospace, monospace;
    font-size: 12px;
    padding: 1px 6px;
    border-radius: 3px;
  }

  .http-code.ok { background: rgba(79, 156, 132, 0.1); color: var(--accent); }
  .http-code.err { background: rgba(239, 68, 68, 0.1); color: var(--color-error); }
</style>
