---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);
const { id } = Astro.params;

let webhook: any = null;
let history: any[] = [];
let error: string | null = null;

try {
  webhook = await sdk.webhooks.get(id!);
} catch (e) {
  console.error('[webhooks/edit] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

if (webhook) {
  try {
    history = await sdk.webhooks.logs(id!, { limit: 50 });
  } catch (e) {
    console.error('[webhooks/edit] Error loading history:', e);
  }
}

function formatDate(isoStr: string): string {
  if (!isoStr) return '—';
  const normalized = isoStr.replace(/(\.\d{3})\d+/, '$1');
  const d = new Date(normalized);
  return isNaN(d.getTime()) ? isoStr : d.toLocaleString();
}

function statusClass(status: string): string {
  if (status === 'success') return 'success';
  if (status === 'failed') return 'failed';
  if (status === 'retrying') return 'timeout';
  return 'none';
}

// Convert UTC time to local for input (truncate microseconds for JS Date compatibility)
let localDateTime = '';
if (webhook?.scheduled_time) {
  const normalized = webhook.scheduled_time.replace(/(\.\d{3})\d+/, '$1');
  const date = new Date(normalized);
  if (!isNaN(date.getTime())) {
    localDateTime = new Date(date.getTime() - date.getTimezoneOffset() * 60000).toISOString().slice(0, 16);
  }
}
---

<AppLayout title="Edit Webhook" eyebrow="Automation">
  <div class="page-header">
    <div>
      <h2>Edit Webhook</h2>
      <p>Update HTTP callback configuration</p>
    </div>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : webhook ? (
    <div class="form-container">
      <form id="update-webhook-form" class="form">
        <input type="hidden" name="id" value={webhook.id} />

        <div class="form-section">
          <h3>Webhook Details</h3>

          <label class="form-field">
            <span class="label">Name *</span>
            <input
              type="text"
              name="name"
              required
              value={webhook.name}
              class="input"
            />
          </label>

          <label class="form-field">
            <span class="label">URL *</span>
            <input
              type="url"
              name="url"
              required
              value={webhook.url}
              class="input"
            />
          </label>

          <div class="form-row">
            <label class="form-field">
              <span class="label">Method</span>
              <select name="method" class="input">
                <option value="POST" selected={webhook.method === 'POST'}>POST</option>
                <option value="GET" selected={webhook.method === 'GET'}>GET</option>
              </select>
            </label>

            <label class="form-field">
              <span class="label">Type</span>
              <select name="webhook_type" class="input">
                <option value="generic" selected={webhook.webhook_type === 'generic'}>Generic</option>
                <option value="user" selected={webhook.webhook_type === 'user'}>User</option>
              </select>
            </label>
          </div>

          <label class="form-field">
            <span class="label">Daily Trigger Time *</span>
            <input
              type="datetime-local"
              name="scheduled_time"
              required
              value={localDateTime}
              class="input"
            />
            <small class="hint">Time of day this webhook fires automatically (uses your local time)</small>
          </label>

          <label class="checkbox-field">
            <input type="checkbox" name="enabled" checked={webhook.enabled !== false} />
            <span>Enabled</span>
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="button">Save Changes</button>
          <button type="button" id="test-btn" class="button secondary">Test</button>
          <button type="button" id="delete-btn" class="button danger">Delete</button>
          <a href="/automation/webhooks" class="button secondary">Cancel</a>
        </div>
      </form>

      <div class="history-section">
        <h3>Execution History</h3>
        {history.length === 0 ? (
          <p class="no-history">No executions yet. Use the Test button to fire a test request.</p>
        ) : (
          <div class="history-table-wrap">
            <table class="history-table">
              <thead>
                <tr>
                  <th>Executed At</th>
                  <th>Status</th>
                  <th>HTTP</th>
                  <th>Attempt</th>
                  <th>Error</th>
                </tr>
              </thead>
              <tbody>
                {history.map((exec: any) => {
                  const executedAt = exec.executedAt ?? exec.executed_at;
                  const httpStatus = exec.httpStatusCode ?? exec.http_status_code;
                  const errorMsg = exec.errorMessage ?? exec.error_message;
                  const retryAttempt = exec.retryAttempt ?? exec.retry_attempt ?? 0;
                  return (
                    <tr>
                      <td class="nowrap">{formatDate(executedAt)}</td>
                      <td>
                        <span class={`run-status status-${statusClass(exec.status)}`}>{exec.status}</span>
                      </td>
                      <td>{httpStatus ?? '—'}</td>
                      <td>{retryAttempt > 0 ? `#${retryAttempt + 1}` : '1'}</td>
                      <td class="error-cell">{errorMsg || '—'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  ) : null}
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';
  const sdk = createSdkClient();
  const form = document.getElementById('update-webhook-form');
  const deleteBtn = document.getElementById('delete-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);
    const webhookId = formData.get('id') as string;

    const payload = {
      name: formData.get('name'),
      url: formData.get('url'),
      method: formData.get('method'),
      webhook_type: formData.get('webhook_type'),
      scheduled_time: formData.get('scheduled_time'),
      enabled: formData.get('enabled') === 'on',
    };

    try {
      await sdk.webhooks.update(webhookId, payload);
      window.location.href = '/automation/webhooks?updated=true';
    } catch (error) {
      alert('Failed to update webhook. Please try again.');
      console.error('Error updating webhook:', error);
    }
  });

  document.getElementById('test-btn')?.addEventListener('click', async () => {
    if (!confirm('Send a test request to this webhook?')) return;
    try {
      await sdk.webhooks.test(webhookId);
      alert('Test request sent! Check the Activity Log for results.');
    } catch (error) {
      alert('Failed to send test request');
      console.error(error);
    }
  });

  deleteBtn?.addEventListener('click', async () => {
    const webhookId = (document.querySelector('input[name="id"]') as HTMLInputElement)?.value;
    if (!confirm('Are you sure you want to delete this webhook?')) return;

    try {
      await sdk.webhooks.delete(webhookId);
      window.location.href = '/automation/webhooks?deleted=true';
    } catch (error) {
      alert('Failed to delete webhook. Please try again.');
      console.error('Error deleting webhook:', error);
    }
  });
</script>

<style>
  .page-header {
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .page-header h2 {
    margin: 0 0 8px;
    font-size: 24px;
    font-weight: 600;
  }

  .page-header p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
  }

  .form-container {
    max-width: 700px;
  }

  .form {
    display: grid;
    gap: 24px;
  }

  .form-section {
    display: grid;
    gap: 16px;
    padding: 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-section h3 {
    margin: 0 0 8px;
    font-size: 16px;
    font-weight: 600;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-field {
    display: grid;
    gap: 6px;
  }

  .checkbox-field {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .checkbox-field input[type="checkbox"] {
    width: auto;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
  }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .hint {
    font-size: 12px;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 12px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .button.danger {
    background: var(--color-error);
    color: white;
  }

  .button.danger:hover {
    background: var(--color-error);
    opacity: 0.9;
  }

  .history-section {
    margin-top: 32px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .history-section h3 { margin: 0 0 16px; font-size: 16px; font-weight: 600; }
  .no-history { color: var(--muted); font-size: 14px; margin: 0; }
  .history-table-wrap { overflow-x: auto; }

  .history-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .history-table th {
    text-align: left;
    padding: 8px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    border-bottom: 1px solid var(--line);
  }

  .history-table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }

  .history-table tr:last-child td { border-bottom: none; }
  .nowrap { white-space: nowrap; }

  .run-status { font-size: 12px; font-weight: 600; text-transform: uppercase; }
  .status-success { color: var(--accent); }
  .status-failed { color: var(--color-error); }
  .status-timeout { color: #d97706; }
  .status-none { color: var(--muted); }

  .error-cell {
    font-size: 12px;
    color: var(--muted);
    font-family: ui-monospace, monospace;
    max-width: 280px;
    word-break: break-word;
  }
</style>
