---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";

const authToken = getAuthToken(Astro.cookies);
let workspace = null;
let webhooks: any[] = [];
let error: string | null = null;

try {
  workspace = await getCurrentWorkspace(authToken);

  if (workspace) {
    // Fetch webhooks for this workspace
    const response = await fetchApi<any>('/api/groups/webhooks', {}, authToken);
    webhooks = response.items || [];
  }
} catch (e) {
  console.error('[webhooks] Error loading:', e);
  error = e instanceof Error ? e.message : String(e);
}

function formatScheduledTime(time: string | null | undefined): string {
  if (!time) return 'Not scheduled';
  try {
    const date = new Date(time);
    return date.toLocaleString();
  } catch {
    return time;
  }
}
---

<AppLayout title="Webhooks" eyebrow="Workspace">
  <div class="toolbar">
    <div>
      <h2>Webhooks</h2>
      <p>Configure HTTP callbacks for workspace events</p>
    </div>
    <a href="/automation/webhooks/new" class="button">New Webhook</a>
  </div>

  <div class="page-container">
    {error ? (
      <div class="alert alert-error">
        <strong>Error:</strong> {error}
      </div>
    ) : webhooks.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">🔗</div>
        <p class="empty-title">No webhooks configured</p>
        <p class="empty-description">
          Webhooks allow you to receive HTTP notifications when events occur in your workspace
        </p>
        <a href="/automation/webhooks/new" class="button">New Webhook</a>
      </div>
    ) : (
      <div class="webhooks-grid">
        {webhooks.map((webhook) => (
          <article class="webhook-card">
            <div class="webhook-header">
              <div>
                <h3>{webhook.name}</h3>
                <code class="webhook-url">{webhook.url}</code>
              </div>
              <span class={`status-badge ${webhook.enabled ? "active" : "inactive"}`}>
                {webhook.enabled ? "Active" : "Inactive"}
              </span>
            </div>
            <div class="webhook-meta">
              <div class="meta-item">
                <span class="meta-label">Method</span>
                <span class="meta-value">{webhook.method || 'POST'}</span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Type</span>
                <span class="meta-value">{webhook.webhook_type || 'generic'}</span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Scheduled</span>
                <span class="meta-value">{formatScheduledTime(webhook.scheduled_time)}</span>
              </div>
            </div>
            <div class="webhook-actions">
              <a
                href={`/automation/webhooks/${webhook.id}`}
                class="button secondary small"
              >Edit</a>
              <button
                class="button secondary small"
                data-action="toggle"
                data-id={webhook.id}
                data-enabled={webhook.enabled}
              >{webhook.enabled ? 'Disable' : 'Enable'}</button>
              <button
                class="button secondary small danger"
                data-action="delete"
                data-id={webhook.id}
                data-name={webhook.name}
              >Delete</button>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>

</AppLayout>

<script>
  import { fetchApi } from '@/lib/api/client';

  // Toggle webhook enabled/disabled
  document.querySelectorAll('[data-action="toggle"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const currentlyEnabled = btn.getAttribute('data-enabled') === 'true';

      try {
        await fetchApi(`/api/groups/webhooks/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ enabled: !currentlyEnabled }),
        });

        window.location.reload();
      } catch (error) {
        alert('Failed to update webhook');
      }
    });
  });

  // Delete webhook
  document.querySelectorAll('[data-action="delete"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      const name = btn.getAttribute('data-name');

      if (!confirm(`Are you sure you want to delete the webhook "${name}"?`)) return;

      try {
        await fetchApi(`/api/groups/webhooks/${id}`, {
          method: 'DELETE',
        });

        window.location.reload();
      } catch (error) {
        alert('Failed to delete webhook');
      }
    });
  });
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .page-container {
    max-width: 1200px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .empty-state {
    padding: 80px 24px;
    text-align: center;
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 16px;
    opacity: 0.3;
  }

  .empty-title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .empty-description {
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 14px;
  }

  .webhooks-grid {
    display: grid;
    gap: 16px;
  }

  .webhook-card {
    padding: 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .webhook-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 12px;
  }

  .webhook-header h3 {
    margin: 0 0 6px;
    font-size: 16px;
    font-weight: 600;
  }

  .webhook-url {
    font-family: ui-monospace, monospace;
    font-size: 13px;
    color: var(--muted);
    word-break: break-all;
  }

  .status-badge {
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-badge.active {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
  }

  .status-badge.inactive {
    background: rgba(128, 128, 128, 0.1);
    color: var(--muted);
  }

  .webhook-meta {
    display: flex;
    gap: 24px;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
  }

  .meta-value {
    font-size: 14px;
  }

  .webhook-actions {
    display: flex;
    gap: 8px;
  }

  .button.small {
    padding: 6px 14px;
    font-size: 13px;
  }

  .button.danger {
    color: var(--color-error);
  }

  .button.danger:hover {
    background: var(--color-error-bg);
  }
</style>
