---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);
const { type, webhookId } = Astro.params;

let eventInfo: any = null;
let webhook: any = null;
let isConnected = false;
let error: string | null = null;

const apiUrl = import.meta.env.PUBLIC_MARVIN_API_URL || 'http://localhost:8080';

function buildExamplePayload(eventType: string, variables: any[]): object {
  const varExamples: Record<string, string> = {};
  for (const v of variables || []) {
    varExamples[v.slug] = v.example || `<${v.slug}>`;
  }

  return {
    eventType,
    eventId: "evt_a1b2c3d4-...",
    timestamp: new Date().toISOString().replace(/\.\d{3}Z$/, 'Z'),
    workspaceId: "<workspace-uuid>",
    message: {
      title: eventType.replace(/_/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase()),
      body: eventType,
    },
    documentData: varExamples,
    userId: "<user-uuid>",
  };
}

try {
  const [allTypes, webhookData] = await Promise.all([
    sdk.events.getOptions() as Promise<any[]>,
    sdk.webhooks.get(webhookId!),
  ]);

  eventInfo = allTypes.find((e: any) => e.value === type) || null;
  webhook = webhookData;

  if (!eventInfo) {
    return Astro.redirect('/automation/events');
  }

  const subscribedEvents: string[] = (webhook as any)?.subscribedEvents ?? (webhook as any)?.subscribed_events ?? [];
  isConnected = subscribedEvents.includes(type || '');
} catch (e) {
  console.error('[events/webhook-connect] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

const examplePayload = eventInfo ? buildExamplePayload(type!, eventInfo.variables ?? []) : {};
---

<AppLayout title="Connect Webhook" eyebrow="Events">
  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : (eventInfo && webhook) ? (
    <>
      <!-- Header -->
      <div class="page-header">
        <div class="breadcrumb">
          <a href="/automation/events">Events</a>
          <span>›</span>
          <a href={`/automation/events/${type}`}>{eventInfo.label}</a>
          <span>›</span>
          <span>Webhook</span>
        </div>

        <div class="header-row">
          <div>
            <h2>{webhook.name}</h2>
            <code class="webhook-url-head">{webhook.url}</code>
          </div>
          {isConnected
            ? <span class="connected-pill">&#10003; Connected</span>
            : <span class="disconnected-pill">Not connected</span>}
        </div>

        <p class="header-desc">
          When <strong>{eventInfo.label}</strong> fires, this webhook receives a POST request.
          {eventInfo.description && ` ${eventInfo.description}`}
        </p>
      </div>

      <!-- Payload section -->
      <div class="payload-section">
        <div class="payload-meta">
          <span class="payload-label">POST to <code>{webhook.url}</code></span>
          {eventInfo.variables?.length > 0 && (
            <div class="vars-inline">
              {eventInfo.variables.map((v: any) => (
                <span class="var-tag" title={v.description}>{'{{' + v.slug + '}}'}</span>
              ))}
            </div>
          )}
        </div>
        <pre class="payload-json">{JSON.stringify(examplePayload, null, 2)}</pre>
      </div>

      <!-- Action strip -->
      <div class="action-strip">
        {isConnected ? (
          <>
            <span class="action-note">Disconnect to stop receiving events on this webhook.</span>
            <button type="button" id="disconnect-btn" class="button secondary danger">Disconnect</button>
          </>
        ) : (
          <>
            <span class="action-note">Your endpoint will receive the payload above on every <strong>{eventInfo.label}</strong> event.</span>
            <button type="button" id="connect-btn" class="button">Connect</button>
          </>
        )}
        <a href={`/automation/events/${type}`} class="button secondary">Back</a>
      </div>
    </>
  ) : null}
</AppLayout>

<script define:vars={{ type, webhookId, isConnected, apiUrl }}>
  const connectBtn = document.getElementById('connect-btn');
  const disconnectBtn = document.getElementById('disconnect-btn');

  async function toggleConnection(connect) {
    try {
      const res = await fetch(`${apiUrl}/api/groups/webhooks/${webhookId}`, { credentials: 'include' });
      if (!res.ok) throw new Error(`Fetch failed: ${res.status}`);
      const webhook = await res.json();

      const currentEvents = webhook.subscribedEvents ?? webhook.subscribed_events ?? [];
      const updated = connect
        ? [...new Set([...currentEvents, type])]
        : currentEvents.filter(e => e !== type);

      const putRes = await fetch(`${apiUrl}/api/groups/webhooks/${webhookId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ ...webhook, subscribed_events: updated }),
      });
      if (!putRes.ok) {
        const err = await putRes.json().catch(() => ({}));
        throw new Error(err.detail || `Save failed: ${putRes.status}`);
      }
      window.location.href = `/automation/events/${type}`;
    } catch (e) {
      alert('Error: ' + e.message);
      console.error(e);
    }
  }

  connectBtn?.addEventListener('click', () => toggleConnection(true));
  disconnectBtn?.addEventListener('click', () => toggleConnection(false));
</script>

<style>
  .alert { padding: 16px; border-radius: var(--radius); background: var(--color-error-bg); color: var(--color-error); border: 1px solid var(--color-error); }

  /* Header */
  .breadcrumb { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted); margin-bottom: 12px; }
  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink); }

  .page-header { margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid var(--line); }

  .header-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .header-row h2 { margin: 0 0 4px; font-size: 22px; font-weight: 600; }
  .webhook-url-head { font-size: 12px; font-family: ui-monospace, monospace; color: var(--muted); }
  .header-desc { margin: 0; font-size: 14px; color: var(--muted); line-height: 1.5; }

  .connected-pill { background: rgba(79,156,132,0.1); color: var(--accent); border: 1px solid rgba(79,156,132,0.25); border-radius: 20px; padding: 4px 12px; font-size: 12px; font-weight: 600; white-space: nowrap; flex-shrink: 0; }
  .disconnected-pill { background: var(--panel); color: var(--muted); border: 1px solid var(--line); border-radius: 20px; padding: 4px 12px; font-size: 12px; font-weight: 600; white-space: nowrap; flex-shrink: 0; }

  /* Payload */
  .payload-section { max-width: 720px; }
  .payload-meta { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 10px; flex-wrap: wrap; }
  .payload-label { font-size: 12px; color: var(--muted); }
  .payload-label code { font-family: ui-monospace, monospace; font-size: 11px; }

  .vars-inline { display: flex; flex-wrap: wrap; gap: 4px; }
  .var-tag { font-size: 11px; font-family: ui-monospace, monospace; color: var(--accent); background: rgba(79,156,132,0.08); padding: 1px 6px; border-radius: 3px; }

  .payload-json { font-size: 12px; font-family: ui-monospace, monospace; background: var(--panel); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px; overflow-x: auto; max-height: 480px; overflow-y: auto; white-space: pre; margin: 0; color: var(--ink); line-height: 1.5; }

  /* Action strip */
  .action-strip { display: flex; align-items: center; gap: 12px; margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--line); flex-wrap: wrap; max-width: 720px; }
  .action-note { font-size: 13px; color: var(--muted); flex: 1; min-width: 200px; }
  .action-note strong { color: var(--ink); }

  .button.secondary.danger { color: var(--color-error); border-color: var(--color-error); }
  .button.secondary.danger:hover { background: var(--color-error-bg); }
</style>
