---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken, fetchApi } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let eventTypes: any[] = [];
let webhooks: any[] = [];
let notifications: any[] = [];
let error: string | null = null;

try {
  [eventTypes, webhooks] = await Promise.all([
    sdk.events.getOptions() as Promise<any[]>,
    sdk.webhooks.list().catch(() => []),
  ]);
  const notifRes = await sdk.notifications.list().catch(() => ({ items: [] }));
  notifications = Array.isArray(notifRes) ? notifRes : (notifRes as any)?.items ?? [];
} catch (e) {
  console.error('[events] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

// Build connection map: eventType → { webhooks: string[], notifications: string[] }
function getConnections(eventType: string) {
  const connectedWebhooks = webhooks.filter((w: any) => {
    const sub = (w as any).subscribedEvents ?? (w as any).subscribed_events ?? [];
    return Array.isArray(sub) && sub.includes(eventType);
  });
  const connectedNotifs = notifications.filter((n: any) => {
    const opts: any[] = (n as any).options ?? [];
    return opts.some((o: any) => (o.option || o.slug || o) === ('core.' + eventType));
  });
  return { webhooks: connectedWebhooks, notifications: connectedNotifs };
}

const categoryFilter = Astro.url.searchParams.get('category') || 'all';

const categories = [...new Set(eventTypes.map((e: any) => e.category).filter(Boolean))];
const filtered = categoryFilter === 'all'
  ? eventTypes
  : eventTypes.filter((e: any) => e.category === categoryFilter);
---

<AppLayout title="Events" eyebrow="Automation">
  <div class="toolbar">
    <div>
      <h2>Events</h2>
      <p>Events are dispatched when things happen in your workspace. Subscribe to them to trigger notifications, webhooks, and emails.</p>
    </div>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : (
    <div class="events-layout">
      <!-- Category filter -->
      <div class="filters">
        <a href="?category=all" class:list={['filter-btn', { active: categoryFilter === 'all' }]}>
          All ({eventTypes.length})
        </a>
        {categories.map((cat: string) => (
          <a href={`?category=${cat}`} class:list={['filter-btn', { active: categoryFilter === cat }]}>
            {cat}
          </a>
        ))}
      </div>

      <!-- Search -->
      <input
        type="text"
        id="event-search"
        class="input event-search"
        placeholder="Search events…"
        autocomplete="off"
      />

      <!-- Event chips -->
      <div class="events-grid" id="events-grid">
        {filtered.map((event: any) => {
          const conn = getConnections(event.value);
          const total = conn.webhooks.length + conn.notifications.length;
          return (
            <article class:list={['event-chip', { connected: total > 0 }]}>
              <div class="chip-left">
                <div class="chip-title">
                  <span class="event-name">{event.label}</span>
                  <code class="event-type">{event.value}</code>
                </div>
                {event.description && (
                  <p class="event-desc">{event.description}</p>
                )}
              </div>
              <div class="chip-right">
                <span class="event-category">{event.category}</span>
                {total > 0 && (
                  <span class="conn-dot" title={[
                    ...conn.webhooks.map((w: any) => w.name),
                    ...conn.notifications.map((n: any) => n.name),
                  ].join(', ')}>●</span>
                )}
                <a href={`/automation/events/${event.value}`} class="button secondary small">
                  {total > 0 ? 'Manage' : 'Subscribe'}
                </a>
              </div>
            </article>
          );
        })}
      </div>

      <div class="empty-state" id="no-results" style="display:none">
        <p>No events match your search.</p>
      </div>

      {filtered.length === 0 && (
        <div class="empty-state">
          <p>No events in this category.</p>
        </div>
      )}
    </div>
  )}
</AppLayout>

<script>
  const search = document.getElementById('event-search') as HTMLInputElement;
  const grid = document.getElementById('events-grid');
  const noResults = document.getElementById('no-results');

  search?.addEventListener('input', () => {
    const q = search.value.toLowerCase();
    let visible = 0;
    grid?.querySelectorAll('.event-card').forEach(card => {
      const text = card.textContent?.toLowerCase() || '';
      const show = !q || text.includes(q);
      (card as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
  });
</script>

<style>
  .toolbar {
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 { margin: 0 0 6px; font-size: 24px; font-weight: 600; }
  .toolbar p { margin: 0; color: var(--muted); font-size: 14px; max-width: 560px; }

  .alert {
    padding: 16px; border-radius: var(--radius);
    background: var(--color-error-bg); color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .events-layout { display: flex; flex-direction: column; gap: 20px; }

  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 5px 14px;
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line);
    background: var(--panel);
    transition: all 0.15s;
    white-space: nowrap;
  }

  .filter-btn:hover { color: var(--ink); border-color: var(--ink); }
  .filter-btn.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .event-search {
    width: 100%;
    max-width: 360px;
  }

  .events-grid {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .event-chip {
    padding: 10px 14px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 12px;
    transition: border-color 0.15s;
  }

  .event-chip:hover { border-color: var(--accent); }
  .event-chip.connected { border-color: rgba(79,156,132,0.35); }

  .chip-left {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .chip-title {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  .event-name {
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .event-type {
    font-size: 10px;
    font-family: ui-monospace, monospace;
    color: var(--muted);
    background: var(--bg);
    padding: 1px 5px;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .event-desc {
    margin: 0;
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chip-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .event-category {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    white-space: nowrap;
  }

  .conn-dot {
    font-size: 8px;
    color: var(--accent);
    cursor: default;
    line-height: 1;
  }

  .button.small { padding: 4px 10px; font-size: 12px; font-weight: 600; min-height: 26px; }

  .empty-state { padding: 60px; text-align: center; color: var(--muted); }
</style>
