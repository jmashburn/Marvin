---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);

let eventOptions: any[] = [];
let error: string | null = null;

try {
  const response = await fetchApi<any>('/api/event/options', {}, authToken);
  eventOptions = response.items || [];
} catch (e) {
  console.error('[events] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

// Categorize events by extracting category from name
const categories = new Map<string, any[]>();

eventOptions.forEach(event => {
  const name = event.name || '';

  // Determine category based on event name patterns
  let category = 'General';

  if (name.includes('User') || name.includes('Password') || name.includes('Login') || name.includes('Session')) {
    category = 'User & Authentication';
  } else if (name.includes('Workspace')) {
    category = 'Workspace';
  } else if (name.includes('Member') || name.includes('Invitation')) {
    category = 'Team & Access';
  } else if (name.match(/Entry(?! Type)/)) {
    category = 'Content (Entries)';
  } else if (name.includes('Collection')) {
    category = 'Collections';
  } else if (name.includes('Asset')) {
    category = 'Assets & Media';
  } else if (name.includes('Entry Type')) {
    category = 'Entry Types';
  } else if (name.includes('Site') || name.includes('Deployment') || name.includes('Build')) {
    category = 'Publishing & Deployment';
  } else if (name.includes('Webhook')) {
    category = 'Webhooks';
  } else if (name.includes('API') || name.includes('Token')) {
    category = 'API & Integration';
  } else if (name.includes('Resource')) {
    category = 'Resources';
  } else if (name.includes('Comment') || name.includes('Shared') || name.includes('Mention')) {
    category = 'Collaboration';
  } else if (name.includes('Workflow') || name.includes('Approval')) {
    category = 'Workflow & Automation';
  } else if (name.includes('Search') || name.includes('Index')) {
    category = 'Search';
  } else if (name.includes('Permission') || name.includes('Role') || name.includes('Suspicious')) {
    category = 'Security & Audit';
  } else if (name.includes('Backup') || name.includes('Storage')) {
    category = 'Storage & Backup';
  } else if (name.includes('Notification') || name.includes('Digest')) {
    category = 'Notifications';
  }

  if (!categories.has(category)) {
    categories.set(category, []);
  }
  categories.get(category)!.push(event);
});

// Sort categories alphabetically and events within each category
const sortedCategories = Array.from(categories.entries())
  .sort((a, b) => a[0].localeCompare(b[0]))
  .map(([category, events]) => ({
    category,
    events: events.sort((a, b) => a.name.localeCompare(b.name)),
    enabledCount: events.filter(e => e.enabled).length,
    totalCount: events.length
  }));

const totalEvents = eventOptions.length;
const enabledEvents = eventOptions.filter(e => e.enabled).length;
---

<AppLayout title="Events" eyebrow="Automation">
  <div class="toolbar">
    <div>
      <h2>Event Types</h2>
      <p>{totalEvents} event types across {sortedCategories.length} categories</p>
    </div>
    <div class="toolbar-stats">
      <div class="stat">
        <span class="stat-value">{enabledEvents}</span>
        <span class="stat-label">Enabled</span>
      </div>
      <div class="stat">
        <span class="stat-value">{totalEvents - enabledEvents}</span>
        <span class="stat-label">Disabled</span>
      </div>
    </div>
  </div>

  <div class="search-bar">
    <input
      type="text"
      id="event-search"
      placeholder="Search events by name or description..."
      class="search-input"
    />
    <div class="filter-buttons">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="enabled">Enabled Only</button>
      <button class="filter-btn" data-filter="disabled">Disabled Only</button>
    </div>
  </div>

  {error ? (
    <div class="alert alert-error">
      <strong>Error loading events</strong>
      <p>{error}</p>
    </div>
  ) : (
    <div class="categories-container">
      {sortedCategories.map(({ category, events, enabledCount, totalCount }) => (
        <section class="category-section" data-category={category}>
          <div class="category-header">
            <h3>{category}</h3>
            <span class="category-count">{enabledCount}/{totalCount} enabled</span>
          </div>

          <div class="events-grid">
            {events.map(event => (
              <div
                class={`event-card ${event.enabled ? 'enabled' : 'disabled'}`}
                data-event-name={event.name.toLowerCase()}
                data-event-description={event.description?.toLowerCase() || ''}
                data-event-enabled={event.enabled}
              >
                <div class="event-header">
                  <span class={`event-status ${event.enabled ? 'status-enabled' : 'status-disabled'}`}>
                    {event.enabled ? '●' : '○'}
                  </span>
                  <strong class="event-name">{event.name}</strong>
                </div>
                {event.description && (
                  <p class="event-description">{event.description}</p>
                )}
                <div class="event-meta">
                  <code class="event-slug">{event.option || `core.${event.slug || event.name.toLowerCase().replace(/\s+/g, '_')}`}</code>
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  )}

  <section class="info-section">
    <h3>How Events Work</h3>
    <div class="info-cards">
      <div class="info-card">
        <div class="info-icon">⚡</div>
        <strong>Automatic Dispatch</strong>
        <p>Events are automatically triggered when actions occur in your workspace</p>
      </div>
      <div class="info-card">
        <div class="info-icon">🪝</div>
        <strong>Webhook Integration</strong>
        <p>Configure webhooks to receive HTTP callbacks when events fire</p>
        <a href="/automation/webhooks" class="info-link">Setup Webhooks →</a>
      </div>
      <div class="info-card">
        <div class="info-icon">📧</div>
        <strong>Notifications</strong>
        <p>Get notified via email, Slack, or other channels</p>
        <a href="/automation/notifications" class="info-link">Configure Notifications →</a>
      </div>
    </div>
  </section>
</AppLayout>

<script>
  // Search functionality
  const searchInput = document.getElementById('event-search') as HTMLInputElement;
  const filterButtons = document.querySelectorAll('.filter-btn');
  const eventCards = document.querySelectorAll('.event-card');
  const categorySections = document.querySelectorAll('.category-section');

  let currentFilter = 'all';

  function filterEvents() {
    const searchTerm = searchInput?.value.toLowerCase() || '';

    eventCards.forEach(card => {
      const name = card.getAttribute('data-event-name') || '';
      const description = card.getAttribute('data-event-description') || '';
      const enabled = card.getAttribute('data-event-enabled') === 'true';

      const matchesSearch = searchTerm === '' ||
        name.includes(searchTerm) ||
        description.includes(searchTerm);

      const matchesFilter = currentFilter === 'all' ||
        (currentFilter === 'enabled' && enabled) ||
        (currentFilter === 'disabled' && !enabled);

      if (matchesSearch && matchesFilter) {
        (card as HTMLElement).style.display = 'block';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });

    // Hide empty categories
    categorySections.forEach(section => {
      const visibleCards = section.querySelectorAll('.event-card:not([style*="display: none"])');
      (section as HTMLElement).style.display = visibleCards.length > 0 ? 'block' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterEvents);

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter') || 'all';
      filterEvents();
    });
  });
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .toolbar-stats {
    display: flex;
    gap: 24px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-value {
    font-size: 24px;
    font-weight: 600;
    color: var(--accent);
  }

  .stat-label {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .search-bar {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
    padding: 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .search-input {
    flex: 1;
    padding: 10px 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
    background: var(--panel-2);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .filter-buttons {
    display: flex;
    gap: 8px;
  }

  .filter-btn {
    padding: 10px 20px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel-2);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    border-color: var(--accent);
  }

  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .categories-container {
    display: grid;
    gap: 32px;
    margin-bottom: 32px;
  }

  .category-section {
    padding: 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .category-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }

  .category-header h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .category-count {
    font-size: 12px;
    color: var(--muted);
    padding: 4px 10px;
    background: var(--panel-2);
    border-radius: 12px;
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 12px;
  }

  .event-card {
    padding: 16px;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    transition: all 0.2s;
  }

  .event-card:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .event-card.enabled {
    border-left: 3px solid var(--accent);
  }

  .event-card.disabled {
    border-left: 3px solid var(--muted);
    opacity: 0.7;
  }

  .event-header {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-bottom: 8px;
  }

  .event-status {
    font-size: 12px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .status-enabled {
    color: var(--accent);
  }

  .status-disabled {
    color: var(--muted);
  }

  .event-name {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
  }

  .event-description {
    margin: 0 0 10px 20px;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  .event-meta {
    margin-left: 20px;
  }

  .event-slug {
    font-family: ui-monospace, monospace;
    font-size: 11px;
    color: var(--muted);
    background: var(--panel);
    padding: 3px 6px;
    border-radius: 3px;
  }

  .info-section {
    padding: 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .info-section h3 {
    margin: 0 0 20px;
    font-size: 18px;
    font-weight: 600;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  .info-card {
    padding: 20px;
    background: var(--panel-2);
    border-radius: var(--radius);
  }

  .info-icon {
    font-size: 32px;
    margin-bottom: 12px;
  }

  .info-card strong {
    display: block;
    margin-bottom: 8px;
    font-size: 15px;
    font-weight: 600;
  }

  .info-card p {
    margin: 0 0 12px;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
  }

  .info-link {
    font-size: 13px;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .info-link:hover {
    text-decoration: underline;
  }

  .alert {
    padding: 20px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    border: 1px solid;
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border-color: var(--color-error);
  }
</style>
