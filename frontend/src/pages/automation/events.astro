---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let eventTypes: any[] = [];
let webhooks: any[] = [];
let notifications: any[] = [];
let error: string | null = null;

try {
  [eventTypes, webhooks] = await Promise.all([
    sdk.events.getOptions() as Promise<any[]>,
    sdk.webhooks.list().catch(() => []),
  ]);
  const notifRes = await sdk.notifications.list().catch(() => ({ items: [] }));
  notifications = Array.isArray(notifRes) ? notifRes : (notifRes as any)?.items ?? [];
} catch (e) {
  console.error('[events] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

function getConnections(eventType: string) {
  const connectedWebhooks = webhooks.filter((w: any) => {
    const sub = (w as any).subscribedEvents ?? (w as any).subscribed_events ?? [];
    return Array.isArray(sub) && sub.includes(eventType);
  });
  const connectedNotifs = notifications.filter((n: any) => {
    const opts: any[] = (n as any).options ?? [];
    return opts.some((o: any) => (o.option || o.slug || o) === ('core.' + eventType));
  });
  return { webhooks: connectedWebhooks, notifications: connectedNotifs };
}

const categories = [...new Set(eventTypes.map((e: any) => e.category).filter(Boolean))] as string[];
const groupedByCategory = categories.map(cat => {
  const events = eventTypes.filter((e: any) => e.category === cat);
  const connectedCount = events.filter((e: any) => {
    const c = getConnections(e.value);
    return c.webhooks.length + c.notifications.length > 0;
  }).length;
  return { category: cat, events, connectedCount };
});
---

<AppLayout title="Events" eyebrow="Automation">
  <div class="toolbar">
    <div>
      <h2>Events</h2>
      <p>Events fire when things happen in your workspace. Subscribe to trigger webhooks, notifications, and emails.</p>
    </div>
  </div>

  {error ? (
    <div class="alert"><strong>Error:</strong> {error}</div>
  ) : (
    <>
      <div class="controls">
        <input
          type="search"
          id="event-search"
          class="filter-search"
          placeholder="Search events…"
          autocomplete="off"
        />
        <div class="view-toggle">
          <button class="toggle-btn active" id="view-all">All ({eventTypes.length})</button>
          <button class="toggle-btn" id="view-types">Types</button>
        </div>
      </div>

      <!-- Flat list -->
      <div id="view-all-section">
        <div class="chips" id="chips-all">
          {eventTypes.map((event: any) => {
            const conn = getConnections(event.value);
            const total = conn.webhooks.length + conn.notifications.length;
            return (
              <article
                class:list={['event-chip', { connected: total > 0 }]}
                data-name={event.label.toLowerCase()}
                data-type={event.value.toLowerCase()}
                data-desc={(event.description || '').toLowerCase()}
                data-category={(event.category || '').toLowerCase()}
              >
                <div class="chip-left">
                  <div class="chip-title">
                    <span class="event-name">{event.label}</span>
                    <code class="event-type">{event.value}</code>
                  </div>
                  {event.description && <p class="event-desc">{event.description}</p>}
                </div>
                <div class="chip-right">
                  <span class="event-category">{event.category}</span>
                  {total > 0 && (
                    <span class="conn-dot" title={[
                      ...conn.webhooks.map((w: any) => w.name),
                      ...conn.notifications.map((n: any) => n.name),
                    ].join(', ')}>●</span>
                  )}
                  <a href={`/automation/events/${event.value}`} class="button secondary small">
                    {total > 0 ? 'Manage' : 'Subscribe'}
                  </a>
                </div>
              </article>
            );
          })}
        </div>
        <div class="empty-state" id="no-results" style="display:none">
          <p>No events match your search.</p>
        </div>
      </div>

      <!-- Grouped by category -->
      <div id="view-types-section" style="display:none">
        {groupedByCategory.map(({ category, events, connectedCount }) => (
          <details class="category-group" data-category={category.toLowerCase()}>
            <summary class="category-header">
              <span class="collapse-chevron"></span>
              <span class="category-name">{category}</span>
              <span class="category-count">{events.length}</span>
              {connectedCount > 0 && (
                <span class="group-conn-dot" title={`${connectedCount} subscribed`}>● {connectedCount}</span>
              )}
            </summary>
            <div class="chips group-chips">
              {events.map((event: any) => {
                const conn = getConnections(event.value);
                const total = conn.webhooks.length + conn.notifications.length;
                return (
                  <article
                    class:list={['event-chip', { connected: total > 0 }]}
                    data-name={event.label.toLowerCase()}
                    data-type={event.value.toLowerCase()}
                    data-desc={(event.description || '').toLowerCase()}
                    data-category={(event.category || '').toLowerCase()}
                  >
                    <div class="chip-left">
                      <div class="chip-title">
                        <span class="event-name">{event.label}</span>
                        <code class="event-type">{event.value}</code>
                      </div>
                      {event.description && <p class="event-desc">{event.description}</p>}
                    </div>
                    <div class="chip-right">
                      {total > 0 && (
                        <span class="conn-dot" title={[
                          ...conn.webhooks.map((w: any) => w.name),
                          ...conn.notifications.map((n: any) => n.name),
                        ].join(', ')}>●</span>
                      )}
                      <a href={`/automation/events/${event.value}`} class="button secondary small">
                        {total > 0 ? 'Manage' : 'Subscribe'}
                      </a>
                    </div>
                  </article>
                );
              })}
            </div>
          </details>
        ))}
      </div>
    </>
  )}
</AppLayout>

<script>
  const search = document.getElementById('event-search') as HTMLInputElement;
  const allSection = document.getElementById('view-all-section')!;
  const typesSection = document.getElementById('view-types-section')!;
  const btnAll = document.getElementById('view-all')!;
  const btnTypes = document.getElementById('view-types')!;
  const noResults = document.getElementById('no-results')!;

  let currentView: 'all' | 'types' = (localStorage.getItem('events-view') as any) || 'all';

  function setView(v: 'all' | 'types') {
    currentView = v;
    localStorage.setItem('events-view', v);
    allSection.style.display = v === 'all' ? '' : 'none';
    typesSection.style.display = v === 'types' ? '' : 'none';
    btnAll.classList.toggle('active', v === 'all');
    btnTypes.classList.toggle('active', v === 'types');
    applySearch();
  }

  function applySearch() {
    const q = search.value.toLowerCase().trim();
    let visibleAll = 0;

    document.querySelectorAll('.event-chip').forEach(chip => {
      const el = chip as HTMLElement;
      const matches = !q ||
        (el.dataset.name || '').includes(q) ||
        (el.dataset.type || '').includes(q) ||
        (el.dataset.desc || '').includes(q) ||
        (el.dataset.category || '').includes(q);
      el.style.display = matches ? '' : 'none';
      if (matches && el.closest('#view-all-section')) visibleAll++;
    });

    // In types view: hide empty groups
    document.querySelectorAll('.category-group').forEach(group => {
      const visible = group.querySelectorAll('.event-chip:not([style*="display: none"])').length;
      (group as HTMLElement).style.display = visible > 0 ? '' : 'none';
    });

    if (noResults) noResults.style.display = (currentView === 'all' && visibleAll === 0 && q) ? 'block' : 'none';
  }

  btnAll.addEventListener('click', () => setView('all'));
  btnTypes.addEventListener('click', () => setView('types'));
  search.addEventListener('input', applySearch);

  setView(currentView);
</script>

<style>
  .toolbar {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }
  .toolbar h2 { margin: 0 0 4px; font-size: 22px; font-weight: 600; }
  .toolbar p { margin: 0; color: var(--muted); font-size: 13px; max-width: 520px; }

  .alert {
    padding: 16px; border-radius: var(--radius);
    background: var(--color-error-bg); color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .filter-search {
    flex: 1;
    max-width: 320px;
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg);
    font-size: 13px;
    color: var(--ink);
  }
  .filter-search:focus { outline: none; border-color: var(--accent); }
  .filter-search::placeholder { color: var(--muted); }

  .view-toggle {
    display: flex;
    gap: 2px;
    background: var(--panel-2, var(--panel));
    border-radius: 6px;
    padding: 2px;
  }

  .toggle-btn {
    padding: 5px 14px;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .toggle-btn:hover { color: var(--ink); }
  .toggle-btn.active {
    background: var(--panel);
    color: var(--ink);
    box-shadow: 0 1px 2px rgba(0,0,0,0.07);
  }

  /* Chips */
  .chips { display: flex; flex-direction: column; gap: 4px; }

  .event-chip {
    padding: 10px 14px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    gap: 12px;
    transition: border-color 0.15s;
  }
  .event-chip:hover { border-color: var(--accent); }
  .event-chip.connected { border-color: rgba(79,156,132,0.35); }

  .chip-left { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
  .chip-title { display: flex; align-items: baseline; gap: 8px; }

  .event-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .event-type {
    font-size: 10px; font-family: ui-monospace, monospace;
    color: var(--muted); background: var(--bg);
    padding: 1px 5px; border-radius: 3px; white-space: nowrap; flex-shrink: 0;
  }

  .event-desc {
    margin: 0; font-size: 11px; color: var(--muted);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .chip-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }

  .event-category {
    font-size: 10px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.5px; color: var(--muted); white-space: nowrap;
  }

  .conn-dot { font-size: 8px; color: var(--accent); cursor: default; line-height: 1; }

  .button.small { padding: 4px 10px; font-size: 12px; font-weight: 600; min-height: 26px; }

  /* Category groups */
  .category-group { margin-bottom: 8px; }
  .group-chips { margin-top: 6px; }

  .category-header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 4px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    border-bottom: 1px solid var(--line);
    margin-bottom: 2px;
  }
  .category-header::-webkit-details-marker { display: none; }

  .collapse-chevron {
    display: inline-block; width: 14px; height: 14px; flex-shrink: 0; transition: transform 0.15s;
  }
  .collapse-chevron::before {
    content: '';
    display: block;
    width: 5px; height: 5px;
    border-right: 1.5px solid var(--muted);
    border-bottom: 1.5px solid var(--muted);
    transform: rotate(-45deg) translate(1px, -1px);
    margin: 4px auto;
  }
  details[open] > .category-header .collapse-chevron { transform: rotate(90deg); }

  .category-name { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: var(--muted); }

  .category-count {
    font-size: 11px; font-weight: 500; color: var(--muted);
    background: var(--bg); padding: 1px 7px; border-radius: 10px;
  }

  .group-conn-dot {
    font-size: 10px; font-weight: 600; color: var(--accent);
    display: flex; align-items: center; gap: 3px;
    margin-left: 4px;
  }

  .empty-state { padding: 48px; text-align: center; color: var(--muted); font-size: 13px; }
</style>
