---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let eventTypes: any[] = [];
let error: string | null = null;

try {
  eventTypes = await sdk.events.getOptions() as any[];
} catch (e) {
  console.error('[events] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

const categoryFilter = Astro.url.searchParams.get('category') || 'all';

const categories = [...new Set(eventTypes.map((e: any) => e.category).filter(Boolean))];
const filtered = categoryFilter === 'all'
  ? eventTypes
  : eventTypes.filter((e: any) => e.category === categoryFilter);
---

<AppLayout title="Events" eyebrow="Automation">
  <div class="toolbar">
    <div>
      <h2>Events</h2>
      <p>Events are dispatched when things happen in your workspace. Subscribe to them to trigger notifications, webhooks, and emails.</p>
    </div>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : (
    <div class="events-layout">
      <!-- Category filter -->
      <div class="filters">
        <a href="?category=all" class:list={['filter-btn', { active: categoryFilter === 'all' }]}>
          All ({eventTypes.length})
        </a>
        {categories.map((cat: string) => (
          <a href={`?category=${cat}`} class:list={['filter-btn', { active: categoryFilter === cat }]}>
            {cat}
          </a>
        ))}
      </div>

      <!-- Event cards -->
      <div class="events-grid">
        {filtered.map((event: any) => (
          <article class="event-card">
            <div class="event-header">
              <div>
                <h3 class="event-name">{event.label}</h3>
                <code class="event-type">{event.value}</code>
              </div>
              <span class="event-category">{event.category}</span>
            </div>

            {event.description && (
              <p class="event-description">{event.description}</p>
            )}

            {event.variables && event.variables.length > 0 && (
              <div class="event-vars">
                <div class="vars-label">Available variables</div>
                <div class="vars-chips">
                  {event.variables.map((v: any) => (
                    <span class="var-chip-sm" title={v.description + ' · e.g. ' + v.example}>
                      <code>{'{{' + v.slug + '}}'}</code>
                    </span>
                  ))}
                </div>
              </div>
            )}

            <div class="event-actions">
              <a href={`/automation/events/${event.value}`} class="button secondary small">
                Subscribe
              </a>
            </div>
          </article>
        ))}
      </div>

      {filtered.length === 0 && (
        <div class="empty-state">
          <p>No events in this category.</p>
        </div>
      )}
    </div>
  )}
</AppLayout>

<style>
  .toolbar {
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 { margin: 0 0 6px; font-size: 24px; font-weight: 600; }
  .toolbar p { margin: 0; color: var(--muted); font-size: 14px; max-width: 560px; }

  .alert {
    padding: 16px; border-radius: var(--radius);
    background: var(--color-error-bg); color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .events-layout { display: flex; flex-direction: column; gap: 20px; }

  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 5px 14px;
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line);
    background: var(--panel);
    transition: all 0.15s;
    white-space: nowrap;
  }

  .filter-btn:hover { color: var(--ink); border-color: var(--ink); }
  .filter-btn.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
  }

  .event-card {
    padding: 18px 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.15s;
  }

  .event-card:hover { border-color: var(--accent); }

  .event-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
  }

  .event-name { margin: 0 0 4px; font-size: 14px; font-weight: 600; }

  .event-type {
    font-size: 11px;
    font-family: ui-monospace, monospace;
    color: var(--muted);
    background: var(--bg);
    padding: 1px 5px;
    border-radius: 3px;
  }

  .event-category {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--accent);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .event-description {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
  }

  .event-vars { display: flex; flex-direction: column; gap: 6px; }

  .vars-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
  }

  .vars-chips { display: flex; flex-wrap: wrap; gap: 5px; }

  .var-chip-sm {
    display: inline-block;
    padding: 2px 7px;
    background: var(--bg);
    border: 1px solid rgba(79,156,132,0.25);
    border-radius: 4px;
    cursor: default;
  }

  .var-chip-sm code {
    font-size: 11px;
    font-family: ui-monospace, monospace;
    color: var(--accent);
    font-weight: 600;
  }

  .event-actions { margin-top: 4px; }

  .button.small { padding: 5px 12px; font-size: 12px; font-weight: 600; min-height: 28px; }

  .empty-state { padding: 60px; text-align: center; color: var(--muted); }
</style>
