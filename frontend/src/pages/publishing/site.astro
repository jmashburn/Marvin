---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { fetchApi } from "@/lib/api/client";
import type { WorkspaceWithMembership, GroupPreferencesRead } from "@/lib/api/types";

const authToken = getAuthToken(Astro.cookies);

let workspace: WorkspaceWithMembership | null = null;
let preferences: GroupPreferencesRead | null = null;
let error: string | null = null;
let success: boolean = false;

// Check for success/error query params
const urlParams = Astro.url.searchParams;
if (urlParams.get('success')) {
  success = true;
}
if (urlParams.get('error')) {
  error = "Failed to save site configuration. Please try again.";
}

try {
  workspace = await fetchApi<WorkspaceWithMembership>('/api/users/me/workspace/current', {}, authToken);

  if (workspace) {
    // Get preferences for this workspace
    preferences = await fetchApi<GroupPreferencesRead>(
      `/api/groups/${workspace.workspace.id}/preferences`,
      {},
      authToken
    );
  }
} catch (e) {
  console.error('[site] Error loading:', e);
  error = e instanceof Error ? e.message : String(e);
}
---

<AppLayout title="Site Configuration" eyebrow="Publishing">
  <div class="toolbar">
    <div>
      <h2>Site Configuration</h2>
      <p>Configure your workspace's public identity and publishing settings</p>
    </div>
    <a class="button secondary" href="/publishing/clients">Manage Clients</a>
  </div>

  {success && (
    <div class="alert alert-success">
      <strong>Saved!</strong> Site configuration updated successfully.
    </div>
  )}

  {error && (
    <div class="alert alert-error">
      <strong>Error:</strong> {error}
    </div>
  )}

  {workspace && preferences ? (
    <form method="POST" action="/api/publishing/site/update" class="site-form">
      <section class="form-section">
        <h3>Identity</h3>
        <p class="section-description">How your site identifies itself to the world</p>
        <div class="form-grid">
          <label class="span-2">
            <span>Site Title</span>
            <input
              type="text"
              name="site_title"
              value={preferences.site_title || ""}
              placeholder={workspace.workspace.name}
            />
            <small>Defaults to workspace name if not set</small>
          </label>
          <label class="span-2">
            <span>Tagline</span>
            <input
              type="text"
              name="site_tagline"
              value={preferences.site_tagline || ""}
              placeholder="A short slogan or motto"
            />
          </label>
          <label class="span-2">
            <span>Description</span>
            <textarea
              name="site_description"
              rows="3"
              placeholder="Describe what this site is about"
            >{preferences.site_description || ""}</textarea>
          </label>
          <label class="span-2">
            <span>Canonical URL</span>
            <input
              type="url"
              name="site_canonical_url"
              value={preferences.site_canonical_url || ""}
              placeholder="https://example.com"
            />
            <small>Where this site is published</small>
          </label>
        </div>
      </section>

      <section class="form-section">
        <h3>Branding</h3>
        <p class="section-description">Visual identity assets</p>
        <div class="form-grid">
          <label>
            <span>Logo URL</span>
            <input
              type="url"
              name="site_logo"
              value={preferences.site_logo || ""}
              placeholder="https://example.com/logo.png"
            />
          </label>
          <label>
            <span>Favicon URL</span>
            <input
              type="url"
              name="site_favicon"
              value={preferences.site_favicon || ""}
              placeholder="https://example.com/favicon.ico"
            />
          </label>
        </div>
      </section>

      <section class="form-section">
        <h3>Localization</h3>
        <p class="section-description">Language and timezone settings</p>
        <div class="form-grid">
          <label>
            <span>Locale</span>
            <input
              type="text"
              name="site_locale"
              value={preferences.site_locale || "en-US"}
              placeholder="en-US"
            />
            <small>e.g., en-US, en-GB, fr-FR</small>
          </label>
          <label>
            <span>Timezone</span>
            <input
              type="text"
              name="site_timezone"
              value={preferences.site_timezone || "America/New_York"}
              placeholder="America/New_York"
            />
            <small>IANA timezone identifier</small>
          </label>
        </div>
      </section>

      <section class="form-section">
        <h3>Contact & Social</h3>
        <p class="section-description">How people can reach you</p>
        <div class="form-grid">
          <label class="span-2">
            <span>Contact Email</span>
            <input
              type="email"
              name="site_contact_email"
              value={preferences.site_contact_email || ""}
              placeholder="hello@example.com"
            />
          </label>
          <label class="span-2">
            <span>Social Links (JSON)</span>
            <textarea
              name="site_social_json"
              rows="4"
              placeholder='{"instagram": "https://...", "twitter": "https://..."}'
            >{JSON.stringify(preferences.site_social_json || {}, null, 2)}</textarea>
            <small>JSON object with social media URLs</small>
          </label>
        </div>
      </section>

      <section class="form-section">
        <h3>Advanced</h3>
        <p class="section-description">Custom metadata for framework-specific settings</p>
        <div class="form-grid">
          <label class="span-2">
            <span>Custom Metadata (JSON)</span>
            <textarea
              name="site_metadata_json"
              rows="6"
              placeholder='{"seo": {"image": "..."}, "analytics": {"id": "..."}}'
            >{JSON.stringify(preferences.site_metadata_json || {}, null, 2)}</textarea>
            <small>Additional metadata for your publishing framework</small>
          </label>
        </div>
      </section>

      <div class="form-actions">
        <button type="submit" class="button">Save Site Configuration</button>
        <a href="/publishing/clients" class="button secondary">Manage Clients</a>
      </div>
    </form>
  ) : !error && (
    <div class="empty-state">
      <p>Loading site configuration...</p>
    </div>
  )}
</AppLayout>

<style>
  .toolbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    font-size: 14px;
  }

  .alert-success {
    background: rgb(53 122 85 / 0.1);
    color: var(--good);
    border: 1px solid var(--good);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .site-form {
    display: grid;
    gap: 32px;
  }

  .form-section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .form-section h3 {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
  }

  .section-description {
    margin: 0 0 20px;
    color: var(--muted);
    font-size: 14px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-grid label {
    display: grid;
    gap: 6px;
  }

  .form-grid label.span-2 {
    grid-column: 1 / -1;
  }

  .form-grid label > span {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
  }

  .form-grid input,
  .form-grid textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    font-size: 14px;
    color: var(--ink);
  }

  .form-grid input:focus,
  .form-grid textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .form-grid textarea {
    resize: vertical;
    font-family: ui-monospace, monospace;
    font-size: 13px;
  }

  .form-grid small {
    font-size: 12px;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 12px;
    padding-top: 8px;
  }

  .empty-state {
    padding: 64px 24px;
    text-align: center;
    color: var(--muted);
  }
</style>
