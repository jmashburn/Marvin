---
import AppLayout from "@/layouts/AppLayout.astro";
---

<AppLayout title="New API Client" eyebrow="Publishing">
  <div class="toolbar">
    <div>
      <h2>Create API Client</h2>
      <p>Generate a token for external sites to access published content</p>
    </div>
    <a class="button secondary" href="/publishing/clients">Back to Clients</a>
  </div>

  <form method="POST" action="/api/api-clients" class="create-form" id="create-client-form">
    <section class="form-section">
      <h3>Client Details</h3>
      <div class="form-grid">
        <label class="span-2">
          <span>Name <span class="required">*</span></span>
          <input
            type="text"
            name="name"
            required
            placeholder="e.g., Production Site, Staging, Mobile App"
            autofocus
          />
          <small>Slug will be auto-generated from the name</small>
        </label>

        <label class="span-2">
          <span>Description</span>
          <textarea
            name="description"
            rows="3"
            placeholder="Optional: where this client is used, what it's for"
          ></textarea>
        </label>
      </div>
    </section>

    <section class="form-section">
      <h3>Permissions</h3>
      <p class="section-description">What this client can access</p>
      <div class="permissions-grid">
        <label class="checkbox-label">
          <input type="checkbox" name="read:published_entries" checked />
          <div>
            <strong>Read Published Entries</strong>
            <small>Access all published entries</small>
          </div>
        </label>

        <label class="checkbox-label">
          <input type="checkbox" name="read:collections" checked />
          <div>
            <strong>Read Collections</strong>
            <small>Access collection metadata and entry lists</small>
          </div>
        </label>

        <label class="checkbox-label">
          <input type="checkbox" name="read:assets" checked />
          <div>
            <strong>Read Assets</strong>
            <small>Access uploaded media files</small>
          </div>
        </label>

        <label class="checkbox-label">
          <input type="checkbox" name="read:resources" />
          <div>
            <strong>Read Resources</strong>
            <small>Access resource metadata</small>
          </div>
        </label>
      </div>
    </section>

    <div class="form-actions">
      <button type="submit" class="button">Create Client</button>
      <a href="/publishing/clients" class="button secondary">Cancel</a>
    </div>

    <div class="info-box">
      <strong>⚠️ Important:</strong> The API token will only be shown once after creation.
      Copy it immediately and store it securely.
    </div>
  </form>
</AppLayout>

<script>
  interface APIClientWithToken {
    id: string;
    groupId: string;
    name: string;
    slug: string;
    description?: string | null;
    permissions: Record<string, unknown>;
    token: string;
    enabled: boolean;
    createdAt?: string | null;
  }

  interface APIClientCreatePayload {
    name: string;
    description?: string | null;
    permissions?: Record<string, boolean> | null;
  }

  // HttpOnly cookie is automatically sent with credentials: 'include'
  const form = document.getElementById('create-client-form') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const nameValue = formData.get('name');
      const descriptionValue = formData.get('description');

      if (typeof nameValue !== 'string' || !nameValue) {
        alert('Name is required');
        return;
      }

      const permissions: Record<string, boolean> = {};

      // Convert checkboxes to permissions object with colon format
      const checkboxes = form.querySelectorAll<HTMLInputElement>('input[type="checkbox"]');
      checkboxes.forEach((checkbox) => {
        if (checkbox.checked && checkbox.name) {
          permissions[checkbox.name] = true;
        }
      });

      const data: APIClientCreatePayload = {
        name: nameValue,
        description: descriptionValue && typeof descriptionValue === 'string' ? descriptionValue : null,
        permissions: Object.keys(permissions).length > 0 ? permissions : null,
      };

      try {
        const { createSdkClient } = await import('@/lib/sdk');

        // SDK uses cookie-based auth automatically via credentials: 'include'
        const sdk = createSdkClient();
        const result = await sdk.apiClients.create(data);

        console.log('API Client created:', result);
        console.log('Token:', result.token);
        console.log('Name:', result.name);

        if (!result.token) {
          console.error('No token in response!', result);
          alert('Warning: Client created but no token was returned. Please rotate the token to get a new one.');
          window.location.href = '/publishing/clients';
          return;
        }

        // Redirect to clients page with token info
        window.location.href = `/publishing/clients?token=${result.token}&client_name=${encodeURIComponent(result.name)}`;
      } catch (err) {
        alert('Error: ' + (err instanceof Error ? err.message : 'Failed to create client'));
      }
    });
  }
</script>

<style>
  .toolbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .create-form {
    max-width: 700px;
    display: grid;
    gap: 24px;
  }

  .form-section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .form-section h3 {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
  }

  .section-description {
    margin: 0 0 20px;
    color: var(--muted);
    font-size: 14px;
  }

  .form-grid {
    display: grid;
    gap: 16px;
  }

  .form-grid label {
    display: grid;
    gap: 6px;
  }

  .form-grid label.span-2 {
    grid-column: 1 / -1;
  }

  .form-grid label > span {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
  }

  .required {
    color: var(--warn);
  }

  .form-grid input,
  .form-grid textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    font-size: 14px;
    color: var(--ink);
  }

  .form-grid input:focus,
  .form-grid textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .form-grid textarea {
    resize: vertical;
  }

  .form-grid small {
    font-size: 12px;
    color: var(--muted);
  }

  .permissions-grid {
    display: grid;
    gap: 12px;
  }

  .checkbox-label {
    display: flex;
    gap: 12px;
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    cursor: pointer;
    transition: background 0.2s;
  }

  .checkbox-label:hover {
    background: var(--panel-2);
  }

  .checkbox-label input[type="checkbox"] {
    margin-top: 2px;
    cursor: pointer;
  }

  .checkbox-label strong {
    display: block;
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 2px;
  }

  .checkbox-label small {
    display: block;
    font-size: 12px;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 12px;
  }

  .info-box {
    padding: 16px;
    background: rgb(169 99 47 / 0.1);
    border-left: 3px solid var(--warn);
    border-radius: var(--radius);
    font-size: 14px;
    color: var(--ink);
  }

  .info-box strong {
    color: var(--warn);
  }
</style>
