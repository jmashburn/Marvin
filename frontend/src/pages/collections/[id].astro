---
import AppLayout from "@/layouts/AppLayout.astro";
import { getCollection } from "@/lib/api/collections";
import { listEntries } from "@/lib/api/entries";
import { getEntryCollections } from "@/lib/api/entries";

const { id } = Astro.params;

let collection = null;
let allEntries = [];
let collectionEntries = [];
let error: string | null = null;

if (!id) {
  error = "Collection ID is required";
} else {
  try {
    [collection, allEntries] = await Promise.all([
      getCollection(id),
      listEntries(),
    ]);

    // Get entries that belong to this collection
    // Since we don't have a direct API for this, we'll filter client-side for now
    // In a future update, add GET /api/collections/{id}/entries endpoint
    collectionEntries = allEntries.filter(entry => {
      // This is a placeholder - in real implementation, fetch collection membership
      return false; // TODO: implement collection membership check
    });

  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[Collection] Failed to load:', error);
  }
}
---

<AppLayout title={collection ? `Edit ${collection.name}` : "Edit Collection"}>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading collection:</strong> {error}</p>
      <a href="/collections" class="button secondary">Back to Collections</a>
    </div>
  ) : collection ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Collection</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Update collection details and manage entries</p>
        </div>
        <a class="button secondary" href="/collections">Back</a>
      </div>

      <section class="form-section">
        <form method="POST" action={`/api/collections/${id}/update`} class="form">
          <div class="form-group">
            <label for="name">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={collection.name}
            />
            <p class="form-help">Display name for this collection</p>
          </div>

          <div class="form-group">
            <label for="slug">Slug *</label>
            <input
              type="text"
              id="slug"
              name="slug"
              required
              value={collection.slug}
              pattern="[a-z0-9-]+"
            />
            <p class="form-help">URL-friendly identifier (lowercase, hyphens only)</p>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="icon">Icon</label>
              <input
                type="text"
                id="icon"
                name="icon"
                value={collection.icon || ""}
                maxlength="4"
              />
              <p class="form-help">Emoji or symbol</p>
            </div>

            <div class="form-group">
              <label for="color">Color</label>
              <input
                type="color"
                id="color"
                name="color"
                value={collection.color || "#a94d3f"}
              />
              <p class="form-help">Theme color</p>
            </div>
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              rows="3"
            >{collection.description || ""}</textarea>
          </div>

          <div class="form-group">
            <label for="sort_order">Sort Order</label>
            <input
              type="number"
              id="sort_order"
              name="sort_order"
              value={collection.sort_order}
              min="0"
            />
            <p class="form-help">Lower numbers appear first</p>
          </div>

          <div class="form-actions">
            <button type="submit" class="button">Save Changes</button>
            <a href="/collections" class="button secondary">Cancel</a>
          </div>
        </form>
      </section>

      <section class="entries-section">
        <h3 style="margin:0 0 1rem;font-size:1.125rem;">Entries in this Collection</h3>
        {collectionEntries.length === 0 ? (
          <div class="empty-state-small">
            <p>No entries in this collection yet.</p>
            <p class="muted">Add entries by editing them and selecting this collection.</p>
          </div>
        ) : (
          <table class="table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {collectionEntries.map((entry) => (
                <tr>
                  <td><strong>{entry.title}</strong></td>
                  <td><span class={`pill ${entry.status}`}>{entry.status}</span></td>
                  <td>
                    <form method="POST" action={`/api/entries/${entry.id}/collections/${id}/remove`} style="display:inline;">
                      <button type="submit" class="button secondary small">Remove</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </section>
    </>
  ) : null}
</AppLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="number"],
  input[type="color"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  input[type="color"] {
    height: 40px;
    cursor: pointer;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .entries-section {
    margin-top: 2rem;
  }

  .empty-state-small {
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-align: center;
  }

  .empty-state-small p {
    margin: 0.5rem 0;
  }

  .empty-state-small .muted {
    color: var(--muted);
    font-size: 0.875rem;
  }

  .button.small {
    min-height: 32px;
    padding: 6px 10px;
    font-size: 0.875rem;
  }
</style>
