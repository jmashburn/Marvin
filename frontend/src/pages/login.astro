---
import { isAuthenticated } from '@/lib/auth';

// Ensure this page is server-rendered (not prerendered)
export const prerender = false;

// Check if user is already logged in
if (await isAuthenticated(Astro.cookies)) {
  // Get return path from query param, default to dashboard
  const returnPath = Astro.url.searchParams.get('return') || '/';
  return Astro.redirect(returnPath);
}

const error = Astro.url.searchParams.get('error');
const returnPath = Astro.url.searchParams.get('return');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login | Marvin</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="login-page">
    <div class="login-container">
      <div class="login-card">
        <div class="login-header">
          <div class="brand-logo">
            <strong>Marvin</strong>
            <span>Content engine</span>
          </div>
          <h1>Welcome back</h1>
          <p>Sign in to your workspace</p>
        </div>

        {error && (
          <div class="error-message">
            <strong>⚠ Authentication failed</strong>
            <p>{error === 'invalid' ? 'Invalid username or password' : 'An error occurred. Please try again.'}</p>
          </div>
        )}

        <form method="POST" action={returnPath ? `/api/auth/login?return=${encodeURIComponent(returnPath)}` : '/api/auth/login'} class="login-form">
          <div class="form-group">
            <label for="username">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              required
              autofocus
              placeholder="Enter your username"
            />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              placeholder="Enter your password"
            />
            <a href="/user/password/forgot" class="forgot-link">Forgot password?</a>
          </div>

          <div class="form-actions">
            <button type="submit" class="button primary">Sign In</button>
          </div>
        </form>

        <div class="login-footer">
          <p class="help-text">
            Default credentials: <code>jason</code> / <code>MyPassword</code>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  .login-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #1e2725 0%, #2f4a47 100%);
    padding: 2rem;
  }

  .login-container {
    width: 100%;
    max-width: 24rem;
  }

  .login-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2.5rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .login-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .brand-logo {
    display: grid;
    gap: 4px;
    margin-bottom: 2rem;
  }

  .brand-logo strong {
    font-size: 32px;
    font-weight: 700;
    color: var(--ink);
  }

  .brand-logo span {
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .login-header h1 {
    margin: 0 0 0.5rem;
    font-size: 24px;
    font-weight: 600;
    color: var(--ink);
  }

  .login-header p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
  }

  .error-message {
    padding: 1rem;
    margin-bottom: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: 8px;
  }

  .error-message strong {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--color-error);
    font-size: 14px;
  }

  .error-message p {
    margin: 0;
    color: var(--color-error);
    font-size: 13px;
  }

  .login-form {
    display: grid;
    gap: 1.25rem;
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .label-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .form-group label {
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
  }

  .form-group input {
    padding: 0.75rem 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg);
    font-size: 15px;
    transition: all 0.2s;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(169, 77, 63, 0.1);
  }

  .form-actions {
    margin-top: 0.5rem;
  }

  .button.primary {
    width: 100%;
    padding: 0.875rem 1.5rem;
    background: var(--accent);
    color: white;
    font-weight: 600;
    font-size: 15px;
    transition: all 0.2s;
  }

  .button.primary:hover {
    background: #8f3f31;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(169, 77, 63, 0.3);
  }

  .button.primary:active {
    transform: translateY(0);
  }

  .login-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .help-text {
    margin: 0;
    text-align: center;
    font-size: 13px;
    color: var(--muted);
  }

  .help-text code {
    padding: 2px 6px;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    font-family: 'SF Mono', Monaco, monospace;
    font-size: 12px;
  }

  .forgot-link {
    font-size: 13px;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }

  .forgot-link:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .login-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
