---
import EntryCard from "@/components/EntryCard.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { listEntries } from "@/lib/api/entries";
import { listEntryTypes } from "@/lib/api/entryTypes";

let entries = [];
let entryTypes = [];
let error: string | null = null;

try {
  [entries, entryTypes] = await Promise.all([
    listEntries(),
    listEntryTypes(),
  ]);
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
  console.error('[Entries] Failed to load:', error);
}

// Get selected type filter from query params
const selectedTypeId = Astro.url.searchParams.get("type_id") ?? "";

// Filter entries by type if specified
const filteredEntries = selectedTypeId
  ? entries.filter(e => e.entry_type_id === selectedTypeId)
  : entries;

// Sort entry types by sort_order
const sortedTypes = entryTypes.sort((a, b) => a.sort_order - b.sort_order);
---

<AppLayout title="Entries">
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading entries:</strong> {error}</p>
      <button onclick="location.reload()" class="button secondary">Retry</button>
    </div>
  ) : (
    <>
      <div class="toolbar">
        <nav class="segmented" aria-label="Entry type">
          <a href="/entries" aria-current={!selectedTypeId ? "page" : undefined}>
            all
          </a>
          {sortedTypes.map((type) => (
            <a
              href={`/entries?type_id=${type.id}`}
              aria-current={selectedTypeId === type.id ? "page" : undefined}
            >
              {type.icon && <span aria-hidden="true">{type.icon}</span>}
              {type.name}
            </a>
          ))}
        </nav>
        <a class="button" href="/entries/new">New Entry</a>
      </div>

      {filteredEntries.length === 0 ? (
        <div class="empty-state">
          <p class="empty-title">No entries yet</p>
          <p class="empty-description">
            {selectedTypeId
              ? `No entries of this type yet. Create one to get started.`
              : `Create your first entry to get started.`}
          </p>
          <a href="/entries/new" class="button">Create Entry</a>
        </div>
      ) : (
        <section class="grid" aria-label="Entries">
          {filteredEntries.map((entry) => <EntryCard entry={entry} />)}
        </section>
      )}
    </>
  )}
</AppLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .empty-state {
    display: grid;
    place-items: center;
    gap: 1rem;
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .empty-description {
    margin: 0;
    color: var(--muted);
    max-width: 32rem;
  }
</style>
