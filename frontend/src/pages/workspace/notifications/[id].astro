---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

let notification: any = null;
let error: string | null = null;

try {
  notification = await fetchApi<any>(`/api/group/notifications/${id}`, {}, authToken);
} catch (e) {
  console.error('[notifications/edit] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}
---

<AppLayout title="Edit Notification" eyebrow="Workspace">
  <div class="page-header">
    <div>
      <h2>Edit Event Notification</h2>
      <p>Update notification endpoint configuration</p>
    </div>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : notification ? (
    <div class="form-container">
      <form id="update-notification-form" class="form">
        <input type="hidden" name="id" value={notification.id} />

        <div class="form-section">
          <h3>Notification Details</h3>

          <label class="form-field">
            <span class="label">Name</span>
            <input
              type="text"
              name="name"
              required
              value={notification.name}
              class="input"
            />
          </label>

          <label class="form-field">
            <span class="label">Apprise URL</span>
            <input
              type="text"
              name="apprise_url"
              required
              value={notification.apprise_url}
              class="input"
            />
            <small class="hint">
              Apprise notification URL. See <a href="https://github.com/caronc/apprise" target="_blank">Apprise docs</a> for formats.
            </small>
          </label>

          <label class="form-field checkbox-field">
            <input type="checkbox" name="enabled" checked={notification.enabled !== false} />
            <span>Enabled</span>
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="button">Save Changes</button>
          <button type="button" id="delete-btn" class="button danger">Delete</button>
          <a href="/workspace/notifications" class="button secondary">Cancel</a>
        </div>
      </form>
    </div>
  ) : null}
</AppLayout>

<script define:vars={{ id }}>
  const form = document.getElementById('update-notification-form');
  const deleteBtn = document.getElementById('delete-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);

    const payload = {
      id: formData.get('id'),
      name: formData.get('name'),
      apprise_url: formData.get('apprise_url'),
      enabled: formData.get('enabled') === 'on',
    };

    try {
      const response = await fetch(`/api/group/notifications/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        window.location.href = '/workspace/notifications?updated=true';
      } else {
        const error = await response.text();
        alert(`Failed to update notification: ${error}`);
      }
    } catch (error) {
      alert('Failed to update notification. Please try again.');
      console.error('Error updating notification:', error);
    }
  });

  deleteBtn?.addEventListener('click', async () => {
    if (!confirm('Are you sure you want to delete this notification?')) return;

    try {
      const response = await fetch(`/api/group/notifications/${id}`, {
        method: 'DELETE',
        credentials: 'include',
      });

      if (response.ok) {
        window.location.href = '/workspace/notifications?deleted=true';
      } else {
        alert('Failed to delete notification');
      }
    } catch (error) {
      alert('Failed to delete notification. Please try again.');
      console.error('Error deleting notification:', error);
    }
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .page-header h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .page-header p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .form-container {
    max-width: 700px;
  }

  .form {
    display: grid;
    gap: 24px;
  }

  .form-section {
    display: grid;
    gap: 16px;
    padding: 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-section h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
  }

  .form-field {
    display: grid;
    gap: 6px;
  }

  .checkbox-field {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 8px;
  }

  .checkbox-field input[type="checkbox"] {
    width: auto;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
  }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .hint {
    font-size: 12px;
    color: var(--muted);
  }

  .hint a {
    color: var(--accent);
    text-decoration: underline;
  }

  .form-actions {
    display: flex;
    gap: 12px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .button.danger {
    background: var(--color-error);
    color: white;
  }

  .button.danger:hover {
    background: var(--color-error);
    opacity: 0.9;
  }
</style>
