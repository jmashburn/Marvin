---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";
import { listWorkspaceMembers } from "@/lib/api/workspaceMembers";
import type { WorkspaceMembershipRead, WorkspaceRole, UserSummary } from "@/lib/api/types";

const authToken = getAuthToken(Astro.cookies);

let workspace = null;
let members: WorkspaceMembershipRead[] = [];
let error: string | null = null;
let currentUserRole: WorkspaceRole | null = null;

try {
  workspace = await getCurrentWorkspace(authToken);

  if (workspace) {
    members = await listWorkspaceMembers(workspace.id, authToken);

    // Get current user info to find their role
    const currentUser = await fetchApi<any>('/api/self', {}, authToken);
    if (currentUser) {
      const currentMembership = members.find(m => m.userId === currentUser.id);
      currentUserRole = currentMembership?.workspaceRole || null;
    }
  }
} catch (e) {
  console.error('[members] Error loading:', e);
  error = e instanceof Error ? e.message : String(e);
}

// Role display names
const roleLabels: Record<WorkspaceRole, string> = {
  OWNER: "Owner",
  ADMIN: "Admin",
  EDITOR: "Editor",
  AUTHOR: "Author",
  VIEWER: "Viewer",
};

// Role descriptions
const roleDescriptions: Record<WorkspaceRole, string> = {
  OWNER: "Full control, can delete workspace",
  ADMIN: "Manage settings, members, and publishing",
  EDITOR: "Create and edit all content",
  AUTHOR: "Create and edit own content",
  VIEWER: "Read-only access",
};

// Check if current user can manage members
const canManage = currentUserRole === 'OWNER' || currentUserRole === 'ADMIN';
---

<AppLayout title="Workspace Members" eyebrow="Workspace">
  <div class="toolbar">
    <div>
      <h2>Workspace Members</h2>
      <p>Manage who has access to {workspace?.name || 'this workspace'}</p>
    </div>
    {canManage && (
      <a href="/workspace/members/new" class="button">Add Member</a>
    )}
  </div>

  {error ? (
    <div class="alert alert-error">
      <strong>Error:</strong> {error}
    </div>
  ) : members.length === 0 ? (
    <div class="empty-state">
      <div class="empty-icon">👥</div>
      <p class="empty-title">No members found</p>
      <p class="empty-description">Add members to collaborate on this workspace</p>
      {canManage && (
        <a href="/workspace/members/new" class="button">Add Member</a>
      )}
    </div>
  ) : (
    <div class="members-list">
      {members.map((member) => {
        const user = member?.user;
        const fullName = user?.fullName;
        const username = user?.username;
        const email = user?.email;
        return (
          <div class="member-card">
            <div class="member-info">
              <div class="member-avatar">
                {fullName?.charAt(0) || username?.charAt(0) || '?'}
              </div>
              <div class="member-details">
                <strong>{fullName || username || 'Unknown'}</strong>
                <span class="member-email">{email || 'No email'}</span>
              </div>
            </div>

            <div class="member-role-section">
              {canManage ? (
                <select
                  class="role-select"
                  data-member-id={member?.id}
                  data-user-id={member?.userId}
                  data-current-role={member?.workspaceRole}
                >
                  {Object.entries(roleLabels).map(([role, label]) => (
                    <option value={role} selected={member?.workspaceRole === role}>
                      {label}
                    </option>
                  ))}
                </select>
              ) : (
                <span class={`role-badge role-${member?.workspaceRole?.toLowerCase()}`}>
                  {roleLabels[member?.workspaceRole || 'VIEWER']}
                </span>
              )}
              <span class="role-description">
                {roleDescriptions[member?.workspaceRole || 'VIEWER']}
              </span>
            </div>

            {canManage && (
              <button
                class="button secondary small remove-btn"
                data-member-id={member?.id}
                data-user-id={member?.userId}
                data-username={username}
              >
                Remove
              </button>
            )}
          </div>
        );
      })}
    </div>
  )}

  <!-- Confirm Remove Modal -->
  <dialog id="confirm-remove-modal" class="modal">
    <div class="modal-content">
      <h3>Remove Member?</h3>
      <p id="remove-message"></p>
      <div class="modal-actions">
        <button type="button" class="button" id="confirm-remove">Remove</button>
        <button type="button" class="button secondary" id="cancel-remove">Cancel</button>
      </div>
    </div>
  </dialog>
</AppLayout>

<script define:vars={{ workspaceId: workspace?.workspace?.id, canManage }}>
  import { fetchApi } from '@/lib/api/client';
  import { getAuthToken } from '@/lib/client-auth';

  const authToken = getAuthToken();

  // Role change
  if (canManage) {
    document.querySelectorAll('.role-select').forEach(select => {
      select.addEventListener('change', async (e) => {
        const target = e.target as HTMLSelectElement;
        const userId = target.dataset.userId;
        const currentRole = target.dataset.currentRole;
        const newRole = target.value;

        if (!userId || newRole === currentRole) return;

        try {
          await fetchApi(`/api/workspaces/${workspaceId}/members/${userId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ workspace_role: newRole }),
          }, authToken);

          window.location.reload();
        } catch (error) {
          console.error('Update role error:', error);
          alert(error instanceof Error ? error.message : 'Failed to update role');
          target.value = currentRole || ''; // Revert on error
        }
      });
    });
  }

  // Remove member
  const removeButtons = document.querySelectorAll('.remove-btn');
  const confirmRemoveModal = document.getElementById('confirm-remove-modal');
  const removeMessage = document.getElementById('remove-message');
  const confirmRemoveBtn = document.getElementById('confirm-remove');
  const cancelRemoveBtn = document.getElementById('cancel-remove');
  let userToRemove: string | null = null;

  removeButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn as HTMLButtonElement;
      userToRemove = target.dataset.userId || null;
      const username = target.dataset.username || 'this user';

      if (removeMessage) {
        removeMessage.textContent = `Remove ${username} from this workspace? They will lose all access immediately.`;
      }

      confirmRemoveModal?.showModal();
    });
  });

  cancelRemoveBtn?.addEventListener('click', () => {
    confirmRemoveModal?.close();
    userToRemove = null;
  });

  confirmRemoveBtn?.addEventListener('click', async () => {
    if (!userToRemove) return;

    try {
      await fetchApi(`/api/workspaces/${workspaceId}/members/${userToRemove}`, {
        method: 'DELETE',
      }, authToken);

      window.location.reload();
    } catch (error) {
      console.error('Remove member error:', error);
      alert(error instanceof Error ? error.message : 'Failed to remove member');
      confirmRemoveModal?.close();
    }
  });
</script>

<style>
  .toolbar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    font-size: 14px;
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .empty-state {
    padding: 64px 24px;
    text-align: center;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
  }

  .empty-title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .empty-description {
    margin: 0 0 24px;
    color: var(--muted);
  }

  .members-list {
    display: grid;
    gap: 12px;
  }

  .member-card {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 16px 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .member-info {
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 1;
    min-width: 0;
  }

  .member-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 16px;
    flex-shrink: 0;
  }

  .member-details {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .member-details strong {
    font-size: 14px;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .member-email {
    font-size: 12px;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .member-role-section {
    display: grid;
    gap: 4px;
    min-width: 200px;
  }

  .role-select {
    padding: 6px 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
  }

  .role-select:focus {
    outline: none;
    border-color: var(--accent);
  }

  .role-badge {
    display: inline-flex;
    padding: 6px 12px;
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 500;
  }

  .role-owner {
    background: rgb(169 77 63 / 0.15);
    color: var(--accent);
  }

  .role-admin {
    background: rgb(47 111 115 / 0.15);
    color: var(--accent-2);
  }

  .role-editor {
    background: rgb(53 122 85 / 0.15);
    color: var(--good);
  }

  .role-author {
    background: rgb(189 145 64 / 0.15);
    color: var(--gold);
  }

  .role-viewer {
    background: var(--panel-2);
    color: var(--muted);
  }

  .role-description {
    font-size: 11px;
    color: var(--muted);
  }

  .remove-btn {
    padding: 6px 12px;
    font-size: 13px;
  }

  /* Modal Styles */
  .modal {
    border: none;
    border-radius: var(--radius);
    padding: 0;
    max-width: 500px;
    width: 90vw;
    box-shadow: 0 8px 32px rgb(0 0 0 / 0.15);
  }

  .modal::backdrop {
    background: rgb(0 0 0 / 0.5);
  }

  .modal-content {
    padding: 24px;
    background: var(--panel);
  }

  .modal h3 {
    margin: 0 0 4px;
    font-size: 20px;
    font-weight: 600;
  }

  .modal-subtitle {
    margin: 0 0 20px;
    font-size: 14px;
    color: var(--muted);
  }

  .modal form {
    display: grid;
    gap: 16px;
  }

  .modal label {
    display: grid;
    gap: 6px;
  }

  .modal label > span {
    font-size: 14px;
    font-weight: 500;
  }

  .modal input,
  .modal select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    font-size: 14px;
  }

  .modal input:focus,
  .modal select:focus {
    outline: none;
    border-color: var(--accent);
  }

  .modal small {
    font-size: 12px;
    color: var(--muted);
  }

  .modal-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 8px;
  }
</style>
