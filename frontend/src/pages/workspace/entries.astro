---
import EntryCard from "@/components/EntryCard.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import FilterBar from "@/components/FilterBar.astro";
import { listEntries, type EntryRead } from "@/lib/api/entries";
import { listEntryTypes, type EntryTypeRead } from "@/lib/api/entryTypes";
import { listCollections, type CollectionRead } from "@/lib/api/collections";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);

// Get URL parameters for pre-filtering
const statusParam = Astro.url.searchParams.get('status');
const statusFilters = statusParam ? statusParam.split(',').map(s => s.trim()) : [];

let entries: EntryRead[] = [];
let entryTypes: EntryTypeRead[] = [];
let collections: CollectionRead[] = [];
let error: string | null = null;

// Ensure we have auth token before making requests
if (!authToken) {
  error = 'Authentication required';
} else {
  try {
    [entries, entryTypes, collections] = await Promise.all([
      listEntries(authToken),
      listEntryTypes(authToken),
      listCollections(authToken),
    ]);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[Entries] Failed to load:', error);
  }
}

// Create a map of collection ID to collection for quick lookup
const collectionsMap = new Map(collections.map(c => [c.id, c]));

// Sort entry types by sort_order
const sortedTypes = entryTypes.sort((a, b) => a.sortOrder - b.sortOrder);

// Group entries by collection (entries can appear in multiple collections)
const collectionGroups = new Map<string, { collection: CollectionRead; entries: EntryRead[] }>();
const uncollected: EntryRead[] = [];

for (const entry of entries) {
  if (entry.collections && entry.collections.length > 0) {
    for (const item of entry.collections) {
      const colId = typeof item === 'string' ? item : item.id;
      const col = collectionsMap.get(colId);
      if (col) {
        if (!collectionGroups.has(colId)) {
          collectionGroups.set(colId, { collection: col, entries: [] });
        }
        collectionGroups.get(colId)!.entries.push(entry);
      }
    }
  } else {
    uncollected.push(entry);
  }
}

// Sort groups by collection name
const sortedGroups = [...collectionGroups.values()].sort((a, b) =>
  a.collection.name.localeCompare(b.collection.name)
);
---

<AppLayout title="Entries">
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading entries:</strong> {error}</p>
      <button onclick="location.reload()" class="button secondary">Retry</button>
    </div>
  ) : (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Entries</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Manage all your content entries.</p>
        </div>
        <div style="display:flex;gap:0.75rem;">
          <FilterBar
            searchPlaceholder="Search entries..."
            filters={[
              {
                id: "type-filter",
                label: "Types",
                options: sortedTypes.map(type => ({
                  value: type.id,
                  label: type.name
                }))
              },
              {
                id: "status-filter",
                label: "Statuses",
                options: [
                  { value: "inbox", label: "Inbox" },
                  { value: "draft", label: "Draft" },
                  { value: "in_progress", label: "In Progress" },
                  { value: "in_review", label: "In Review" },
                  { value: "published", label: "Published" },
                  { value: "archived", label: "Archived" }
                ]
              }
            ]}
          />
          <a class="button" href="/workspace/entries/new">New Entry</a>
        </div>
      </div>

      {entries.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">📝</div>
          <h3>No entries yet</h3>
          <p>Entries are your content items like blog posts, products, pages, or any structured content.</p>
          <a href="/workspace/entries/new" class="button">Create Your First Entry</a>
        </div>
      ) : (
        <>
          <div class="view-toggle">
            <button class="toggle-btn active" id="view-grid" title="All entries">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
              All
            </button>
            <button class="toggle-btn" id="view-grouped" title="Group by collection">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="1" y="1" width="14" height="3" rx="1"/><rect x="3" y="5.5" width="12" height="2" rx="0.5" opacity="0.6"/><rect x="3" y="8.5" width="12" height="2" rx="0.5" opacity="0.6"/><rect x="1" y="12" width="14" height="3" rx="1"/></svg>
              Collections
            </button>
          </div>

          {/* Flat grid view */}
          <section class="grid view-section" id="grid-view" aria-label="Entries">
            {entries.map((entry) => {
              const matchesStatusFilter = statusFilters.length === 0 || statusFilters.includes(entry.status);
              return (
                <div class="entry-wrapper"
                  data-type={entry.entryTypeId}
                  data-status={entry.status}
                  data-title={entry.title.toLowerCase()}
                  data-summary={(entry.summary || '').toLowerCase()}
                  data-collections={entry.collections?.map((c: any) => typeof c === 'string' ? c : c.id).join(',') || ''}
                  style={matchesStatusFilter ? '' : 'display: none;'}>
                  <EntryCard entry={entry} collectionsMap={collectionsMap} />
                </div>
              );
            })}
          </section>

          {/* Grouped by collection view */}
          <div class="view-section" id="grouped-view" style="display:none;">
            {sortedGroups.map(({ collection, entries: groupEntries }) => (
              <details class="collection-group" data-collection-id={collection.id}>
                <summary class="collection-header">
                  <h3 class="collection-title">
                    <span class="collapse-chevron"></span>
                    {collection.icon && <span class="collection-icon">{collection.icon}</span>}
                    {collection.name}
                    <span class="collection-count">{groupEntries.length}</span>
                  </h3>
                  {collection.description && (
                    <p class="collection-desc">{collection.description}</p>
                  )}
                </summary>
                <section class="grid" aria-label={`${collection.name} entries`}>
                  {groupEntries.map((entry) => (
                    <div class="entry-wrapper"
                      data-type={entry.entryTypeId}
                      data-status={entry.status}
                      data-title={entry.title.toLowerCase()}
                      data-summary={(entry.summary || '').toLowerCase()}>
                      <EntryCard entry={entry} collectionsMap={collectionsMap} />
                    </div>
                  ))}
                </section>
              </details>
            ))}

            {uncollected.length > 0 && (
              <details class="collection-group" data-collection-id="uncollected">
                <summary class="collection-header">
                  <h3 class="collection-title">
                    <span class="collapse-chevron"></span>
                    Uncollected
                    <span class="collection-count">{uncollected.length}</span>
                  </h3>
                </summary>
                <section class="grid" aria-label="Uncollected entries">
                  {uncollected.map((entry) => (
                    <div class="entry-wrapper"
                      data-type={entry.entryTypeId}
                      data-status={entry.status}
                      data-title={entry.title.toLowerCase()}
                      data-summary={(entry.summary || '').toLowerCase()}>
                      <EntryCard entry={entry} collectionsMap={collectionsMap} />
                    </div>
                  ))}
                </section>
              </details>
            )}
          </div>
        </>
      )}
    </>
  )}
</AppLayout>

<script>
  const searchInput = document.getElementById('filter-search') as HTMLInputElement;
  const typeFilter = document.getElementById('type-filter') as HTMLSelectElement;
  const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
  const gridView = document.getElementById('grid-view');
  const groupedView = document.getElementById('grouped-view');
  const viewGridBtn = document.getElementById('view-grid');
  const viewGroupedBtn = document.getElementById('view-grouped');

  const urlParams = new URLSearchParams(window.location.search);
  const statusParam = urlParams.get('status');
  const urlStatusFilters = statusParam ? statusParam.split(',').map(s => s.trim()) : [];

  // View toggle
  function setView(view: 'grid' | 'grouped') {
    if (!gridView || !groupedView) return;
    gridView.style.display = view === 'grid' ? '' : 'none';
    groupedView.style.display = view === 'grouped' ? '' : 'none';
    viewGridBtn?.classList.toggle('active', view === 'grid');
    viewGroupedBtn?.classList.toggle('active', view === 'grouped');
    localStorage.setItem('entries-view', view);
    filterEntries();
  }

  viewGridBtn?.addEventListener('click', () => setView('grid'));
  viewGroupedBtn?.addEventListener('click', () => setView('grouped'));

  // Restore saved view preference
  const savedView = localStorage.getItem('entries-view') as 'grid' | 'grouped' | null;
  if (savedView) setView(savedView);

  function filterEntries() {
    const searchQuery = searchInput?.value.toLowerCase() || '';
    const typeQuery = typeFilter?.value || '';
    const statusQuery = statusFilter?.value || '';

    // Filter all entry wrappers across both views
    const wrappers = document.querySelectorAll('.entry-wrapper');
    wrappers.forEach(wrapper => {
      const title = wrapper.getAttribute('data-title') || '';
      const summary = wrapper.getAttribute('data-summary') || '';
      const type = wrapper.getAttribute('data-type') || '';
      const status = wrapper.getAttribute('data-status') || '';

      const matchesSearch = !searchQuery || title.includes(searchQuery) || summary.includes(searchQuery);
      const matchesType = !typeQuery || type === typeQuery;

      let matchesStatus = true;
      if (statusQuery) {
        matchesStatus = status === statusQuery;
      } else if (urlStatusFilters.length > 0) {
        matchesStatus = urlStatusFilters.includes(status);
      }

      (wrapper as HTMLElement).style.display = (matchesSearch && matchesType && matchesStatus) ? '' : 'none';
    });

    // Hide collection groups where all entries are filtered out
    document.querySelectorAll('.collection-group').forEach(group => {
      const visibleEntries = group.querySelectorAll('.entry-wrapper:not([style*="display: none"])');
      (group as HTMLElement).style.display = visibleEntries.length > 0 ? '' : 'none';
    });
  }

  filterEntries();

  searchInput?.addEventListener('input', filterEntries);
  typeFilter?.addEventListener('change', filterEntries);
  statusFilter?.addEventListener('change', filterEntries);
</script>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .empty-state {
    display: grid;
    place-items: center;
    gap: 1rem;
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .empty-state h3 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .empty-state p {
    margin: 0;
    color: var(--muted);
    max-width: 32rem;
  }

  .view-toggle {
    display: flex;
    gap: 2px;
    background: var(--panel-2);
    border-radius: 6px;
    padding: 2px;
    width: fit-content;
    margin-bottom: 1.5rem;
  }

  .toggle-btn {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border: none;
    border-radius: 4px;
    background: transparent;
    color: var(--muted);
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }

  .toggle-btn:hover {
    color: var(--ink);
  }

  .toggle-btn.active {
    background: var(--panel);
    color: var(--ink);
    box-shadow: 0 1px 2px rgba(0,0,0,0.06);
  }

  .collection-group {
    margin-bottom: 1.5rem;
  }

  .collection-group > .grid {
    margin-top: 1rem;
  }

  .collection-header {
    padding: 0.625rem 0.75rem;
    border-bottom: 1px solid var(--line);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .collection-header::-webkit-details-marker {
    display: none;
  }

  .collection-header:hover {
    background: var(--panel-2);
    border-radius: 6px;
  }

  .collection-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .collapse-chevron {
    display: inline-block;
    width: 16px;
    height: 16px;
    transition: transform 0.15s;
  }

  .collapse-chevron::before {
    content: '';
    display: block;
    width: 6px;
    height: 6px;
    border-right: 2px solid var(--muted);
    border-bottom: 2px solid var(--muted);
    transform: rotate(-45deg) translate(1px, -1px);
    margin: 4px auto;
  }

  details[open] > .collection-header .collapse-chevron {
    transform: rotate(90deg);
  }

  .collection-icon {
    font-size: 1.125rem;
  }

  .collection-count {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    background: var(--panel-2);
    padding: 0.125rem 0.5rem;
    border-radius: 10px;
  }

  .collection-desc {
    margin: 0.25rem 0 0;
    font-size: 0.8125rem;
    color: var(--muted);
  }
</style>
