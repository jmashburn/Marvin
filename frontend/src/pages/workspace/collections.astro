---
import AppLayout from "@/layouts/AppLayout.astro";
import FilterBar from "@/components/FilterBar.astro";
import { listCollections, type CollectionRead } from "@/lib/api/collections";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);

let collections: CollectionRead[] = [];
let error: string | null = null;

if (!authToken) {
  error = 'Not authenticated';
} else {
  try {
    collections = await listCollections(authToken);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[Collections] Failed to load:', error);
  }
}

// Sort by sort_order
const sortedCollections = collections.sort((a, b) => a.sortOrder - b.sortOrder);
---

<AppLayout title="Collections">
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading collections:</strong> {error}</p>
      <button onclick="location.reload()" class="button secondary">Retry</button>
    </div>
  ) : (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Collections</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Curated groupings of related entries.</p>
        </div>
        <div style="display:flex;gap:0.75rem;">
          <FilterBar
            searchPlaceholder="Search collections..."
            filters={[
              {
                id: "type-filter",
                label: "Types",
                options: [
                  { value: "manual", label: "Manual" },
                  { value: "smart", label: "Smart" }
                ]
              }
            ]}
          />
          <a class="button" href="/workspace/collections/new">Create Collection</a>
        </div>
      </div>

      {sortedCollections.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">📚</div>
          <h3>No collections yet</h3>
          <p>Collections are curated groupings of entries, like Featured Projects or Recent Articles.</p>
          <a href="/workspace/collections/new" class="button">Create Your First Collection</a>
        </div>
      ) : (
        <table class="table">
          <thead>
            <tr>
              <th>Icon</th>
              <th>Name</th>
              <th>Slug</th>
              <th>Description</th>
              <th>Type</th>
              <th>Sort Order</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {sortedCollections.map((collection) => (
              <tr class="collection-row" data-type={collection.isSmart ? 'smart' : 'manual'}>
                <td>
                  {collection.icon ? (
                    <span style={`font-size:1.5rem;${collection.color ? `color:${collection.color}` : ''}`}>
                      {collection.icon}
                    </span>
                  ) : (
                    <span class="empty-value">EMPTY</span>
                  )}
                </td>
                <td class="collection-name">{collection.name ? <strong>{collection.name}</strong> : <span class="empty-value">EMPTY</span>}</td>
                <td>{collection.slug ? <code>{collection.slug}</code> : <span class="empty-value">EMPTY</span>}</td>
                <td>{collection.description || <span class="empty-value">EMPTY</span>}</td>
                <td>
                  <span class="pill">{collection.isSmart ? 'Smart' : 'Manual'}</span>
                </td>
                <td>{collection.sortOrder}</td>
                <td>
                  <div class="actions">
                    <a href={`/workspace/collections/${collection.id}`} class="button secondary small">Edit</a>
                    <form method="POST" action={`/api/collections/${collection.id}/delete`} style="display:inline;">
                      <button type="submit" class="button secondary small danger" onclick="return confirm('Delete this collection?')">
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </>
  )}
</AppLayout>

<script>
  const searchInput = document.getElementById('filter-search') as HTMLInputElement;
  const typeFilter = document.getElementById('type-filter') as HTMLSelectElement;

  function filterCollections() {
    const searchQuery = searchInput?.value.toLowerCase() || '';
    const typeQuery = typeFilter?.value || '';
    const rows = document.querySelectorAll('.collection-row');

    rows.forEach(row => {
      const name = row.querySelector('.collection-name')?.textContent?.toLowerCase() || '';
      const type = row.getAttribute('data-type') || '';

      const matchesSearch = !searchQuery || name.includes(searchQuery);
      const matchesType = !typeQuery || type === typeQuery;

      (row as HTMLElement).style.display = (matchesSearch && matchesType) ? '' : 'none';
    });
  }

  searchInput?.addEventListener('input', filterCollections);
  typeFilter?.addEventListener('change', filterCollections);
</script>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .empty-state {
    display: grid;
    place-items: center;
    gap: 1rem;
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 1rem;
    opacity: 0.5;
  }

  .empty-state h3 {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .empty-state p {
    margin: 0;
    color: var(--muted);
    max-width: 32rem;
  }

  .actions {
    display: flex;
    gap: 0.5rem;
  }

  .button.small {
    min-height: 32px;
    padding: 6px 10px;
    font-size: 0.875rem;
  }

  .button.danger {
    color: var(--color-error);
    border-color: var(--color-error);
  }

  .button.danger:hover {
    background: var(--color-error-bg);
  }

  .empty-value {
    color: var(--muted);
    font-size: 0.75rem;
    font-style: italic;
    opacity: 0.6;
  }
</style>
