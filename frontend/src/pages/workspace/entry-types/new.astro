---
import AppLayout from "@/layouts/AppLayout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import SlugInput from "@/components/SlugInput.astro";
import EmojiPicker from "@/components/EmojiPicker.astro";
import SchemaEditor from "@/components/SchemaEditor.astro";
---

<AppLayout title="Create Entry Type">
  <Breadcrumb items={[
    { label: "Workspace Settings", href: "/workspace/settings?tab=entry-types" },
    { label: "Entry Types", href: "/workspace/entry-types" },
    { label: "New" }
  ]} />

  <div class="toolbar">
    <div>
      <h2 style="margin:0;font-size:20px;">New Entry Type</h2>
      <p style="margin:4px 0 0;color:var(--muted);">Define a new content type for your workspace.</p>
    </div>
    <a class="button secondary" href="/workspace/entry-types">Cancel</a>
  </div>

  <section class="form-section">
    <form method="POST" action="/api/entry-types/create" class="form">
      <div class="form-group">
        <label for="name">Name *</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="e.g., Tutorial, Case Study, Blog Post"
        />
      </div>

      <SlugInput nameFieldId="name" />

      <div class="form-row">
        <div class="form-group">
          <label for="icon">Icon</label>
          <EmojiPicker inputId="icon" value="📚" />
          <p class="form-help">Emoji or symbol</p>
        </div>

        <div class="form-group">
          <label for="color">Color</label>
          <input
            type="color"
            id="color"
            name="color"
            value="#a94d3f"
          />
          <p class="form-help">Theme color</p>
        </div>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea
          id="description"
          name="description"
          rows="3"
          placeholder="Optional description of this entry type"
        ></textarea>
      </div>

      <div class="form-group">
        <label for="sort_order">Sort Order</label>
        <input
          type="number"
          id="sort_order"
          name="sort_order"
          value="0"
          min="0"
        />
        <p class="form-help">Lower numbers appear first</p>
      </div>

      {/* Schema Editor */}
      <div class="schema-section">
        <SchemaEditor schema={null} />
      </div>

      {/* Rendering Configuration */}
      <div class="config-section">
        <label class="checkbox-label" style="margin-bottom: 0.75rem;">
          <input type="checkbox" id="is_rendered" name="is_rendered" />
          Uses a renderer component
        </label>
        <p class="form-help" style="margin-bottom: 1rem;">Enable for types rendered by a registered renderer (e.g. page, article). Leave off for types that inject data into layouts or use custom components.</p>
        <details id="rendering-details">
          <summary class="section-heading">Rendering</summary>
          <div class="config-fields">
            <div class="form-group">
              <label for="renderer_name">Renderer Name</label>
              <input type="text" id="renderer_name" placeholder="e.g., page, form, external-embed" />
              <p class="form-help">Identifies the renderer component to use</p>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="renderer_package">Package</label>
                <input type="text" id="renderer_package" placeholder="e.g., @inneropen/marvin-renderers-core" />
              </div>
              <div class="form-group">
                <label for="renderer_version">Version</label>
                <input type="text" id="renderer_version" placeholder="e.g., ^1.0.0" />
              </div>
            </div>
          </div>
        </details>
        <input type="hidden" name="rendering_json" id="rendering_json" />
      </div>

      {/* Capabilities */}
      <div class="config-section">
        <details id="capabilities-details">
          <summary class="section-heading">Capabilities</summary>
          <div class="config-fields">
            <label class="checkbox-label">
              <input type="checkbox" id="cap_publishable" checked />
              Publishable
            </label>
            <label class="checkbox-label">
              <input type="checkbox" id="cap_submittable" />
              Submittable
            </label>
            <label class="checkbox-label">
              <input type="checkbox" id="cap_routable" checked />
              Routable
            </label>
          </div>
        </details>
        <input type="hidden" name="capabilities_json" id="capabilities_json" />
      </div>

      {/* Recipe (authoring) */}
      <div class="config-section">
        <details id="recipe-details">
          <summary class="section-heading">Recipe (authoring)</summary>
          <div class="config-fields">
            <p style="margin:0 0 8px;color:var(--muted);font-size:13px;">
              What to gather &amp; derive to build one — assets contract, resource extraction, enrichment. JSON for now.
            </p>
            <textarea
              name="recipe_json"
              id="recipe_json"
              rows="10"
              spellcheck="false"
              style="width:100%;font-family:ui-monospace,monospace;font-size:13px;line-height:1.5;padding:10px;box-sizing:border-box;border:1px solid var(--line);border-radius:var(--radius);background:var(--bg);color:var(--ink);"
              placeholder={'{\n  "assets": { "min": 1, "roles": [{ "role": "hero", "required": true }] }\n}'}
            ></textarea>
          </div>
        </details>
      </div>

      <div class="form-actions">
        <button type="submit" class="button">Create Entry Type</button>
        <a href="/workspace/entry-types" class="button secondary">Cancel</a>
      </div>
    </form>
  </section>
</AppLayout>

<style>
  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="number"],
  input[type="color"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  input[type="color"] {
    height: 40px;
    cursor: pointer;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .schema-section {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .config-section {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .section-heading {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
    padding: 0.25rem 0;
  }

  .config-fields {
    display: grid;
    gap: 1rem;
    padding-top: 1rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 400;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
</style>

<script>
  function syncRenderingJson() {
    const name = (document.getElementById('renderer_name') as HTMLInputElement).value.trim();
    const pkg = (document.getElementById('renderer_package') as HTMLInputElement).value.trim();
    const version = (document.getElementById('renderer_version') as HTMLInputElement).value.trim();
    const hidden = document.getElementById('rendering_json') as HTMLInputElement;

    if (!name && !pkg && !version) {
      hidden.value = '';
      return;
    }
    hidden.value = JSON.stringify({
      ...(name && { renderer: name }),
      ...(pkg && { package: pkg }),
      ...(version && { version }),
    });
  }

  function syncCapabilitiesJson() {
    const hidden = document.getElementById('capabilities_json') as HTMLInputElement;
    hidden.value = JSON.stringify({
      publishable: (document.getElementById('cap_publishable') as HTMLInputElement).checked,
      submittable: (document.getElementById('cap_submittable') as HTMLInputElement).checked,
      routable: (document.getElementById('cap_routable') as HTMLInputElement).checked,
    });
  }

  document.getElementById('renderer_name')?.addEventListener('input', syncRenderingJson);
  document.getElementById('renderer_package')?.addEventListener('input', syncRenderingJson);
  document.getElementById('renderer_version')?.addEventListener('input', syncRenderingJson);
  document.getElementById('cap_publishable')?.addEventListener('change', syncCapabilitiesJson);
  document.getElementById('cap_submittable')?.addEventListener('change', syncCapabilitiesJson);
  document.getElementById('cap_routable')?.addEventListener('change', syncCapabilitiesJson);

  const isRenderedCheckbox = document.getElementById('is_rendered') as HTMLInputElement;
  const renderingDetails = document.getElementById('rendering-details') as HTMLDetailsElement;
  const capabilitiesDetails = document.getElementById('capabilities-details') as HTMLDetailsElement;

  isRenderedCheckbox?.addEventListener('change', () => {
    if (isRenderedCheckbox.checked) {
      renderingDetails.open = true;
      capabilitiesDetails.open = true;
    } else {
      renderingDetails.open = false;
      capabilitiesDetails.open = false;
    }
  });

  syncCapabilitiesJson();
</script>
