---
import Breadcrumb from "@/components/Breadcrumb.astro";
import SchemaEditor from "@/components/SchemaEditor.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { getEntryType } from "@/lib/api/entryTypes";

const { id } = Astro.params;

let entryType = null;
let error: string | null = null;

if (!id) {
  error = "Entry type ID is required";
} else {
  try {
    const authToken = await getAuthToken(Astro.cookies);
    entryType = await getEntryType(id, authToken);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error("[EntryType] Failed to load:", error);
  }
}

const isSystem = entryType?.isSystem ?? false;

const rendering = (entryType?.renderingJson ?? {}) as Record<string, unknown>;
const capabilities = (entryType?.capabilitiesJson ?? {}) as Record<string, unknown>;
const recipe = (entryType?.recipeJson ?? {}) as Record<string, unknown>;
// The authoring instructions get their own prose box; the JSON textarea holds the structured contract.
const recipeInstructions = typeof recipe.instructions === "string" ? recipe.instructions : "";
const { instructions: _omitInstructions, ...recipeStructured } = recipe;
const recipeStr = Object.keys(recipeStructured).length ? JSON.stringify(recipeStructured, null, 2) : "";
---

<AppLayout
  title={entryType ? `Edit ${entryType.name}` : "Edit Entry Type"}
  entityType="entry_type"
  entityId={id}
  entityLabel={entryType?.name}
>
  <Breadcrumb items={[
    { label: "Workspace Settings", href: "/workspace/settings?tab=entry-types" },
    { label: "Entry Types", href: "/workspace/entry-types" },
    { label: entryType?.name || "Edit" }
  ]} />

  {error ? (
    <div class="error-banner">
      <p><strong>Error loading entry type:</strong> {error}</p>
      <a href="/workspace/entry-types" class="button secondary">Back to Entry Types</a>
    </div>
  ) : entryType ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Entry Type</h2>
          <p style="margin:4px 0 0;color:var(--muted);">
            {isSystem ? "System entry types have limited editing" : "Update entry type details"}
          </p>
        </div>
        <a class="button secondary" href="/workspace/entry-types">Back</a>
      </div>

      <section class="form-section">
        <form method="POST" action={`/api/entry-types/${id}/update`} class="form">
          <div class="form-group">
            <label for="name">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={entryType.name}
              disabled={isSystem}
            />
            <p class="form-help">{isSystem ? 'System entry type name cannot be changed' : 'Display name for this entry type'}</p>
          </div>

          <div class="form-group">
            <label>Slug</label>
            <input
              type="text"
              id="slug"
              value={entryType.slug}
              disabled
              style="background: var(--panel-2); color: var(--muted);"
            />
            <p class="form-help" style="font-size: 12px; color: var(--muted);">Slug is fixed once created to avoid breaking references</p>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="icon">Icon</label>
              <input
                type="text"
                id="icon"
                name="icon"
                value={entryType.icon || ""}
                maxlength="4"
              />
              <p class="form-help">Emoji or symbol</p>
            </div>

            <div class="form-group">
              <label for="color">Color</label>
              <input
                type="color"
                id="color"
                name="color"
                value={entryType.color || "#a94d3f"}
              />
              <p class="form-help">Theme color</p>
            </div>
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              rows="3"
            >{entryType.description || ""}</textarea>
          </div>

          <div class="form-group">
            <label for="sort_order">Sort Order</label>
            <input
              type="number"
              id="sort_order"
              name="sort_order"
              value={entryType.sortOrder}
              min="0"
            />
            <p class="form-help">Lower numbers appear first</p>
          </div>

          {/* Schema Editor */}
          <div class="schema-section">
            <SchemaEditor schema={entryType.schemaJson} />
          </div>

          {/* Rendering Configuration */}
          <div class="config-section">
            <label class="checkbox-label" style="margin-bottom: 0.75rem;">
              <input type="checkbox" id="is_rendered" name="is_rendered" checked={entryType.isRendered} />
              Uses a renderer component
            </label>
            <p class="form-help" style="margin-bottom: 1rem;">Enable for types rendered by a registered renderer (e.g. page, article). Leave off for types that inject data into layouts or use custom components.</p>
            <details id="rendering-details" open={!!rendering.renderer}>
              <summary class="section-heading">Rendering</summary>
              <div class="config-fields">
                <div class="form-group">
                  <label for="renderer_name">Renderer Name</label>
                  <input type="text" id="renderer_name" value={String(rendering.renderer || '')} placeholder="e.g., page, form, external-embed" />
                  <p class="form-help">Identifies the renderer component to use</p>
                </div>
                <div class="form-row">
                  <div class="form-group">
                    <label for="renderer_package">Package</label>
                    <input type="text" id="renderer_package" value={String(rendering.package || '')} placeholder="e.g., @inneropen/marvin-renderers-core" />
                  </div>
                  <div class="form-group">
                    <label for="renderer_version">Version</label>
                    <input type="text" id="renderer_version" value={String(rendering.version || '')} placeholder="e.g., ^1.0.0" />
                  </div>
                </div>
              </div>
            </details>
            <input type="hidden" name="rendering_json" id="rendering_json" />
          </div>

          {/* Capabilities */}
          <div class="config-section">
            <details id="capabilities-details" open={Object.keys(capabilities).length > 0}>
              <summary class="section-heading">Capabilities</summary>
              <div class="config-fields">
                <label class="checkbox-label">
                  <input type="checkbox" id="cap_publishable" checked={capabilities.publishable !== false} />
                  Publishable
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" id="cap_submittable" checked={capabilities.submittable === true} />
                  Submittable
                </label>
                <label class="checkbox-label">
                  <input type="checkbox" id="cap_routable" checked={capabilities.routable !== false} />
                  Routable
                </label>
              </div>
            </details>
            <input type="hidden" name="capabilities_json" id="capabilities_json" />
          </div>

          {/* Recipe (authoring) */}
          <div class="config-section">
            <details id="recipe-details" open={Object.keys(recipe).length > 0}>
              <summary class="section-heading">Recipe (authoring)</summary>
              <div class="config-fields">
                <label for="recipe_instructions" style="display:block;font-weight:600;margin:0 0 4px;">Authoring instructions</label>
                <p style="margin:0 0 6px;color:var(--muted);font-size:13px;">
                  Plain-language directions the AI follows when composing this type. e.g. "A short
                  navigation page. No images. One-line blurb linking to a URL."
                </p>
                <textarea
                  id="recipe_instructions"
                  rows="4"
                  placeholder="Describe how to author this type…"
                  style="width:100%;font-size:14px;line-height:1.5;padding:10px;box-sizing:border-box;border:1px solid var(--line);border-radius:var(--radius);background:var(--bg);color:var(--ink);margin-bottom:14px;"
                >{recipeInstructions}</textarea>

                <label for="recipe_json" style="display:block;font-weight:600;margin:0 0 4px;">Structured contract</label>
                <p style="margin:0 0 8px;color:var(--muted);font-size:13px;">
                  What to gather &amp; derive — assets contract (min/max + roles like hero/gallery, with
                  derive), resource extraction, enrichment. JSON for now.
                </p>
                <textarea
                  name="recipe_json"
                  id="recipe_json"
                  rows="12"
                  spellcheck="false"
                  style="width:100%;font-family:ui-monospace,monospace;font-size:13px;line-height:1.5;padding:10px;box-sizing:border-box;border:1px solid var(--line);border-radius:var(--radius);background:var(--bg);color:var(--ink);"
                  placeholder={'{\n  "assets": { "min": 1, "max": 4, "roles": [{ "role": "hero", "required": true, "derive": ["thumbnail", "palette"] }] },\n  "resources": { "extract": [{ "type": "supplier", "source": "body", "capture": ["name", "url"] }] }\n}'}
                >{recipeStr}</textarea>
              </div>
            </details>
          </div>

          {isSystem && (
            <div class="notice">
              <strong>⚠️ System Entry Type</strong>
              <p>Name and slug cannot be changed for system entry types. Only visual properties can be updated.</p>
            </div>
          )}

          <div class="form-actions">
            <button type="submit" class="button">Save Changes</button>
            <a href="/workspace/entry-types" class="button secondary">Cancel</a>
          </div>
        </form>
      </section>
    </>
  ) : null}
</AppLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="number"],
  input[type="color"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  input[type="color"] {
    height: 40px;
    cursor: pointer;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .schema-section {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .notice {
    padding: 1rem;
    background: rgb(169 99 47 / 0.1);
    border: 1px solid var(--warn);
    border-radius: 6px;
  }

  .notice strong {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--warn);
  }

  .notice p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .config-section {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .section-heading {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
    cursor: pointer;
    user-select: none;
    padding: 0.25rem 0;
  }

  .config-fields {
    display: grid;
    gap: 1rem;
    padding-top: 1rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 400;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
</style>

<script>
  function syncRenderingJson() {
    const name = (document.getElementById('renderer_name') as HTMLInputElement)?.value.trim();
    const pkg = (document.getElementById('renderer_package') as HTMLInputElement)?.value.trim();
    const version = (document.getElementById('renderer_version') as HTMLInputElement)?.value.trim();
    const hidden = document.getElementById('rendering_json') as HTMLInputElement;

    if (!name && !pkg && !version) {
      hidden.value = '';
      return;
    }
    hidden.value = JSON.stringify({
      ...(name && { renderer: name }),
      ...(pkg && { package: pkg }),
      ...(version && { version }),
    });
  }

  function syncCapabilitiesJson() {
    const hidden = document.getElementById('capabilities_json') as HTMLInputElement;
    hidden.value = JSON.stringify({
      publishable: (document.getElementById('cap_publishable') as HTMLInputElement).checked,
      submittable: (document.getElementById('cap_submittable') as HTMLInputElement).checked,
      routable: (document.getElementById('cap_routable') as HTMLInputElement).checked,
    });
  }

  // Fold the prose Instructions box back into recipe_json on save (it's edited separately so authors
  // don't have to hand-write the "instructions" key inside the JSON).
  function syncRecipeJson() {
    const instr = (document.getElementById('recipe_instructions') as HTMLTextAreaElement)?.value.trim() ?? '';
    const jsonEl = document.getElementById('recipe_json') as HTMLTextAreaElement;
    const raw = jsonEl.value.trim();
    let obj: Record<string, unknown> = {};
    if (raw) {
      try { obj = JSON.parse(raw); }
      catch { return; }  // invalid structured JSON — let the server reject it rather than silently drop it
    }
    if (instr) obj.instructions = instr; else delete obj.instructions;
    jsonEl.value = Object.keys(obj).length ? JSON.stringify(obj, null, 2) : '';
  }
  document.querySelector('form[action*="/update"]')?.addEventListener('submit', syncRecipeJson);

  document.getElementById('renderer_name')?.addEventListener('input', syncRenderingJson);
  document.getElementById('renderer_package')?.addEventListener('input', syncRenderingJson);
  document.getElementById('renderer_version')?.addEventListener('input', syncRenderingJson);
  document.getElementById('cap_publishable')?.addEventListener('change', syncCapabilitiesJson);
  document.getElementById('cap_submittable')?.addEventListener('change', syncCapabilitiesJson);
  document.getElementById('cap_routable')?.addEventListener('change', syncCapabilitiesJson);

  const isRenderedCheckbox = document.getElementById('is_rendered') as HTMLInputElement;
  const renderingDetails = document.getElementById('rendering-details') as HTMLDetailsElement;
  const capabilitiesDetails = document.getElementById('capabilities-details') as HTMLDetailsElement;

  isRenderedCheckbox?.addEventListener('change', () => {
    if (isRenderedCheckbox.checked) {
      renderingDetails.open = true;
      capabilitiesDetails.open = true;
    } else {
      renderingDetails.open = false;
      capabilitiesDetails.open = false;
    }
  });

  syncRenderingJson();
  syncCapabilitiesJson();
</script>

<script>
  // Auto-generate slug preview from name (if not system type)
  const nameInput = document.getElementById('name') as HTMLInputElement | null;
  const slugInput = document.getElementById('slug') as HTMLInputElement | null;

  if (nameInput && slugInput && !nameInput.disabled) {
    nameInput.addEventListener('input', () => {
      const slug = nameInput.value
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
      slugInput.value = slug;
    });
  }
</script>
