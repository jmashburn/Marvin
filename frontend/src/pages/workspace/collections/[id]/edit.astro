---
import EmojiPicker from "@/components/EmojiPicker.astro";
import SmartCollectionFields from "@/components/SmartCollectionFields.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { getCollection, getCollectionEntries } from "@/lib/api/collections";
import type { CollectionRead, EntryRead } from "@/lib/api/entries";
import { listEntries } from "@/lib/api/entries";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

let collection: CollectionRead | null = null;
let allEntries: EntryRead[] = [];
let collectionEntries: EntryRead[] = [];
let error: string | null = null;

if (!authToken) {
  error = "Authentication required";
} else if (!id) {
  error = "Collection ID is required";
} else {
  try {
    [collection, allEntries, collectionEntries] = await Promise.all([
      getCollection(id, authToken),
      listEntries(authToken),
      getCollectionEntries(id, authToken),
    ]);

    // Sort collection entries by order field (already sorted by API, but ensure it)
    collectionEntries.sort((a, b) => (a.order ?? 999) - (b.order ?? 999));
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error("[Collection] Failed to load:", error);
  }
}
---

<AppLayout
  title={collection ? `Edit ${collection.name}` : "Edit Collection"}
  entityType="collection"
  entityId={id}
  entityLabel={collection?.name}
>
  <div id="delete-error" class="error-banner" style="margin-bottom:1rem;display:none;"></div>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading collection:</strong> {error}</p>
      <a href="/workspace/collections" class="button secondary">Back to Collections</a>
    </div>
  ) : collection ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Collection</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Update collection details and manage entries</p>
        </div>
        <a class="button secondary" href={`/workspace/collections/${id}`}>Back</a>
      </div>

      <section class="form-section">
        <form id="collection-form" class="form">
          <div class="form-group">
            <label for="name">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={collection.name}
            />
            <p class="form-help">Slug will be auto-generated from the name</p>
          </div>

          <div class="form-group">
            <label>Slug</label>
            <input
              type="text"
              value={collection.slug}
              disabled
              style="background: var(--panel-2); color: var(--muted);"
            />
            <p class="form-help" style="font-size: 12px; color: var(--muted);">Auto-generated from name</p>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="icon">Icon</label>
              <EmojiPicker inputId="icon" value={collection.icon || ""} />
              <p class="form-help">Emoji or symbol</p>
            </div>

            <div class="form-group">
              <label for="color">Color</label>
              <input
                type="color"
                id="color"
                name="color"
                value={collection.color || "#a94d3f"}
              />
              <p class="form-help">Theme color</p>
            </div>
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              rows="3"
            >{collection.description || ""}</textarea>
          </div>

          <div class="form-group">
            <label for="sort_order">Sort Order</label>
            <input
              type="number"
              id="sort_order"
              name="sort_order"
              value={collection.sortOrder}
              min="0"
            />
            <p class="form-help">Lower numbers appear first</p>
          </div>

          <SmartCollectionFields checked={collection.isSmart === true} rules={collection.smartRules} targetType={(collection as any).targetType ?? 'entry'} />

          <div class="form-group">
            <label for="metadata">Metadata (JSON)</label>
            <textarea
              id="metadata"
              name="metadata"
              rows="6"
              placeholder='&#123;"featured": true, "priority": 1&#125;'
              class="metadata-editor"
            >{collection.metadataJson ? JSON.stringify(collection.metadataJson, null, 2) : ''}</textarea>
            <p class="form-help">Custom metadata as JSON. Example: &#123;"featured": true, "priority": 1&#125;</p>

            {collection.metadataJson && Object.keys(collection.metadataJson).length > 0 && (
              <div class="metadata-preview">
                <p class="metadata-preview-title">Current Metadata:</p>
                <dl class="metadata-preview-list">
                  {Object.entries(collection.metadataJson).map(([key, value]) => (
                    <div class="metadata-preview-item">
                      <dt>{key}</dt>
                      <dd>{typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value)}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
          </div>

          <div class="form-actions">
            <button type="submit" class="button">Save Changes</button>
            <a href="/workspace/collections" class="button secondary">Cancel</a>
          </div>
        </form>

        <form method="POST" action={`/api/collections/${id}/delete`} style="margin-top:2rem;">
          <button type="submit" class="button secondary danger" onclick="return confirm('Delete this collection? This cannot be undone.')">
            Delete Collection
          </button>
        </form>
      </section>

      <section class="entries-section">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
          <h3 style="margin:0;font-size:1.125rem;">Entries (<span id="entry-count">{collectionEntries.length}</span>)</h3>
          <button id="save-entries-btn" class="button small" style="display:none;">Save Changes</button>
        </div>

        <div id="attached-entries" class="attached-list">
          {collectionEntries.map((entry, idx) => {
            const junction = (entry.collections || []).find((c: any) => c.id === id);
            return (
              <div class="attachment-card" data-entry-id={entry.id} data-entry-title={entry.title} data-entry-status={entry.status}>
                <div class="attachment-header">
                  <div class="drag-handle" draggable="true">⋮⋮</div>
                  <div class="sortable-order">{idx + 1}</div>
                  <div class="attachment-name">
                    <strong>{entry.title}</strong>
                    <span class="picker-meta">
                      <span class={`pill ${entry.status}`}>{entry.status}</span>
                    </span>
                  </div>
                  <div class="attachment-actions">
                    <button type="button" class="move-up-btn icon-btn" title="Move up">↑</button>
                    <button type="button" class="move-down-btn icon-btn" title="Move down">↓</button>
                    <button type="button" class="remove-btn icon-btn" title="Remove">×</button>
                  </div>
                </div>
                <div class="attachment-fields">
                  <div class="field-row">
                    <label>Role</label>
                    <input type="text" class="junction-role" value={junction?.role || ''} placeholder="e.g. primary, featured" />
                  </div>
                  <div class="field-row field-row-full">
                    <label>Metadata</label>
                    <textarea class="junction-metadata attachment-metadata" rows="2" placeholder='{"featured": true}'>{junction?.placementMetadata ? JSON.stringify(junction.placementMetadata, null, 2) : ''}</textarea>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <details class="add-picker">
          <summary>Add Entry</summary>
          <div class="add-picker-panel">
            <div class="picker-search">
              <input type="search" id="entry-search" placeholder="Search entries..." />
            </div>
            <div class="picker-list">
              {allEntries.filter(e => !collectionEntries.some(ce => ce.id === e.id)).map((entry) => (
                <div class="attachment-card add-entry-item" data-entry-id={entry.id} data-entry-title={entry.title} data-entry-status={entry.status}>
                  <div class="attachment-header">
                    <div class="attachment-name">
                      <strong>{entry.title}</strong>
                      <span class="picker-meta">
                        <span class={`pill ${entry.status}`}>{entry.status}</span>
                        {entry.entryType && <span> &bull; {entry.entryType.name}</span>}
                      </span>
                    </div>
                    <div class="attachment-actions">
                      <button type="button" class="add-btn icon-btn" title="Add">+</button>
                    </div>
                  </div>
                </div>
              ))}
              {allEntries.length === 0 && (
                <p class="empty-message">No entries available. <a href="/workspace/entries/new">Create one</a>.</p>
              )}
            </div>
          </div>
        </details>
      </section>
    </>
  ) : null}
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';

  const sdk = createSdkClient();

  // Intercept the delete submit so a failed delete (e.g. 409 — collection still in
  // use by entries) shows an inline banner instead of navigating to the /delete
  // endpoint and rendering raw JSON. The button's onclick confirm() already gated it.
  document.addEventListener('submit', async (e) => {
    const formEl = e.target as HTMLFormElement;
    if (!(formEl instanceof HTMLFormElement)) return;
    if (!/\/api\/collections\/[^/]+\/delete$/.test(formEl.getAttribute('action') || '')) return;

    e.preventDefault();
    const res = await fetch(formEl.action, { method: 'POST' });
    if (res.ok) {
      window.location.href = '/workspace/collections';
      return;
    }

    let msg = 'Failed to delete collection';
    try {
      const data = await res.json();
      if (data?.error) msg = data.error;
    } catch {
      // keep the generic message
    }
    const banner = document.getElementById('delete-error');
    if (banner) {
      banner.innerHTML = `<p><strong>Couldn't delete collection:</strong> ${msg}</p>`;
      banner.style.display = 'flex';
      banner.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  const form = document.getElementById('collection-form') as HTMLFormElement;
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  // Smart-collection field toggling lives in the SmartCollectionFields component.

  // Handle form submission via SDK
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const icon = formData.get('icon') as string;
      const color = formData.get('color') as string;
      const description = formData.get('description') as string;
      const sortOrder = formData.get('sort_order') as string;
      const isSmart = formData.get('is_smart') === 'true';
      const targetType = (formData.get('target_type') as string) || 'entry';
      const smartRulesStr = formData.get('smartRules') as string;
      const metadataStr = formData.get('metadata') as string;

      let smartRules = null;
      if (isSmart && smartRulesStr?.trim()) {
        try {
          smartRules = JSON.parse(smartRulesStr);
        } catch (error) {
          alert('Invalid JSON in Smart Rules field');
          return;
        }
      }

      let metadataJson = null;
      if (metadataStr?.trim()) {
        try {
          metadataJson = JSON.parse(metadataStr);
        } catch (error) {
          alert('Invalid JSON in Metadata field');
          return;
        }
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Saving...';

      try {
        const collectionId = window.location.pathname.split('/').filter(Boolean).slice(-2)[0]!;
        await sdk.collections.update(collectionId, {
          name,
          icon: icon?.trim() || null,
          color: color || null,
          description: description?.trim() || null,
          sortOrder: sortOrder ? parseInt(sortOrder) : 0,
          isSmart,
          targetType,
          smartRules: smartRules,
          metadataJson: metadataJson,
        });

        window.location.href = '/workspace/collections';
      } catch (error: any) {
        const message = error?.message || error?.detail || 'Failed to update collection';
        alert(message);
        submitButton.disabled = false;
        submitButton.textContent = 'Save Changes';
      }
    });
  }

  // Metadata preview update
  const metadataEditor = document.getElementById('metadata') as HTMLTextAreaElement;
  const metadataPreviewContainer = metadataEditor?.closest('.form-group')?.querySelector('.metadata-preview');

  if (metadataEditor) {
    metadataEditor.addEventListener('input', () => {
      const value = metadataEditor.value.trim();

      if (!value) {
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
        return;
      }

      try {
        const parsed = JSON.parse(value);
        const entries = Object.entries(parsed);

        if (entries.length === 0) {
          if (metadataPreviewContainer) {
            metadataPreviewContainer.remove();
          }
          return;
        }

        let previewHTML = `
          <div class="metadata-preview">
            <p class="metadata-preview-title">Current Metadata:</p>
            <dl class="metadata-preview-list">
        `;

        entries.forEach(([key, value]) => {
          const displayValue = typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value);
          previewHTML += `
            <div class="metadata-preview-item">
              <dt>${key}</dt>
              <dd>${displayValue}</dd>
            </div>
          `;
        });

        previewHTML += `</dl></div>`;

        if (metadataPreviewContainer) {
          metadataPreviewContainer.outerHTML = previewHTML;
        } else {
          const helpText = metadataEditor.closest('.form-group')?.querySelector('.form-help');
          if (helpText) {
            helpText.insertAdjacentHTML('afterend', previewHTML);
          }
        }
      } catch (error) {
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
      }
    });
  }

  // --- Entry attachment card management ---
  const collectionId = window.location.pathname.split('/').filter(Boolean).slice(-2)[0]!;
  const entriesContainer = document.getElementById('attached-entries') as HTMLElement;
  const saveEntriesBtn = document.getElementById('save-entries-btn') as HTMLButtonElement;
  let draggedCard: HTMLElement | null = null;
  let entriesDirty = false;

  function markDirty() {
    entriesDirty = true;
    if (saveEntriesBtn) saveEntriesBtn.style.display = 'inline-block';
  }

  function updateEntryOrderNumbers() {
    entriesContainer?.querySelectorAll('.attachment-card').forEach((card, index) => {
      const orderEl = card.querySelector('.sortable-order');
      if (orderEl) orderEl.textContent = String(index + 1);
    });
  }

  function updateEntryCount() {
    const countEl = document.getElementById('entry-count');
    if (countEl) countEl.textContent = String(entriesContainer?.querySelectorAll('.attachment-card').length ?? 0);
  }

  function setupEntryCard(card: HTMLElement) {
    card.querySelector('.remove-btn')?.addEventListener('click', async () => {
      const entryId = card.dataset.entryId!;

      card.style.opacity = '0.5';
      try {
        const entry = await sdk.entries.get(entryId);
        const currentIds = (entry.collections || []).map((c: any) => typeof c === 'string' ? c : c.id);
        const updatedIds = currentIds.filter((cid: string) => cid !== collectionId);
        await sdk.entries.update(entryId, { collection_ids: updatedIds });
      } catch (error: any) {
        alert(error?.message || 'Failed to remove entry');
        card.style.opacity = '1';
        return;
      }

      card.remove();
      updateEntryOrderNumbers();
      updateEntryCount();

      const pickerItem = document.querySelector(`.add-entry-item[data-entry-id="${entryId}"]`) as HTMLElement;
      if (pickerItem) pickerItem.style.display = '';
    });

    card.querySelector('.move-up-btn')?.addEventListener('click', () => {
      const prev = card.previousElementSibling;
      if (prev) entriesContainer.insertBefore(card, prev);
      updateEntryOrderNumbers();
      markDirty();
    });

    card.querySelector('.move-down-btn')?.addEventListener('click', () => {
      const next = card.nextElementSibling;
      if (next) entriesContainer.insertBefore(next, card);
      updateEntryOrderNumbers();
      markDirty();
    });

    // Mark dirty on field changes
    card.querySelector('.junction-role')?.addEventListener('input', markDirty);
    card.querySelector('.junction-metadata')?.addEventListener('input', markDirty);

    // Drag and drop on the handle
    const handle = card.querySelector('.drag-handle') as HTMLElement;
    if (handle) {
      handle.addEventListener('dragstart', (e) => {
        draggedCard = card;
        card.classList.add('dragging');
        (e as DragEvent).dataTransfer!.effectAllowed = 'move';
      });

      handle.addEventListener('dragend', () => {
        card.classList.remove('dragging');
        draggedCard = null;
      });
    }

    card.addEventListener('dragover', (e) => {
      e.preventDefault();
      (e as DragEvent).dataTransfer!.dropEffect = 'move';
      if (draggedCard && draggedCard !== card) {
        const bounding = card.getBoundingClientRect();
        const offset = (e as DragEvent).clientY - bounding.top;
        if (offset > bounding.height / 2) {
          card.parentNode!.insertBefore(draggedCard, card.nextSibling);
        } else {
          card.parentNode!.insertBefore(draggedCard, card);
        }
        updateEntryOrderNumbers();
        markDirty();
      }
    });
  }

  // Initialize existing cards
  if (entriesContainer) {
    entriesContainer.querySelectorAll('.attachment-card').forEach(card => {
      setupEntryCard(card as HTMLElement);
    });
  }

  // Add entry from picker
  document.querySelectorAll('.add-entry-item').forEach(item => {
    const addBtn = item.querySelector('.add-btn');
    if (!addBtn) return;
    addBtn.addEventListener('click', async () => {
      const el = item as HTMLElement;
      const entryId = el.dataset.entryId!;
      const title = el.dataset.entryTitle!;
      const entryStatus = el.dataset.entryStatus || 'draft';

      // Add to collection via SDK first
      el.style.opacity = '0.5';
      try {
        const entry = await sdk.entries.get(entryId);
        const currentIds = (entry.collections || []).map((c: any) => typeof c === 'string' ? c : c.id);
        if (!currentIds.includes(collectionId)) {
          await sdk.entries.update(entryId, {
            collection_ids: [...currentIds, collectionId]
          });
        }
      } catch (error: any) {
        alert(error?.message || 'Failed to add entry');
        el.style.opacity = '1';
        return;
      }

      const idx = entriesContainer.querySelectorAll('.attachment-card').length;

      const card = document.createElement('div');
      card.className = 'attachment-card';
      card.dataset.entryId = entryId;
      card.dataset.entryTitle = title;
      card.dataset.entryStatus = entryStatus;
      card.innerHTML = `
        <div class="attachment-header">
          <div class="drag-handle" draggable="true">⋮⋮</div>
          <div class="sortable-order">${idx + 1}</div>
          <div class="attachment-name">
            <strong>${title}</strong>
            <span class="picker-meta">
              <span class="pill ${entryStatus}">${entryStatus}</span>
            </span>
          </div>
          <div class="attachment-actions">
            <button type="button" class="move-up-btn icon-btn" title="Move up">↑</button>
            <button type="button" class="move-down-btn icon-btn" title="Move down">↓</button>
            <button type="button" class="remove-btn icon-btn" title="Remove">×</button>
          </div>
        </div>
        <div class="attachment-fields">
          <div class="field-row">
            <label>Role</label>
            <input type="text" class="junction-role" value="" placeholder="e.g. primary, featured" />
          </div>
          <div class="field-row field-row-full">
            <label>Metadata</label>
            <textarea class="junction-metadata attachment-metadata" rows="2" placeholder='{"featured": true}'></textarea>
          </div>
        </div>
      `;

      entriesContainer.appendChild(card);
      setupEntryCard(card);
      updateEntryCount();
      el.style.display = 'none';
    });
  });

  // Entry search filter for add picker
  const entrySearch = document.getElementById('entry-search') as HTMLInputElement;
  if (entrySearch) {
    entrySearch.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      document.querySelectorAll('.add-entry-item').forEach(item => {
        const text = item.textContent?.toLowerCase() || '';
        const el = item as HTMLElement;
        // Only filter visible items (not already added)
        if (el.style.display !== 'none') {
          el.style.display = text.includes(query) ? '' : 'none';
        }
      });
    });
  }

  // Save all entry changes (junction updates + reorder)
  if (saveEntriesBtn) {
    saveEntriesBtn.addEventListener('click', async () => {
      const cards = entriesContainer?.querySelectorAll('.attachment-card');
      if (!cards || cards.length === 0) return;

      saveEntriesBtn.disabled = true;
      saveEntriesBtn.textContent = 'Saving...';

      try {
        const orderEntries: Array<{ entryId: string; sortOrder: number }> = [];

        for (const [index, card] of Array.from(cards).entries()) {
          const el = card as HTMLElement;
          const entryId = el.dataset.entryId!;
          const role = (el.querySelector('.junction-role') as HTMLInputElement)?.value?.trim() || null;
          const metadataStr = (el.querySelector('.junction-metadata') as HTMLTextAreaElement)?.value?.trim() || '';

          let metadataJson: Record<string, unknown> | null = null;
          if (metadataStr) {
            try {
              metadataJson = JSON.parse(metadataStr);
            } catch {
              alert(`Invalid JSON in metadata for "${el.dataset.entryTitle}"`);
              saveEntriesBtn.disabled = false;
              saveEntriesBtn.textContent = 'Save Changes';
              return;
            }
          }

          await sdk.collections.updateEntryJunction(collectionId, entryId, {
            role,
            metadataJson,
          });

          orderEntries.push({ entryId, sortOrder: index });
        }

        await sdk.collections.reorderEntries(collectionId, orderEntries);

        saveEntriesBtn.textContent = 'Saved';
        saveEntriesBtn.style.display = 'none';
        entriesDirty = false;

        setTimeout(() => {
          saveEntriesBtn.textContent = 'Save Changes';
          saveEntriesBtn.disabled = false;
        }, 2000);
      } catch (error: any) {
        alert(error?.message || 'Failed to save entry changes');
        saveEntriesBtn.disabled = false;
        saveEntriesBtn.textContent = 'Save Changes';
      }
    });
  }
</script>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="number"],
  input[type="color"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  input[type="color"] {
    height: 40px;
    cursor: pointer;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .entries-section {
    margin-top: 2rem;
  }

  .section-help {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .picker-meta {
    font-size: 0.75rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pill {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .pill.published {
    background: rgba(34, 197, 94, 0.1);
    color: rgb(34, 197, 94);
  }

  .pill.draft {
    background: rgba(156, 163, 175, 0.1);
    color: rgb(107, 114, 128);
  }

  .empty-message {
    text-align: center;
    color: var(--muted);
    padding: 2rem;
  }

  .button.small {
    min-height: 32px;
    padding: 6px 10px;
    font-size: 0.875rem;
  }

  .metadata-preview {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--panel-2);
    border-radius: 6px;
  }

