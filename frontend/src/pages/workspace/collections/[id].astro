---
import AppLayout from "@/layouts/AppLayout.astro";
import EmojiPicker from "@/components/EmojiPicker.astro";
import { getAuthToken } from "@/lib/api/client";
import { getCollection, getCollectionEntries } from "@/lib/api/collections";
import { listEntries } from "@/lib/api/entries";
import type { EntryRead, CollectionRead } from "@/lib/api/entries";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

let collection: CollectionRead | null = null;
let allEntries: EntryRead[] = [];
let collectionEntries: EntryRead[] = [];
let error: string | null = null;

if (!authToken) {
  error = "Authentication required";
} else if (!id) {
  error = "Collection ID is required";
} else {
  try {
    [collection, allEntries, collectionEntries] = await Promise.all([
      getCollection(id, authToken),
      listEntries(authToken),
      getCollectionEntries(id, authToken),
    ]);

    // Sort collection entries by order field (already sorted by API, but ensure it)
    collectionEntries.sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[Collection] Failed to load:', error);
  }
}
---

<AppLayout title={collection ? `Edit ${collection.name}` : "Edit Collection"}>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading collection:</strong> {error}</p>
      <a href="/workspace/collections" class="button secondary">Back to Collections</a>
    </div>
  ) : collection ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Collection</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Update collection details and manage entries</p>
        </div>
        <a class="button secondary" href="/workspace/collections">Back</a>
      </div>

      <section class="form-section">
        <form id="collection-form" class="form">
          <div class="form-group">
            <label for="name">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={collection.name}
            />
            <p class="form-help">Slug will be auto-generated from the name</p>
          </div>

          <div class="form-group">
            <label>Slug</label>
            <input
              type="text"
              value={collection.slug}
              disabled
              style="background: var(--panel-2); color: var(--muted);"
            />
            <p class="form-help" style="font-size: 12px; color: var(--muted);">Auto-generated from name</p>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="icon">Icon</label>
              <EmojiPicker inputId="icon" value={collection.icon || ""} />
              <p class="form-help">Emoji or symbol</p>
            </div>

            <div class="form-group">
              <label for="color">Color</label>
              <input
                type="color"
                id="color"
                name="color"
                value={collection.color || "#a94d3f"}
              />
              <p class="form-help">Theme color</p>
            </div>
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              rows="3"
            >{collection.description || ""}</textarea>
          </div>

          <div class="form-group">
            <label for="sort_order">Sort Order</label>
            <input
              type="number"
              id="sort_order"
              name="sort_order"
              value={collection.sortOrder}
              min="0"
            />
            <p class="form-help">Lower numbers appear first</p>
          </div>

          <div class="form-group">
            <label>
              <input
                type="checkbox"
                name="is_smart"
                id="is_smart"
                value="true"
                checked={collection.isSmart === true}
              />
              Smart Collection
            </label>
            <p class="form-help">Smart collections automatically populate based on query criteria</p>
          </div>

          <div class="form-group" id="query-field" style={collection.isSmart ? '' : 'display: none;'}>
            <label for="smartRules">Smart Rules (JSON)</label>
            <textarea
              id="smartRules"
              name="smartRules"
              rows="8"
              placeholder='&#123;"type": "blog", "status": "published"&#125;'
            >{collection.smartRules ? JSON.stringify(collection.smartRules, null, 2) : ''}</textarea>
            <p class="form-help">JSON rules for filtering entries. Example: &#123;"type": "blog", "status": "published"&#125;</p>
          </div>

          <div class="form-group">
            <label for="metadata">Metadata (JSON)</label>
            <textarea
              id="metadata"
              name="metadata"
              rows="6"
              placeholder='&#123;"featured": true, "priority": 1&#125;'
              class="metadata-editor"
            >{collection.metadataJson ? JSON.stringify(collection.metadataJson, null, 2) : ''}</textarea>
            <p class="form-help">Custom metadata as JSON. Example: &#123;"featured": true, "priority": 1&#125;</p>

            {collection.metadataJson && Object.keys(collection.metadataJson).length > 0 && (
              <div class="metadata-preview">
                <p class="metadata-preview-title">Current Metadata:</p>
                <dl class="metadata-preview-list">
                  {Object.entries(collection.metadataJson).map(([key, value]) => (
                    <div class="metadata-preview-item">
                      <dt>{key}</dt>
                      <dd>{typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value)}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
          </div>

          <div class="form-actions">
            <button type="submit" class="button">Save Changes</button>
            <a href="/workspace/collections" class="button secondary">Cancel</a>
          </div>
        </form>

        <form method="POST" action={`/api/collections/${id}/delete`} style="margin-top:2rem;">
          <button type="submit" class="button secondary danger" onclick="return confirm('Delete this collection? This cannot be undone.')">
            Delete Collection
          </button>
        </form>
      </section>

      <section class="entries-section">
        <h3 style="margin:0 0 1rem;font-size:1.125rem;">Collection Entries ({collectionEntries.length})</h3>

        {collectionEntries.length > 0 && (
          <div class="order-section">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem;">
              <p class="section-help" style="margin:0;">Drag to reorder entries</p>
              <button id="save-order-btn" class="button small" style="display:none;">Save Order</button>
            </div>
            <div id="sortable-entries" class="sortable-list">
              {collectionEntries.map((entry, index) => (
                <div class="sortable-item" data-entry-id={entry.id} data-order={entry.order ?? index} draggable="true">
                  <div class="drag-handle">⋮⋮</div>
                  <div class="sortable-content">
                    <div class="sortable-order">{(entry.order ?? index) + 1}</div>
                    <div class="sortable-info">
                      <strong>{entry.title}</strong>
                      <span class="sortable-meta">
                        <span class={`pill ${entry.status}`}>{entry.status}</span>
                      </span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <h4 style="margin:2rem 0 1rem;font-size:1rem;">Add/Remove Entries</h4>
        <p class="section-help">Select entries to include in this collection</p>

        <div class="picker-search">
          <input
            type="search"
            id="entry-search"
            placeholder="Search entries..."
          />
        </div>

        <div class="picker-list">
          {allEntries.map((entry) => {
            const isInCollection = collectionEntries.some(ce => ce.id === entry.id);
            return (
              <label class="picker-item entry-picker-item">
                <input
                  type="checkbox"
                  class="entry-checkbox"
                  value={entry.id}
                  checked={isInCollection}
                  data-entry-id={entry.id}
                  data-entry-title={entry.title}
                />
                <div class="picker-info">
                  <strong>{entry.title}</strong>
                  <span class="picker-meta">
                    <span class={`pill ${entry.status}`}>{entry.status}</span>
                    {entry.entryType && ` • ${entry.entryType.name}`}
                  </span>
                </div>
              </label>
            );
          })}
          {allEntries.length === 0 && (
            <p class="empty-message">No entries available. <a href="/workspace/entries/new">Create one</a>.</p>
          )}
        </div>
      </section>
    </>
  ) : null}
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';

  const sdk = createSdkClient();
  const form = document.getElementById('collection-form') as HTMLFormElement;
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;

  // Toggle query field visibility based on smart collection checkbox
  const smartCheckbox = document.getElementById('is_smart') as HTMLInputElement;
  const queryField = document.getElementById('query-field');

  if (smartCheckbox && queryField) {
    smartCheckbox.addEventListener('change', () => {
      queryField.style.display = smartCheckbox.checked ? 'grid' : 'none';
    });
  }

  // Handle form submission via SDK
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const icon = formData.get('icon') as string;
      const color = formData.get('color') as string;
      const description = formData.get('description') as string;
      const sortOrder = formData.get('sort_order') as string;
      const isSmart = formData.get('is_smart') === 'true';
      const smartRulesStr = formData.get('smartRules') as string;
      const metadataStr = formData.get('metadata') as string;

      let smartRules = null;
      if (isSmart && smartRulesStr?.trim()) {
        try {
          smartRules = JSON.parse(smartRulesStr);
        } catch (error) {
          alert('Invalid JSON in Smart Rules field');
          return;
        }
      }

      let metadataJson = null;
      if (metadataStr?.trim()) {
        try {
          metadataJson = JSON.parse(metadataStr);
        } catch (error) {
          alert('Invalid JSON in Metadata field');
          return;
        }
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Saving...';

      try {
        const collectionId = window.location.pathname.split('/').pop()!;
        await sdk.collections.update(collectionId, {
          name,
          icon: icon?.trim() || null,
          color: color || null,
          description: description?.trim() || null,
          sortOrder: sortOrder ? parseInt(sortOrder) : 0,
          isSmart,
          smartRules: smartRules,
          metadataJson: metadataJson,
        });

        window.location.href = '/workspace/collections';
      } catch (error: any) {
        const message = error?.message || error?.detail || 'Failed to update collection';
        alert(message);
        submitButton.disabled = false;
        submitButton.textContent = 'Save Changes';
      }
    });
  }

  // Entry search filter
  const entrySearch = document.getElementById('entry-search') as HTMLInputElement;
  if (entrySearch) {
    entrySearch.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      document.querySelectorAll('.entry-picker-item').forEach(item => {
        const text = item.textContent?.toLowerCase() || '';
        (item as HTMLElement).style.display = text.includes(query) ? '' : 'none';
      });
    });
  }

  // Handle entry checkbox changes (real-time update)
  document.querySelectorAll('.entry-checkbox').forEach(checkbox => {
    checkbox.addEventListener('change', async (e) => {
      const cb = e.target as HTMLInputElement;
      const entryId = cb.dataset.entryId!;
      const entryTitle = cb.dataset.entryTitle!;
      const isChecked = cb.checked;

      cb.disabled = true;
      const label = cb.closest('.picker-item') as HTMLElement;
      if (label) label.style.opacity = '0.5';

      try {
        const entry = await sdk.entries.get(entryId);
        const collectionId = window.location.pathname.split('/').pop()!;

        const updatedCollectionIds = isChecked
          ? [...(entry.collections || []), collectionId]
          : (entry.collections || []).filter((cid: string) => cid !== collectionId);

        await sdk.entries.update(entryId, {
          collection_ids: updatedCollectionIds
        });

        // Success - keep checkbox state
        cb.disabled = false;
        if (label) label.style.opacity = '1';
      } catch (error: any) {
        const message = error?.message || error?.detail || 'Failed to update entry';
        alert(message);
        // Revert checkbox
        cb.checked = !isChecked;
        cb.disabled = false;
        if (label) label.style.opacity = '1';
      }
    });
  });

  // Metadata preview update
  const metadataEditor = document.getElementById('metadata') as HTMLTextAreaElement;
  const metadataPreviewContainer = metadataEditor?.closest('.form-group')?.querySelector('.metadata-preview');

  if (metadataEditor) {
    metadataEditor.addEventListener('input', () => {
      const value = metadataEditor.value.trim();

      if (!value) {
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
        return;
      }

      try {
        const parsed = JSON.parse(value);
        const entries = Object.entries(parsed);

        if (entries.length === 0) {
          if (metadataPreviewContainer) {
            metadataPreviewContainer.remove();
          }
          return;
        }

        let previewHTML = `
          <div class="metadata-preview">
            <p class="metadata-preview-title">Current Metadata:</p>
            <dl class="metadata-preview-list">
        `;

        entries.forEach(([key, value]) => {
          const displayValue = typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value);
          previewHTML += `
            <div class="metadata-preview-item">
              <dt>${key}</dt>
              <dd>${displayValue}</dd>
            </div>
          `;
        });

        previewHTML += `</dl></div>`;

        if (metadataPreviewContainer) {
          metadataPreviewContainer.outerHTML = previewHTML;
        } else {
          const helpText = metadataEditor.closest('.form-group')?.querySelector('.form-help');
          if (helpText) {
            helpText.insertAdjacentHTML('afterend', previewHTML);
          }
        }
      } catch (error) {
        // Invalid JSON - remove preview
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
      }
    });
  }

  // Drag and drop for entry ordering
  const sortableList = document.getElementById('sortable-entries');
  const saveOrderBtn = document.getElementById('save-order-btn');
  let draggedItem: HTMLElement | null = null;
  let hasChanges = false;

  if (sortableList) {
    const items = sortableList.querySelectorAll('.sortable-item');

    items.forEach(item => {
      item.addEventListener('dragstart', (e) => {
        draggedItem = item as HTMLElement;
        item.classList.add('dragging');
        (e as DragEvent).dataTransfer!.effectAllowed = 'move';
      });

      item.addEventListener('dragend', () => {
        item.classList.remove('dragging');
        draggedItem = null;
      });

      item.addEventListener('dragover', (e) => {
        e.preventDefault();
        (e as DragEvent).dataTransfer!.dropEffect = 'move';

        if (draggedItem && draggedItem !== item) {
          const bounding = item.getBoundingClientRect();
          const offset = (e as DragEvent).clientY - bounding.top;

          if (offset > bounding.height / 2) {
            item.parentNode!.insertBefore(draggedItem, item.nextSibling);
          } else {
            item.parentNode!.insertBefore(draggedItem, item);
          }

          updateOrderNumbers();
          hasChanges = true;
          if (saveOrderBtn) saveOrderBtn.style.display = 'inline-block';
        }
      });
    });
  }

  function updateOrderNumbers() {
    const items = sortableList?.querySelectorAll('.sortable-item');
    items?.forEach((item, index) => {
      const orderEl = item.querySelector('.sortable-order');
      if (orderEl) orderEl.textContent = String(index + 1);
    });
  }

  // Save order button
  if (saveOrderBtn) {
    saveOrderBtn.addEventListener('click', async () => {
      const items = sortableList?.querySelectorAll('.sortable-item');
      if (!items) return;

      const entries = Array.from(items).map((item, index) => ({
        entryId: (item as HTMLElement).dataset.entryId!,
        sortOrder: index,
      }));

      saveOrderBtn.disabled = true;
      saveOrderBtn.textContent = 'Saving...';

      try {
        const collectionId = window.location.pathname.split('/').pop()!;
        await sdk.collections.reorderEntries(collectionId, entries);
        saveOrderBtn.textContent = '✓ Saved';
        saveOrderBtn.style.display = 'none';
        hasChanges = false;

        setTimeout(() => {
          saveOrderBtn.textContent = 'Save Order';
        }, 2000);
      } catch (error: any) {
        const message = error?.message || error?.detail || 'Failed to save order';
        alert(message);
        saveOrderBtn.disabled = false;
        saveOrderBtn.textContent = 'Save Order';
      }
    });
  }
</script>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="number"],
  input[type="color"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  input[type="color"] {
    height: 40px;
    cursor: pointer;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .entries-section {
    margin-top: 2rem;
  }

  .section-help {
    margin: 0 0 1rem;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .picker-search {
    margin-bottom: 1rem;
  }

  .picker-search input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  .picker-list {
    display: grid;
    gap: 0.5rem;
    max-height: 500px;
    overflow-y: auto;
    padding: 1rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .picker-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .picker-item:hover {
    background: var(--panel-2);
    border-color: var(--brand);
  }

  .picker-item input[type="checkbox"] {
    margin: 0;
    cursor: pointer;
  }

  .picker-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .picker-info strong {
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .picker-meta {
    font-size: 0.75rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pill {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .pill.published {
    background: rgba(34, 197, 94, 0.1);
    color: rgb(34, 197, 94);
  }

  .pill.draft {
    background: rgba(156, 163, 175, 0.1);
    color: rgb(107, 114, 128);
  }

  .empty-message {
    text-align: center;
    color: var(--muted);
    padding: 2rem;
  }

  .empty-state-small {
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    text-align: center;
  }

  .empty-state-small p {
    margin: 0.5rem 0;
  }

  .empty-state-small .muted {
    color: var(--muted);
    font-size: 0.875rem;
  }

  .button.small {
    min-height: 32px;
    padding: 6px 10px;
    font-size: 0.875rem;
  }

  .metadata-preview {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--panel-2);
    border-radius: 6px;
  }

  .metadata-preview-title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .metadata-preview-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .metadata-preview-item {
    padding: 0.5rem;
    background: var(--bg);
    border-radius: 4px;
  }

  .metadata-preview-item dt {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .metadata-preview-item dd {
    margin: 0;
    font-size: 0.875rem;
    word-break: break-word;
    white-space: pre-wrap;
    font-family: monospace;
  }

  .order-section {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .sortable-list {
    display: grid;
    gap: 0.5rem;
  }

  .sortable-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    cursor: move;
    transition: all 0.2s;
  }

  .sortable-item:hover {
    background: var(--panel-2);
    border-color: var(--brand);
  }

  .sortable-item.dragging {
    opacity: 0.5;
  }

  .drag-handle {
    color: var(--muted);
    font-size: 1rem;
    cursor: grab;
    user-select: none;
  }

  .drag-handle:active {
    cursor: grabbing;
  }

  .sortable-content {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .sortable-order {
    min-width: 2rem;
    text-align: center;
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--muted);
    padding: 0.25rem 0.5rem;
    background: var(--panel-2);
    border-radius: 4px;
  }

  .sortable-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .sortable-info strong {
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sortable-meta {
    font-size: 0.75rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
</style>
