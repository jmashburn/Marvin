---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { getCollection, getCollectionEntries } from "@/lib/api/collections";
import { listEntryTypes } from "@/lib/api/entryTypes";
import type { EntryRead, CollectionRead } from "@/lib/api/entries";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

let collection: CollectionRead | null = null;
let entries: EntryRead[] = [];
let typeMap = new Map<string, string>();
let error: string | null = null;

if (!authToken) {
  error = "Authentication required";
} else if (!id) {
  error = "Collection ID is required";
} else {
  try {
    const [col, ents, types] = await Promise.all([
      getCollection(id, authToken),
      getCollectionEntries(id, authToken),
      listEntryTypes(authToken),
    ]);
    collection = col;
    entries = ents;
    typeMap = new Map(types.map((t) => [t.id, t.name]));
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error("[Collection view] Failed to load:", error);
  }
}

const statusMeta: Record<string, { label: string; cls: string }> = {
  inbox: { label: "Inbox", cls: "s-inbox" },
  processing: { label: "Processing", cls: "s-processing" },
  draft: { label: "Draft", cls: "s-draft" },
  needs_review: { label: "Needs Review", cls: "s-review" },
  approved: { label: "Approved", cls: "s-approved" },
  published: { label: "Published", cls: "s-published" },
  archived: { label: "Archived", cls: "s-archived" },
};

function fmtDate(d?: string | null): string {
  if (!d) return "";
  try {
    return new Date(d).toLocaleDateString(undefined, { month: "short", day: "numeric" });
  } catch {
    return "";
  }
}
---

<AppLayout title={collection ? collection.name : "Collection"}>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading collection:</strong> {error}</p>
      <a href="/workspace/collections" class="button secondary">Back to Collections</a>
    </div>
  ) : collection ? (
    <>
      <div class="toolbar">
        <div class="head">
          <a href="/workspace/collections" class="back-link">← Collections</a>
          <h2 class="col-title">
            {collection.icon && <span class="col-icon">{collection.icon}</span>}
            {collection.name}
            <span class="col-count">{entries.length}</span>
            {collection.isSmart && <span class="pill">Smart</span>}
            {collection.isSystem && <span class="pill system-pill">System</span>}
          </h2>
          {collection.description && <p class="col-desc">{collection.description}</p>}
        </div>
        {!collection.isSystem && (
          <a class="button secondary" href={`/workspace/collections/${id}/edit`}>Edit collection</a>
        )}
      </div>

      {entries.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">📭</div>
          <h3>No entries</h3>
          <p>Entries matching this collection will appear here.</p>
        </div>
      ) : (
        <ul class="inbox">
          {entries.map((entry) => {
            const s = statusMeta[entry.status] ?? { label: entry.status, cls: "s-default" };
            return (
              <li class="inbox-row">
                <a class="inbox-link" href={`/workspace/entries/${entry.id}`}>
                  <span class={`status-dot ${s.cls}`} title={s.label}></span>
                  <span class="inbox-main">
                    <span class="inbox-title">{entry.title || "Untitled"}</span>
                    {entry.summary && <span class="inbox-summary">{entry.summary}</span>}
                  </span>
                  <span class="inbox-meta">
                    {typeMap.get(entry.entryTypeId) && (
                      <span class="inbox-type">{typeMap.get(entry.entryTypeId)}</span>
                    )}
                    <span class={`status-pill ${s.cls}`}>{s.label}</span>
                    <span class="inbox-date">{fmtDate(entry.updateAt ?? entry.createdAt)}</span>
                  </span>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </>
  ) : (
    <div class="error-banner"><p>Collection not found.</p></div>
  )}
</AppLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .head {
    display: grid;
    gap: 0.35rem;
  }

  .back-link {
    font-size: 0.8125rem;
    color: var(--muted);
    text-decoration: none;
  }
  .back-link:hover {
    color: var(--ink);
  }

  .col-title {
    margin: 0;
    font-size: 20px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .col-icon {
    font-size: 1.25rem;
  }
  .col-count {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--muted);
    background: var(--panel-2);
    padding: 0.1rem 0.55rem;
    border-radius: 10px;
  }
  .system-pill {
    background: var(--panel-2);
    color: var(--muted);
  }
  .col-desc {
    margin: 0;
    color: var(--muted);
    font-size: 0.875rem;
  }

  .inbox {
    list-style: none;
    margin: 1.25rem 0 0;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--panel);
  }

  .inbox-row + .inbox-row {
    border-top: 1px solid var(--line);
  }

  .inbox-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.12s;
  }
  .inbox-link:hover {
    background: var(--panel-2);
  }

  .status-dot {
    flex: 0 0 auto;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--muted);
  }

  .inbox-main {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .inbox-title {
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .inbox-summary {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .inbox-meta {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .inbox-type {
    font-size: 0.75rem;
    color: var(--muted);
  }
  .inbox-date {
    font-size: 0.75rem;
    color: var(--muted);
    min-width: 3rem;
    text-align: right;
  }

  .status-pill {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.1rem 0.5rem;
    border-radius: 10px;
    background: var(--panel-2);
    color: var(--muted);
    white-space: nowrap;
  }

  /* status colors (dot + pill tint) */
  .s-inbox { --sc: #6b7280; }
  .s-processing { --sc: #8b5cf6; }
  .s-draft { --sc: #d97706; }
  .s-review { --sc: #2563eb; }
  .s-approved { --sc: #059669; }
  .s-published { --sc: #16a34a; }
  .s-archived { --sc: #9ca3af; }
  .s-default { --sc: var(--muted); }

  .status-dot { background: var(--sc, var(--muted)); }
  .status-pill {
    color: var(--sc, var(--muted));
    background: color-mix(in srgb, var(--sc, var(--muted)) 14%, transparent);
  }

  .empty-state {
    display: grid;
    place-items: center;
    gap: 0.75rem;
    padding: 4rem 2rem;
    text-align: center;
  }
  .empty-icon {
    font-size: 3rem;
    opacity: 0.5;
  }
  .empty-state h3 {
    margin: 0;
    font-size: 1.25rem;
  }
  .empty-state p {
    margin: 0;
    color: var(--muted);
  }
</style>
