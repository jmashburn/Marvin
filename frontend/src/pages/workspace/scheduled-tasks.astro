---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { createSdkClient } from "@/lib/sdk";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let tasks: any[] = [];
let error: string | null = null;

try {
  const result = await sdk.scheduledTasks.list();
  tasks = Array.isArray(result) ? result : ((result as any)?.items ?? []);
} catch (e) {
  console.error("[scheduled-tasks] Error loading:", e);
  error = e instanceof Error ? e.message : String(e);
}

function formatSchedule(task: any): string {
  const scheduleType = task.scheduleType ?? task.schedule_type;
  const sc = task.scheduleConfig ?? task.schedule_config;
  if (!sc) return "No schedule";
  if (scheduleType === "interval") {
    const s = sc.intervalSeconds ?? sc.interval_seconds;
    if (s >= 86400) return `Every ${s / 86400} day(s)`;
    if (s >= 3600) return `Every ${s / 3600} hour(s)`;
    if (s >= 60) return `Every ${s / 60} minute(s)`;
    return `Every ${s}s`;
  }
  if (scheduleType === "cron") return `Cron: ${sc.cronExpression ?? sc.cron_expression}`;
  if (scheduleType === "once") return `Once: ${(sc.runAt ?? sc.run_at) || "—"}`;
  return "—";
}

function formatDate(isoStr: string | null): string {
  if (!isoStr) return "—";
  const normalized = isoStr.replace(/(\.\d{3})\d+/, "$1");
  const d = new Date(normalized);
  return Number.isNaN(d.getTime()) ? isoStr : d.toLocaleString();
}

function statusClass(status: string | null): string {
  if (status === "success") return "success";
  if (status === "failed") return "failed";
  if (status === "timeout") return "timeout";
  if (status === "cancelled") return "cancelled";
  return "none";
}
---

<AppLayout title="Scheduled Tasks" eyebrow="Automation">
  <div class="toolbar">
    <div>
      <h2>Scheduled Tasks</h2>
      <p>Automate recurring workspace operations</p>
    </div>
    <div class="toolbar-actions">
      <a href="/workspace/scheduled-tasks/log" class="button secondary">Activity Log</a>
      <a href="/workspace/scheduled-tasks/new" class="button">New Task</a>
    </div>
  </div>

  <div class="page-container">
    {error ? (
      <div class="alert alert-error">
        <strong>Error:</strong> {error}
      </div>
    ) : tasks.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">⏱</div>
        <p class="empty-title">No scheduled tasks configured</p>
        <p class="empty-description">
          Scheduled tasks automate recurring operations like cleanup, rebuilds, and maintenance
        </p>
        <a href="/workspace/scheduled-tasks/new" class="button">New Task</a>
      </div>
    ) : (
      <div class="tasks-grid">
        {tasks.map((task) => (
          <article class="task-card">
            <div class="task-header">
              <div>
                <h3>{task.name}</h3>
                {task.description && <p class="task-description">{task.description}</p>}
              </div>
              <span class={`status-badge ${task.enabled ? 'active' : 'inactive'}`}>
                {task.enabled ? 'Active' : 'Inactive'}
              </span>
            </div>
            <div class="task-meta">
              <div class="meta-item">
                <span class="meta-label">Type</span>
                <code class="meta-value">{task.taskType ?? task.task_type}</code>
              </div>
              <div class="meta-item">
                <span class="meta-label">Scheduled</span>
                <span class="meta-value">{formatSchedule(task)}</span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Last Run</span>
                <span class="meta-value">
                  {(task.lastRunAt ?? task.last_run_at)
                    ? <>{formatDate(task.lastRunAt ?? task.last_run_at)} <span class={`run-status status-${statusClass(task.lastStatus ?? task.last_status)}`}>({task.lastStatus ?? task.last_status})</span></>
                    : <span class="muted">Never</span>}
                </span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Next Run</span>
                <span class="meta-value">
                  {(task.nextRunAt ?? task.next_run_at) ? formatDate(task.nextRunAt ?? task.next_run_at) : <span class="muted">Not scheduled</span>}
                </span>
              </div>
            </div>
            <div class="task-actions">
              <a href={`/workspace/scheduled-tasks/${task.id}`} class="button secondary small">Edit</a>
              <button
                class="button secondary small"
                data-action="toggle"
                data-id={task.id}
                data-enabled={String(task.enabled)}
              >{task.enabled ? 'Disable' : 'Enable'}</button>
              <button
                class="button secondary small"
                data-action="run"
                data-id={task.id}
                data-name={task.name}
              >Run Now</button>
              <button
                class="button secondary small danger"
                data-action="delete"
                data-id={task.id}
                data-name={task.name}
              >Delete</button>
            </div>
          </article>
        ))}
      </div>
    )}
  </div>
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';
  const sdk = createSdkClient();

  document.querySelectorAll('[data-action="toggle"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id')!;
      const currentlyEnabled = btn.getAttribute('data-enabled') === 'true';
      try {
        await sdk.scheduledTasks.update(id, { enabled: !currentlyEnabled });
        window.location.reload();
      } catch {
        alert('Failed to update task');
      }
    });
  });

  document.querySelectorAll('[data-action="run"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id')!;
      const name = btn.getAttribute('data-name');
      if (!confirm(`Manually trigger "${name}" now?`)) return;
      try {
        await sdk.scheduledTasks.execute(id);
        alert('Task triggered! Check the task history for results.');
      } catch {
        alert('Failed to trigger task');
      }
    });
  });

  document.querySelectorAll('[data-action="delete"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id')!;
      const name = btn.getAttribute('data-name');
      if (!confirm(`Are you sure you want to delete "${name}"?`)) return;
      try {
        await sdk.scheduledTasks.delete(id);
        window.location.reload();
      } catch {
        alert('Failed to delete task');
      }
    });
  });
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar-actions {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .page-container {
    max-width: 1200px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .empty-state {
    padding: 80px 24px;
    text-align: center;
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 16px;
    opacity: 0.3;
  }

  .empty-title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .empty-description {
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 14px;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }

  .tasks-grid {
    display: grid;
    gap: 16px;
  }

  .task-card {
    padding: 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .task-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 12px;
  }

  .task-header h3 {
    margin: 0 0 4px;
    font-size: 16px;
    font-weight: 600;
  }

  .task-description {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
  }

  .status-badge {
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .status-badge.active {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
  }

  .status-badge.inactive {
    background: rgba(128, 128, 128, 0.1);
    color: var(--muted);
  }

  .task-meta {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
  }

  .meta-value {
    font-size: 14px;
  }

  .muted { color: var(--muted); }

  .run-status {
    font-size: 13px;
    font-weight: 500;
  }

  .status-success { color: var(--accent); }
  .status-failed { color: var(--color-error); }
  .status-timeout { color: #d97706; }
  .status-cancelled { color: var(--muted); }
  .status-none { color: var(--muted); }

  .task-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .button.small {
    padding: 6px 14px;
    font-size: 13px;
  }

  .button.danger {
    color: var(--color-error);
  }

  .button.danger:hover {
    background: var(--color-error-bg);
  }
</style>
