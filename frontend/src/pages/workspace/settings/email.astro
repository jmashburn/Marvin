---
import AppLayout from "@/layouts/AppLayout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getAuthToken } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";
import { listEmailTemplates } from "@/lib/api/emailTemplates";

const authToken = getAuthToken(Astro.cookies);

let workspace = null;
let emailTemplates = [];
let error: string | null = null;

try {
  workspace = await getCurrentWorkspace(authToken);
  const wsId = (workspace as any)?.id ?? (workspace as any)?.groupId;
  console.log('[email-settings] workspace keys:', Object.keys(workspace || {}));
  console.log('[email-settings] wsId:', wsId);
  if (wsId) {
    emailTemplates = await listEmailTemplates(wsId, authToken);
    console.log('[email-settings] templates loaded:', emailTemplates.length);
  } else {
    console.warn('[email-settings] wsId is undefined — workspace shape:', JSON.stringify(workspace));
  }
} catch (e) {
  console.error('[email-settings] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

const groupId = (workspace as any)?.id ?? (workspace as any)?.groupId;
const apiUrl = import.meta.env.PUBLIC_MARVIN_API_URL || 'http://localhost:8080';

// Group templates by type to compute effective state
const templatesByType = new Map<string, any[]>();
for (const t of emailTemplates) {
  const type = (t as any).templateType ?? (t as any).template_type ?? 'custom';
  if (!templatesByType.has(type)) templatesByType.set(type, []);
  templatesByType.get(type)!.push(t);
}

// A system template is "superseded" when any workspace template of the same type is enabled
function isSuperseded(template: any): boolean {
  const isSystem = !((template as any).groupId ?? (template as any).group_id);
  if (!isSystem) return false;
  const type = (template as any).templateType ?? (template as any).template_type;
  const siblings = templatesByType.get(type) || [];
  return siblings.some(t => {
    const tIsWorkspace = !!((t as any).groupId ?? (t as any).group_id);
    return tIsWorkspace && t.enabled;
  });
}
---

<AppLayout title="Email Settings" eyebrow="Workspace">
  <Breadcrumb items={[
    { label: "Workspace Settings", href: "/workspace/settings" },
    { label: "Email Settings" }
  ]} />

  <div class="toolbar">
    <div>
      <h2>Email Settings</h2>
      <p>Manage email templates and test sending for {workspace?.workspace?.name || 'this workspace'}</p>
    </div>
    <button class="button" id="create-template-btn">
      <span>+ Create Template</span>
    </button>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : (
    <div class="email-settings">
      <section class="settings-section">
        <h3>Email Templates</h3>
        <p class="section-description">Customize the emails sent from your workspace</p>

        {emailTemplates.length > 0 && (
          <div class="template-search-row">
            <input type="text" id="template-search" class="input" placeholder="Search templates…" />
          </div>
        )}

        <div id="templates-list-container">
          {emailTemplates.length === 0 ? (
            <div class="empty-state">
              <p>No email templates yet</p>
              <small>System templates will appear after the server starts</small>
            </div>
          ) : (() => {
            const systemTemplates = emailTemplates.filter((t: any) => !(t.groupId ?? t.group_id));
            const customTemplates = emailTemplates.filter((t: any) => !!(t.groupId ?? t.group_id));
            const renderCard = (template: any) => (
              <div class:list={['template-card', { 'is-superseded': isSuperseded(template) }]} data-template-id={template.id}>
                <div class="template-info">
                  <div class="template-header">
                    <strong>{template.name}</strong>
                    <span class="badge badge-type">{(template as any).templateType ?? template.template_type}</span>
                    {template.enabled ? (
                      <span class="badge badge-active">Active</span>
                    ) : (
                      <span class="badge badge-inactive">Inactive</span>
                    )}
                    {!(template.groupId ?? template.group_id) && (
                      <span class="badge badge-system" title="System default — click Customize to create a workspace override">Default</span>
                    )}
                    {!!(template.groupId ?? template.group_id) && (
                      <span class="badge badge-customized" title="Workspace customization — overrides the system default">Customized</span>
                    )}
                    {isSuperseded(template) && (
                      <span class="badge badge-superseded" title="A workspace customization is active for this type">Superseded</span>
                    )}
                  </div>
                  <p>{template.description || 'No description'}</p>
                  {isSuperseded(template) && (
                    <small class="superseded-note">A workspace customization is currently active — this template won't be used.</small>
                  )}
                </div>
                <div class="template-actions">
                  <button
                    class="button secondary small edit-template-btn"
                    data-template-id={template.id}
                    data-is-system={!(template.groupId ?? template.group_id) ? 'true' : 'false'}
                  >
                    {!(template.groupId ?? template.group_id) ? 'Customize' : 'Edit'}
                  </button>
                  <button
                    class="button secondary small test-send-btn"
                    data-template-id={template.id}
                    data-template-type={(template as any).templateType ?? template.template_type}
                  >
                    Test Send
                  </button>
                  {!!(template.groupId ?? template.group_id) && (
                    <button
                      class="button danger small delete-template-btn"
                      data-template-id={template.id}
                    >
                      Delete
                    </button>
                  )}
                </div>
              </div>
            );
            return (
              <>
                {systemTemplates.length > 0 && (
                  <div class="templates-section">
                    <p class="templates-section-title">System Templates</p>
                    <div class="templates-list">{systemTemplates.map(renderCard)}</div>
                  </div>
                )}
                {customTemplates.length > 0 && (
                  <div class="templates-section">
                    <p class="templates-section-title">Workspace Customizations &amp; Custom Templates</p>
                    <div class="templates-list">{customTemplates.map(renderCard)}</div>
                  </div>
                )}
              </>
            );
          })()}
        </div>
      </section>

      <section class="settings-section">
        <h3>Test Email Delivery</h3>
        <p class="section-description">Send a test email to verify SMTP configuration</p>

        <form id="test-email-form" class="test-form">
          <label class="form-field">
            <span class="label">Test Email Address *</span>
            <input
              type="email"
              name="test_email"
              placeholder="test@example.com"
              required
              class="input"
            />
          </label>

          <label class="form-field">
            <span class="label">Subject</span>
            <input
              type="text"
              name="subject"
              value="Marvin Platform - Test Email"
              class="input"
            />
          </label>

          <label class="form-field">
            <span class="label">Message</span>
            <textarea
              name="message"
              rows="4"
              class="input textarea"
            >This is a test email from Marvin Platform. If you received this, your SMTP configuration is working correctly.</textarea>
          </label>

          <div class="form-actions">
            <button type="submit" class="button">Send Test Email</button>
          </div>
        </form>

        <div id="test-result" class="test-result hidden"></div>
      </section>

      <section class="settings-section">
        <h3>SMTP Configuration</h3>
        <p class="section-description">Workspace-specific email server settings (optional)</p>

        <div class="coming-soon-box">
          <p>📧 Workspace-specific SMTP configuration coming soon</p>
          <p class="hint">Currently using system-wide SMTP settings from admin configuration</p>
        </div>
      </section>
    </div>
  )}

  <!-- Email Template Modal -->
  <div id="template-modal" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">Create Email Template</h3>
        <button class="modal-close" id="close-modal">&times;</button>
      </div>
      <form id="template-form">
        <input type="hidden" id="template-id" />
        <input type="hidden" id="edit-is-system" value="false" />

        <div class="form-section">
          <h4 class="section-label">Basic Information</h4>

          <div class="form-group">
            <label for="template-type-select">Template Type *</label>
            <select id="template-type" class="input">
              <option value="invitation">Workspace Invitation — invitation</option>
              <option value="password_reset">Password Reset — password_reset</option>
              <option value="welcome">New User Welcome — welcome</option>
              <option value="notification">General Notification — notification</option>
              <option value="custom">Custom / Manual — custom</option>
            </select>
            <small class="type-note">System types (invitation, password_reset, welcome) are sent automatically by Marvin. Custom templates must be triggered from code.</small>
          </div>

          <div class="form-group">
            <label for="template-name">Template Name *</label>
            <input
              type="text"
              id="template-name"
              placeholder="e.g., Workspace Invitation"
              required
            />
            <small>A friendly name for this template. The template type will be automatically generated.</small>
          </div>

          <div class="form-group">
            <label for="template-description">Description</label>
            <input
              type="text"
              id="template-description"
              placeholder="Brief description of this template"
            />
          </div>

          <div class="form-group">
            <label for="template-subject">Email Subject *</label>
            <input
              type="text"
              id="template-subject"
              placeholder="e.g., You're invited to {{ workspace_name }}"
              required
            />
            <small>Use {'{{ variable }}'} for dynamic values</small>
          </div>
        </div>

        <div class="form-section">
          <h4 class="section-label">Template Content</h4>

          <div class="template-mode-tabs">
            <button type="button" class="mode-tab active" data-mode="structured">
              <span>📝 Structured</span>
              <small>Default email layout</small>
            </button>
            <button type="button" class="mode-tab" data-mode="custom">
              <span>💻 Custom HTML</span>
              <small>Full control over design</small>
            </button>
            <button type="button" class="mode-tab" data-mode="preview">
              <span>👁 Preview</span>
              <small>See rendered output</small>
            </button>
          </div>

          <div id="structured-fields" class="template-mode-content">
            <div class="form-group">
              <label for="template-header">Header Text</label>
              <input
                type="text"
                id="template-header"
                placeholder="e.g., You're Invited!"
              />
              <small>Large heading at the top of the email</small>
            </div>

            <div class="form-group">
              <label for="template-message-top">Message Top</label>
              <textarea
                id="template-message-top"
                rows="4"
                placeholder="Main message content (supports {{ variables }})"
              ></textarea>
              <small>Primary message shown above the button</small>
            </div>

            <div class="form-group">
              <label for="template-button-text">Button Text</label>
              <input
                type="text"
                id="template-button-text"
                placeholder="e.g., Accept Invitation"
              />
            </div>

            <div class="form-group">
              <label for="template-message-bottom">Message Bottom</label>
              <textarea
                id="template-message-bottom"
                rows="3"
                placeholder="Additional message content"
              ></textarea>
              <small>Secondary message shown below the button</small>
            </div>
          </div>

          <div id="custom-html-field" class="template-mode-content" style="display: none;">
            <div class="form-group">
              <label for="template-custom-html">Custom HTML Template</label>
              <textarea
                id="template-custom-html"
                rows="16"
                placeholder="<!DOCTYPE html>
<html>
<body>
  <h1>{{ workspace_name }}</h1>
  <p>Your custom email content here...</p>
</body>
</html>"
              ></textarea>
              <small>Full Jinja2 HTML template with complete control over styling and structure</small>
            </div>
          </div>

          <div id="preview-panel" style="display:none">
            <div class="preview-hint">Live preview — variables shown as placeholders</div>
            <iframe id="preview-iframe" class="preview-iframe" sandbox="allow-same-origin"></iframe>
          </div>
        </div>

        <div class="form-section form-section-compact">
          <label class="checkbox-label">
            <input type="checkbox" id="template-enabled" checked />
            <span>Enable this template</span>
          </label>
        </div>

        <div class="vars-panel">
          <div class="vars-header">
            <span class="vars-title">Insert</span>
            <span class="vars-hint"><strong>&#123;&#123;lower_case&#125;&#125;</strong> per-send &nbsp;·&nbsp; <strong>&#123;&#123;UPPER_CASE&#125;&#125;</strong> workspace &nbsp;·&nbsp; click to copy</span>
          </div>
          <div id="vars-list" class="vars-list">
            <span class="vars-loading">Loading variables…</span>
          </div>
        </div>

        <div class="modal-actions">
          <button type="button" class="button secondary" id="cancel-btn">Cancel</button>
          <button type="submit" class="button primary">Save Template</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Test Send Modal -->
  <div id="test-send-modal" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-content modal-small">
      <div class="modal-header">
        <h3>Send Test Email</h3>
        <button class="modal-close" id="close-test-modal">&times;</button>
      </div>
      <form id="test-send-form">
        <input type="hidden" id="test-template-id" />

        <div class="form-group">
          <label for="test-recipient">Recipient Email *</label>
          <input
            type="email"
            id="test-recipient"
            placeholder="test@example.com"
            required
          />
        </div>

        <div id="test-vars-container" style="display:none">
          <p style="font-size:13px;font-weight:600;margin:0 0 4px;">Template Variables</p>
          <p style="font-size:11px;color:var(--muted);margin:0 0 12px;">
            Fill in the values for this test send. <code>&#123;&#123;UPPER_CASE&#125;&#125;</code> workspace variables resolve automatically — no need to fill those in.
          </p>
          <div id="test-vars-fields"></div>
        </div>

        <div class="modal-actions">
          <button type="button" class="button secondary" id="cancel-test-btn">Cancel</button>
          <button type="submit" class="button">Send Test Email</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ groupId, apiUrl }}>
    const GROUP_ID = groupId;

    // Slugify function
    function slugify(text) {
      return text
        .toString()
        .toLowerCase()
        .trim()
        .replace(/\s+/g, '_')           // Replace spaces with _
        .replace(/[^\w\-]+/g, '')       // Remove non-word chars
        .replace(/\_\_+/g, '_')         // Replace multiple _ with single _
        .replace(/^-+/, '')             // Trim _ from start
        .replace(/-+$/, '');            // Trim _ from end
    }

    // Modal management
    const templateModal = document.getElementById('template-modal');
    const testSendModal = document.getElementById('test-send-modal');
    const templateForm = document.getElementById('template-form');
    const testSendForm = document.getElementById('test-send-form');

    // Build a single var chip element
    function makeChip(slug, subtitle, clickSlug) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'var-chip';
      btn.dataset.slug = clickSlug;
      btn.title = subtitle || slug;
      const inner = document.createElement('span');
      inner.className = 'var-chip-inner';
      const code = document.createElement('code');
      code.textContent = clickSlug;
      inner.appendChild(code);
      if (subtitle) {
        const val = document.createElement('span');
        val.className = 'var-value';
        val.textContent = subtitle;
        inner.appendChild(val);
      }
      btn.appendChild(inner);
      btn.addEventListener('click', async () => {
        await navigator.clipboard.writeText(clickSlug);
        const orig = code.textContent;
        code.textContent = '✓';
        setTimeout(() => { code.textContent = orig; }, 1200);
      });
      return btn;
    }

    function makeSectionLabel(text, color) {
      const el = document.createElement('div');
      el.style.cssText = 'width:100%; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:0.5px; color:' + color + '; margin:4px 0 2px; padding-top:6px; border-top:1px solid #eee;';
      el.textContent = text;
      return el;
    }

    // Load workspace variables + per-send context vars into the template modal
    async function loadVariables() {
      const varsList = document.getElementById('vars-list');
      const templateType = document.getElementById('template-type')?.value || '';
      if (!varsList) return;
      varsList.innerHTML = '<span class="vars-loading">Loading…</span>';
      try {
        const [wsRes, ctxRes] = await Promise.all([
          fetch(`${apiUrl}/api/groups/variables`, { credentials: 'include' }),
          fetch(`${apiUrl}/api/platform/email/template-vars?template_type=${templateType}`, { credentials: 'include' }),
        ]);
        const wsVars = wsRes.ok ? await wsRes.json() : [];
        const ctxData = ctxRes.ok ? await ctxRes.json() : { context_vars: [] };
        const ctxVars = ctxData.context_vars || [];

        varsList.innerHTML = '';

        // Per-send context variables (lower_case) — shown first
        const requiredVars = ctxData.required_vars || [];

        if (ctxVars.length) {
          varsList.appendChild(makeSectionLabel('Per-send · changes each email', '#7c6fb0'));
          ctxVars.forEach(v => {
            const chip = makeChip(v.slug, v.description, '{{' + v.slug + '}}');
            chip.classList.add('var-chip-context');
            if (requiredVars.includes(v.slug)) {
              chip.title = '⚠ Required — ' + (v.description || v.slug);
              const badge = document.createElement('span');
              badge.style.cssText = 'font-size:9px;font-weight:700;color:#c84b4b;letter-spacing:0.3px;margin-top:1px;';
              badge.textContent = 'REQUIRED';
              chip.querySelector('.var-chip-inner').appendChild(badge);
            }
            varsList.appendChild(chip);
          });
        }

        // Workspace variables (UPPER_CASE) — static
        if (wsVars.length) {
          varsList.appendChild(makeSectionLabel('Workspace · same for all emails', '#3a8a6e'));
          wsVars.forEach(v => {
            const val = v.value || '';
            const preview = val.length > 28 ? val.slice(0, 28) + '…' : val;
            varsList.appendChild(makeChip(v.slug, preview, '{{' + v.slug + '}}'));
          });
        }

        if (!ctxVars.length && !wsVars.length) {
          varsList.innerHTML = '<span class="vars-empty">No variables available. Add workspace variables in <a href="/workspace/settings/environment">Environment settings</a>.</span>';
        }
      } catch {
        varsList.innerHTML = '<span class="vars-empty">Could not load variables.</span>';
      }
    }

    // Reload vars when template type changes
    document.getElementById('template-type')?.addEventListener('change', loadVariables);

    // Show/hide modals
    function showModal(modal) {
      modal.classList.add('show');
      document.body.style.overflow = 'hidden';
      if (modal === templateModal) loadVariables();
    }

    function hideModal(modal) {
      modal.classList.remove('show');
      document.body.style.overflow = '';
    }

    // Preview tab
    const previewPanel = document.getElementById('preview-panel');
    const previewIframe = document.getElementById('preview-iframe');
    let lastEditMode = 'structured'; // track last editing mode before switching to preview

    function updatePreview() {
      if (!previewPanel || previewPanel.style.display === 'none') return;

      const isCustom = lastEditMode === 'custom';
      let html = '';

      if (isCustom) {
        html = document.getElementById('template-custom-html').value;
      } else {
        // Build structured preview matching default.html layout
        const header = document.getElementById('template-header').value || 'Email Header';
        const msgTop = document.getElementById('template-message-top').value || '';
        const msgBottom = document.getElementById('template-message-bottom').value || '';
        const btnText = document.getElementById('template-button-text').value || '';
        const btnRow = btnText ? `<tr><td style="padding:20px 40px;"><a href="#" style="background:#4f9c84;color:#fff;text-decoration:none;padding:12px 24px;border-radius:8px;font-weight:600;display:inline-block;">${btnText}</a></td></tr>` : '';
        const bottomRow = msgBottom ? `<tr><td style="padding:0 40px 28px;font-size:13px;color:#888;line-height:1.6;">${msgBottom}</td></tr>` : '';
        html = `<!DOCTYPE html><html><body style="margin:0;padding:0;background:#f4f6f4;font-family:-apple-system,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0"><tr><td align="center" style="padding:32px 16px;">
<table width="540" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08);">
<tr><td style="height:4px;background:#4f9c84;"></td></tr>
<tr><td style="padding:28px 40px 20px;border-bottom:1px solid #f0f0f0;font-size:18px;font-weight:700;color:#1a1a1a;">${header}</td></tr>
<tr><td style="padding:24px 40px 8px;font-size:15px;line-height:1.7;color:#444;">${msgTop.replace(/\n/g,'<br>')}</td></tr>
${btnRow}${bottomRow}
<tr><td style="padding:16px 40px;border-top:1px solid #f0f0f0;background:#fafafa;font-size:12px;color:#aaa;">Sent by Marvin CMS</td></tr>
</table></td></tr></table></body></html>`;
      }

      if (previewIframe) {
        const doc = previewIframe.contentDocument || previewIframe.contentWindow?.document;
        if (doc) {
          doc.open();
          doc.write(html);
          doc.close();
        }
      }
    }

    // Template mode tabs
    document.querySelectorAll('.mode-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const mode = tab.dataset.mode;
        document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        if (mode === 'preview') {
          document.getElementById('structured-fields').style.display = 'none';
          document.getElementById('custom-html-field').style.display = 'none';
          previewPanel.style.display = 'block';
          updatePreview();
          return;
        }

        if (previewPanel) previewPanel.style.display = 'none';

        if (mode === 'structured') {
          lastEditMode = 'structured';
          document.getElementById('structured-fields').style.display = 'block';
          document.getElementById('custom-html-field').style.display = 'none';
        } else {
          lastEditMode = 'custom';
          document.getElementById('structured-fields').style.display = 'none';
          document.getElementById('custom-html-field').style.display = 'block';

          // Generate starter HTML from structured fields if custom textarea is empty
          const customTextarea = document.getElementById('template-custom-html');
          if (!customTextarea.value.trim()) {
            const subject = document.getElementById('template-subject').value || 'Email Subject';
            const header = document.getElementById('template-header').value || subject;
            const msgTop = document.getElementById('template-message-top').value || '';
            const msgBottom = document.getElementById('template-message-bottom').value || '';
            const btnText = document.getElementById('template-button-text').value || '';

            const btnRow = btnText
              ? `\n        <p style="margin:24px 0;"><a href="{{button_link}}" style="background:#4f9c84;color:#fff;text-decoration:none;padding:12px 24px;border-radius:8px;font-weight:600;display:inline-block;">${btnText}</a></p>`
              : '';
            const bottomRow = msgBottom
              ? `\n        <p style="color:#888;font-size:13px;line-height:1.6;">${msgBottom}</p>`
              : '';

            customTextarea.value = `<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"></head>
<body style="margin:0;padding:0;background:#f4f6f4;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr><td align="center" style="padding:40px 16px;">
      <table width="560" cellpadding="0" cellspacing="0" border="0" style="background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08);">
        <tr><td style="height:4px;background:#4f9c84;"></td></tr>
        <tr>
          <td style="padding:28px 40px 20px;border-bottom:1px solid #f0f0f0;">
            <table width="100%"><tr>
              <td style="font-size:18px;font-weight:700;color:#1a1a1a;">${header}</td>
              <td align="right" style="font-size:12px;font-weight:600;color:#4f9c84;text-transform:uppercase;">Marvin</td>
            </tr></table>
          </td>
        </tr>
        <tr><td style="padding:24px 40px 8px;font-size:15px;line-height:1.7;color:#444;">${msgTop}</td></tr>${btnRow}${bottomRow}
        <tr>
          <td style="padding:20px 40px;border-top:1px solid #f0f0f0;background:#fafafa;font-size:12px;color:#aaa;">
            Sent by <a href="{{button_link}}" style="color:#4f9c84;text-decoration:none;">Marvin CMS</a>{% if workspace_name %} &middot; {{workspace_name}}{% endif %}
          </td>
        </tr>
      </table>
    </td></tr>
  </table>
</body>
</html>`;
          }
        }
      });
    });

    // Update preview when fields change (debounced)
    let previewTimer = null;
    ['template-header', 'template-message-top', 'template-message-bottom', 'template-button-text', 'template-custom-html'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', () => {
        clearTimeout(previewTimer);
        previewTimer = setTimeout(updatePreview, 400);
      });
    });

    let isEditMode = false;

    // Create template
    document.getElementById('create-template-btn').addEventListener('click', () => {
      isEditMode = false;
      document.getElementById('modal-title').textContent = 'Create Email Template';
      templateForm.reset();
      document.getElementById('template-id').value = '';
      document.getElementById('edit-is-system').value = 'false';
      document.getElementById('template-type').value = '';
      showModal(templateModal);
    });

    // Edit template
    document.querySelectorAll('.edit-template-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const templateId = btn.dataset.templateId;
        try {
          const response = await fetch(`${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}`, {
            credentials: 'include',
          });
          if (!response.ok) throw new Error('Failed to fetch template');

          const template = await response.json();

          const isSystem = btn.dataset.isSystem === 'true';
          isEditMode = !isSystem; // Don't auto-slug from name if editing
          document.getElementById('edit-is-system').value = isSystem ? 'true' : 'false';
          document.getElementById('modal-title').textContent = isSystem
            ? 'Customize Template (workspace override)'
            : 'Edit Email Template';
          // API returns camelCase due to _MarvinModel alias_generator
          const tpl = template;
          const f = (camel, snake) => tpl[camel] ?? tpl[snake] ?? '';

          document.getElementById('template-id').value = tpl.id;
          document.getElementById('template-type').value = f('templateType', 'template_type');
          document.getElementById('template-name').value = tpl.name || '';
          document.getElementById('template-description').value = tpl.description || '';
          document.getElementById('template-subject').value = tpl.subject || '';
          document.getElementById('template-header').value = f('headerText', 'header_text');
          document.getElementById('template-message-top').value = f('messageTop', 'message_top');
          document.getElementById('template-message-bottom').value = f('messageBottom', 'message_bottom');
          document.getElementById('template-button-text').value = f('buttonText', 'button_text');
          document.getElementById('template-custom-html').value = f('customHtml', 'custom_html');
          document.getElementById('template-enabled').checked = tpl.enabled !== false;

          const customHtml = f('customHtml', 'custom_html');
          if (customHtml) {
            document.querySelector('[data-mode="custom"]').click();
          } else {
            document.querySelector('[data-mode="structured"]').click();
          }

          showModal(templateModal);
        } catch (error) {
          console.error('Error loading template:', error);
          alert('Failed to load template');
        }
      });
    });

    // Save template
    templateForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const templateId = document.getElementById('template-id').value;
      const isCustomMode = document.querySelector('[data-mode="custom"]').classList.contains('active');

      const data = {
        template_type: document.getElementById('template-type').value,
        name: document.getElementById('template-name').value,
        description: document.getElementById('template-description').value,
        subject: document.getElementById('template-subject').value,
        enabled: document.getElementById('template-enabled').checked,
      };

      if (isCustomMode) {
        data.custom_html = document.getElementById('template-custom-html').value;
      } else {
        data.header_text = document.getElementById('template-header').value;
        data.message_top = document.getElementById('template-message-top').value;
        data.message_bottom = document.getElementById('template-message-bottom').value;
        data.button_text = document.getElementById('template-button-text').value;
      }

      try {
        // If editing a system template (no group_id), save as a new workspace override (POST)
        const isSystemTemplate = document.getElementById('edit-is-system')?.value === 'true';
        const url = (templateId && !isSystemTemplate)
          ? `${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}`
          : `${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates`;
        const method = (templateId && !isSystemTemplate) ? 'PATCH' : 'POST';

        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.detail || 'Failed to save template');
        }

        hideModal(templateModal);
        window.location.reload();
      } catch (error) {
        console.error('Error saving template:', error);
        alert(error.message);
      }
    });

    // Delete template
    document.querySelectorAll('.delete-template-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const templateId = btn.dataset.templateId;
        if (!confirm('Are you sure you want to delete this template?')) return;

        try {
          const response = await fetch(`${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}`, {
            method: 'DELETE',
            credentials: 'include',
          });

          if (!response.ok) throw new Error('Failed to delete template');

          window.location.reload();
        } catch (error) {
          console.error('Error deleting template:', error);
          alert('Failed to delete template');
        }
      });
    });

    // Known defaults so pre-filled fields don't distract from the unique ones
    const KNOWN_DEFAULTS = {
      workspace_name: GROUP_ID ? '(your workspace)' : '',
      inviter_name: 'A teammate',
      username: 'testuser',
      first_name: 'Test',
      expiry_hours: '24',
      title: 'Test Notification',
      message: 'This is a test notification.',
    };

    function extractSlugs(text) {
      const re = /\{\{([A-Za-z0-9_]+)\}\}/g;
      const slugs = new Set();
      let m;
      while ((m = re.exec(text)) !== null) slugs.add(m[1]);
      return [...slugs];
    }

    // Test send — scan actual template content for {{slugs}}
    document.querySelectorAll('.test-send-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const templateId = btn.dataset.templateId;
        const templateType = btn.dataset.templateType || '';
        document.getElementById('test-template-id').value = templateId;

        const varsContainer = document.getElementById('test-vars-container');
        const varsFields = document.getElementById('test-vars-fields');

        try {
          // Fetch the actual template content
          const res = await fetch(`${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}`, { credentials: 'include' });
          const tpl = res.ok ? await res.json() : null;

          let slugs = [];
          if (tpl) {
            const content = [
              tpl.subject, tpl.headerText ?? tpl.header_text,
              tpl.messageTop ?? tpl.message_top,
              tpl.messageBottom ?? tpl.message_bottom,
              tpl.buttonText ?? tpl.button_text,
              tpl.customHtml ?? tpl.custom_html,
            ].filter(Boolean).join(' ');
            slugs = extractSlugs(content);
          }

          // Also fetch type-level metadata for descriptions
          const metaRes = await fetch(`${apiUrl}/api/platform/email/template-vars?template_type=${templateType}`, { credentials: 'include' });
          const meta = metaRes.ok ? await metaRes.json() : { context_vars: [], required_vars: [] };
          const contextVars = meta.context_vars || [];
          const requiredVars = meta.required_vars || [];

          if (slugs.length > 0) {
            varsFields.innerHTML = slugs.map(slug => {
              const info = contextVars.find(v => v.slug === slug);
              const isRequired = requiredVars.includes(slug);
              const defaultVal = KNOWN_DEFAULTS[slug] || '';
              return `<div class="form-group" style="margin-bottom:12px;">
                <label style="font-size:13px;font-weight:500;display:block;margin-bottom:4px;">
                  <code style="color:#4f9c84;">{{${slug}}}</code>
                  ${isRequired ? '<span style="color:#c84b4b;font-size:10px;font-weight:700;margin-left:4px;">REQUIRED</span>' : ''}
                  ${info?.description ? `<span style="color:var(--muted);font-weight:400;"> — ${info.description}</span>` : ''}
                </label>
                <input type="text" class="input test-var-input" data-slug="${slug}"
                  placeholder="${info?.example || defaultVal || slug}"
                  value="${defaultVal}" />
              </div>`;
            }).join('');
            varsContainer.style.display = 'block';
          } else {
            varsContainer.style.display = 'none';
            varsFields.innerHTML = '';
          }
        } catch {
          varsContainer.style.display = 'none';
        }

        showModal(testSendModal);
      });
    });

    testSendForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const templateId = document.getElementById('test-template-id').value;
      const recipient = document.getElementById('test-recipient').value;

      const vars = {};
      document.querySelectorAll('.test-var-input').forEach(inp => {
        const slug = inp.dataset.slug;
        const val = inp.value.trim();
        if (slug && val) vars[slug] = val;
      });
      console.log('[test-send] variables being sent:', vars);

      try {
        const response = await fetch(`${apiUrl}/api/platform/email/templates/${templateId}/test`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ recipient_email: recipient, variables: vars }),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.detail || 'Failed to send test email');
        }

        const result = await response.json();
        if (result.warning) {
          alert('Test email sent, but: ' + result.warning);
        } else {
          alert('Test email sent successfully!');
        }
        hideModal(testSendModal);
      } catch (error) {
        console.error('Error sending test email:', error);
        alert(error.message);
      }
    });

    // Template search filter
    document.getElementById('template-search')?.addEventListener('input', (e) => {
      const q = e.target.value.toLowerCase();
      document.querySelectorAll('#templates-list-container .template-card').forEach(card => {
        const text = card.textContent.toLowerCase();
        card.style.display = text.includes(q) ? '' : 'none';
      });
    });

    // Close modal handlers
    document.getElementById('close-modal').addEventListener('click', () => hideModal(templateModal));
    document.getElementById('cancel-btn').addEventListener('click', () => hideModal(templateModal));
    document.getElementById('close-test-modal').addEventListener('click', () => hideModal(testSendModal));
    document.getElementById('cancel-test-btn').addEventListener('click', () => hideModal(testSendModal));

    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
          hideModal(templateModal);
          hideModal(testSendModal);
        }
      });
    });
  </script>

  <script define:vars={{ apiUrl }}>
    const testForm = document.getElementById('test-email-form');
    const testResult = document.getElementById('test-result');

    testForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);

      const payload = {
        email: formData.get('test_email'),
        subject: formData.get('subject') || null,
        message: formData.get('message') || null,
      };

      testResult?.classList.remove('hidden', 'success', 'error');
      if (testResult) testResult.textContent = 'Sending test email...';
      testResult?.classList.add('info');

      try {
        const response = await fetch(`${apiUrl}/api/platform/email/test`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        testResult?.classList.remove('info');
        if (response.ok && result.success) {
          testResult?.classList.add('success');
          if (testResult) testResult.textContent = '✓ Test email sent successfully! Check your inbox at ' + payload.email;
        } else {
          testResult?.classList.add('error');
          const msg = result.error || result.detail || 'Unknown error';
          if (testResult) testResult.textContent = `✗ Failed: ${msg}`;
        }
      } catch (error) {
        testResult?.classList.remove('info');
        testResult?.classList.add('error');
        if (testResult) testResult.textContent = '✗ Network error. Please try again.';
        console.error('Error sending test email:', error);
      }
    });
  </script>
</AppLayout>

