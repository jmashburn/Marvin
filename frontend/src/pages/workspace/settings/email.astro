---
import AppLayout from "@/layouts/AppLayout.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { getAuthToken } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";
import { listEmailTemplates } from "@/lib/api/emailTemplates";

const authToken = getAuthToken(Astro.cookies);

let workspace = null;
let emailTemplates = [];
let error: string | null = null;

try {
  workspace = await getCurrentWorkspace(authToken);

  if (workspace?.workspace?.group?.id) {
    emailTemplates = await listEmailTemplates(workspace.workspace.group.id, authToken);
  }
} catch (e) {
  console.error('[email-settings] Error:', e);
  error = e instanceof Error ? e.message : String(e);
}

const groupId = workspace?.workspace?.group?.id;
const apiUrl = import.meta.env.PUBLIC_MARVIN_API_URL || 'http://localhost:8080';
---

<AppLayout title="Email Settings" eyebrow="Workspace">
  <Breadcrumb items={[
    { label: "Workspace Settings", href: "/workspace/settings" },
    { label: "Email Settings" }
  ]} />

  <div class="toolbar">
    <div>
      <h2>Email Settings</h2>
      <p>Manage email templates and test sending for {workspace?.workspace?.name || 'this workspace'}</p>
    </div>
    <button class="button" id="create-template-btn">
      <span>+ Create Template</span>
    </button>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : (
    <div class="email-settings">
      <section class="settings-section">
        <h3>Email Templates</h3>
        <p class="section-description">Customize the emails sent from your workspace</p>

        <div class="templates-list">
          {emailTemplates.length === 0 ? (
            <div class="empty-state">
              <p>No custom email templates yet</p>
              <small>Create a template to customize emails sent from this workspace</small>
            </div>
          ) : (
            emailTemplates.map((template) => (
              <div class="template-card" data-template-id={template.id}>
                <div class="template-info">
                  <div class="template-header">
                    <strong>{template.name}</strong>
                    <span class="badge badge-type">{template.template_type}</span>
                    {template.enabled ? (
                      <span class="badge badge-active">Active</span>
                    ) : (
                      <span class="badge badge-inactive">Inactive</span>
                    )}
                    {!template.group_id && (
                      <span class="badge badge-system">System</span>
                    )}
                  </div>
                  <p>{template.description || 'No description'}</p>
                </div>
                <div class="template-actions">
                  <button
                    class="button secondary small edit-template-btn"
                    data-template-id={template.id}
                    disabled={!template.group_id}
                  >
                    Edit
                  </button>
                  <button
                    class="button secondary small test-send-btn"
                    data-template-id={template.id}
                  >
                    Test Send
                  </button>
                  {template.group_id && (
                    <button
                      class="button danger small delete-template-btn"
                      data-template-id={template.id}
                    >
                      Delete
                    </button>
                  )}
                </div>
              </div>
            ))
          )}
        </div>
      </section>

      <section class="settings-section">
        <h3>Test Email Delivery</h3>
        <p class="section-description">Send a test email to verify SMTP configuration</p>

        <form id="test-email-form" class="test-form">
          <label class="form-field">
            <span class="label">Test Email Address *</span>
            <input
              type="email"
              name="test_email"
              placeholder="test@example.com"
              required
              class="input"
            />
          </label>

          <label class="form-field">
            <span class="label">Subject</span>
            <input
              type="text"
              name="subject"
              value="Marvin Platform - Test Email"
              class="input"
            />
          </label>

          <label class="form-field">
            <span class="label">Message</span>
            <textarea
              name="message"
              rows="4"
              class="input textarea"
            >This is a test email from Marvin Platform. If you received this, your SMTP configuration is working correctly.</textarea>
          </label>

          <div class="form-actions">
            <button type="submit" class="button">Send Test Email</button>
          </div>
        </form>

        <div id="test-result" class="test-result hidden"></div>
      </section>

      <section class="settings-section">
        <h3>SMTP Configuration</h3>
        <p class="section-description">Workspace-specific email server settings (optional)</p>

        <div class="coming-soon-box">
          <p>📧 Workspace-specific SMTP configuration coming soon</p>
          <p class="hint">Currently using system-wide SMTP settings from admin configuration</p>
        </div>
      </section>
    </div>
  )}

  <!-- Email Template Modal -->
  <div id="template-modal" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">Create Email Template</h3>
        <button class="modal-close" id="close-modal">&times;</button>
      </div>
      <form id="template-form">
        <input type="hidden" id="template-id" />

        <div class="form-section">
          <h4 class="section-label">Basic Information</h4>

          <input type="hidden" id="template-type" />

          <div class="form-group">
            <label for="template-name">Template Name *</label>
            <input
              type="text"
              id="template-name"
              placeholder="e.g., Workspace Invitation"
              required
            />
            <small>A friendly name for this template. The template type will be automatically generated.</small>
          </div>

          <div class="form-group">
            <label for="template-description">Description</label>
            <input
              type="text"
              id="template-description"
              placeholder="Brief description of this template"
            />
          </div>

          <div class="form-group">
            <label for="template-subject">Email Subject *</label>
            <input
              type="text"
              id="template-subject"
              placeholder="e.g., You're invited to {{ workspace_name }}"
              required
            />
            <small>Use {'{{ variable }}'} for dynamic values</small>
          </div>
        </div>

        <div class="form-section">
          <h4 class="section-label">Template Content</h4>

          <div class="template-mode-tabs">
            <button type="button" class="mode-tab active" data-mode="structured">
              <span>📝 Structured Template</span>
              <small>Use the default email layout</small>
            </button>
            <button type="button" class="mode-tab" data-mode="custom">
              <span>💻 Custom HTML</span>
              <small>Full control over design</small>
            </button>
          </div>

          <div id="structured-fields" class="template-mode-content">
            <div class="form-group">
              <label for="template-header">Header Text</label>
              <input
                type="text"
                id="template-header"
                placeholder="e.g., You're Invited!"
              />
              <small>Large heading at the top of the email</small>
            </div>

            <div class="form-group">
              <label for="template-message-top">Message Top</label>
              <textarea
                id="template-message-top"
                rows="4"
                placeholder="Main message content (supports {{ variables }})"
              ></textarea>
              <small>Primary message shown above the button</small>
            </div>

            <div class="form-group">
              <label for="template-button-text">Button Text</label>
              <input
                type="text"
                id="template-button-text"
                placeholder="e.g., Accept Invitation"
              />
            </div>

            <div class="form-group">
              <label for="template-message-bottom">Message Bottom</label>
              <textarea
                id="template-message-bottom"
                rows="3"
                placeholder="Additional message content"
              ></textarea>
              <small>Secondary message shown below the button</small>
            </div>
          </div>

          <div id="custom-html-field" class="template-mode-content" style="display: none;">
            <div class="form-group">
              <label for="template-custom-html">Custom HTML Template</label>
              <textarea
                id="template-custom-html"
                rows="16"
                placeholder="<!DOCTYPE html>
<html>
<body>
  <h1>{{ workspace_name }}</h1>
  <p>Your custom email content here...</p>
</body>
</html>"
              ></textarea>
              <small>Full Jinja2 HTML template with complete control over styling and structure</small>
            </div>
          </div>
        </div>

        <div class="form-section form-section-compact">
          <label class="checkbox-label">
            <input type="checkbox" id="template-enabled" checked />
            <span>Enable this template</span>
          </label>
        </div>

        <div class="vars-panel">
          <div class="vars-header">
            <span class="vars-title">Insert variable</span>
            <span class="vars-hint">Click to copy — paste into subject or body</span>
          </div>
          <div id="vars-list" class="vars-list">
            <span class="vars-loading">Loading…</span>
          </div>
        </div>

        <div class="modal-actions">
          <button type="button" class="button secondary" id="cancel-btn">Cancel</button>
          <button type="submit" class="button primary">Save Template</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Test Send Modal -->
  <div id="test-send-modal" class="modal">
    <div class="modal-overlay"></div>
    <div class="modal-content modal-small">
      <div class="modal-header">
        <h3>Send Test Email</h3>
        <button class="modal-close" id="close-test-modal">&times;</button>
      </div>
      <form id="test-send-form">
        <input type="hidden" id="test-template-id" />

        <div class="form-group">
          <label for="test-recipient">Recipient Email *</label>
          <input
            type="email"
            id="test-recipient"
            placeholder="test@example.com"
            required
          />
        </div>

        <div class="modal-actions">
          <button type="button" class="button secondary" id="cancel-test-btn">Cancel</button>
          <button type="submit" class="button">Send Test Email</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ groupId, apiUrl }}>
    const GROUP_ID = groupId;

    // Slugify function
    function slugify(text) {
      return text
        .toString()
        .toLowerCase()
        .trim()
        .replace(/\s+/g, '_')           // Replace spaces with _
        .replace(/[^\w\-]+/g, '')       // Remove non-word chars
        .replace(/\_\_+/g, '_')         // Replace multiple _ with single _
        .replace(/^-+/, '')             // Trim _ from start
        .replace(/-+$/, '');            // Trim _ from end
    }

    // Modal management
    const templateModal = document.getElementById('template-modal');
    const testSendModal = document.getElementById('test-send-modal');
    const templateForm = document.getElementById('template-form');
    const testSendForm = document.getElementById('test-send-form');

    // Load workspace variables into the template modal
    async function loadVariables() {
      const varsList = document.getElementById('vars-list');
      if (!varsList) return;
      try {
        const res = await fetch(`${apiUrl}/api/groups/variables`, { credentials: 'include' });
        if (!res.ok) throw new Error();
        const vars = await res.json();
        if (!vars.length) {
          varsList.innerHTML = '<span class="vars-empty">No variables defined. Add them in <a href="/workspace/settings/environment">Environment settings</a>.</span>';
          return;
        }
        varsList.innerHTML = vars.map((v) => {
          const slug = '{{' + v.slug + '}}';
          const val = v.value || '';
          const valDisplay = val.length > 30 ? val.slice(0, 30) + '...' : val;
          const valHtml = val ? '<span class="var-value">' + valDisplay + '</span>' : '';
          return '<button type="button" class="var-chip" data-slug="' + slug + '" title="' + val + '">' +
            '<code>' + slug + '</code>' + valHtml + '</button>';
        }).join('');
        varsList.querySelectorAll('.var-chip').forEach(chip => {
          chip.addEventListener('click', async () => {
            const slug = chip.dataset.slug;
            await navigator.clipboard.writeText(slug);
            const orig = chip.querySelector('code').textContent;
            chip.querySelector('code').textContent = '✓ Copied!';
            setTimeout(() => { chip.querySelector('code').textContent = orig; }, 1200);
          });
        });
      } catch {
        varsList.innerHTML = '<span class="vars-empty">Could not load variables.</span>';
      }
    }

    // Show/hide modals
    function showModal(modal) {
      modal.classList.add('show');
      document.body.style.overflow = 'hidden';
      if (modal === templateModal) loadVariables();
    }

    function hideModal(modal) {
      modal.classList.remove('show');
      document.body.style.overflow = '';
    }

    // Template mode tabs
    document.querySelectorAll('.mode-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const mode = tab.dataset.mode;
        document.querySelectorAll('.mode-tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        if (mode === 'structured') {
          document.getElementById('structured-fields').style.display = 'block';
          document.getElementById('custom-html-field').style.display = 'none';
        } else {
          document.getElementById('structured-fields').style.display = 'none';
          document.getElementById('custom-html-field').style.display = 'block';
        }
      });
    });

    // Auto-generate template type from name
    let isEditMode = false;
    document.getElementById('template-name').addEventListener('input', (e) => {
      if (!isEditMode) {
        const slug = slugify(e.target.value);
        document.getElementById('template-type').value = slug;
      }
    });

    // Create template
    document.getElementById('create-template-btn').addEventListener('click', () => {
      isEditMode = false;
      document.getElementById('modal-title').textContent = 'Create Email Template';
      templateForm.reset();
      document.getElementById('template-id').value = '';
      document.getElementById('template-type').value = '';
      showModal(templateModal);
    });

    // Edit template
    document.querySelectorAll('.edit-template-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const templateId = btn.dataset.templateId;
        try {
          const response = await fetch(`${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}`, {
            credentials: 'include',
          });
          if (!response.ok) throw new Error('Failed to fetch template');

          const template = await response.json();

          isEditMode = true;
          document.getElementById('modal-title').textContent = 'Edit Email Template';
          document.getElementById('template-id').value = template.id;
          document.getElementById('template-type').value = template.template_type;
          document.getElementById('template-name').value = template.name;
          document.getElementById('template-description').value = template.description || '';
          document.getElementById('template-subject').value = template.subject;
          document.getElementById('template-header').value = template.header_text || '';
          document.getElementById('template-message-top').value = template.message_top || '';
          document.getElementById('template-message-bottom').value = template.message_bottom || '';
          document.getElementById('template-button-text').value = template.button_text || '';
          document.getElementById('template-custom-html').value = template.custom_html || '';
          document.getElementById('template-enabled').checked = template.enabled;

          if (template.custom_html) {
            document.querySelector('[data-mode="custom"]').click();
          } else {
            document.querySelector('[data-mode="structured"]').click();
          }

          showModal(templateModal);
        } catch (error) {
          console.error('Error loading template:', error);
          alert('Failed to load template');
        }
      });
    });

    // Save template
    templateForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const templateId = document.getElementById('template-id').value;
      const isCustomMode = document.querySelector('[data-mode="custom"]').classList.contains('active');

      const data = {
        template_type: document.getElementById('template-type').value,
        name: document.getElementById('template-name').value,
        description: document.getElementById('template-description').value,
        subject: document.getElementById('template-subject').value,
        enabled: document.getElementById('template-enabled').checked,
      };

      if (isCustomMode) {
        data.custom_html = document.getElementById('template-custom-html').value;
      } else {
        data.header_text = document.getElementById('template-header').value;
        data.message_top = document.getElementById('template-message-top').value;
        data.message_bottom = document.getElementById('template-message-bottom').value;
        data.button_text = document.getElementById('template-button-text').value;
      }

      try {
        const url = templateId
          ? `${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}`
          : `${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates`;
        const method = templateId ? 'PATCH' : 'POST';

        const response = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.detail || 'Failed to save template');
        }

        hideModal(templateModal);
        window.location.reload();
      } catch (error) {
        console.error('Error saving template:', error);
        alert(error.message);
      }
    });

    // Delete template
    document.querySelectorAll('.delete-template-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const templateId = btn.dataset.templateId;
        if (!confirm('Are you sure you want to delete this template?')) return;

        try {
          const response = await fetch(`${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}`, {
            method: 'DELETE',
            credentials: 'include',
          });

          if (!response.ok) throw new Error('Failed to delete template');

          window.location.reload();
        } catch (error) {
          console.error('Error deleting template:', error);
          alert('Failed to delete template');
        }
      });
    });

    // Test send
    document.querySelectorAll('.test-send-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.getElementById('test-template-id').value = btn.dataset.templateId;
        showModal(testSendModal);
      });
    });

    testSendForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const templateId = document.getElementById('test-template-id').value;
      const recipient = document.getElementById('test-recipient').value;

      try {
        const response = await fetch(`${apiUrl}/api/platform/workspaces/${GROUP_ID}/email-templates/${templateId}/test`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ recipient_email: recipient }),
        });

        if (!response.ok) {
          const error = await response.json();
          throw new Error(error.detail || 'Failed to send test email');
        }

        alert('Test email sent successfully!');
        hideModal(testSendModal);
      } catch (error) {
        console.error('Error sending test email:', error);
        alert(error.message);
      }
    });

    // Close modal handlers
    document.getElementById('close-modal').addEventListener('click', () => hideModal(templateModal));
    document.getElementById('cancel-btn').addEventListener('click', () => hideModal(templateModal));
    document.getElementById('close-test-modal').addEventListener('click', () => hideModal(testSendModal));
    document.getElementById('cancel-test-btn').addEventListener('click', () => hideModal(testSendModal));

    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
          hideModal(templateModal);
          hideModal(testSendModal);
        }
      });
    });
  </script>

  <script define:vars={{ apiUrl }}>
    const testForm = document.getElementById('test-email-form');
    const testResult = document.getElementById('test-result');

    testForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);

      const payload = {
        email: formData.get('test_email'),
      };

      testResult?.classList.remove('hidden', 'success', 'error');
      if (testResult) testResult.textContent = 'Sending test email...';
      testResult?.classList.add('info');

      try {
        const response = await fetch(`${apiUrl}/api/platform/email/test`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          const result = await response.json();
          testResult?.classList.remove('info');
          testResult?.classList.add('success');
          if (testResult) testResult.textContent = '✓ Test email sent successfully! Check your inbox at ' + payload.email;
        } else {
          const error = await response.json();
          testResult?.classList.remove('info');
          testResult?.classList.add('error');
          if (testResult) testResult.textContent = `✗ Failed to send test email: ${error.detail || error.error || 'Unknown error'}`;
        }
      } catch (error) {
        testResult?.classList.remove('info');
        testResult?.classList.add('error');
        if (testResult) testResult.textContent = '✗ Network error. Please try again.';
        console.error('Error sending test email:', error);
      }
    });
  </script>
</AppLayout>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .email-settings {
    max-width: 900px;
  }

  .settings-section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 24px;
  }

  .settings-section h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .section-description {
    margin: 0 0 20px;
    color: var(--muted);
    font-size: 14px;
  }

  .test-form {
    display: grid;
    gap: 16px;
  }

  .form-field {
    display: grid;
    gap: 6px;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
  }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

  .test-result {
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: var(--radius);
    font-size: 14px;
  }

  .test-result.hidden {
    display: none;
  }

  .test-result.info {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .test-result.success {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .test-result.error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .templates-list {
    display: grid;
    gap: 12px;
  }

  .template-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 20px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .template-info {
    flex: 1;
  }

  .template-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 4px;
  }

  .template-header strong {
    font-size: 15px;
    font-weight: 600;
  }

  .template-info p {
    margin: 0;
    font-size: 13px;
    color: var(--muted);
  }

  .template-actions {
    display: flex;
    gap: 8px;
  }

  .badge {
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge-active {
    background: rgb(53 122 85 / 0.1);
    color: var(--good);
  }

  .badge-coming-soon {
    background: rgb(169 77 63 / 0.1);
    color: var(--muted);
  }

  .test-email-form {
    display: grid;
    gap: 16px;
    max-width: 500px;
  }

  .form-group {
    display: grid;
    gap: 6px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 500;
  }

  .form-group input {
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .form-group input:disabled {
    background: var(--panel-2);
    color: var(--muted);
    cursor: not-allowed;
  }

  .form-group small {
