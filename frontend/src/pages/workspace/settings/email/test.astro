---
import Breadcrumb from "@/components/Breadcrumb.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";

const authToken = getAuthToken(Astro.cookies);

let workspace = null;
try {
  workspace = await getCurrentWorkspace(authToken);
} catch (e) {
  console.error("[email-test] Error loading workspace:", e);
}

const apiUrl = import.meta.env.PUBLIC_MARVIN_API_URL || "http://localhost:8080";
---

<AppLayout title="Test Emails" eyebrow="Workspace">
  <Breadcrumb items={[
    { label: "Workspace Settings", href: "/workspace/settings" },
    { label: "Email", href: "/workspace/settings?tab=email" },
    { label: "Test Emails" }
  ]} />

  <div class="toolbar">
    <div>
      <h2>Test Emails</h2>
      <p>Send a test email to verify SMTP delivery for {workspace?.workspace?.name || 'this workspace'}</p>
    </div>
  </div>

  <div class="email-test">
    <section class="settings-section">
      <h3>Test Email Delivery</h3>
      <p class="section-description">Send a test email to verify SMTP configuration</p>

      <form id="test-email-form" class="test-form">
        <label class="form-field">
          <span class="label">Test Email Address *</span>
          <input
            type="email"
            name="test_email"
            placeholder="test@example.com"
            required
            class="input"
          />
        </label>

        <label class="form-field">
          <span class="label">Subject</span>
          <input
            type="text"
            name="subject"
            value="Marvin Platform - Test Email"
            class="input"
          />
        </label>

        <label class="form-field">
          <span class="label">Message</span>
          <textarea
            name="message"
            rows="4"
            class="input textarea"
          >This is a test email from Marvin Platform. If you received this, your SMTP configuration is working correctly.</textarea>
        </label>

        <div class="form-actions">
          <button type="submit" class="button">Send Test Email</button>
        </div>
      </form>

      <div id="test-result" class="test-result hidden"></div>
    </section>
  </div>

  <script define:vars={{ apiUrl }}>
    const testForm = document.getElementById('test-email-form');
    const testResult = document.getElementById('test-result');

    testForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);

      const payload = {
        email: formData.get('test_email'),
        subject: formData.get('subject') || null,
        message: formData.get('message') || null,
      };

      testResult?.classList.remove('hidden', 'success', 'error');
      if (testResult) testResult.textContent = 'Sending test email...';
      testResult?.classList.add('info');

      try {
        const response = await fetch(`${apiUrl}/api/platform/email/test`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        testResult?.classList.remove('info');
        if (response.ok && result.success) {
          testResult?.classList.add('success');
          if (testResult) testResult.textContent = '✓ Test email sent successfully! Check your inbox at ' + payload.email;
        } else {
          testResult?.classList.add('error');
          const msg = result.error || result.detail || 'Unknown error';
          if (testResult) testResult.textContent = `✗ Failed: ${msg}`;
        }
      } catch (error) {
        testResult?.classList.remove('info');
        testResult?.classList.add('error');
        if (testResult) testResult.textContent = '✗ Network error. Please try again.';
        console.error('Error sending test email:', error);
      }
    });
  </script>
</AppLayout>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .email-test {
    max-width: 900px;
  }

  .settings-section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 24px;
  }

  .settings-section h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .section-description {
    margin: 0 0 20px;
    color: var(--muted);
    font-size: 14px;
  }

  .test-form {
    display: grid;
    gap: 16px;
  }

  .form-field {
    display: grid;
    gap: 6px;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
  }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

  .test-result {
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: var(--radius);
    font-size: 14px;
  }

  .test-result.hidden {
    display: none;
  }

  .test-result.info,
  .test-result.success {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .test-result.error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }
</style>
