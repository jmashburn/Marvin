---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";
import { getCurrentWorkspace } from "@/lib/api/workspaces";
import { listWorkspaceMembers } from "@/lib/api/workspaceMembers";
import type { WorkspaceRole } from "@/lib/api/types";

const authToken = getAuthToken(Astro.cookies);
let workspace = null;
let error: string | null = null;
let currentUserRole: WorkspaceRole | null = null;
let isPlatformAdmin = false;

try {
  workspace = await getCurrentWorkspace(authToken);

  if (workspace) {
    // Get current user's role and admin status
    const members = await listWorkspaceMembers(workspace.id, authToken);
    const currentUser = await fetchApi<any>('/api/self', {}, authToken);
    if (currentUser) {
      const currentMembership = members.find(m => (m as any).userId === currentUser.id || (m as any).user_id === currentUser.id);
      currentUserRole = (currentMembership as any)?.workspaceRole || (currentMembership as any)?.workspace_role || null;
      isPlatformAdmin = currentUser.admin === true;
    }
  }
} catch (e) {
  console.error('[settings] Error loading:', e);
  error = e instanceof Error ? e.message : String(e);
}

const canManage = currentUserRole && (currentUserRole === 'OWNER' || currentUserRole === 'ADMIN');

const urlParams = Astro.url.searchParams;
const success = urlParams.get('success') === '1';
---

<AppLayout title="General Settings" eyebrow="Workspace">
  <div class="toolbar">
    <div>
      <h2>Workspace Settings</h2>
      <p>Manage your workspace configuration and preferences</p>
    </div>
  </div>

  {success && (
    <div class="alert alert-success">
      <strong>Success!</strong> Workspace settings updated successfully
    </div>
  )}

  {error ? (
    <div class="error-banner">
      <p><strong>Error:</strong> {error}</p>
    </div>
  ) : workspace ? (
    <div class="settings-container">
      {!canManage ? (
        <div class="alert alert-info">
          You need OWNER or ADMIN role to manage workspace settings.
        </div>
      ) : null}

      <section class="settings-section">
        <h3>General Settings</h3>
        <form
          id="workspace-settings-form"
          data-workspace-id={workspace.id}
          method="POST"
          action="/api/groups/{workspace.id}/preferences"
          class="settings-form"
        >
          <div class="form-grid">
            <label>
              <span>Workspace Name</span>
              <input
                type="text"
                name="name"
                value={workspace.name}
                disabled={!canManage}
              />
              <small>Slug is auto-generated from the name</small>
            </label>
          </div>

          {canManage && (
            <div class="form-actions">
              <button type="submit" id="submit-btn" class="button">Save Changes</button>
              <button type="reset" class="button secondary">Reset</button>
            </div>
          )}
        </form>
      </section>

      <section class="settings-section">
        <h3>Workspace Information</h3>
        <div class="info-grid">
          <div class="info-item">
            <span class="info-label">Workspace ID</span>
            <code class="info-value">{workspace.id}</code>
          </div>
          <div class="info-item">
            <span class="info-label">Slug</span>
            <code class="info-value">{workspace.slug || "Not set"}</code>
          </div>
          <div class="info-item">
            <span class="info-label">Your Role</span>
            <span class="info-value role-badge">{currentUserRole}</span>
          </div>
          <div class="info-item">
            <span class="info-label">Active Status</span>
            <span class="info-value">{true ? "Active" : "Inactive"}</span>
          </div>
        </div>
      </section>

      <section class="settings-section danger-zone">
        <h3>Danger Zone</h3>
        <p>Irreversible and destructive actions.</p>

        {isPlatformAdmin ? (
          <div class="danger-actions">
            <button
              type="button"
              id="delete-workspace-btn"
              class="button danger"
              data-workspace-id={workspace.id}
              data-workspace-name={workspace.name}
            >
              Delete Workspace
            </button>
            <small>⚠️ Platform admin only - This will permanently delete the workspace and all its data</small>
          </div>
        ) : (
          <p class="muted">Only platform administrators can delete workspaces.</p>
        )}
      </section>
    </div>
  ) : (
    <div class="empty-state">
      <p>No workspace selected</p>
    </div>
  )}
</AppLayout>

<script>
  import { fetchApi } from '@/lib/api/client';

  const form = document.getElementById('workspace-settings-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const deleteBtn = document.getElementById('delete-workspace-btn') as HTMLButtonElement;

  // Settings form submission
  if (form && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const workspaceId = form.dataset.workspaceId;
      if (!workspaceId) {
        alert('Workspace ID not found');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Saving...';

      try {
        const formData = new FormData(form);
        const data = {
          name: formData.get('name') as string,
        };

        await fetchApi(`/api/groups/${workspaceId}/preferences`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        window.location.href = '/workspace/settings?success=1';
      } catch (err) {
        alert('Error: ' + (err instanceof Error ? err.message : 'Failed to update workspace settings'));
        submitBtn.disabled = false;
        submitBtn.textContent = 'Save Changes';
      }
    });
  }

  // Delete workspace
  if (deleteBtn) {
    deleteBtn.addEventListener('click', async () => {
      const workspaceId = deleteBtn.dataset.workspaceId;
      const workspaceName = deleteBtn.dataset.workspaceName;

      if (!workspaceId) {
        alert('Workspace ID not found');
        return;
      }

      // Double confirmation for destructive action
      const confirmation = confirm(
        `⚠️ DELETE WORKSPACE: "${workspaceName}"\n\n` +
        `This will permanently delete:\n` +
        `• The workspace and all settings\n` +
        `• All workspace members\n` +
        `• All entries and collections\n` +
        `• All assets and media\n\n` +
        `This action CANNOT be undone.\n\n` +
        `Are you absolutely sure you want to proceed?`
      );

      if (!confirmation) return;

      // Second confirmation
      const secondConfirmation = confirm(
        `FINAL WARNING\n\n` +
        `You are about to permanently delete workspace "${workspaceName}".\n\n` +
        `Type the workspace name to confirm, or click Cancel.`
      );

      if (!secondConfirmation) return;

      deleteBtn.disabled = true;
      deleteBtn.textContent = 'Deleting...';

      try {
        await fetchApi(`/api/admin/groups/${workspaceId}?force=true`, {
          method: 'DELETE',
        });

        alert('Workspace deleted successfully. Redirecting...');
        window.location.href = '/';
      } catch (err) {
        console.error('Delete error:', err);
        alert('Error: ' + (err instanceof Error ? err.message : 'Failed to delete workspace'));
        deleteBtn.disabled = false;
        deleteBtn.textContent = 'Delete Workspace';
      }
    });
  }
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .settings-container {
    max-width: 800px;
  }

  .settings-section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 24px;
  }

  .settings-section h3 {
    margin: 0 0 16px;
    font-size: 18px;
    font-weight: 600;
  }

  .settings-section > p {
    margin: 0 0 16px;
    color: var(--muted);
    font-size: 14px;
  }

  .form-grid {
    display: grid;
    gap: 20px;
  }

  .form-grid label {
    display: grid;
    gap: 8px;
  }

  .form-grid label > span {
    font-size: 14px;
    font-weight: 500;
  }

  .form-grid small {
    font-size: 13px;
    color: var(--muted);
    margin-top: -4px;
  }

  .form-grid input {
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .form-grid input:disabled {
    background: var(--panel-2);
    color: var(--muted);
    cursor: not-allowed;
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--line);
  }

  .info-grid {
    display: grid;
    gap: 16px;
  }

  .info-item {
    display: grid;
    gap: 6px;
  }

  .info-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-value {
    font-size: 14px;
  }

  .info-value code {
    font-family: 'SF Mono', 'Monaco', 'Courier New', monospace;
    font-size: 13px;
    background: var(--panel-2);
    padding: 4px 8px;
    border-radius: 4px;
  }

  .role-badge {
    display: inline-block;
    padding: 4px 10px;
    background: var(--color-primary-bg);
    color: var(--accent);
    border-radius: 4px;
    font-size: 13px;
    font-weight: 500;
  }

  .danger-zone {
    border-color: var(--warn);
  }

  .danger-zone h3 {
    color: var(--warn);
  }

  .danger-actions {
    display: grid;
    gap: 8px;
  }

  .danger-actions small {
    font-size: 13px;
    color: var(--muted);
  }

  .button.danger {
    background: var(--warn);
    color: white;
    border: none;
  }

  .button.danger:hover:not(:disabled) {
    background: var(--accent);
  }

  .button.danger:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-info {
    background: rgb(47 111 115 / 0.1);
    color: var(--accent-2);
    border: 1px solid var(--accent-2);
  }

  .error-banner {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    padding: 16px;
    margin-bottom: 24px;
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--muted);
  }

  .muted {
    color: var(--muted);
    font-size: 14px;
  }

  .alert-success {
    background: rgb(53 122 85 / 0.1);
    color: var(--good);
    border: 1px solid var(--good);
  }

  .button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
</style>
