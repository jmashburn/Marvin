---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { listProviders, listIntegrations, listPlugins } from "@/lib/api/integrations";
import type { Integration, IntegrationProviderInfo, IntegrationPluginInfo } from "@/lib/api/integrations";

const authToken = getAuthToken(Astro.cookies);

let providers: IntegrationProviderInfo[] = [];
let integrations: Integration[] = [];
let plugins: IntegrationPluginInfo[] = [];
let error: string | null = null;

try {
  [providers, integrations, plugins] = await Promise.all([
    listProviders(authToken),
    listIntegrations(authToken),
    listPlugins(authToken),
  ]);
} catch (e) {
  console.error("[integrations] load error:", e);
  error = e instanceof Error ? e.message : String(e);
}

const providersBySlug = new Map(providers.map((p) => [p.slug, p]));

const CATEGORY_LABEL: Record<string, string> = {
  source: "Source",
  destination: "Destination",
  capability: "Capability",
  notify: "Notify",
};

function statusMeta(status: string): { text: string; cls: string } {
  if (status === "ok") return { text: "Connected", cls: "ok" };
  if (status === "error") return { text: "Error", cls: "err" };
  if (status === "unavailable") return { text: "Unavailable", cls: "err" };
  return { text: "Not configured", cls: "warn" };
}
---

<AppLayout title="Integrations" eyebrow="Settings">
  <div class="page-header">
    <div>
      <h2>Integrations</h2>
      <p>Connect external services — sources that feed content in, destinations that react when you publish.</p>
    </div>
    <a href="/workspace/settings?tab=integrations" class="button secondary small">Back to Settings</a>
  </div>

  {error && (
    <div class="alert"><strong>Couldn't load integrations.</strong> {error}</div>
  )}

  <!-- Connected -->
  <section class="block">
    <h3 class="block-title">Connected</h3>
    {integrations.length === 0 ? (
      <div class="empty">
        <p>No integrations yet.</p>
        <p class="hint">Add one from the catalog below.</p>
      </div>
    ) : (
      <div class="conn-list">
        {integrations.map((it) => {
          const prov = providersBySlug.get(it.provider);
          const st = statusMeta(it.status);
          return (
            <article class={`conn-card ${it.enabled ? "" : "is-disabled"}`} data-id={it.id}>
              <div class="conn-top">
                <div class="conn-id">
                  <strong>{it.name}</strong>
                  <span class="conn-sub">
                    {prov?.name ?? it.provider}
                    {prov && ` · ${CATEGORY_LABEL[prov.category] ?? prov.category}`}
                  </span>
                </div>
                <div class="conn-status">
                  <span class={`badge ${st.cls}`}>{st.text}</span>
                  <label class="toggle" title={it.enabled ? "Enabled — click to disable" : "Disabled — click to enable"}>
                    <input type="checkbox" class="js-toggle" checked={it.enabled} data-id={it.id} />
                    <span class="toggle-track"><span class="toggle-thumb"></span></span>
                  </label>
                </div>
              </div>
              {it.lastError && <p class="conn-error">{it.lastError}</p>}
              <div class="conn-foot">
                <code class="conn-slug" title="Reference this integration from automations">{it.slug}</code>
                <div class="conn-btns">
                  {(prov?.actions ?? []).map((a) => (
                    <button type="button" class="button small secondary js-action" data-id={it.id} data-provider={it.provider} data-action={a.key} title={a.description}>
                      {a.label}
                    </button>
                  ))}
                  <button type="button" class="icon-btn-sm js-check" data-id={it.id} title="Run health check" aria-label="Run health check">↻</button>
                  <button type="button" class="icon-btn-sm danger js-delete" data-id={it.id} data-name={it.name} title="Delete integration" aria-label="Delete integration">✕</button>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </section>

  <!-- Catalog -->
  <section class="block">
    <h3 class="block-title">Add an integration</h3>
    {providers.length === 0 ? (
      <div class="empty"><p>No providers available.</p></div>
    ) : (
      <div class="catalog">
        {providers.map((p) => (
          <article class="cat-card">
            <div class="cat-head">
              <strong>{p.name}</strong>
              <span class="chip">{CATEGORY_LABEL[p.category] ?? p.category}</span>
            </div>
            <p class="cat-desc">{p.description}</p>
            <button type="button" class="button small js-configure" data-slug={p.slug}>Configure</button>
          </article>
        ))}
      </div>
    )}
  </section>

  <!-- Installed plugins -->
  <section class="block">
    <h3 class="block-title">Installed plugins</h3>
    <p class="block-sub">Provider packages available on this server. Install more with <code>uv pip install marvin-integration-…</code> and restart.</p>
    <div class="plugin-list">
      {plugins.map((pl) => (
        <article class={`plugin-row ${pl.ok ? "" : "is-error"}`}>
          <div class="plugin-id">
            <strong>{pl.distribution ?? pl.name}</strong>
            <span class="plugin-tags">
              <span class="chip">{pl.source === "builtin" ? "Built-in" : "Plugin"}</span>
              {pl.version && <span class="plugin-ver">v{pl.version}</span>}
            </span>
          </div>
          <div class="plugin-slugs">
            {pl.ok ? (
              pl.slugs.length ? pl.slugs.map((s) => <code>{s}</code>) : <span class="muted">no providers</span>
            ) : (
              <span class="plugin-err">Failed to load: {pl.error}</span>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Add panel (hidden until a provider is chosen) -->
  <div id="add-overlay" class="overlay" hidden>
    <div class="panel" role="dialog" aria-modal="true" aria-labelledby="add-title">
      <div class="panel-head">
        <h3 id="add-title">Configure integration</h3>
        <button type="button" class="icon-btn" id="add-close" aria-label="Close">×</button>
      </div>
      <form id="add-form">
        <input type="hidden" name="provider" id="add-provider" />
        <p class="panel-sub" id="add-provider-desc"></p>
        <label class="field">
          <span>Name</span>
          <input type="text" name="name" id="add-name" required placeholder="e.g. Production site" />
          <small>A label for this connection.</small>
        </label>
        <div id="add-fields"></div>
        <div id="add-error" class="inline-error" hidden></div>
        <div class="panel-actions">
          <button type="submit" class="button" id="add-submit">Add integration</button>
          <button type="button" class="button secondary" id="add-cancel">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Action panel (collects an action's inputs before firing) -->
  <div id="action-overlay" class="overlay" hidden>
    <div class="panel" role="dialog" aria-modal="true" aria-labelledby="action-title">
      <div class="panel-head">
        <h3 id="action-title">Run action</h3>
        <button type="button" class="icon-btn" id="action-close" aria-label="Close">×</button>
      </div>
      <p class="panel-sub" id="action-sub"></p>
      <div id="action-fields"></div>
      <div id="action-error" class="inline-error" hidden></div>
      <div class="panel-actions">
        <button type="button" class="button" id="action-run">Run</button>
        <button type="button" class="button secondary" id="action-cancel">Cancel</button>
      </div>
    </div>
  </div>

  <script type="application/json" id="providers-data" set:html={JSON.stringify(providers)}></script>
</AppLayout>

<script>
  import {
    createIntegration,
    deleteIntegration,
    updateIntegration,
    checkIntegration,
    runIntegrationAction,
  } from "@/lib/api/integrations";
  import type { IntegrationProviderInfo } from "@/lib/api/integrations";

  const providers: IntegrationProviderInfo[] = JSON.parse(
    document.getElementById("providers-data")?.textContent || "[]",
  );
  const bySlug = new Map(providers.map((p) => [p.slug, p]));

  const overlay = document.getElementById("add-overlay") as HTMLElement;
  const form = document.getElementById("add-form") as HTMLFormElement;
  const fieldsEl = document.getElementById("add-fields") as HTMLElement;
  const errEl = document.getElementById("add-error") as HTMLElement;

  function reload() {
    window.location.reload();
  }

  function toast(message: string, ok = true) {
    const el = document.createElement("div");
    el.className = `mv-toast ${ok ? "ok" : "err"}`;
    el.textContent = message;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 3200);
  }

  function showError(el: HTMLElement, message: string) {
    el.textContent = message;
    el.hidden = false;
  }

  function errorMessage(e: unknown): string {
    // SDK errors expose the API detail; fall back to the message.
    const anyE = e as { body?: { detail?: string }; message?: string };
    return anyE?.body?.detail || anyE?.message || "Something went wrong.";
  }

  function isNotFound(e: unknown): boolean {
    // The SDK raises _MarvinNotFoundError (status 404) when the row no longer exists.
    const anyE = e as { status?: number; name?: string; message?: string };
    return anyE?.status === 404 || anyE?.name === "_MarvinNotFoundError" || /not found/i.test(anyE?.message ?? "");
  }

  // ---- open / build the add panel ----
  function esc(s: unknown): string {
    return String(s ?? "").replace(
      /[&<>"']/g,
      (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c] as string),
    );
  }

  function fieldHtml(o: {
    kind: "credential" | "config";
    key: string;
    label: string;
    required: boolean;
    help?: string;
    type?: string;
    placeholder?: string;
  }): string {
    return `
      <label class="field">
        <span>${esc(o.label)}${o.required ? ' <em class="req">Required</em>' : ""}</span>
        <input type="${o.type ?? "text"}" data-kind="${o.kind}" data-key="${esc(o.key)}"
               ${o.required ? "required" : ""} placeholder="${esc(o.placeholder ?? "")}" autocomplete="off" />
        ${o.help ? `<small>${esc(o.help)}</small>` : ""}
      </label>`;
  }

  function openPanel(slug: string) {
    const p = bySlug.get(slug);
    if (!p) return;
    (document.getElementById("add-provider") as HTMLInputElement).value = slug;
    (document.getElementById("add-provider-desc") as HTMLElement).textContent = p.description;
    (document.getElementById("add-name") as HTMLInputElement).value = "";
    errEl.hidden = true;

    const props = (p.configSchema?.properties ?? {}) as Record<string, any>;
    const required = (p.configSchema?.required ?? []) as string[];
    const configKeys = Object.keys(props);
    // Only show section headers when the form has both kinds — otherwise they're noise.
    const grouped = p.credentials.length > 0 && configKeys.length > 0;

    const parts: string[] = [];
    if (p.credentials.length) {
      if (grouped) parts.push('<p class="group-label">Credentials</p>');
      for (const c of p.credentials) {
        parts.push(
          fieldHtml({ kind: "credential", key: c.key, label: c.label, required: c.required, help: c.help, type: "password", placeholder: "Stored as a secret" }),
        );
      }
    }
    if (configKeys.length) {
      if (grouped) parts.push('<p class="group-label">Settings</p>');
      for (const key of configKeys) {
        const prop = props[key];
        const isUri = prop.format === "uri" || prop.format === "url";
        parts.push(
          fieldHtml({
            kind: "config",
            key,
            label: prop.title || key,
            required: required.includes(key),
            help: prop.description,
            type: isUri ? "url" : "text",
            placeholder: isUri ? "https://…" : "",
          }),
        );
      }
    }
    fieldsEl.innerHTML = parts.join("");
    overlay.hidden = false;
  }

  function closePanel() {
    overlay.hidden = true;
  }

  document.querySelectorAll<HTMLButtonElement>(".js-configure").forEach((b) =>
    b.addEventListener("click", () => openPanel(b.dataset.slug!)),
  );
  document.getElementById("add-close")?.addEventListener("click", closePanel);
  document.getElementById("add-cancel")?.addEventListener("click", closePanel);
  overlay?.addEventListener("click", (e) => {
    if (e.target === overlay) closePanel();
  });

  // ---- submit create ----
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errEl.hidden = true;
    const provider = (document.getElementById("add-provider") as HTMLInputElement).value;
    const name = (document.getElementById("add-name") as HTMLInputElement).value.trim();

    const config: Record<string, unknown> = {};
    let credential: string | undefined;
    fieldsEl.querySelectorAll<HTMLInputElement>("input[data-kind]").forEach((inp) => {
      const v = inp.value.trim();
      if (!v) return;
      if (inp.dataset.kind === "config") config[inp.dataset.key!] = v;
      // Phase A stores a single credential; the first non-empty credential field wins.
      else if (inp.dataset.kind === "credential" && credential === undefined) credential = v;
    });

    const submit = document.getElementById("add-submit") as HTMLButtonElement;
    submit.disabled = true;
    try {
      await createIntegration({ provider, name, config, credential });
      reload();
    } catch (err) {
      showError(errEl, errorMessage(err));
      submit.disabled = false;
    }
  });

  // ---- connected-card actions ----
  document.querySelectorAll<HTMLInputElement>(".js-toggle").forEach((t) =>
    t.addEventListener("change", async () => {
      try {
        await updateIntegration(t.dataset.id!, { enabled: t.checked });
      } catch (err) {
        alert(errorMessage(err));
        t.checked = !t.checked;
      }
    }),
  );

  document.querySelectorAll<HTMLButtonElement>(".js-check").forEach((b) =>
    b.addEventListener("click", async () => {
      b.disabled = true;
      b.classList.add("busy");
      try {
        await checkIntegration(b.dataset.id!);
        reload();
      } catch (err) {
        alert(errorMessage(err));
        b.disabled = false;
        b.classList.remove("busy");
      }
    }),
  );

  // ---- action test-fire (collects inputs first when the action declares any) ----
  const actionOverlay = document.getElementById("action-overlay") as HTMLElement;
  const actionFieldsEl = document.getElementById("action-fields") as HTMLElement;
  const actionErrEl = document.getElementById("action-error") as HTMLElement;
  let pendingAction: { id: string; key: string } | null = null;

  function closeActionPanel() {
    actionOverlay.hidden = true;
    pendingAction = null;
  }

  async function fireAction(id: string, key: string, args: Record<string, unknown>) {
    return runIntegrationAction(id, key, args);
  }

  document.querySelectorAll<HTMLButtonElement>(".js-action").forEach((b) =>
    b.addEventListener("click", async () => {
      const provider = bySlug.get(b.dataset.provider || "");
      const action = provider?.actions?.find((a) => a.key === b.dataset.action);
      const schema = (action?.inputSchema || {}) as any;
      const props = (schema.properties || {}) as Record<string, any>;

      // No inputs → fire straight away. Otherwise open the panel to collect them.
      if (Object.keys(props).length === 0) {
        b.disabled = true;
        try {
          const res = await fireAction(b.dataset.id!, b.dataset.action!, {});
          toast(res.ok ? "Done." : "Action returned a failure.", res.ok);
        } catch (err) {
          toast(errorMessage(err), false);
        } finally {
          b.disabled = false;
        }
        return;
      }

      const required: string[] = schema.required || [];
      (document.getElementById("action-title") as HTMLElement).textContent = action!.label;
      (document.getElementById("action-sub") as HTMLElement).textContent = action!.description || "";
      actionErrEl.hidden = true;
      actionFieldsEl.innerHTML = Object.entries(props)
        .map(([key, prop]) =>
          fieldHtml({
            kind: "config",
            key,
            label: prop.title || key,
            required: required.includes(key),
            type: prop.format === "uri" ? "url" : "text",
          }),
        )
        .join("");
      pendingAction = { id: b.dataset.id!, key: b.dataset.action! };
      actionOverlay.hidden = false;
    }),
  );

  document.getElementById("action-close")?.addEventListener("click", closeActionPanel);
  document.getElementById("action-cancel")?.addEventListener("click", closeActionPanel);
  actionOverlay?.addEventListener("click", (e) => {
    if (e.target === actionOverlay) closeActionPanel();
  });

  document.getElementById("action-run")?.addEventListener("click", async () => {
    if (!pendingAction) return;
    actionErrEl.hidden = true;
    const args: Record<string, unknown> = {};
    let missing = false;
    actionFieldsEl.querySelectorAll<HTMLInputElement>("input[data-key]").forEach((inp) => {
      const v = inp.value.trim();
      if (v) args[inp.dataset.key!] = v;
      else if (inp.required) missing = true;
    });
    if (missing) {
      showError(actionErrEl, "Please fill in the required fields.");
      return;
    }
    const runBtn = document.getElementById("action-run") as HTMLButtonElement;
    runBtn.disabled = true;
    try {
      const res = await fireAction(pendingAction.id, pendingAction.key, args);
      closeActionPanel();
      toast(res.ok ? "Sent ✓" : "Action returned a failure.", res.ok);
    } catch (err) {
      showError(actionErrEl, errorMessage(err));
    } finally {
      runBtn.disabled = false;
    }
  });

  document.querySelectorAll<HTMLButtonElement>(".js-delete").forEach((b) =>
    b.addEventListener("click", async () => {
      if (b.disabled) return; // guard against a double-click firing two DELETEs
      if (!confirm(`Delete integration "${b.dataset.name}"? Its stored credential is removed too.`)) return;
      b.disabled = true;
      try {
        await deleteIntegration(b.dataset.id!);
        reload();
      } catch (err) {
        // A 404 means the row is already gone — that's the outcome we wanted, so treat it as success
        // (e.g. a duplicate request, or it was deleted elsewhere) rather than surfacing a scary popup.
        if (isNotFound(err)) {
          reload();
          return;
        }
        b.disabled = false;
        alert(errorMessage(err));
      }
    }),
  );
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }
  .page-header h2 { margin: 0; font-size: 24px; font-weight: 600; }
  .page-header p { margin: 8px 0 0; color: var(--muted); font-size: 14px; max-width: 60ch; }

  .alert {
    padding: 14px 16px;
    margin-bottom: 20px;
    border-radius: var(--radius);
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
    font-size: 14px;
  }

  .block { margin-bottom: 36px; }
  .block-title { margin: 0 0 6px; font-size: 15px; font-weight: 600; }
  .block-sub { margin: 0 0 14px; font-size: 13px; color: var(--muted); }
  .block-sub code { font-family: ui-monospace, monospace; font-size: 12px; }

  /* installed plugins */
  .plugin-list { display: grid; gap: 8px; }
  .plugin-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 16px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .plugin-row.is-error { border-color: var(--color-error); }
  .plugin-id { display: flex; align-items: center; gap: 10px; min-width: 0; }
  .plugin-id strong { font-size: 14px; }
  .plugin-tags { display: flex; align-items: center; gap: 8px; }
  .plugin-ver { font-size: 12px; color: var(--muted); font-family: ui-monospace, monospace; }
  .plugin-slugs { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; justify-content: flex-end; }
  .plugin-slugs code { font-family: ui-monospace, monospace; font-size: 12px; padding: 2px 7px; background: var(--panel-2); border-radius: 4px; }
  .plugin-slugs .muted { font-size: 12px; color: var(--muted); }
  .plugin-err { font-size: 12px; color: var(--color-error); }

  .empty {
    padding: 40px 24px;
    text-align: center;
    color: var(--muted);
    background: var(--panel);
    border: 1px dashed var(--line);
    border-radius: var(--radius);
  }
  .empty p { margin: 0; }
  .empty .hint { margin-top: 6px; font-size: 13px; }

  /* connected list */
  .conn-list { display: grid; gap: 12px; }
  .conn-card {
    padding: 14px 16px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .conn-card.is-disabled { opacity: 0.62; }

  .conn-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .conn-id { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .conn-id strong { font-size: 15px; }
  .conn-sub { font-size: 13px; color: var(--muted); }
  .conn-status { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }

  .conn-error { margin: 10px 0 0; font-size: 13px; color: var(--color-error); }

  .conn-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
  }
  .conn-slug { font-family: ui-monospace, monospace; font-size: 12px; color: var(--muted); }
  .conn-btns { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }

  .icon-btn-sm {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    color: var(--muted);
    font-size: 14px;
    cursor: pointer;
    transition: color 0.12s, border-color 0.12s;
  }
  .icon-btn-sm:hover { color: var(--ink); border-color: var(--muted); }
  .icon-btn-sm.danger:hover { color: var(--color-error); border-color: var(--color-error); }
  .icon-btn-sm.busy { opacity: 0.5; pointer-events: none; }
  .icon-btn-sm:disabled { opacity: 0.5; cursor: default; }

  .badge {
    font-size: 12px;
    font-weight: 500;
    padding: 3px 9px;
    border-radius: 999px;
    border: 1px solid var(--line);
  }
  .badge.ok { color: var(--good); border-color: var(--good); background: rgb(53 122 85 / 0.08); }
  .badge.err { color: var(--color-error); border-color: var(--color-error); background: var(--color-error-bg); }
  .badge.warn { color: #9a7b00; border-color: #d9c07a; background: rgb(217 192 122 / 0.12); }
  .badge.muted { color: var(--muted); }

  /* catalog */
  .catalog { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .cat-head { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .cat-head strong { font-size: 15px; }
  .chip { font-size: 11px; font-weight: 500; color: var(--muted); border: 1px solid var(--line); border-radius: 999px; padding: 2px 8px; }
  .cat-desc { margin: 0; font-size: 13px; color: var(--muted); flex: 1; }
  .cat-card .button { align-self: flex-start; margin-top: 4px; }

  /* buttons + toggle (local, minimal — align with app tokens) */
  .button.danger { color: var(--color-error); border-color: var(--color-error); }
  .toggle { position: relative; display: inline-flex; cursor: pointer; }
  .toggle input { position: absolute; opacity: 0; width: 0; height: 0; }
