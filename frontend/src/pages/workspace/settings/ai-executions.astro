---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const authed = !!authToken;

const filter = Astro.url.searchParams.get('filter') || 'all';

let executions: any[] = [];
let error: string | null = null;
let aiEnabled = true;

// Read-only history still requires auth; also surface whether AI is currently enabled.
if (authed) {
  const sdk = createSdkClient(authToken);
  try {
    const [execs, settings] = await Promise.all([
      sdk.ai.executions.list({ limit: 200 }),
      sdk.ai.settings.get().catch(() => null),
    ]);
    executions = execs;
    if (settings) aiEnabled = (settings as any).enabled !== false;
  } catch (e) {
    console.error('[ai-executions] Error:', e);
    error = e instanceof Error ? e.message : String(e);
  }
}

// Responses are camelCase (_MarvinModel alias_generator); read snake defensively.
function getField(row: any, camel: string, snake: string) {
  return row[camel] ?? row[snake];
}

const filteredExecutions = filter === 'all'
  ? executions
  : executions.filter((e: any) => e.status === filter);

function formatDate(isoStr: string): string {
  if (!isoStr) return '—';
  const normalized = isoStr.replace(/(\.\d{3})\d+/, '$1');
  const d = new Date(normalized);
  return isNaN(d.getTime()) ? isoStr : d.toLocaleString();
}

function statusClass(status: string): string {
  if (status === 'completed') return 'success';
  if (status === 'failed') return 'failed';
  if (status === 'running' || status === 'pending') return 'running';
  return 'none';
}

function formatTokens(n: number | null): string {
  return n == null ? '—' : n.toLocaleString();
}

function formatCost(cost: number | null): string {
  if (cost == null) return '—';
  if (cost === 0) return 'Free';
  if (cost < 0.0001) return '<$0.0001';
  return `$${cost.toFixed(4)}`;
}

function formatDuration(ms: number | null): string {
  if (ms == null) return '—';
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}
---

<AppLayout title="AI Executions" eyebrow="Settings">
  <div class="page-header">
    <div class="breadcrumb">
      <a href="/workspace/settings?tab=ai">AI</a>
      <span>›</span>
      <span>AI Executions</span>
    </div>
    <h2>AI Executions</h2>
    <p>History of every AI operation run in this workspace — tokens, cost, and output</p>
  </div>

  {!authed ? (
    <div class="alert alert-error"><strong>Authentication required.</strong> Sign in to view AI executions.</div>
  ) : (
  <>
  {!aiEnabled && (
    <div class="alert alert-info">
      AI is currently disabled for this workspace — showing past executions.
      <a href="/workspace/settings/ai-workflow">Review AI settings</a>
    </div>
  )}

  <div class="filters">
    <a href="?filter=all" class:list={['filter-btn', { active: filter === 'all' }]}>All ({executions.length})</a>
    <a href="?filter=completed" class:list={['filter-btn', { active: filter === 'completed' }]}>Completed</a>
    <a href="?filter=failed" class:list={['filter-btn', { active: filter === 'failed' }]}>Failed</a>
    <a href="?filter=running" class:list={['filter-btn', { active: filter === 'running' }]}>Running</a>
  </div>

  {error ? (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  ) : filteredExecutions.length === 0 ? (
    <div class="empty-state">
      <div class="empty-icon">✨</div>
      <p class="empty-title">No AI executions yet</p>
      <p class="empty-desc">Runs appear here after AI operations execute from the editor, assets, or API</p>
      <a href="/workspace/settings/ai-workflow" class="button">AI Workflow Settings</a>
    </div>
  ) : (
    <div class="table-wrap">
      <table class="log-table">
        <thead>
          <tr>
            <th></th>
            <th>Ran At</th>
            <th>Operation</th>
            <th>Model</th>
            <th>Status</th>
            <th>Tokens</th>
            <th>Cost</th>
            <th>Duration</th>
          </tr>
        </thead>
        <tbody>
          {filteredExecutions.map((exec: any, i: number) => {
            const operationSlug = getField(exec, 'operationSlug', 'operation_slug');
            const providerType = getField(exec, 'providerType', 'provider_type');
            const modelId = getField(exec, 'modelId', 'model_id');
            const createdAt = getField(exec, 'createdAt', 'created_at');
            const totalTokens = getField(exec, 'totalTokens', 'total_tokens');
            const estimatedCost = getField(exec, 'estimatedCostUsd', 'estimated_cost_usd');
            const durationMs = getField(exec, 'durationMs', 'duration_ms');
            const outputJson = getField(exec, 'outputJson', 'output_json');
            const errorMsg = getField(exec, 'errorMessage', 'error_message');
            const entityType = getField(exec, 'entityType', 'entity_type');
            const entityId = getField(exec, 'entityId', 'entity_id');
            const triggerType = getField(exec, 'triggerType', 'trigger_type');
            const hasDetails = !!(errorMsg || outputJson || entityType);
            return (
              <>
                <tr class:list={['log-row', { 'has-details': hasDetails }]}>
                  <td class="expand-cell">
                    {hasDetails && (
                      <button class="expand-btn" data-target={`detail-${i}`}>▶</button>
                    )}
                  </td>
                  <td class="nowrap">{formatDate(createdAt)}</td>
                  <td><code class="op-badge">{operationSlug}</code></td>
                  <td>
                    <span class="model-cell">
                      <span class="muted">{providerType}</span>
                      <span class="model-id">{modelId}</span>
                    </span>
                  </td>
                  <td>
                    <span class={`status-chip status-${statusClass(exec.status)}`}>{exec.status}</span>
                  </td>
                  <td class="nowrap">{formatTokens(totalTokens)}</td>
                  <td class="nowrap">{formatCost(estimatedCost)}</td>
                  <td class="nowrap">{formatDuration(durationMs)}</td>
                </tr>
                {hasDetails && (
                  <tr class="detail-row" id={`detail-${i}`} style="display:none">
                    <td colspan="8">
                      <div class="detail-body">
                        {(entityType || triggerType) && (
                          <div class="detail-section">
                            <div class="detail-label">Context</div>
                            <div class="detail-meta">
                              {entityType && <span><b>Entity:</b> {entityType}{entityId ? ` · ${entityId}` : ''}</span>}
                              {triggerType && <span><b>Trigger:</b> {triggerType}</span>}
                            </div>
                          </div>
                        )}
                        {errorMsg && (
                          <div class="detail-section">
                            <div class="detail-label">Error</div>
                            <div class="detail-message">{errorMsg}</div>
                          </div>
                        )}
                        {outputJson && (
                          <div class="detail-section">
                            <div class="detail-label">Output</div>
                            <pre class="payload-json">{JSON.stringify(outputJson, null, 2)}</pre>
                          </div>
                        )}
                      </div>
                    </td>
                  </tr>
                )}
              </>
            );
          })}
        </tbody>
      </table>
    </div>
  )}
  </>
  )}
</AppLayout>

<script>
  document.querySelectorAll('.expand-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.target!;
      const row = document.getElementById(id);
      if (!row) return;
      const open = row.style.display !== 'none';
      row.style.display = open ? 'none' : 'table-row';
      (btn as HTMLElement).textContent = open ? '▶' : '▼';
    });
  });
</script>

<style>
  .page-header {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .breadcrumb a { color: var(--muted); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink); }

  .page-header h2 { margin: 0 0 8px; font-size: 24px; font-weight: 600; }
  .page-header p { margin: 0; color: var(--muted); font-size: 14px; }

  .filters { display: flex; gap: 8px; margin-bottom: 24px; }

  .filter-btn {
    padding: 6px 14px;
    border-radius: var(--radius);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    color: var(--muted);
    border: 1px solid var(--line);
    background: var(--panel);
    transition: all 0.15s;
  }

  .filter-btn:hover { color: var(--ink); border-color: var(--ink); }
  .filter-btn.active { background: var(--ink); color: var(--bg); border-color: var(--ink); }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .alert-info {
    background: var(--panel);
    color: var(--ink);
    border: 1px solid var(--line);
    font-size: 14px;
  }

  .alert-info a { color: var(--accent); }

  .empty-state { padding: 80px 24px; text-align: center; }
  .empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.3; }
  .empty-title { margin: 0 0 8px; font-size: 18px; font-weight: 600; }
  .empty-desc { margin: 0 0 24px; color: var(--muted); font-size: 14px; }

  .table-wrap { overflow-x: auto; }

  .log-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .log-table th {
    text-align: left;
    padding: 10px 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    border-bottom: 2px solid var(--line);
    white-space: nowrap;
  }

  .log-table td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
    vertical-align: middle;
  }

  .log-row:hover td { background: var(--panel); }

  .expand-cell { width: 32px; padding: 10px 6px 10px 12px; }

  .expand-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    font-size: 11px;
    padding: 2px 4px;
    border-radius: 3px;
  }

  .expand-btn:hover { background: var(--line); color: var(--ink); }

  .detail-row td { padding: 0; border-bottom: 1px solid var(--line); }

  .detail-body {
    padding: 16px 16px 16px 52px;
    background: var(--panel);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .detail-section { display: flex; flex-direction: column; gap: 4px; }

  .detail-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--muted);
  }

  .detail-meta { display: flex; gap: 16px; flex-wrap: wrap; font-size: 13px; color: var(--ink); }
  .detail-meta b { color: var(--muted); font-weight: 600; }

  .detail-message {
    font-size: 13px;
    color: var(--color-error);
    font-family: ui-monospace, monospace;
  }

  .payload-json {
    font-size: 12px;
    font-family: ui-monospace, monospace;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 12px;
    margin: 0;
    overflow-x: auto;
    max-height: 400px;
    overflow-y: auto;
    white-space: pre;
    color: var(--ink);
  }

  .nowrap { white-space: nowrap; }
  .muted { color: var(--muted); font-size: 13px; }

  .op-badge {
    font-size: 12px;
    font-family: ui-monospace, monospace;
    background: var(--panel);
    border: 1px solid var(--line);
    padding: 2px 8px;
    border-radius: 4px;
    color: var(--ink);
  }

  .model-cell { display: flex; flex-direction: column; gap: 1px; }
  .model-id { font-size: 13px; color: var(--ink); }

  .status-chip {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .status-success { background: rgba(79, 156, 132, 0.1); color: var(--accent); }
  .status-failed { background: rgba(239, 68, 68, 0.1); color: var(--color-error); }
  .status-running { background: rgba(217, 119, 6, 0.1); color: #d97706; }
  .status-none { color: var(--muted); }
</style>
