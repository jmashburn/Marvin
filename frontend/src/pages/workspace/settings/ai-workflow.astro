---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { createSdkClient } from "@/lib/sdk";

const authToken = getAuthToken(Astro.cookies);

let settings: any = null;
let secrets: any[] = [];
let sources: any[] = [];
let error: string | null = null;

try {
  const sdk = createSdkClient(authToken);
  [settings, secrets, sources] = await Promise.all([
    sdk.ai.settings.get(),
    sdk.secrets.list(),
    sdk.ai.settings.sources().catch(() => []), // catalog for the invocation-sources editor
  ]);
} catch (e) {
  console.error("[ai-workflow] Error loading settings:", e);
  error = e instanceof Error ? e.message : String(e);
}

// API returns camelCase (_MarvinModel alias_generator=camelize)
const s = {
  enabled: settings?.enabled ?? true,
  credentialMode: settings?.credentialMode ?? "platform",
  provider: settings?.provider ?? null,
  model: settings?.model ?? null,
  secretRef: settings?.secretRef ?? null,
  approvalMode: settings?.approvalMode ?? "suggest-only",
  invocationSources: settings?.invocationSources ?? null,
  budgetConfig: settings?.budgetConfig ?? null,
  loggingConfig: settings?.loggingConfig ?? null,
  moderationConfig: settings?.moderationConfig ?? null,
  allowWorkspaceCredentials: settings?.allowWorkspaceCredentials ?? true,
  assistantName: settings?.assistantName ?? null,
  personaPrompt: settings?.personaPrompt ?? null,
  defaultRegister: settings?.defaultRegister ?? "auto",
};

const invSrc = s.invocationSources ?? {};
// Catalog-driven so every real source (incl. `automation`) renders and can't drift from the backend.
// Fallback to the canonical key list if the catalog fetch failed.
const sourceCatalog = sources.length
  ? sources
  : [
      { key: "editor", label: "Entry editor", description: "Inline AI actions inside the entry editor." },
      { key: "forms", label: "Forms", description: "AI on form submissions." },
      { key: "actions", label: "Manual actions", description: "AI actions triggered by hand." },
      { key: "mcp", label: "External MCP hosts", description: "External assistants calling in over MCP." },
      { key: "scheduled", label: "Scheduled tasks", description: "AI run by scheduled tasks." },
      { key: "agent", label: "Ask Marvin", description: "The Ask-Marvin assistant." },
      { key: "automation", label: "Automations", description: "Workflows running an AI-operation step." },
      { key: "api", label: "API", description: "Direct calls to the AI operation endpoints." },
    ];

const budgetCfg = s.budgetConfig ?? {};
const logCfg = s.loggingConfig ?? {};
const modCfg = s.moderationConfig ?? {};
---

<AppLayout title="AI Settings" eyebrow="Settings">
  <div class="page-header">
    <div>
      <h2>AI Settings</h2>
      <p>Control how and whether AI features operate in this workspace.</p>
    </div>
    <a href="/workspace/settings?tab=ai" class="button secondary small">Back to AI</a>
  </div>

  {error && (
    <div class="alert alert-error"><strong>Error loading settings:</strong> {error}</div>
  )}

  <form id="ai-settings-form">
    <!-- 1. Enable / Disable -->
    <div class="section-card">
      <div class="section-header">
        <div>
          <h3>AI Features</h3>
          <p>Enable or disable all AI capabilities for this workspace.</p>
        </div>
        <label class="toggle-label">
          <input type="checkbox" name="enabled" id="ai-enabled" class="toggle-input" checked={s.enabled} />
          <span class="toggle-track"><span class="toggle-thumb"></span></span>
          <span class="toggle-text" id="ai-enabled-text">{s.enabled ? "Enabled" : "Disabled"}</span>
        </label>
      </div>
    </div>

    <!-- 2. Credential Mode -->
    <div class="section-card ai-dependent" id="credential-section">
      <div class="section-title">
        <h3>Credential Mode</h3>
        <p>Which AI credentials this workspace uses.</p>
      </div>
      <div class="radio-group">
        <label class:list={["radio-card", { selected: s.credentialMode === "platform" }]}>
          <input type="radio" name="credential_mode" value="platform" checked={s.credentialMode === "platform"} />
          <div class="radio-content">
            <strong>Platform</strong>
            <span>Credentials configured by your platform administrator.</span>
          </div>
        </label>
        <label class:list={["radio-card", { selected: s.credentialMode === "workspace", disabled: !s.allowWorkspaceCredentials }]}>
          <input type="radio" name="credential_mode" value="workspace" checked={s.credentialMode === "workspace"} disabled={!s.allowWorkspaceCredentials} />
          <div class="radio-content">
            <strong>Workspace</strong>
            <span>{s.allowWorkspaceCredentials
              ? "Use a specific key stored in this workspace's secrets."
              : "Disabled by the platform administrator — only platform credentials are allowed."}</span>
          </div>
        </label>
      </div>

      <div id="platform-info" class="info-banner" style={s.credentialMode !== "platform" ? "display:none" : ""}>
        Credentials are provided by the platform administrator. No further configuration needed.
      </div>

      <div id="workspace-creds" style={s.credentialMode !== "workspace" ? "display:none" : ""}>
        <div class="info-banner" style="margin-bottom:16px;">
          <strong>Bring your own AI.</strong> You need one thing: your provider's API key.
          Add it under <a href="/workspace/settings/environment">Environment → Secrets</a>, then
          pick a provider + model and reference that secret below.
          <br />
          <small style="color:var(--muted);">Ollama needs no key (just a Base URL); Ollama &amp; Azure use the Providers config for their endpoint.</small>
        </div>
        <div class="form-row">
          <label class="form-field">
            <span class="label">Provider</span>
            <select name="provider" class="input" id="provider-select">
              <option value="" selected={!s.provider}>— select —</option>
              <option value="openai" selected={s.provider === "openai"}>OpenAI</option>
              <option value="anthropic" selected={s.provider === "anthropic"}>Anthropic</option>
              <option value="ollama" selected={s.provider === "ollama"}>Ollama (self-hosted)</option>
              <option value="other" selected={s.provider === "other"}>Other</option>
            </select>
          </label>
          <label class="form-field">
            <span class="label">Model</span>
            <input type="text" name="model" class="input" value={s.model ?? ""} placeholder="e.g. gpt-4o, claude-sonnet-5" />
          </label>
        </div>

        <!-- Ollama-only: what's installed locally + pull new models on demand -->
        <div class="ollama-models" id="ollama-models" hidden={s.provider !== "ollama"}>
          <div class="ollama-head">
            <span class="label">Ollama model library</span>
            <button type="button" class="link-btn" id="ollama-refresh">Refresh</button>
          </div>
          <div class="installed-list" id="installed-list">
            <span class="hint">Loading installed models…</span>
          </div>
          <div class="pull-row">
            <input type="text" class="input" id="pull-name" placeholder="Pull a model, e.g. qwen3-coder, nomic-embed-text" />
            <button type="button" class="button secondary" id="pull-btn">Pull</button>
          </div>
          <div class="pull-progress" id="pull-progress" hidden>
            <div class="pull-bar"><div class="pull-bar-fill" id="pull-bar-fill"></div></div>
            <span class="hint" id="pull-status"></span>
          </div>
        </div>
        <label class="form-field">
          <span class="label">Secret Reference</span>
          <select name="secret_ref" class="input">
            <option value="" selected={!s.secretRef}>— none —</option>
            {secrets.map((sec: any) => (
              <option value={sec.slug} selected={s.secretRef === sec.slug}>{sec.name} ({sec.slug})</option>
            ))}
          </select>
          <small class="hint">Pick the workspace secret holding your provider's API key. The key lives in Secrets — never stored here.</small>
        </label>
      </div>

    </div>

    <!-- 3. Approval Mode -->
    <div class="section-card ai-dependent" id="approval-section">
      <div class="section-title">
        <h3>Approval Mode</h3>
        <p>How much autonomy AI has to apply changes without human review.</p>
      </div>
      <div class="radio-group">
        <label class:list={["radio-card", { selected: s.approvalMode === "suggest-only" }]}>
          <input type="radio" name="approval_mode" value="suggest-only" checked={s.approvalMode === "suggest-only"} />
          <div class="radio-content">
            <strong>Suggest only</strong>
            <span>AI outputs are shown as suggestions. Users must accept manually.</span>
          </div>
        </label>
        <label class:list={["radio-card", { selected: s.approvalMode === "allow-draft-update" }]}>
          <input type="radio" name="approval_mode" value="allow-draft-update" checked={s.approvalMode === "allow-draft-update"} />
          <div class="radio-content">
            <strong>Allow draft update</strong>
            <span>AI can update draft entries automatically. Published entries still require review.</span>
          </div>
        </label>
        <label class:list={["radio-card", { selected: s.approvalMode === "allow-automatic-update" }]}>
          <input type="radio" name="approval_mode" value="allow-automatic-update" checked={s.approvalMode === "allow-automatic-update"} />
          <div class="radio-content">
            <strong>Allow automatic update</strong>
            <span>AI can apply changes to any entry without additional approval.</span>
          </div>
        </label>
      </div>
    </div>

    <!-- 4. Invocation Sources -->
    <div class="section-card ai-dependent">
      <div class="section-title">
        <h3>Invocation Sources</h3>
        <p>Which subsystems are allowed to trigger AI calls.</p>
      </div>
      <div class="toggle-grid">
        {sourceCatalog.map(({ key, label, description }) => (
          <label class="source-toggle">
            <div class="source-info">
              <strong>{label}</strong>
              <span>{description}</span>
            </div>
            <input
              type="checkbox"
              name={`invocation_sources.${key}`}
              class="toggle-input"
              checked={invSrc[key] !== false}
            />
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
          </label>
        ))}
      </div>
    </div>

    <!-- 5. Persona -->
    <div class="section-card ai-dependent">
      <div class="section-title">
        <h3>Persona</h3>
        <p>Give the assistant a name and a voice for this workspace.</p>
      </div>
      <div class="form-row">
        <label class="form-field">
          <span class="label">Assistant name</span>
          <input type="text" name="assistant_name" class="input" value={s.assistantName ?? ""} placeholder="Marvin" />
          <small class="hint">Shown in place of the default name. Leave blank to use "Marvin".</small>
        </label>
      </div>
      <label class="form-field">
        <span class="label">Voice / tone</span>
        <textarea name="persona_prompt" class="input persona-prompt" rows="4"
          placeholder="e.g. Warm and upbeat; concise; a leathercraft studio's helper.">{s.personaPrompt ?? ""}</textarea>
        <small class="hint">A free-text instruction appended to the assistant's system prompt. Leave blank for the default voice.</small>
      </label>
      <label class="form-field">
        <span class="label">Default register</span>
        <select name="default_register" class="input">
          <option value="auto" selected={s.defaultRegister === "auto" || !s.defaultRegister}>Auto — voice for chat, plain for work</option>
          <option value="professional" selected={s.defaultRegister === "professional"}>Professional — plain everywhere, no persona</option>
          <option value="playful" selected={s.defaultRegister === "playful"}>Playful — persona applies to everything</option>
        </select>
        <small class="hint">
          Separate from the voice above. The <strong>voice</strong> is how the assistant addresses
          you; the <strong>register</strong> is how its work product reads. <em>Auto</em> keeps the
          voice for chat but writes reviews, critiques and suggested copy plainly. Specific actions
          (like "Review &amp; suggest") may still override this per run.
        </small>
      </label>
    </div>

    <!-- 6. Advanced (collapsible) -->
    <details class="section-card ai-dependent advanced-section">
      <summary class="advanced-summary">Advanced Settings</summary>

      <div class="advanced-body">
        <!-- Budget -->
        <div class="sub-section">
          <h4>Budget Limits</h4>
          <div class="form-row">
            <label class="form-field">
              <span class="label">Max tokens per request</span>
              <input type="number" name="budget.max_tokens_per_request" class="input"
                value={budgetCfg.max_tokens_per_request ?? ""} placeholder="e.g. 4096" min="1" />
            </label>
            <label class="form-field">
              <span class="label">Max requests per day</span>
              <input type="number" name="budget.max_requests_per_day" class="input"
                value={budgetCfg.max_requests_per_day ?? ""} placeholder="e.g. 1000" min="1" />
            </label>
          </div>
        </div>

        <!-- Logging -->
        <div class="sub-section">
          <h4>Logging</h4>
          <div class="toggle-grid compact">
            <label class="source-toggle">
              <div class="source-info"><strong>Log inputs</strong><span>Record prompts sent to AI</span></div>
              <input type="checkbox" name="logging.log_inputs" class="toggle-input" checked={logCfg.log_inputs !== false} />
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
            </label>
            <label class="source-toggle">
              <div class="source-info"><strong>Log outputs</strong><span>Record AI responses</span></div>
              <input type="checkbox" name="logging.log_outputs" class="toggle-input" checked={logCfg.log_outputs !== false} />
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
            </label>
          </div>
          <label class="form-field" style="margin-top:12px">
            <span class="label">Retention (days)</span>
            <input type="number" name="logging.retention_days" class="input"
              value={logCfg.retention_days ?? ""} placeholder="e.g. 30" min="1" style="max-width:160px" />
          </label>
        </div>

        <!-- Moderation -->
        <div class="sub-section">
          <h4>Moderation</h4>
          <div class="toggle-grid compact">
            <label class="source-toggle">
              <div class="source-info"><strong>Enable moderation</strong><span>Run AI outputs through a content moderation layer</span></div>
              <input type="checkbox" name="moderation.enabled" class="toggle-input" checked={modCfg.enabled === true} />
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
            </label>
            <label class="source-toggle">
              <div class="source-info"><strong>Block on flag</strong><span>Prevent flagged output from being applied</span></div>
              <input type="checkbox" name="moderation.block_on_flag" class="toggle-input" checked={modCfg.block_on_flag === true} />
              <span class="toggle-track"><span class="toggle-thumb"></span></span>
            </label>
          </div>
        </div>
      </div>
    </details>

    <!-- Save -->
    <div class="form-actions">
      <button type="submit" class="button" id="save-btn">Save Settings</button>
      <span id="save-status" class="save-status"></span>
    </div>
  </form>
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';

  const form = document.getElementById('ai-settings-form');
  const enabledToggle = document.getElementById('ai-enabled');
  const enabledText = document.getElementById('ai-enabled-text');
  const saveStatus = document.getElementById('save-status');

  // Dependent sections dim when AI is disabled
  function syncEnabled() {
    const on = (enabledToggle as HTMLInputElement)?.checked;
    enabledText.textContent = on ? 'Enabled' : 'Disabled';
    document.querySelectorAll('.ai-dependent').forEach(el => {
      (el as HTMLElement).style.opacity = on ? '' : '0.45';
      (el as HTMLElement).style.pointerEvents = on ? '' : 'none';
    });
  }
  enabledToggle?.addEventListener('change', syncEnabled);
  syncEnabled();

  // Credential mode visibility
  const modeInputs = form?.querySelectorAll('input[name="credential_mode"]');
  const platformInfo = document.getElementById('platform-info');
  const workspaceCreds = document.getElementById('workspace-creds');

  function syncMode() {
    const mode = (form?.querySelector('input[name="credential_mode"]:checked') as HTMLInputElement)?.value;
    platformInfo.style.display = mode === 'platform' ? '' : 'none';
    workspaceCreds.style.display = mode === 'workspace' ? '' : 'none';
  }

  modeInputs?.forEach(inp => inp.addEventListener('change', syncMode));
  syncMode();

  // ── Ollama model library: show installed models + pull new ones ────────────
  const providerSelect = document.getElementById('provider-select') as HTMLSelectElement | null;
  const ollamaBlock = document.getElementById('ollama-models');
  const installedList = document.getElementById('installed-list');
  const pullName = document.getElementById('pull-name') as HTMLInputElement | null;
  const pullBtn = document.getElementById('pull-btn') as HTMLButtonElement | null;
  const pullProgress = document.getElementById('pull-progress');
  const pullBarFill = document.getElementById('pull-bar-fill');
  const pullStatus = document.getElementById('pull-status');
  let installedLoaded = false;

  function isOllama() { return providerSelect?.value === 'ollama'; }

  function syncOllamaVisibility() {
    if (!ollamaBlock) return;
    (ollamaBlock as HTMLElement).hidden = !isOllama();
    if (isOllama() && !installedLoaded) loadInstalled();
  }

  async function loadInstalled() {
    if (!installedList) return;
    installedLoaded = true;
    installedList.innerHTML = '<span class="hint">Loading installed models…</span>';
    try {
      const res = await createSdkClient().ai.models.installed();
      const models = res.models ?? [];
      if (!models.length) {
        installedList.innerHTML = '<span class="hint">No models installed yet — pull one below.</span>';
        return;
      }
      installedList.innerHTML = '';
      for (const m of models) {
        const chip = document.createElement('span');
        chip.className = 'model-chip';
        chip.textContent = m;
        installedList.appendChild(chip);
      }
    } catch (err: any) {
      installedList.innerHTML = `<span class="hint error">Couldn't reach the provider: ${err?.message ?? err}</span>`;
    }
  }

  async function pollPull(jobId: string) {
    try {
      const s = await createSdkClient().ai.models.pullStatus(jobId);
      if (pullBarFill) (pullBarFill as HTMLElement).style.width = `${s.percent}%`;
      if (pullStatus) pullStatus.textContent = s.status === 'error'
        ? `Failed: ${s.error ?? 'unknown error'}`
        : `${s.detail}${s.total ? ` — ${s.percent}%` : ''}`;
      if (s.done) {
        pullBtn && (pullBtn.disabled = false);
        if (s.status === 'success') {
          if (pullStatus) pullStatus.textContent = `Installed ${s.name}.`;
          installedLoaded = false;
          loadInstalled();
          if (pullName) pullName.value = '';
          setTimeout(() => { if (pullProgress) (pullProgress as HTMLElement).hidden = true; }, 2500);
        }
        return;
      }
      setTimeout(() => pollPull(jobId), 900);
    } catch (err: any) {
      pullBtn && (pullBtn.disabled = false);
      if (pullStatus) pullStatus.textContent = `Error: ${err?.message ?? err}`;
    }
  }

  async function startPull() {
    const name = pullName?.value.trim();
    if (!name) { pullName?.focus(); return; }
    if (pullBtn) pullBtn.disabled = true;
    if (pullProgress) (pullProgress as HTMLElement).hidden = false;
    if (pullBarFill) (pullBarFill as HTMLElement).style.width = '0%';
    if (pullStatus) { pullStatus.textContent = 'Starting…'; pullStatus.className = 'hint'; }
    try {
      const job = await createSdkClient().ai.models.pull({ name });
      pollPull(job.id);
    } catch (err: any) {
      if (pullBtn) pullBtn.disabled = false;
      if (pullStatus) { pullStatus.textContent = `Error: ${err?.message ?? err}`; pullStatus.className = 'hint error'; }
    }
  }

  providerSelect?.addEventListener('change', syncOllamaVisibility);
  pullBtn?.addEventListener('click', startPull);
  pullName?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); startPull(); } });
  document.getElementById('ollama-refresh')?.addEventListener('click', () => { installedLoaded = false; loadInstalled(); });
  syncOllamaVisibility();

  // Radio card selected style
  form?.querySelectorAll('.radio-group').forEach(group => {
    group.querySelectorAll('input[type="radio"]').forEach(inp => {
      inp.addEventListener('change', () => {
        group.querySelectorAll('.radio-card').forEach(c => c.classList.remove('selected'));
        inp.closest('.radio-card')?.classList.add('selected');
      });
    });
  });

  // Save handler
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form as HTMLFormElement);

    // Collect whatever sources were rendered (catalog-driven) — no hardcoded key list to drift.
    const invSrc: Record<string, boolean> = {};
    form!.querySelectorAll('input[name^="invocation_sources."]').forEach((el) => {
      const key = (el as HTMLInputElement).name.slice('invocation_sources.'.length);
      invSrc[key] = (el as HTMLInputElement).checked;
    });

    const budgetCfg: Record<string, number> = {};
    const maxTokens = fd.get('budget.max_tokens_per_request');
    const maxReqs = fd.get('budget.max_requests_per_day');
    if (maxTokens) budgetCfg.max_tokens_per_request = Number(maxTokens);
    if (maxReqs) budgetCfg.max_requests_per_day = Number(maxReqs);

    const logCfg: Record<string, unknown> = {
      log_inputs: fd.has('logging.log_inputs'),
      log_outputs: fd.has('logging.log_outputs'),
    };
    const retDays = fd.get('logging.retention_days');
    if (retDays) logCfg.retention_days = Number(retDays);

    const modCfg = {
      enabled: fd.has('moderation.enabled'),
      block_on_flag: fd.has('moderation.block_on_flag'),
    };

    const mode = fd.get('credential_mode') as string;
    // camelCase top-level fields for the SDK (AISettingsUpdate); the nested config dicts stay as-is
    // (they're opaque JSON the backend reads by their own keys).
    const payload = {
      enabled: fd.has('enabled'),
      credentialMode: mode,
      approvalMode: fd.get('approval_mode') as string,
      provider: mode === 'workspace' ? (fd.get('provider')?.toString() || null) : null,
      model: mode === 'workspace' ? (fd.get('model')?.toString() || null) : null,
      secretRef: mode === 'workspace' ? (fd.get('secret_ref')?.toString() || null) : null,
      invocationSources: invSrc,
      budgetConfig: Object.keys(budgetCfg).length ? budgetCfg : null,
      loggingConfig: logCfg,
      moderationConfig: modCfg,
      assistantName: (fd.get('assistant_name')?.toString().trim() || null),
      personaPrompt: (fd.get('persona_prompt')?.toString().trim() || null),
      defaultRegister: (fd.get('default_register')?.toString() || 'auto'),
    };

    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    saveBtn.disabled = true;
    saveStatus.textContent = 'Saving…';
    saveStatus.className = 'save-status';

    try {
      await createSdkClient().ai.settings.update(payload);

      saveStatus.textContent = 'Saved';
      saveStatus.className = 'save-status success';
      setTimeout(() => window.location.reload(), 800);
    } catch (err) {
      saveStatus.textContent = `Error: ${err.message}`;
      saveStatus.className = 'save-status error';
    } finally {
      saveBtn.disabled = false;
    }
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 28px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
    gap: 16px;
  }

  .page-header h2 { margin: 0 0 6px; font-size: 22px; font-weight: 600; }
  .page-header p { margin: 0; color: var(--muted); font-size: 14px; }

  .alert {
    padding: 14px 16px; margin-bottom: 20px; border-radius: var(--radius);
    background: var(--color-error-bg); color: var(--color-error);
    border: 1px solid var(--color-error); font-size: 14px;
  }

  /* ── Section cards ── */
  .section-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 16px;
    transition: opacity 0.2s, pointer-events 0.2s;
  }

  .section-card > .section-title,
  .section-card > legend.section-title {
    display: block;
    padding: 0;
    border: none;
    margin-bottom: 16px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .section-title h3, .section-header h3 { margin: 0 0 4px; font-size: 15px; font-weight: 600; }
  .section-title p, .section-header p { margin: 0; font-size: 13px; color: var(--muted); }

  /* ── Toggle ── */
  .toggle-label {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    user-select: none;
    flex-shrink: 0;
  }

  .toggle-input { position: absolute; opacity: 0; width: 0; height: 0; }

  .toggle-track {
    display: inline-block;
    width: 40px;
    height: 22px;
    background: var(--line);
    border-radius: 11px;
    position: relative;
