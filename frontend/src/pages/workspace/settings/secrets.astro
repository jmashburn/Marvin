---
import AppLayout from "@/layouts/AppLayout.astro";
import { createSdkClient } from "@/lib/sdk";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let secrets: any[] = [];
let error: string | null = null;

try {
  secrets = await sdk.secrets.list();
} catch (e) {
  console.error('[secrets] Error loading:', e);
  error = e instanceof Error ? e.message : String(e);
}

function formatDate(isoStr: string): string {
  if (!isoStr) return '—';
  const normalized = isoStr.replace(/(\.\d{3})\d+/, '$1');
  const d = new Date(normalized);
  return isNaN(d.getTime()) ? isoStr : d.toLocaleDateString();
}
---

<AppLayout title="Workspace Secrets" eyebrow="Settings">
  <div class="page-header">
    <div>
      <h2>Workspace Secrets</h2>
      <p>Store API keys, tokens, and credentials. Reference them in webhook headers with <code>&#123;&#123;SLUG&#125;&#125;</code>.</p>
    </div>
    <button id="new-btn" class="button">New Secret</button>
  </div>

  {error && (
    <div class="alert alert-error"><strong>Error:</strong> {error}</div>
  )}

  <div id="new-form" class="form-card" style="display:none">
    <h3>New Secret</h3>
    <form id="create-form">
      <div class="form-row">
        <label class="form-field">
          <span class="label">Name *</span>
          <input type="text" name="name" required placeholder="Cloudflare API Token" class="input" />
        </label>
        <label class="form-field">
          <span class="label">Slug *</span>
          <input type="text" name="slug" required placeholder="CLOUDFLARE_TOKEN" class="input slug-input" />
          <small class="hint">Use in webhooks as <code>&#123;&#123;CLOUDFLARE_TOKEN&#125;&#125;</code></small>
        </label>
      </div>
      <label class="form-field">
        <span class="label">Description</span>
        <input type="text" name="description" placeholder="Used for cache purge webhooks" class="input" />
      </label>
      <label class="form-field">
        <span class="label">Value *</span>
        <input type="password" name="value" required placeholder="Paste secret value" class="input" autocomplete="new-password" />
        <small class="hint">Encrypted at rest. Never shown after saving.</small>
      </label>
      <div class="form-actions">
        <button type="submit" class="button">Save Secret</button>
        <button type="button" id="cancel-btn" class="button secondary">Cancel</button>
      </div>
    </form>
  </div>

  {secrets.length === 0 && !error ? (
    <div class="empty-state">
      <div class="empty-icon">🔑</div>
      <p class="empty-title">No secrets yet</p>
      <p class="empty-desc">
        Store API keys and tokens here, then reference them in webhook headers with
        <code>&#123;&#123;SLUG&#125;&#125;</code> — values are encrypted and never exposed.
      </p>
      <button id="empty-new-btn" class="button">New Secret</button>
    </div>
  ) : (
    <div class="secrets-list">
      <div class="list-header">
        <span>Name / Slug</span>
        <span>Description</span>
        <span>Created</span>
        <span></span>
      </div>
      {secrets.map((secret: any) => (
        <div class="secret-row">
          <div>
            <div class="secret-name">{secret.name}</div>
            <code class="secret-slug">&#123;&#123;{secret.slug}&#125;&#125;</code>
          </div>
          <div class="secret-description">{secret.description || <span class="muted">—</span>}</div>
          <div class="secret-date">{formatDate(secret.createdAt ?? secret.created_at)}</div>
          <div class="secret-actions">
            <button
              class="button secondary small"
              data-action="rotate"
              data-id={secret.id}
              data-name={secret.name}
            >Rotate</button>
            <button
              class="button small danger"
              data-action="delete"
              data-id={secret.id}
              data-name={secret.name}
            >Delete</button>
          </div>
        </div>
      ))}
    </div>
  )}

  <div id="rotate-form" class="form-card" style="display:none">
    <h3 id="rotate-title">Rotate Secret</h3>
    <form id="rotate-form-inner">
      <input type="hidden" id="rotate-id" />
      <label class="form-field">
        <span class="label">New Value *</span>
        <input type="password" id="rotate-value" required placeholder="Paste new secret value" class="input" autocomplete="new-password" />
        <small class="hint">The old value will be overwritten immediately.</small>
      </label>
      <div class="form-actions">
        <button type="submit" class="button">Save New Value</button>
        <button type="button" id="cancel-rotate-btn" class="button secondary">Cancel</button>
      </div>
    </form>
  </div>
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';
  const sdk = createSdkClient();

  const newBtn = document.getElementById('new-btn');
  const emptyNewBtn = document.getElementById('empty-new-btn');
  const newForm = document.getElementById('new-form');
  const cancelBtn = document.getElementById('cancel-btn');
  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const nameInput = createForm?.querySelector('[name="name"]') as HTMLInputElement;
  const slugInput = createForm?.querySelector('[name="slug"]') as HTMLInputElement;

  function showNewForm() { newForm!.style.display = ''; newForm!.scrollIntoView({ behavior: 'smooth' }); }
  newBtn?.addEventListener('click', showNewForm);
  emptyNewBtn?.addEventListener('click', showNewForm);
  cancelBtn?.addEventListener('click', () => { newForm!.style.display = 'none'; });

  // Auto-generate slug from name
  nameInput?.addEventListener('input', () => {
    if (!slugInput.dataset.manual) {
      slugInput.value = nameInput.value.toUpperCase().replace(/[^A-Z0-9]+/g, '_').replace(/^_|_$/g, '');
    }
  });
  slugInput?.addEventListener('input', () => { slugInput.dataset.manual = 'true'; });

  createForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(createForm);
    try {
      await sdk.secrets.create({
        name: fd.get('name') as string,
        slug: fd.get('slug') as string,
        description: (fd.get('description') as string) || null,
        value: fd.get('value') as string,
      });
      window.location.reload();
    } catch (err: any) {
      alert(`Failed to create secret: ${err?.message || err}`);
    }
  });

  // Rotate
  const rotateFormDiv = document.getElementById('rotate-form');
  const rotateTitle = document.getElementById('rotate-title');
  const rotateId = document.getElementById('rotate-id') as HTMLInputElement;
  const rotateValue = document.getElementById('rotate-value') as HTMLInputElement;
  const rotateFormInner = document.getElementById('rotate-form-inner') as HTMLFormElement;
  const cancelRotate = document.getElementById('cancel-rotate-btn');

  cancelRotate?.addEventListener('click', () => { rotateFormDiv!.style.display = 'none'; });

  document.querySelectorAll('[data-action="rotate"]').forEach(btn => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLElement).dataset.id!;
      const name = (btn as HTMLElement).dataset.name!;
      rotateId.value = id;
      rotateTitle!.textContent = `Rotate: ${name}`;
      rotateFormDiv!.style.display = '';
      rotateFormDiv!.scrollIntoView({ behavior: 'smooth' });
    });
  });

  rotateFormInner?.addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      await sdk.secrets.update(rotateId.value, { value: rotateValue.value });
      rotateFormDiv!.style.display = 'none';
      rotateValue.value = '';
      alert('Secret rotated successfully.');
    } catch (err: any) {
      alert(`Failed to rotate secret: ${err?.message || err}`);
    }
  });

  // Delete
  document.querySelectorAll('[data-action="delete"]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.id!;
      const name = (btn as HTMLElement).dataset.name!;
      if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;
      try {
        await sdk.secrets.delete(id);
        window.location.reload();
      } catch (err: any) {
        alert(`Failed to delete secret: ${err?.message || err}`);
      }
    });
  });
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .page-header h2 { margin: 0 0 8px; font-size: 24px; font-weight: 600; }
  .page-header p { margin: 0; color: var(--muted); font-size: 14px; }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .form-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 32px;
    display: grid;
    gap: 16px;
  }

  .form-card h3 { margin: 0; font-size: 16px; font-weight: 600; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .form-field { display: grid; gap: 6px; }
  .label { font-size: 14px; font-weight: 500; }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
    background: var(--bg);
    color: var(--ink);
  }

  .hint { font-size: 12px; color: var(--muted); }
  .hint code { background: var(--panel); padding: 1px 4px; border-radius: 3px; }

  .form-actions { display: flex; gap: 12px; }

  .empty-state { padding: 80px 24px; text-align: center; }
  .empty-icon { font-size: 48px; margin-bottom: 16px; opacity: 0.3; }
  .empty-title { margin: 0 0 8px; font-size: 18px; font-weight: 600; }
  .empty-desc { margin: 0 0 24px; color: var(--muted); font-size: 14px; max-width: 480px; margin-inline: auto; }
  .empty-desc code { background: var(--panel); padding: 1px 4px; border-radius: 3px; }

  .secrets-list { display: grid; gap: 1px; background: var(--line); border-radius: var(--radius); overflow: hidden; }

  .list-header {
    display: grid;
    grid-template-columns: 2fr 2fr 1fr auto;
    gap: 16px;
    padding: 10px 16px;
    background: var(--panel);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
  }

  .secret-row {
    display: grid;
    grid-template-columns: 2fr 2fr 1fr auto;
    gap: 16px;
    align-items: center;
    padding: 14px 16px;
    background: var(--bg);
  }

  .secret-row:hover { background: var(--panel); }

  .secret-name { font-size: 14px; font-weight: 500; margin-bottom: 2px; }
  .secret-slug { font-size: 12px; color: var(--accent); background: rgba(79,156,132,0.08); padding: 1px 6px; border-radius: 3px; }
  .secret-description { font-size: 13px; color: var(--muted); }
  .secret-date { font-size: 13px; color: var(--muted); white-space: nowrap; }
  .secret-actions { display: flex; gap: 8px; }
  .muted { color: var(--muted); }

  .button.small { padding: 6px 12px; font-size: 13px; }
  .button.danger { color: var(--color-error); }
  .button.danger:hover { background: var(--color-error-bg); }
</style>
