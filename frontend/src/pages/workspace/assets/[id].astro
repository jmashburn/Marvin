---
import AppLayout from "@/layouts/AppLayout.astro";
import TagChips from "@/components/TagChips.astro";
import { getAuthToken } from "@/lib/api/client";
import { createSdkClient } from "@/lib/sdk";
import { listTags, type TagRead } from "@/lib/api/tags";
import type { PlatformAsset } from "@inneropen/marvin-sdk/platform";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

let asset: PlatformAsset | null = null;
let allTags: TagRead[] = [];
let error: string | null = null;

if (!id) {
  error = "Asset ID is required";
} else if (!authToken) {
  error = "Authentication required";
} else {
  try {
    const sdk = createSdkClient(authToken);
    [asset, allTags] = await Promise.all([sdk.assets.get(id), listTags(authToken)]);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[Asset] Failed to load:', error);
  }
}

// asset.tags is a slug list; resolve to {id, name} via the workspace vocabulary for the chips.
const tagBySlug = new Map((allTags || []).map((t) => [t.slug, t]));
const attachedTags = (((asset as any)?.tags as string[] | undefined) || [])
  .map((slug) => tagBySlug.get(slug))
  .filter(Boolean)
  .map((t) => ({ id: t!.id, name: t!.name }));

// AI assist: only shown for image assets when AI is enabled for the workspace.
let aiEnabled = false;
if (asset && authToken) {
  try {
    const aiSdk = createSdkClient(authToken);
    const aiSettings: any = await aiSdk.ai.settings.get();
    aiEnabled = aiSettings?.enabled !== false;
    const sources = aiSettings?.invocationSources ?? aiSettings?.invocation_sources;
    if (sources && sources.assets === false) aiEnabled = false;
  } catch {
    aiEnabled = false; // fail closed — hide the panel if settings can't be read
  }
}
const isImage = (asset as any)?.mimeType?.startsWith('image/') ?? false;
const showAiPanel = aiEnabled && isImage;
---

<AppLayout
  title={asset ? asset.name : "Edit Asset"}
  entityType="asset"
  entityId={id}
  entityLabel={asset?.name}
>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading asset:</strong> {error}</p>
      <a href="/workspace/assets" class="button secondary">Back to Assets</a>
    </div>
  ) : asset ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Asset</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Update asset metadata and details</p>
        </div>
        <div style="display:flex;gap:0.75rem;">
          <button type="button" id="delete-button" class="button secondary">
            Delete
          </button>
          <a class="button secondary" href="/workspace/assets">Back</a>
        </div>
      </div>

      <div class="editor-layout">
        <section class="main-section">
          <form id="asset-form" class="form">
            <div class="form-group">
              <label for="name">Name *</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                value={asset.name}
              />
            </div>

            <div class="form-group">
              <label for="slug">Slug</label>
              <input
                type="text"
                id="slug"
                name="slug"
                value={asset.slug}
                disabled
                style="background: var(--panel-2); color: var(--muted);"
              />
              <p class="form-help">Auto-generated from name</p>
            </div>

            <div class="form-group">
              <label for="altText">Alt Text</label>
              <input
                type="text"
                id="altText"
                name="altText"
                value={asset.altText || ""}
                placeholder="Describe this image for accessibility"
              />
              <p class="form-help">Important for accessibility and SEO</p>
            </div>

            <div class="form-group">
              <label for="description">Description</label>
              <textarea
                id="description"
                name="description"
                rows="4"
              >{asset.description || ""}</textarea>
            </div>

            <div class="form-group">
              <label for="metadata">Metadata (JSON)</label>
              <textarea
                id="metadata"
                name="metadata"
                rows="6"
                placeholder='{"key": "value"}'
                class="metadata-editor"
              >{asset.metadataJson ? JSON.stringify(asset.metadataJson, null, 2) : ""}</textarea>
              <p class="form-help">Must be valid JSON. Example: {`{"photographer": "Jane", "license": "CC-BY"}`}</p>

              {asset.metadataJson && Object.keys(asset.metadataJson).length > 0 && (
                <div class="metadata-preview">
                  <p class="metadata-preview-title">Current Metadata:</p>
                  <dl class="metadata-preview-list">
                    {Object.entries(asset.metadataJson).map(([key, value]) => (
                      <div class="metadata-preview-item">
                        <dt>{key}</dt>
                        <dd>{typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value)}</dd>
                      </div>
                    ))}
                  </dl>
                </div>
              )}
            </div>

            <TagChips attachedTags={attachedTags} allTags={(allTags || []).map((t) => ({ id: t.id, name: t.name, slug: t.slug }))} />

            <div class="form-actions">
              <button type="submit" class="button">Save Changes</button>
              <a href="/workspace/assets" class="button secondary">Cancel</a>
            </div>
          </form>
        </section>

        <aside class="sidebar">
          <div class="sidebar-section">
            <h3>Preview</h3>
            {asset.publicUrl && asset.mimeType?.startsWith('image/') ? (
              <div class="asset-preview">
                <img
                  src={asset.publicUrl}
                  alt={asset.altText || asset.name}
                />
              </div>
            ) : asset.publicUrl ? (
              <div class="asset-preview file-preview">
                <span class="file-icon">{
                  asset.mimeType?.startsWith('video/') ? '🎬' :
                  asset.mimeType?.startsWith('audio/') ? '🎵' :
                  asset.mimeType?.includes('pdf') ? '📄' : '📎'
                }</span>
                <span class="file-label">{asset.originalFilename || asset.name}</span>
              </div>
            ) : null}
            {asset.publicUrl && (
              <a href={asset.publicUrl} target="_blank" rel="noopener noreferrer" class="button secondary" style="width:100%;margin-top:1rem;">
                {asset.mimeType?.startsWith('image/') ? 'View Full Size ↗' : 'Download File ↗'}
              </a>
            )}
          </div>

          {showAiPanel && (
            <div class="sidebar-section ai-assist">
              <h3>AI Assist</h3>
              <p class="ai-help">Generate accessible alt text and a description for this image.</p>
              <button type="button" id="ai-alt-text-btn" class="button" style="width:100%;">
                ✨ Generate alt text
              </button>
              <p id="ai-status" class="ai-status" style="display:none;"></p>
            </div>
          )}

          <div class="sidebar-section">
            <h3>File Info</h3>
            <dl class="info-list">
              <dt>Type</dt>
              <dd><code>{asset.mimeType}</code></dd>

              {asset.width && asset.height && (
                <>
                  <dt>Dimensions</dt>
                  <dd>{asset.width} × {asset.height}px</dd>
                </>
              )}

              <dt>File Size</dt>
              <dd>{(asset.fileSize / 1024).toFixed(1)} KB</dd>
            </dl>
          </div>
        </aside>
      </div>
    </>
  ) : null}
</AppLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .editor-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 32rem;
    gap: 1.5rem;
  }

  .main-section {
    min-width: 0;
  }

  .form {
    display: grid;
    gap: 2rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .sidebar {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }

  .sidebar-section {
    padding: 1.5rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .sidebar-section h3 {
    margin: 0 0 1rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .asset-preview {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 6px;
    overflow: hidden;
    background: var(--panel-2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .asset-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .file-preview {
    flex-direction: column;
    gap: 0.75rem;
  }

  .file-icon {
    font-size: 3rem;
    opacity: 0.7;
  }

  .file-label {
    font-size: 0.8rem;
    color: var(--muted);
    text-align: center;
    word-break: break-all;
    padding: 0 1rem;
  }

  .info-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .info-list dt {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-list dd {
    margin: 0;
    font-size: 0.875rem;
  }

  .metadata-editor {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 12px;
    line-height: 1.5;
    background: var(--panel-2);
  }

  .ai-help {
    margin: 0 0 0.75rem;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .ai-status {
    margin: 0.75rem 0 0;
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
  }

  .ai-status.ok { color: var(--accent); background: rgba(79, 156, 132, 0.1); }
  .ai-status.err { color: var(--color-error); background: var(--color-error-bg); }

  @media (max-width: 1024px) {
    .editor-layout {
      grid-template-columns: 1fr;
    }

    .sidebar {
      order: -1;
    }
  }

  .metadata-preview {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--panel-2);
    border-radius: 6px;
  }

  .metadata-preview-title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .metadata-preview-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .metadata-preview-item {
    padding: 0.5rem;
    background: var(--bg);
    border-radius: 4px;
  }

  .metadata-preview-item dt {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .metadata-preview-item dd {
    margin: 0;
    font-size: 0.875rem;
    word-break: break-word;
    white-space: pre-wrap;
    font-family: monospace;
  }
</style>

<script>
  import { createSdkClient } from '@/lib/sdk';
  import { resolveTagIds } from '@/lib/api/tagChips';

  console.log('[Asset Edit] Script loading...');

  const sdk = createSdkClient();
  const form = document.getElementById('asset-form') as HTMLFormElement;
  const metadataField = document.getElementById('metadata') as HTMLTextAreaElement;
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
  const deleteButton = document.getElementById('delete-button') as HTMLButtonElement;

  console.log('[Asset Edit] Elements found:', { form, submitButton, deleteButton, metadataField });

  if (!form) {
    console.error('[Asset Edit] Form not found!');
  }
  if (!submitButton) {
    console.error('[Asset Edit] Submit button not found!');
  }

  // Validate metadata JSON
  if (metadataField) {
    metadataField.addEventListener('blur', () => {
      const value = metadataField.value.trim();
      if (!value) return;

      try {
        JSON.parse(value);
        metadataField.style.borderColor = 'var(--line)';
      } catch (error) {
        metadataField.style.borderColor = '#ef5350';
      }
    });
  }

  // Handle delete via SDK
  deleteButton.addEventListener('click', async () => {
    if (!confirm('Delete this asset? This cannot be undone.')) {
      return;
    }

    deleteButton.disabled = true;
    deleteButton.textContent = 'Deleting...';

    try {
      const assetId = window.location.pathname.split('/').pop()!;
      await sdk.assets.delete(assetId);
      window.location.href = '/workspace/assets';
    } catch (error: any) {
      const message = error?.message || error?.detail || 'Failed to delete asset';
      alert(message);
      deleteButton.disabled = false;
      deleteButton.textContent = 'Delete';
    }
  });

  // Handle form submission via SDK
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      console.log('[Asset Edit] Form submitted');

    const formData = new FormData(form);
    const name = formData.get('name') as string;
    const altText = formData.get('altText') as string;
    const description = formData.get('description') as string;
    const metadataStr = formData.get('metadata') as string;

    // Parse metadata JSON
    let metadata = null;
    if (metadataStr?.trim()) {
      try {
        metadata = JSON.parse(metadataStr);
      } catch (error) {
        alert('Invalid JSON in metadata field');
        return;
      }
    }

    // Disable submit button
    submitButton.disabled = true;
    submitButton.textContent = 'Saving...';

    try {
      const assetId = window.location.pathname.split('/').pop()!;

      // Build update payload - always include metadata even if null/{}
      const updateData: any = {
        name,
        altText: altText?.trim() || null,
        description: description?.trim() || null,
      };

      // Always send metadata field (can be null or object)
      updateData.metadataJson = metadata;
      updateData.tag_ids = await resolveTagIds(document.getElementById('tags-payload') as HTMLInputElement | null);

      console.log('Updating asset with data:', updateData);
      await sdk.assets.update(assetId, updateData);
      console.log('Update successful');

      // Redirect back to assets list after a brief delay to see logs
      setTimeout(() => {
        window.location.href = '/workspace/assets';
      }, 500);
    } catch (error: any) {
      const message = error?.message || error?.detail || 'Failed to update asset';
      alert(message);
      submitButton.disabled = false;
      submitButton.textContent = 'Save Changes';
    }
    });
  } else {
    console.error('[Asset Edit] Cannot add submit handler - form not found');
  }

  // AI assist: generate alt text + description, then fill the fields as a suggestion.
  const aiBtn = document.getElementById('ai-alt-text-btn') as HTMLButtonElement | null;
  const aiStatus = document.getElementById('ai-status') as HTMLElement | null;
  if (aiBtn) {
    aiBtn.addEventListener('click', async () => {
      const assetId = window.location.pathname.split('/').pop()!;
      const original = aiBtn.textContent;
      aiBtn.disabled = true;
      aiBtn.textContent = 'Generating…';
      if (aiStatus) { aiStatus.style.display = 'none'; aiStatus.className = 'ai-status'; }
      try {
        const exec: any = await sdk.ai.operations.execute('generate-alt-text', {
          entityType: 'asset',
          entityId: assetId,
        });
        const out = exec?.outputJson ?? exec?.output_json ?? {};
        const altText = out.alt_text ?? out.altText;
        const description = out.description;
        const altField = document.getElementById('altText') as HTMLInputElement | null;
        const descField = document.getElementById('description') as HTMLTextAreaElement | null;
        if (altText && altField) altField.value = altText;
        if (description && descField) descField.value = description;
        if (aiStatus) {
          const tokens = exec?.totalTokens ?? exec?.total_tokens;
          aiStatus.textContent = altText
            ? `Suggestion applied${tokens ? ` · ${tokens} tokens` : ''}. Review, then Save Changes to keep it.`
            : 'No suggestion returned.';
          aiStatus.classList.add(altText ? 'ok' : 'err');
          aiStatus.style.display = 'block';
        }
      } catch (error: any) {
        if (aiStatus) {
          aiStatus.textContent = error?.message || error?.detail || 'AI request failed';
          aiStatus.classList.add('err');
          aiStatus.style.display = 'block';
        }
      } finally {
        aiBtn.disabled = false;
        aiBtn.textContent = original;
      }
    });
  }

  // Metadata preview update
  const metadataEditor = document.getElementById('metadata') as HTMLTextAreaElement;
  const metadataPreviewContainer = metadataEditor?.closest('.form-group')?.querySelector('.metadata-preview');

  if (metadataEditor) {
    metadataEditor.addEventListener('input', () => {
      const value = metadataEditor.value.trim();

      if (!value) {
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
        return;
      }

      try {
        const parsed = JSON.parse(value);
        const entries = Object.entries(parsed);

        if (entries.length === 0) {
          if (metadataPreviewContainer) {
            metadataPreviewContainer.remove();
          }
          return;
        }

        let previewHTML = `
          <div class="metadata-preview">
            <p class="metadata-preview-title">Current Metadata:</p>
            <dl class="metadata-preview-list">
        `;

        entries.forEach(([key, value]) => {
          const displayValue = typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value);
          previewHTML += `
            <div class="metadata-preview-item">
              <dt>${key}</dt>
              <dd>${displayValue}</dd>
            </div>
          `;
        });

        previewHTML += `</dl></div>`;

        if (metadataPreviewContainer) {
          metadataPreviewContainer.outerHTML = previewHTML;
        } else {
          const helpText = metadataEditor.closest('.form-group')?.querySelector('.form-help');
          if (helpText) {
            helpText.insertAdjacentHTML('afterend', previewHTML);
          }
        }
      } catch (error) {
        // Invalid JSON - remove preview
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
      }
    });
  }
</script>
