  // Per-field ✨ Improve — attached to prose textareas only. JSON editors and attachment
  // metadata are structured, not prose; Summary already has its own Generate.
  if (aiMenuBtn) {
    const SKIP_CLASS = ['data-json-editor', 'metadata-editor', 'attachment-metadata'];
    document.querySelectorAll<HTMLTextAreaElement>('textarea').forEach((field) => {
      if (field.id === 'summary') return;
      if (SKIP_CLASS.some((c) => field.classList.contains(c))) return;

      const label = document.querySelector<HTMLLabelElement>(`label[for="${field.id}"]`);
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'ai-mini-btn';
      btn.textContent = '✨ Improve';
      btn.title = 'Rewrite this field for clarity, grammar and style';
      (label?.parentElement?.classList.contains('label-row') ? label.parentElement : label ?? field.parentElement)
        ?.appendChild(btn);

      btn.addEventListener('click', async () => {
        const text = field.value.trim();
        if (!text) return aiToast('Nothing to improve in that field yet.', false);
        const original = btn.textContent;
        btn.disabled = true; btn.textContent = '…';
        try {
          const { out } = await runEntryOp('improve-writing', {
            text, field: label?.textContent?.trim() || field.id,
          });
          if (out.improved) {
            field.value = out.improved;
            const changes: string[] = out.changes ?? [];
            aiToast(`Rewrote ${label?.textContent?.trim() || field.id}${changes.length ? ` · ${changes.length} changes` : ''}. Review, then Save.`);
          } else {
            aiToast('No improvement returned.', false);
          }
        } catch (err: any) {
          aiToast(err?.message || 'Improve failed', false);
        } finally {
          btn.disabled = false; btn.textContent = original;
