---
import AppLayout from "@/layouts/AppLayout.astro";
import SchemaForm from "@/components/SchemaForm.astro";
import { getAuthToken } from "@/lib/api/client";
import { getEntry, updateEntry, type EntryRead, type CollectionRead } from "@/lib/api/entries";
import { listEntryTypes, type EntryTypeRead } from "@/lib/api/entryTypes";
import { listCollections } from "@/lib/api/collections";
import { getAssets } from "@/lib/api/platform";
import { listResources } from "@/lib/api/resources";
import { createSdkClient } from "@/lib/sdk";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

// Handle form submission (server-side)
if (Astro.request.method === 'POST' && id && authToken) {
  try {
    const formData = await Astro.request.formData();

    // Parse structured collection attachments
    const collectionAttachments: Array<Record<string, any>> = [];
    let collIdx = 0;
    while (formData.has(`collection_attachments[${collIdx}].collection_id`)) {
      let collMeta = null;
      const collMetaStr = (formData.get(`collection_attachments[${collIdx}].metadata`) as string) || '';
      if (collMetaStr.trim()) {
        try { collMeta = JSON.parse(collMetaStr); } catch { /* ignore invalid JSON */ }
      }
      collectionAttachments.push({
        collection_id: formData.get(`collection_attachments[${collIdx}].collection_id`) as string,
        role: (formData.get(`collection_attachments[${collIdx}].role`) as string) || null,
        metadata: collMeta,
      });
      collIdx++;
    }

    // Parse structured asset attachments
    const assetAttachments: Array<Record<string, any>> = [];
    let assetIdx = 0;
    while (formData.has(`asset_attachments[${assetIdx}].asset_id`)) {
      let assetMeta = null;
      const assetMetaStr = (formData.get(`asset_attachments[${assetIdx}].metadata`) as string) || '';
      if (assetMetaStr.trim()) {
        try { assetMeta = JSON.parse(assetMetaStr); } catch { /* ignore invalid JSON */ }
      }
      assetAttachments.push({
        asset_id: formData.get(`asset_attachments[${assetIdx}].asset_id`) as string,
        role: (formData.get(`asset_attachments[${assetIdx}].role`) as string) || null,
        metadata: assetMeta,
        position: assetIdx,
      });
      assetIdx++;
    }

    // Parse structured resource attachments
    const resourceAttachments: Array<Record<string, any>> = [];
    let resIdx = 0;
    while (formData.has(`resource_attachments[${resIdx}].resource_id`)) {
      let resMeta = null;
      const resMetaStr = (formData.get(`resource_attachments[${resIdx}].metadata`) as string) || '';
      if (resMetaStr.trim()) {
        try { resMeta = JSON.parse(resMetaStr); } catch { /* ignore invalid JSON */ }
      }
      resourceAttachments.push({
        resource_id: formData.get(`resource_attachments[${resIdx}].resource_id`) as string,
        role: (formData.get(`resource_attachments[${resIdx}].role`) as string) || null,
        metadata: resMeta,
        position: resIdx,
      });
      resIdx++;
    }

    // Parse dataJson from schema fields (dataJson.fieldKey format)
    const dataJson: Record<string, any> = {};
    for (const [key, value] of formData.entries()) {
      if (key.startsWith('dataJson.')) {
        const fieldKey = key.replace('dataJson.', '');
        // Handle boolean checkboxes (only present if checked)
        if (value === 'true' || value === 'false') {
          dataJson[fieldKey] = value === 'true';
        } else {
          dataJson[fieldKey] = value || null;
        }
      }
    }

    // Parse metadata JSON
    const metadataJsonStr = formData.get('metadata_json') as string | null;
    let metadataJson = null;
    if (metadataJsonStr?.trim()) {
      try {
        metadataJson = JSON.parse(metadataJsonStr);
      } catch (error) {
        console.error('[Entry] Invalid metadata JSON:', error);
        // Let it pass as null
      }
    }

    const updateData: Record<string, any> = {
      entry_type_id: formData.get('entry_type_id') as string,
      title: formData.get('title') as string,
      slug: (formData.get('slug') as string) || null,
      summary: (formData.get('summary') as string) || null,
      description: (formData.get('description') as string) || null,
      data_json: Object.keys(dataJson).length > 0 ? dataJson : null,
      status: formData.get('status') as string,
      metadata_json: metadataJson,
      collection_attachments: collectionAttachments,
      asset_attachments: assetAttachments,
      resource_attachments: resourceAttachments,
    };

    await updateEntry(id, updateData, authToken);
    return Astro.redirect('/workspace/entries');
  } catch (e) {
    console.error('[Entry] Failed to update entry:', e);
    // Error will be shown below
  }
}

let entry: EntryRead | null = null;
let entryTypes: EntryTypeRead[] = [];
let collections: CollectionRead[] = [];
let allAssets: any[] = [];
let allResources: any[] = [];
let error: string | null = null;

if (!id) {
  error = "Entry ID is required";
} else if (!authToken) {
  error = "Authentication required";
} else {
  try {
    [entry, entryTypes, collections, allAssets, allResources] = await Promise.all([
      getEntry(id, authToken),
      listEntryTypes(authToken),
      listCollections(authToken),
      getAssets(authToken),
      listResources(authToken),
    ]);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[Entry] Failed to load:', error);
  }
}

const sortedTypes = entryTypes.sort((a, b) => a.sortOrder - b.sortOrder);
const sortedCollections = collections.sort((a, b) => a.sortOrder - b.sortOrder);
const attachedCollections = (entry?.collections || []).sort((a: any, b: any) => (a.sortOrder ?? 0) - (b.sortOrder ?? 0));
const attachedCollectionIds = new Set(attachedCollections.map((c: any) => c.id));
const attachedAssets = (entry?.assets || []).sort((a: any, b: any) => (a.position ?? 0) - (b.position ?? 0));
const attachedResources = (entry?.resources || []).sort((a: any, b: any) => (a.position ?? 0) - (b.position ?? 0));
const attachedAssetIds = new Set(attachedAssets.map((a: any) => a.id));
const attachedResourceIds = new Set(attachedResources.map((r: any) => r.id));

// Get entry type schema for schema-driven form
const entryType = entry ? entryTypes.find(t => t.id === entry.entryTypeId) : null;
const hasSchema = entryType?.schemaJson && (entryType.schemaJson as any).fields?.length > 0;

// AI assist gating: workspace AI enabled + editor invocation source + auth (fail closed).
let aiEditorEnabled = false;
if (entry && authToken) {
  try {
    const aiSdk = createSdkClient(authToken);
    const aiSettings: any = await aiSdk.ai.settings.get();
    const sources = aiSettings?.invocationSources ?? aiSettings?.invocation_sources;
    aiEditorEnabled = aiSettings?.enabled !== false && sources?.editor !== false;
  } catch {
    aiEditorEnabled = false;
  }
}

// Pending AI suggestion (write-back): proposed field changes staged for human review.
const suggestion = (entry as any)?.suggestionJson as Record<string, any> | null | undefined;
function suggestionCurrent(target: string): any {
  if (!entry) return undefined;
  if (target.startsWith('data_json.')) return (entry as any).dataJson?.[target.slice('data_json.'.length)];
  if (target.startsWith('metadata_json.')) return (entry as any).metadataJson?.[target.slice('metadata_json.'.length)];
  return (entry as any)[target];
}
function suggestionFormat(v: any): string {
  if (v == null || v === '') return '—';
  if (Array.isArray(v)) return v.join(', ');
  if (typeof v === 'object') return JSON.stringify(v);
  return String(v);
}
const suggestionFields = suggestion
  ? Object.keys(suggestion)
      .filter((k) => k !== '_meta')
      .map((target) => ({
        label: target.replace(/^data_json\./, '').replace(/^metadata_json\./, ''),
        current: suggestionFormat(suggestionCurrent(target)),
        proposed: suggestionFormat(suggestion[target]),
      }))
  : [];
const suggestionOp = suggestion?._meta?.operation as string | undefined;
---

<AppLayout
  title={entry ? entry.title : "Edit Entry"}
  entityType="entry"
  entityId={id}
  entityLabel={entry?.title}
>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading entry:</strong> {error}</p>
      <a href="/workspace/entries" class="button secondary">Back to Entries</a>
    </div>
  ) : entry ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Entry</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Update entry details and content</p>
        </div>
        <div style="display:flex;gap:0.75rem;">
          {aiEditorEnabled && (
            <div class="ai-menu-wrap">
              <button type="button" id="ai-menu-btn" class="button secondary"
                aria-haspopup="menu" aria-expanded="false">✨ AI</button>
              <div id="ai-menu" class="ai-menu" role="menu" hidden>
                <button type="button" role="menuitem" class="ai-menu-item" data-ai-action="summary">
                  Generate summary
                  <span class="ai-menu-hint">Fills the Summary field for review</span>
                </button>
                <button type="button" role="menuitem" class="ai-menu-item" data-ai-action="tags">
                  Generate tags
                  <span class="ai-menu-hint">Staged for review, per your approval mode</span>
                </button>
                <button type="button" role="menuitem" class="ai-menu-item" data-ai-action="review">
                  Review &amp; suggest
                  <span class="ai-menu-hint">Opens Marvin with this entry in context</span>
                </button>
              </div>
            </div>
          )}
          <button type="button" id="delete-entry-button" class="button secondary">
            Delete
          </button>
          <a class="button secondary" href="/workspace/entries">Back</a>
        </div>
      </div>

      {/* Always mounted (even when empty) so a staged suggestion can be rendered in place
          after an AI action, without reloading and discarding unsaved form edits. */}
      <div id="suggestion-mount">
      {suggestionFields.length > 0 && (
        <div class="suggestion-banner">
          <div class="suggestion-head">
            <span class="suggestion-title">✨ AI suggested changes</span>
            {suggestionOp && <span class="suggestion-op">from <code>{suggestionOp}</code></span>}
          </div>
          <ul class="suggestion-list">
            {suggestionFields.map((f) => (
              <li class="suggestion-field">
                <span class="suggestion-label">{f.label}</span>
                <div class="suggestion-diff">
                  <div class="diff-row diff-current"><span class="diff-tag">current</span><span class="diff-val">{f.current}</span></div>
                  <div class="diff-row diff-proposed"><span class="diff-tag">proposed</span><span class="diff-val">{f.proposed}</span></div>
                </div>
              </li>
            ))}
          </ul>
          <div class="suggestion-actions">
            <button type="button" id="apply-suggestion" class="button">Apply changes</button>
            <button type="button" id="reject-suggestion" class="button secondary">Reject</button>
          </div>
        </div>
      )}
      </div>

      <div class="editor-layout">
        <section class="main-editor">
          <form id="entry-form" method="POST" class="form">
            <div class="form-group">
              <label for="title">Title *</label>
              <input
                type="text"
                id="title"
                name="title"
                required
                value={entry.title}
                class="title-input"
              />
            </div>

            {/* Schema-driven content fields */}
            {hasSchema ? (
              <div class="schema-content-section">
                <h3 style="margin:0 0 1rem;font-size:1rem;font-weight:600;">Content Fields</h3>
                <SchemaForm
                  schema={entryType.schemaJson}
                  values={entry.dataJson || {}}
                />
              </div>
            ) : (
              <details class="legacy-content-section">
                <summary class="migration-notice">
                  <strong>⚠️ Legacy Content Mode</strong>
                  <span style="font-size:0.8rem;color:var(--muted);margin-left:0.5rem;">
                    No schema defined.
                    <a href={`/workspace/entry-types/${entry.entryTypeId}`}>Add a schema →</a>
                  </span>
                </summary>

                <div class="form-group" style="margin-top:1rem;">
                  <label for="content_markdown">Content (Markdown)</label>
                  <textarea
                    id="content_markdown"
                    name="dataJson.body"
                    rows="20"
                    placeholder="Write your content in Markdown..."
                    class="content-markdown-field"
                  >{entry.contentMarkdown || entry.dataJson?.body || ""}</textarea>
                </div>
              </details>
            )}

            <div class="form-group">
              <label for="data_json_editor">Data JSON (Schema Fields)</label>
              <p class="form-help">View or edit schema field data as JSON. Paste complete JSON to populate form fields.</p>
              <textarea
                id="data_json_editor"
                rows="8"
                placeholder='{"text_field": "value", "number_field": 42}'
                class="data-json-editor"
              >{entry.dataJson ? JSON.stringify(entry.dataJson, null, 2) : "{}"}</textarea>
              <button type="button" id="apply-data-json-btn" class="button secondary" style="margin-top: 0.5rem;">Apply JSON to Form</button>
              <small style="font-size: 11px; color: var(--muted); display: block; margin-top: 0.5rem;">
                Changes here will update the form fields above when you click "Apply JSON to Form"
              </small>
            </div>

            <div class="form-group">
              <label for="metadata_json">Metadata (JSON)</label>
              <p class="form-help">Custom JSON metadata for this entry</p>
              <textarea
                id="metadata_json"
                name="metadata_json"
                rows="8"
                placeholder='{"key": "value"}'
                form="entry-form"
                class="metadata-editor"
              >{entry.metadataJson ? JSON.stringify(entry.metadataJson, null, 2) : ""}</textarea>
              <small style="font-size: 11px; color: var(--muted);">
                Must be valid JSON. Example: {`{"seo_title": "My Title", "featured": true}`}
              </small>

              {entry.metadataJson && Object.keys(entry.metadataJson).length > 0 && (
                <div class="metadata-preview">
                  <p class="metadata-preview-title">Current Metadata:</p>
                  <dl class="metadata-preview-list">
                    {Object.entries(entry.metadataJson).map(([key, value]) => (
                      <div class="metadata-preview-item">
                        <dt>{key}</dt>
                        <dd>{typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value)}</dd>
                      </div>
                    ))}
                  </dl>
                </div>
              )}
            </div>

            <div class="form-actions">
              <button type="submit" id="save-button" class="button">
                Save
              </button>
              <button type="button" id="publish-button" class="button secondary">
                Publish
              </button>
            </div>
          </form>
        </section>

        <aside class="sidebar-editor">
          <div class="sidebar-section">
            <h3>Entry Details</h3>

            <div class="form-group">
              <label for="entry_type_display">Entry Type</label>
              <select id="entry_type_display" form="entry-form" disabled>
                {sortedTypes.map((type) => (
                  <option value={type.id} selected={type.id === entry.entryTypeId}>
                    {type.icon && `${type.icon} `}{type.name}
                  </option>
                ))}
              </select>
              <p class="form-help" style="color: var(--muted); font-size: 0.75rem; margin-top: 0.25rem;">
                Entry type cannot be changed after creation
              </p>
              <input type="hidden" name="entry_type_id" form="entry-form" value={entry.entryTypeId} />
            </div>

            <div class="form-group">
              <label for="slug">Slug</label>
              <input
                type="text"
                id="slug"
                name="slug"
                value={entry.slug}
                disabled={entry.status === "published"}
                style={entry.status === "published" ? "background: var(--panel-2); color: var(--muted);" : ""}
                form="entry-form"
              />
              <small style="font-size: 12px; color: var(--muted);">
                {entry.status === "published"
                  ? "Slug is locked for published entries to protect external URLs"
                  : "Auto-generated from title, or enter custom slug"}
              </small>
            </div>

            <div class="form-group">
              <label for="status">Status</label>
              <select id="status" name="status" form="entry-form">
                <option value="inbox" selected={entry.status === "inbox"}>Inbox</option>
                <option value="draft" selected={entry.status === "draft"}>Draft</option>
                <option value="needs_review" selected={entry.status === "needs_review"}>Needs Review</option>
                <option value="approved" selected={entry.status === "approved"}>Approved</option>
                <option value="published" selected={entry.status === "published"}>Published</option>
              </select>
            </div>

            <div class="form-group">
              <div class="label-row">
                <label for="summary">Summary</label>
                {aiEditorEnabled && (
                  <button type="button" id="ai-summary-btn" class="ai-mini-btn">✨ Generate</button>
                )}
              </div>
              <textarea
                id="summary"
                name="summary"
                rows="3"
                form="entry-form"
              >{entry.summary || ""}</textarea>
              {aiEditorEnabled && <p id="ai-summary-status" class="ai-status" style="display:none;"></p>}
            </div>

            <div class="form-group">
              <label for="description">Description</label>
              <textarea
                id="description"
                name="description"
                rows="3"
                form="entry-form"
              >{entry.description || ""}</textarea>
            </div>

            <div class="form-group">
              <label for="published_at">Published Date</label>
              <input
                type="datetime-local"
                id="published_at"
                name="published_at"
                value={entry.publishedAt ? new Date(entry.publishedAt).toISOString().slice(0, 16) : ""}
                form="entry-form"
              />
              <p class="form-help">Actual date/time this entry was published</p>
            </div>

            <div class="form-group">
              <label for="publish_at">Scheduled Publish</label>
              <input
                type="datetime-local"
                id="publish_at"
                name="publish_at"
                value={entry.publishAt ? new Date(entry.publishAt).toISOString().slice(0, 16) : ""}
                form="entry-form"
              />
              <p class="form-help">Schedule when this entry should be published</p>
            </div>

            <div class="form-group">
              <label for="expire_at">Expiration Date</label>
              <input
                type="datetime-local"
                id="expire_at"
                name="expire_at"
                value={entry.expireAt ? new Date(entry.expireAt).toISOString().slice(0, 16) : ""}
                form="entry-form"
              />
              <p class="form-help">When this entry should expire and be hidden</p>
            </div>
          </div>

          <div class="sidebar-section">
            <h3>Collections (<span id="collection-count">{attachedCollections.length}</span>)</h3>
            <p class="section-help">Organize entry by collection</p>

            <div id="attached-collections" class="attached-list">
              {attachedCollections.map((coll: any, idx: number) => (
                <div class="attachment-card" data-collection-id={coll.id}>
                  <div class="attachment-header">
                    <div class="attachment-preview" style={`background-color: ${coll.color || '#a94d3f'}`}>
                      <span class="attachment-icon" style="font-size:18px;">{coll.icon || '📁'}</span>
                    </div>
                    <div class="attachment-name">
                      <strong>{coll.name}</strong>
                      <span class="picker-meta">{coll.slug}</span>
                    </div>
                    <div class="attachment-actions">
                      <button type="button" class="move-up-btn icon-btn" title="Move up">↑</button>
                      <button type="button" class="move-down-btn icon-btn" title="Move down">↓</button>
                      <button type="button" class="remove-btn icon-btn" title="Remove">×</button>
                    </div>
                  </div>
                  <div class="attachment-fields">
                    <input type="hidden" name={`collection_attachments[${idx}].collection_id`} value={coll.id} form="entry-form" />
                    <div class="field-row">
                      <label>Role</label>
                      <input type="text" name={`collection_attachments[${idx}].role`} value={coll.role || ''} placeholder="e.g. primary, featured" form="entry-form" />
                    </div>
                    <div class="field-row field-row-full">
                      <label>Metadata</label>
                      <textarea name={`collection_attachments[${idx}].metadata`} rows="2" placeholder='{"featured": true}' form="entry-form" class="attachment-metadata">{coll.placementMetadata ? JSON.stringify(coll.placementMetadata, null, 2) : ''}</textarea>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <details class="add-picker">
              <summary>Add Collection</summary>
              <div class="add-picker-panel">
                <div class="picker-search">
                  <input type="search" id="collection-search" placeholder="Search collections..." />
                </div>
                <div class="picker-list">
                  {sortedCollections.filter((c) => !attachedCollectionIds.has(c.id)).map((collection) => (
                    <div class="attachment-card add-collection-item" data-collection-id={collection.id} data-collection-name={collection.name} data-collection-slug={collection.slug} data-collection-icon={collection.icon || '📁'} data-collection-color={collection.color || '#a94d3f'}>
                      <div class="attachment-header">
                        <div class="attachment-preview" style={`background-color: ${collection.color || '#a94d3f'}`}>
                          <span class="attachment-icon" style="font-size:18px;">{collection.icon || '📁'}</span>
                        </div>
                        <div class="attachment-name">
                          <strong>{collection.name}</strong>
                          <span class="picker-meta">{collection.slug}</span>
                        </div>
                        <div class="attachment-actions">
                          <button type="button" class="add-btn icon-btn" title="Add">+</button>
                        </div>
                      </div>
                    </div>
                  ))}
                  {sortedCollections.length === 0 && (
                    <p class="empty-message">No collections available. <a href="/workspace/collections/new">Create one</a>.</p>
                  )}
                </div>
              </div>
            </details>
          </div>

          <div class="sidebar-section">
            <h3>Assets (<span id="asset-count">{attachedAssets.length}</span>)</h3>
            <p class="section-help">Attach images, files, and media</p>

            <div id="attached-assets" class="attached-list">
              {attachedAssets.map((asset: any, idx: number) => (
                <div class="attachment-card" data-asset-id={asset.id}>
                  <div class="attachment-header">
                    <div class="attachment-preview">
                      {asset.publicUrl && asset.mimeType?.startsWith('image/') ? (
                        <img src={asset.publicUrl} alt={asset.altText || asset.name} />
                      ) : (
                        <span class="attachment-icon">📄</span>
                      )}
                    </div>
                    <div class="attachment-name">
                      <strong>{asset.name}</strong>
                      <span class="picker-meta">{asset.mimeType}</span>
                    </div>
                    <div class="attachment-actions">
                      <button type="button" class="move-up-btn icon-btn" title="Move up">↑</button>
                      <button type="button" class="move-down-btn icon-btn" title="Move down">↓</button>
                      <button type="button" class="remove-btn icon-btn" title="Remove">×</button>
                    </div>
                  </div>
                  <div class="attachment-fields">
                    <input type="hidden" name={`asset_attachments[${idx}].asset_id`} value={asset.id} form="entry-form" />
                    <div class="field-row">
                      <label>Role</label>
                      <input type="text" name={`asset_attachments[${idx}].role`} value={asset.role || ''} placeholder="e.g. hero, thumbnail" form="entry-form" />
                    </div>
                    <div class="field-row field-row-full">
                      <label>Metadata</label>
                      <textarea name={`asset_attachments[${idx}].metadata`} rows="2" placeholder='{"focal_point": "50% 30%"}' form="entry-form" class="attachment-metadata">{asset.placementMetadata ? JSON.stringify(asset.placementMetadata, null, 2) : ''}</textarea>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <details class="add-picker">
              <summary>Add Asset</summary>
              <div class="add-picker-panel">
                <div class="picker-search">
                  <input type="search" id="asset-search" placeholder="Search assets..." />
                </div>
                <div class="picker-list">
                  {allAssets.filter((a: any) => !attachedAssetIds.has(a.id)).map((asset: any) => (
                    <div class="attachment-card add-asset-item" data-asset-id={asset.id} data-asset-name={asset.name} data-asset-mime={asset.mimeType} data-asset-url={asset.publicUrl || ''} data-asset-alt={asset.altText || ''}>
                      <div class="attachment-header">
                        <div class="attachment-preview">
                          {asset.publicUrl && asset.mimeType?.startsWith('image/') ? (
                            <img src={asset.publicUrl} alt={asset.altText || asset.name} />
                          ) : (
                            <span class="attachment-icon">📄</span>
                          )}
                        </div>
                        <div class="attachment-name">
                          <strong>{asset.name}</strong>
                          <span class="picker-meta">{asset.mimeType}</span>
                        </div>
                        <div class="attachment-actions">
                          <button type="button" class="add-btn icon-btn" title="Add">+</button>
                        </div>
                      </div>
                    </div>
                  ))}
                  {allAssets.length === 0 && (
                    <p class="empty-message">No assets available. <a href="/workspace/assets/new">Upload one</a>.</p>
                  )}
                </div>
              </div>
            </details>
          </div>

          <div class="sidebar-section">
            <h3>Resources (<span id="resource-count">{attachedResources.length}</span>)</h3>
            <p class="section-help">Attach external resources and references</p>

            <div id="attached-resources" class="attached-list">
              {attachedResources.map((resource: any, idx: number) => (
                <div class="attachment-card" data-resource-id={resource.id}>
                  <div class="attachment-header">
                    <div class="attachment-name">
                      <strong>{resource.name}</strong>
                      <span class="picker-meta">{resource.resourceType}{resource.url ? ` • ${resource.url}` : ''}</span>
                    </div>
                    <div class="attachment-actions">
                      <button type="button" class="move-up-btn icon-btn" title="Move up">↑</button>
                      <button type="button" class="move-down-btn icon-btn" title="Move down">↓</button>
                      <button type="button" class="remove-btn icon-btn" title="Remove">×</button>
                    </div>
                  </div>
                  <div class="attachment-fields">
                    <input type="hidden" name={`resource_attachments[${idx}].resource_id`} value={resource.id} form="entry-form" />
                    <div class="field-row">
                      <label>Role</label>
                      <input type="text" name={`resource_attachments[${idx}].role`} value={resource.role || ''} placeholder="e.g. primary, accent" form="entry-form" />
                    </div>
                    <div class="field-row field-row-full">
                      <label>Metadata</label>
                      <textarea name={`resource_attachments[${idx}].metadata`} rows="2" placeholder='{"quantity": "2.5", "unit": "yards"}' form="entry-form" class="attachment-metadata">{resource.placementMetadata ? JSON.stringify(resource.placementMetadata, null, 2) : ''}</textarea>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <details class="add-picker">
              <summary>Add Resource</summary>
              <div class="add-picker-panel">
                <div class="picker-search">
                  <input type="search" id="resource-search" placeholder="Search resources..." />
                </div>
                <div class="picker-list">
                  {allResources.filter((r: any) => !attachedResourceIds.has(r.id)).map((resource: any) => (
                    <div class="attachment-card add-resource-item" data-resource-id={resource.id} data-resource-name={resource.name} data-resource-type={resource.resourceType} data-resource-url={resource.url || ''}>
                      <div class="attachment-header">
                        <div class="attachment-name">
                          <strong>{resource.name}</strong>
                          <span class="picker-meta">{resource.resourceType}{resource.url ? ` • ${resource.url}` : ''}</span>
                        </div>
                        <div class="attachment-actions">
                          <button type="button" class="add-btn icon-btn" title="Add">+</button>
                        </div>
                      </div>
                    </div>
                  ))}
                  {allResources.length === 0 && (
                    <p class="empty-message">No resources available. <a href="/workspace/resources/new">Create one</a>.</p>
                  )}
                </div>
              </div>
            </details>
          </div>

        </aside>
      </div>
    </>
  ) : null}
</AppLayout>

