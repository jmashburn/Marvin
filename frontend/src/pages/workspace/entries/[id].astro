          const fieldName = `dataJson.${key}`;
          const field = form.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;

          if (field) {
            if (field.type === 'checkbox') {
