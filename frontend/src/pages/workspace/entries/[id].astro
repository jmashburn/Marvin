  // Enhanced markdown to HTML converter
  function renderMarkdown(markdown: string): string {
    if (!markdown || markdown.trim() === '') {
      return '<p style="color:var(--muted);text-align:center;padding:2rem;">Nothing to preview yet. Start writing in the Edit tab!</p>';
    }

    let html = markdown;
    let frontmatterHtml = '';

    // Extract YAML frontmatter (only at the very start with content between)
    const frontmatterMatch = html.match(/^---\n(.+[\s\S]*?)\n---\n/);
    if (frontmatterMatch && frontmatterMatch[1].includes(':')) {
      const frontmatterContent = frontmatterMatch[1];
      // Remove frontmatter from main content
      html = html.replace(frontmatterMatch[0], '');

      // Parse and display frontmatter as a card
      const frontmatterLines = frontmatterContent.split('\n')
        .filter((line: string) => line.trim())
        .map((line: string) => {
          const [key, ...valueParts] = line.split(':');
          const value = valueParts.join(':').trim();
          return `<div style="display:flex;gap:0.5rem;"><strong>${key.trim()}:</strong> <span>${value}</span></div>`;
        })
        .join('');

      frontmatterHtml = `<div class="frontmatter-preview">${frontmatterLines}</div>`;
    }

    // Markdown tables
    const tableRegex = /^\|(.+)\|\n\|[-:\s|]+\|\n((?:\|.+\|\n?)*)/gim;
    html = html.replace(tableRegex, (match: string, header: string, rows: string) => {
      const headerCells = header.split('|').map((cell: string) => cell.trim()).filter(Boolean);
      const headerRow = '<tr>' + headerCells.map((cell: string) => `<th>${cell}</th>`).join('') + '</tr>';

      const bodyRows = rows.trim().split('\n').map((row: string) => {
        const cells = row.split('|').map((cell: string) => cell.trim()).filter(Boolean);
        return '<tr>' + cells.map((cell: string) => `<td>${cell}</td>`).join('') + '</tr>';
      }).join('');

      return `<table class="markdown-table"><thead>${headerRow}</thead><tbody>${bodyRows}</tbody></table>`;
    });

    // Code blocks (fenced) - must come before inline code
    html = html.replace(/```(\w+)?\n([\s\S]*?)```/g, (match: string, lang: string, code: string) => {
      const language = lang ? ` class="language-${lang}"` : '';
      return `<pre><code${language}>${escapeHtml(code.trim())}</code></pre>`;
    });

    // Blockquotes
    html = html.replace(/^> (.*$)/gim, '<blockquote>$1</blockquote>');

    // Horizontal rules
    html = html.replace(/^---$/gim, '<hr>');
    html = html.replace(/^\*\*\*$/gim, '<hr>');

    // Headers (h1-h6)
    html = html.replace(/^###### (.*$)/gim, '<h6>$1</h6>');
    html = html.replace(/^##### (.*$)/gim, '<h5>$1</h5>');
    html = html.replace(/^#### (.*$)/gim, '<h4>$1</h4>');
    html = html.replace(/^### (.*$)/gim, '<h3>$1</h3>');
    html = html.replace(/^## (.*$)/gim, '<h2>$1</h2>');
    html = html.replace(/^# (.*$)/gim, '<h1>$1</h1>');

    // Images
    html = html.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<img src="$2" alt="$1" style="max-width:100%;height:auto;border-radius:6px;margin:1rem 0;">');

    // Links
    html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');

    // Unordered lists
    html = html.replace(/^\* (.*$)/gim, '<li>$1</li>');
    html = html.replace(/^- (.*$)/gim, '<li>$1</li>');
    html = html.replace(/(<li>.*<\/li>)/s, '<ul>$1</ul>');

    // Ordered lists
    html = html.replace(/^\d+\. (.*$)/gim, '<li>$1</li>');

    // Strikethrough
    html = html.replace(/~~(.*?)~~/g, '<del>$1</del>');

    // Bold (must come before italic)
    html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    html = html.replace(/__(.*?)__/g, '<strong>$1</strong>');

    // Italic
    html = html.replace(/\*((?!\*).+?)\*/g, '<em>$1</em>');
    html = html.replace(/_((?!_).+?)_/g, '<em>$1</em>');

    // Inline code
    html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

    // Task lists
    html = html.replace(/- \[ \] (.*$)/gim, '<li style="list-style:none;"><input type="checkbox" disabled> $1</li>');
    html = html.replace(/- \[x\] (.*$)/gim, '<li style="list-style:none;"><input type="checkbox" checked disabled> $1</li>');

    // Paragraphs
    html = html.split('\n\n').map((block: string) => {
      // Don't wrap if already has block-level tags
      if (block.match(/^<(h[1-6]|ul|ol|pre|blockquote|hr)/)) {
        return block;
      }
      return `<p>${block.replace(/\n/g, '<br>')}</p>`;
    }).join('\n');

    return frontmatterHtml + html;
  }

  // Helper to escape HTML in code blocks
  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Tab switching
  tabButtons.forEach(button => {
    button.addEventListener('click', () => {
      const targetTab = (button as HTMLElement).dataset.tab;

      // Update buttons
      tabButtons.forEach(btn => btn.classList.remove('active'));
      button.classList.add('active');

      // Update content
      tabContents.forEach(content => {
        if ((content as HTMLElement).dataset.tabContent === targetTab) {
          content.classList.add('active');
        } else {
          content.classList.remove('active');
        }
      });

      // Render preview if switching to preview tab
      if (targetTab === 'preview' && markdownTextarea && previewPane) {
        const rendered = renderMarkdown((markdownTextarea as HTMLTextAreaElement).value);
        previewPane.innerHTML = rendered;
      }
    });
  });

  // Handle form submission with JSON metadata parsing
  const entryForm = document.getElementById('entry-form') as HTMLFormElement | null;
  const metadataField = document.getElementById('metadata_json') as HTMLTextAreaElement | null;
  const statusField = document.getElementById('status') as HTMLSelectElement | null;

  if (entryForm && metadataField && statusField) {
    // Set status dropdown value when Save Draft or Publish button is clicked
    entryForm.addEventListener('click', (e) => {
      if (e.target instanceof HTMLButtonElement && e.target.type === 'submit' && e.target.name === 'status') {
        statusField.value = e.target.value; // Set dropdown to "draft" or "published"
      }
    });

    // Add syntax highlighting on blur (basic validation feedback)
    metadataField.addEventListener('blur', () => {
      const value = metadataField.value.trim();
      if (!value) return;

      try {
        JSON.parse(value);
        metadataField.style.borderColor = 'var(--line)';
      } catch (error) {
        metadataField.style.borderColor = '#ef5350';
      }
    });
  }
</script>
