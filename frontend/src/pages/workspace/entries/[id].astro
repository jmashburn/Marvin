<script>
  import { createSdkClient } from '@/lib/sdk';

  const sdk = createSdkClient();
  const form = document.getElementById('entry-form') as HTMLFormElement;
  const deleteButton = document.getElementById('delete-entry-button') as HTMLButtonElement;

  // AI suggestion (write-back) apply / reject
  const applySuggestionBtn = document.getElementById('apply-suggestion') as HTMLButtonElement | null;
  const rejectSuggestionBtn = document.getElementById('reject-suggestion') as HTMLButtonElement | null;
  async function suggestionAction(kind: 'apply' | 'reject') {
    const entryId = document.body.dataset.entityId || window.location.pathname.split('/').pop();
    if (!entryId) return;
    applySuggestionBtn?.setAttribute('disabled', 'true');
    rejectSuggestionBtn?.setAttribute('disabled', 'true');
    try {
      const res = await fetch(`/api/entries/${entryId}/${kind}-suggestion`, { method: 'POST' });
      if (!res.ok) throw new Error(String(res.status));
      window.location.reload();
    } catch (e) {
      alert(`Failed to ${kind} suggestion.`);
      applySuggestionBtn?.removeAttribute('disabled');
      rejectSuggestionBtn?.removeAttribute('disabled');
    }
  }
  applySuggestionBtn?.addEventListener('click', () => suggestionAction('apply'));
  rejectSuggestionBtn?.addEventListener('click', () => suggestionAction('reject'));

  // Auto-generate slug from title for unpublished entries
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;
  const statusSelect = document.getElementById('status') as HTMLSelectElement;
  const saveButton = document.getElementById('save-button') as HTMLButtonElement;
  const publishButton = document.getElementById('publish-button') as HTMLButtonElement;

  // AI assist: generate a summary and fill the field as a suggestion.
  const aiSummaryBtn = document.getElementById('ai-summary-btn') as HTMLButtonElement | null;
  const aiSummaryStatus = document.getElementById('ai-summary-status') as HTMLElement | null;
  if (aiSummaryBtn) {
    aiSummaryBtn.addEventListener('click', async () => {
      const entryId = document.body.dataset.entityId || window.location.pathname.split('/').pop()!;
      const original = aiSummaryBtn.textContent;
      aiSummaryBtn.disabled = true;
      aiSummaryBtn.textContent = '…';
      if (aiSummaryStatus) { aiSummaryStatus.style.display = 'none'; aiSummaryStatus.className = 'ai-status'; }
      try {
        const exec: any = await sdk.ai.operations.execute('generate-summary', {
          entityType: 'entry',
          entityId: entryId,
        });
        const out = exec?.outputJson ?? exec?.output_json ?? {};
        const summary = out.summary;
        const field = document.getElementById('summary') as HTMLTextAreaElement | null;
        if (summary && field) field.value = summary;
        if (aiSummaryStatus) {
          const tokens = exec?.totalTokens ?? exec?.total_tokens;
          aiSummaryStatus.textContent = summary
            ? `Suggestion applied${tokens ? ` · ${tokens} tokens` : ''}. Review, then Save to keep it.`
            : 'No suggestion returned.';
          aiSummaryStatus.classList.add(summary ? 'ok' : 'err');
          aiSummaryStatus.style.display = 'block';
        }
      } catch (err: any) {
        if (aiSummaryStatus) {
          aiSummaryStatus.textContent = err?.message || err?.detail || 'AI request failed';
          aiSummaryStatus.classList.add('err');
          aiSummaryStatus.style.display = 'block';
        }
      } finally {
        aiSummaryBtn.disabled = false;
        aiSummaryBtn.textContent = original;
      }
    });
  }

  // ── AI actions: entry-level menu + per-field improve ────────────────────────
  // Entry id comes from the context the layout stamps on <body>, not from parsing the URL.
  const aiEntryId = document.body.dataset.entityId || window.location.pathname.split('/').pop() || '';
  const aiMenuBtn = document.getElementById('ai-menu-btn') as HTMLButtonElement | null;
  const aiMenu = document.getElementById('ai-menu') as HTMLElement | null;

  function aiToast(msg: string, ok = true) {
    if (!aiSummaryStatus) return;
    aiSummaryStatus.textContent = msg;
    aiSummaryStatus.className = `ai-status ${ok ? 'ok' : 'err'}`;
    aiSummaryStatus.style.display = 'block';
  }

  function closeAiMenu() {
    aiMenu?.setAttribute('hidden', '');
    aiMenuBtn?.setAttribute('aria-expanded', 'false');
  }
  aiMenuBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const open = !aiMenu?.hasAttribute('hidden');
    if (open) return closeAiMenu();
    aiMenu?.removeAttribute('hidden');
    aiMenuBtn.setAttribute('aria-expanded', 'true');
  });
  document.addEventListener('click', closeAiMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeAiMenu(); });

  /** Re-render the suggestion banner in place. Avoids a reload, which would drop unsaved edits. */
  function renderSuggestion(entry: any) {
    const mount = document.getElementById('suggestion-mount');
    if (!mount) return;
    const suggestion = entry?.suggestionJson ?? entry?.suggestion_json;
    const targets = suggestion ? Object.keys(suggestion).filter((k) => k !== '_meta') : [];
    if (!targets.length) { mount.innerHTML = ''; return; }

    const esc = (s: unknown) => String(s ?? '')
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    const fmt = (v: any) => v == null || v === '' ? '—'
      : Array.isArray(v) ? v.join(', ') : typeof v === 'object' ? JSON.stringify(v) : String(v);
    const current = (t: string) =>
      t.startsWith('data_json.') ? entry?.dataJson?.[t.slice(10)]
      : t.startsWith('metadata_json.') ? entry?.metadataJson?.[t.slice(14)]
      : entry?.[t];

    const rows = targets.map((t) => `
      <li class="suggestion-field">
        <span class="suggestion-label">${esc(t.replace(/^(data_json|metadata_json)\./, ''))}</span>
        <div class="suggestion-diff">
          <div class="diff-row diff-current"><span class="diff-tag">current</span><span class="diff-val">${esc(fmt(current(t)))}</span></div>
          <div class="diff-row diff-proposed"><span class="diff-tag">proposed</span><span class="diff-val">${esc(fmt(suggestion[t]))}</span></div>
        </div>
      </li>`).join('');
    const op = suggestion?._meta?.operation;

    mount.innerHTML = `
      <div class="suggestion-banner">
        <div class="suggestion-head">
          <span class="suggestion-title">✨ AI suggested changes</span>
          ${op ? `<span class="suggestion-op">from <code>${esc(op)}</code></span>` : ''}
        </div>
        <ul class="suggestion-list">${rows}</ul>
        <div class="suggestion-actions">
          <button type="button" id="apply-suggestion" class="button">Apply changes</button>
          <button type="button" id="reject-suggestion" class="button secondary">Reject</button>
        </div>
      </div>`;
    // Freshly-created buttons need their handlers bound (the originals are gone).
    mount.querySelector('#apply-suggestion')?.addEventListener('click', () => suggestionAction('apply'));
    mount.querySelector('#reject-suggestion')?.addEventListener('click', () => suggestionAction('reject'));
    mount.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  async function refreshSuggestionBanner() {
    try {
      renderSuggestion(await sdk.entries.get(aiEntryId));
    } catch {
      aiToast('Staged, but the banner could not refresh — reload to review.', false);
    }
  }

  /** Run an operation against this entry; returns its output plus the write-back outcome. */
  async function runEntryOp(slug: string, input: Record<string, unknown> = {}) {
    const exec: any = await sdk.ai.operations.execute(slug, {
      entityType: 'entry', entityId: aiEntryId, input,
    });
    const meta = exec?.metadataJson ?? exec?.metadata_json ?? {};
    return {
      out: exec?.outputJson ?? exec?.output_json ?? {},
      // "applied" | "staged" | undefined — depends on the workspace approval_mode, so the UI
      // must not assume staging. Under allow-automatic-update the entry is already changed.
      writeback: meta?.writeback as 'applied' | 'staged' | undefined,
    };
  }

  async function aiGenerateTags() {
    aiToast('Generating tags…');
    try {
      let existing: string[] = [];
      try {
        const meta = JSON.parse((document.getElementById('metadata_json') as HTMLTextAreaElement)?.value || '{}');
        if (Array.isArray(meta.tags)) existing = meta.tags;
      } catch { /* invalid metadata JSON — just don't pass existing tags */ }
      const { out, writeback } = await runEntryOp('generate-tags', { existing_tags: existing });
      const tags: string[] = out.tags ?? [];
      if (!tags.length) return aiToast('No tags returned.', false);
      await refreshSuggestionBanner();
      // Report what actually happened — it depends on approval_mode, not on our assumptions.
      if (writeback === 'applied') {
        aiToast(`${tags.length} tags applied to this entry (approval mode: automatic): ${tags.join(', ')}`);
      } else if (writeback === 'staged') {
        aiToast(`${tags.length} tags staged — review the suggestion above.`);
      } else {
        aiToast(`Suggested ${tags.length} tags: ${tags.join(', ')}`);
      }
    } catch (err: any) {
      aiToast(err?.message || 'Tag generation failed', false);
    }
  }

  function aiReviewAndSuggest() {
    // Hand off to the bubble; it already sends this page's entity context + history.
    // 'professional' suppresses the workspace persona for this run — a review written in
    // character reads well and is useless to act on.
    document.dispatchEvent(new CustomEvent('marvin:ask', {
      detail: { text: 'Review this entry and suggest specific improvements.', register: 'professional' },
    }));
  }

  aiMenu?.querySelectorAll<HTMLButtonElement>('[data-ai-action]').forEach((item) => {
