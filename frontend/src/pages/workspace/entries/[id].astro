    function updateDataJsonFromForm() {
      const dataJson: Record<string, any> = {};
      const formData = new FormData(form);

      for (const [key, value] of formData.entries()) {
        if (key.startsWith('dataJson.')) {
          const fieldKey = key.replace('dataJson.', '');
          // Handle boolean checkboxes
          if (value === 'true' || value === 'false') {
            dataJson[fieldKey] = value === 'true';
          } else {
            dataJson[fieldKey] = value || null;
          }
        }
      }

      dataJsonEditor.value = JSON.stringify(dataJson, null, 2);
    }

    // Update form fields when JSON changes
    applyDataJsonBtn.addEventListener('click', () => {
      try {
