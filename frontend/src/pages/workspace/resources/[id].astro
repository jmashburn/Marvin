---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { getResource } from "@/lib/api/resources";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

let resource = null;
let error: string | null = null;

if (!id) {
  error = "Resource ID is required";
} else {
  try {
    resource = await getResource(id, authToken);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[Resource] Failed to load:', error);
  }
}
---

<AppLayout title={resource ? resource.name : "Edit Resource"}>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading resource:</strong> {error}</p>
      <a href="/workspace/resources" class="button secondary">Back to Resources</a>
    </div>
  ) : resource ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Resource</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Update resource details</p>
        </div>
        <div style="display:flex;gap:0.75rem;">
          <button type="button" id="delete-button" class="button secondary">
            Delete
          </button>
          <a class="button secondary" href="/workspace/resources">Back</a>
        </div>
      </div>

      <section class="form-section">
        <form id="resource-form" class="form">
          <div class="form-group">
            <label for="name">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={resource.name}
            />
          </div>

          <div class="form-group">
            <label for="slug">Slug</label>
            <input
              type="text"
              id="slug"
              name="slug"
              value={resource.slug}
              disabled
              style="background: var(--panel-2); color: var(--muted);"
            />
            <p class="form-help">Auto-generated from name</p>
          </div>

          <div class="form-group">
            <label for="resource_type">Type *</label>
            <input
              type="text"
              id="resource_type"
              name="resource_type"
              required
              value={resource.resourceType}
            />
            <p class="form-help">Category for this resource</p>
          </div>

          <div class="form-group">
            <label for="url">URL</label>
            <input
              type="url"
              id="url"
              name="url"
              value={resource.url || ""}
            />
            <p class="form-help">External website or documentation</p>
            {resource.url && (
              <a href={resource.url} target="_blank" rel="noopener noreferrer" class="external-link">
                Open in new tab ↗
              </a>
            )}
          </div>

          <div class="form-group">
            <label for="external_id">External ID</label>
            <input
              type="text"
              id="external_id"
              name="external_id"
              value={resource.externalId || ""}
            />
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              rows="4"
            >{resource.description || ""}</textarea>
          </div>

          <div class="form-group">
            <label for="metadata_">Metadata (JSON)</label>
            <p class="form-help">Custom metadata fields for this resource</p>
            <textarea
              id="metadata_"
              name="metadata_"
              rows="6"
              placeholder='{"key": "value"}'
              class="metadata-editor"
            >{resource.metadata ? JSON.stringify(resource.metadata, null, 2) : ""}</textarea>
            <small style="font-size: 11px; color: var(--muted);">
              Must be valid JSON. Example: {`{"supplier_code": "ABC123", "contact": "john@example.com"}`}
            </small>

            {resource.metadata && Object.keys(resource.metadata).length > 0 && (
              <div class="metadata-preview">
                <p class="metadata-preview-title">Current Metadata:</p>
                <dl class="metadata-preview-list">
                  {Object.entries(resource.metadata).map(([key, value]) => (
                    <div class="metadata-preview-item">
                      <dt>{key}</dt>
                      <dd>{typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value)}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )}
          </div>

          <div class="form-actions">
            <button type="submit" class="button">Save Changes</button>
            <a href="/workspace/resources" class="button secondary">Cancel</a>
          </div>
        </form>
      </section>
    </>
  ) : null}
</AppLayout>

<script>
  import { createSdkClient } from '@/lib/sdk';

  console.log('[Resources] Script loading...');

  const sdk = createSdkClient();
  const form = document.getElementById('resource-form') as HTMLFormElement;
  const metadataField = document.getElementById('metadata_') as HTMLTextAreaElement;
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement;
  const deleteButton = document.getElementById('delete-button') as HTMLButtonElement;

  console.log('[Resources] Elements:', { form, deleteButton, submitButton });

  // Handle delete via SDK
  if (deleteButton) {
    console.log('[Resources] Attaching delete handler');
    deleteButton.addEventListener('click', async () => {
      if (!confirm('Delete this resource? This cannot be undone.')) {
        return;
      }

      deleteButton.disabled = true;
      deleteButton.textContent = 'Deleting...';

      try {
        const resourceId = window.location.pathname.split('/').pop()!;
        console.log('[Resources] Deleting resource:', resourceId);
        await sdk.resources.delete(resourceId);
        console.log('[Resources] Delete successful');
        window.location.href = '/workspace/resources';
      } catch (error: any) {
        const message = error?.message || error?.detail || 'Failed to delete resource';
        alert(message);
        deleteButton.disabled = false;
        deleteButton.textContent = 'Delete';
      }
    });
  }

  // Validate metadata JSON
  if (metadataField) {
    metadataField.addEventListener('blur', () => {
      const value = metadataField.value.trim();
      if (!value) return;

      try {
        JSON.parse(value);
        metadataField.style.borderColor = 'var(--line)';
      } catch (error) {
        metadataField.style.borderColor = '#ef5350';
      }
    });
  }

  // Handle form submission via SDK
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const resourceType = formData.get('resource_type') as string;
      const url = formData.get('url') as string;
      const externalId = formData.get('external_id') as string;
      const description = formData.get('description') as string;
      const metadataStr = formData.get('metadata_') as string;

      // Parse metadata JSON
      let metadata = null;
      if (metadataStr?.trim()) {
        try {
          metadata = JSON.parse(metadataStr);
        } catch (error) {
          alert('Invalid JSON in metadata field');
          return;
        }
      }

      // Disable submit button
      submitButton.disabled = true;
      submitButton.textContent = 'Saving...';

      try {
        const resourceId = window.location.pathname.split('/').pop()!;
        await sdk.resources.update(resourceId, {
          name,
          resourceType,
          url: url?.trim() || null,
          externalId: externalId?.trim() || null,
          description: description?.trim() || null,
          metadata: metadata,
        });

        // Redirect back to resources list
        window.location.href = '/workspace/resources';
      } catch (error: any) {
        const message = error?.message || error?.detail || 'Failed to update resource';
        alert(message);
        submitButton.disabled = false;
        submitButton.textContent = 'Save Changes';
      }
    });
  }

  // Metadata preview update
  const metadataEditor = document.getElementById('metadata_') as HTMLTextAreaElement;
  const metadataPreviewContainer = metadataEditor?.closest('.form-group')?.querySelector('.metadata-preview');

  if (metadataEditor) {
    metadataEditor.addEventListener('input', () => {
      const value = metadataEditor.value.trim();

      if (!value) {
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
        return;
      }

      try {
        const parsed = JSON.parse(value);
        const entries = Object.entries(parsed);

        if (entries.length === 0) {
          if (metadataPreviewContainer) {
            metadataPreviewContainer.remove();
          }
          return;
        }

        let previewHTML = `
          <div class="metadata-preview">
            <p class="metadata-preview-title">Current Metadata:</p>
            <dl class="metadata-preview-list">
        `;

        entries.forEach(([key, value]) => {
          const displayValue = typeof value === 'object' ? JSON.stringify(value, null, 2) : String(value);
          previewHTML += `
            <div class="metadata-preview-item">
              <dt>${key}</dt>
              <dd>${displayValue}</dd>
            </div>
          `;
        });

        previewHTML += `</dl></div>`;

        if (metadataPreviewContainer) {
          metadataPreviewContainer.outerHTML = previewHTML;
        } else {
          const helpText = metadataEditor.closest('.form-group')?.querySelector('.form-help');
          if (helpText) {
            helpText.insertAdjacentHTML('afterend', previewHTML);
          }
        }
      } catch (error) {
        // Invalid JSON - remove preview
        if (metadataPreviewContainer) {
          metadataPreviewContainer.remove();
        }
      }
    });
  }
</script>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 2rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="url"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .external-link {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
  }

  .external-link:hover {
    text-decoration: underline;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .metadata-editor {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 12px;
    line-height: 1.5;
    background: var(--panel-2);
  }

  .metadata-preview {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--panel-2);
    border-radius: 6px;
  }

  .metadata-preview-title {
    margin: 0 0 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .metadata-preview-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .metadata-preview-item {
    padding: 0.5rem;
    background: var(--bg);
    border-radius: 4px;
  }

  .metadata-preview-item dt {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .metadata-preview-item dd {
    margin: 0;
    font-size: 0.875rem;
    word-break: break-word;
    white-space: pre-wrap;
    font-family: monospace;
  }
</style>
