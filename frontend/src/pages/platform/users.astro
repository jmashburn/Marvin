---
import AppLayout from "@/layouts/AppLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { getAuthToken, fetchApi } from "@/lib/api/client";
import { createSdkClient } from '@/lib/sdk';

const currentUser = await requireAdmin(Astro.cookies, Astro.redirect, Astro.url.pathname);

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);
let users: any[] = [];
let error: string | null = null;

let groups: any[] = [];

try {
  const [usersResponse, groupsResponse] = await Promise.all([
    sdk.adminUsers.list(),
    fetchApi<any>('/api/admin/groups', {}, authToken),
  ]);

  users = usersResponse.items || [];
  groups = groupsResponse.items || [];
} catch (e) {
  console.error('[platform/users] Error loading:', e);
  error = e instanceof Error ? e.message : String(e);
}

// Create a map of group IDs to names
const groupMap = new Map(groups.map((g: any) => [g.id, g.name]));
---

<AppLayout title="Users" eyebrow="Platform">
  <div class="toolbar">
    <div>
      <h2>Platform Users</h2>
      <p>Manage user accounts and permissions</p>
    </div>
    <a href="/platform/users/new" class="button">Create User</a>
  </div>

  <div class="page-container">
    {error ? (
      <div class="alert alert-error">
        <strong>Error:</strong> {error}
      </div>
    ) : users.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">👥</div>
        <p class="empty-title">No users found</p>
        <p class="empty-description">Create your first user to get started</p>
        <a href="/admin/users/new" class="button">Create User</a>
      </div>
    ) : (
      <div class="users-list">
        {users.map((user) => (
          <div class="user-card">
            <div class="user-info">
              <div class="user-header">
                <strong>{user.fullName || user.username}</strong>
                {user.admin && <span class="admin-badge">Admin</span>}
                {user.platformRole === 'SUPER_ADMIN' && <span class="super-admin-badge">Super Admin</span>}
              </div>
              <p class="user-email">{user.email}</p>
              <div class="user-meta">
                <span>Username: {user.username}</span>
              </div>
              <div class="workspace-info">
                {(() => {
                  // Combine default workspace with additional memberships
                  const allWorkspaces = [];

                  // Add default workspace first
                  if (user.group) {
                    allWorkspaces.push({
                      name: user.group,
                      role: 'MEMBER', // Default workspace doesn't have explicit role
                      isDefault: true
                    });
                  }

                  // Add additional workspace memberships
                  if (user.workspaceMemberships && user.workspaceMemberships.length > 0) {
                    user.workspaceMemberships.forEach((membership: any) => {
                      // Only add if it's not the same as default workspace
                      if (membership.groupId !== user.groupId) {
                        allWorkspaces.push({
                          name: groupMap.get(membership.groupId) || membership.groupId,
                          role: membership.workspaceRole,
                          isDefault: false
                        });
                      } else {
                        // Update default workspace with actual role
                        const defaultWs = allWorkspaces.find((w: any) => w.isDefault);
                        if (defaultWs) {
                          defaultWs.role = membership.workspaceRole;
                        }
                      }
                    });
                  }

                  return allWorkspaces.length > 0 && (
                    <div class="workspace-item">
                      <span class="workspace-label">Workspace Access ({allWorkspaces.length}):</span>
                      <div class="workspaces-grid">
                        {allWorkspaces.map((ws: any) => (
                          <div class="workspace-entry">
                            <span class="workspace-entry-name">
                              {ws.name}
                              {ws.isDefault && <span class="default-indicator">(Default)</span>}
                            </span>
                            <span class={`membership-badge role-${ws.role.toLowerCase()}`}>
                              {ws.role}
                            </span>
                          </div>
                        ))}
                      </div>
                    </div>
                  );
                })()}
              </div>
            </div>
            <div class="user-actions">
              <a href={`/admin/users/${user.id}`} class="button secondary small">Edit</a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AppLayout>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .page-container {
    max-width: 900px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .empty-state {
    padding: 80px 24px;
    text-align: center;
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 16px;
    opacity: 0.3;
  }

  .empty-title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .empty-description {
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 14px;
  }

  .users-list {
    display: grid;
    gap: 16px;
  }

  .user-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    padding: 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .user-info {
    flex: 1;
    min-width: 0;
  }

  .user-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .user-header strong {
    font-size: 15px;
    font-weight: 600;
  }

  .admin-badge {
    padding: 2px 8px;
    background: rgb(169 99 47 / 0.1);
    color: var(--warn);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .super-admin-badge {
    padding: 2px 8px;
    background: rgb(220 38 38 / 0.1);
    color: #dc2626;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .user-email {
    margin: 0 0 8px;
    font-size: 14px;
    color: var(--muted);
  }

  .user-meta {
    font-size: 12px;
    color: var(--muted);
    display: flex;
    gap: 6px;
  }

  .user-actions {
    flex-shrink: 0;
  }

  .button.small {
    padding: 6px 14px;
    font-size: 13px;
  }

  .workspace-info {
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--line);
    display: grid;
    gap: 10px;
  }

  .workspace-item {
    display: grid;
    gap: 6px;
  }

  .workspace-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
  }

  .workspace-name {
    font-size: 13px;
    font-weight: 500;
  }

  .workspaces-grid {
    display: grid;
    gap: 8px;
  }

  .workspace-entry {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 8px 12px;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 4px;
  }

  .workspace-entry-name {
    font-size: 13px;
    font-weight: 500;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .default-indicator {
    margin-left: 6px;
    font-size: 11px;
    color: var(--muted);
    font-weight: 400;
  }

  .memberships-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .membership-badge {
    padding: 4px 10px;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
  }

  .membership-badge.role-owner {
    background: rgb(169 77 63 / 0.15);
    color: var(--accent);
    border-color: rgb(169 77 63 / 0.3);
  }

  .membership-badge.role-admin {
    background: rgb(47 111 115 / 0.15);
    color: var(--accent-2);
    border-color: rgb(47 111 115 / 0.3);
  }

  .membership-badge.role-editor {
    background: rgb(53 122 85 / 0.15);
    color: var(--good);
    border-color: rgb(53 122 85 / 0.3);
  }

  .membership-badge.role-author {
    background: rgb(189 145 64 / 0.15);
    color: var(--gold);
    border-color: rgb(189 145 64 / 0.3);
  }

  .membership-badge.role-viewer {
    background: var(--panel-2);
    color: var(--muted);
  }
</style>
