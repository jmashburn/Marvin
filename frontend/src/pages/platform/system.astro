---
import AppLayout from "@/layouts/AppLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { createSdkClient } from '@/lib/sdk';
import { getAuthToken } from '@/lib/api/client';

// Require admin authentication
const user = await requireAdmin(Astro.cookies, Astro.redirect, Astro.url.pathname);
const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

let error: string | null = null;
let stats: any = null;

// Fetch system statistics
try {
  stats = await sdk.adminMaintenance.getStats();
} catch (e) {
  console.error('[platform/system] Failed to fetch stats:', e);
  error = 'Failed to load system statistics';
}
---

<AppLayout title="Workspace System" eyebrow="Platform">
  <div class="toolbar">
    <div>
      <h2>Workspace System</h2>
      <p>Workspace statistics and maintenance tasks</p>
    </div>
  </div>

  {error && (
    <div class="alert alert-error">
      <strong>Error:</strong> {error}
    </div>
  )}

  <div class="page-container">
    <div class="maintenance-grid">
      <!-- Workspace Statistics -->
      <section class="card">
        <h3>Workspace Statistics</h3>
        <p class="card-description">Overview of data in your workspace</p>
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-label">Total Users</div>
            <div class="stat-value">{stats?.users_count || '—'}</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Total Groups</div>
            <div class="stat-value">{stats?.groups_count || '—'}</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Total Entries</div>
            <div class="stat-value">{stats?.entries_count || '—'}</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Total Assets</div>
            <div class="stat-value">{stats?.assets_count || '—'}</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">API Tokens</div>
            <div class="stat-value">{stats?.api_tokens_count || '—'}</div>
          </div>
          <div class="stat-item">
            <div class="stat-label">Webhooks</div>
            <div class="stat-value">{stats?.webhooks_count || '—'}</div>
          </div>
        </div>
      </section>
    </div>
  </div>
</AppLayout>


<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .page-container {
    max-width: 1200px;
  }

  .maintenance-grid {
    display: grid;
    gap: 24px;
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .card h3 {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
  }

  .card-description {
    margin: 0 0 20px;
    font-size: 14px;
    color: var(--muted);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .stat-label {
    font-size: 13px;
    color: var(--muted);
    font-weight: 500;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 600;
    color: var(--accent);
  }

</style>
