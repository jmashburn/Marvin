---
import AppLayout from "@/layouts/AppLayout.astro";
import { fetchApi, getAuthToken } from "@/lib/api/client";
import { requireAdmin } from "@/lib/auth";
import { createSdkClient } from "@/lib/sdk";

await requireAdmin(Astro.cookies, Astro.redirect, Astro.url.pathname);

const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);

// Platform roles are NONE or SUPER_ADMIN — the only two values the backend enum defines.
// Workspace-level roles (OWNER/ADMIN/EDITOR/...) are granted per membership, not here.
const platformRoles = [
  { value: "NONE", label: "Standard user", hint: "No platform-level privileges" },
  {
    value: "SUPER_ADMIN",
    label: "Super admin",
    hint: "Unrestricted access to every workspace and to platform settings",
  },
];

let workspaces: { id: string; name: string }[] = [];
let loadError: string | null = null;
let error: string | null = null;

// Values are echoed back so a failed submit does not clear the form.
let form = { email: "", fullName: "", username: "", platformRole: "NONE", group: "" };

try {
  const groupsResponse = await fetchApi<any>("/api/admin/groups", {}, authToken);
  workspaces = groupsResponse.items || [];
} catch (e) {
  console.error("[platform/users/new] Failed to load workspaces:", e);
  loadError = e instanceof Error ? e.message : String(e);
}

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const password = (formData.get("password") as string) || "";
  const passwordConfirm = (formData.get("password_confirm") as string) || "";

  form = {
    email: ((formData.get("email") as string) || "").trim(),
    fullName: ((formData.get("full_name") as string) || "").trim(),
    username: ((formData.get("username") as string) || "").trim(),
    platformRole: (formData.get("platform_role") as string) || "NONE",
    group: (formData.get("group") as string) || "",
  };

  // Checked here rather than only in the browser: the form posts without JavaScript, so
  // client-side validation alone would let a mismatch through.
  if (password !== passwordConfirm) {
    error = "Passwords do not match.";
  } else if (password.length < 8) {
    error = "Password must be at least 8 characters.";
  } else {
    try {
      // Sent server-side because `marvin.access_token` is HttpOnly — the browser cannot read it,
      // so a fetch from client script would carry no credentials.
      await sdk.adminUsers.create({
        email: form.email,
        password,
        fullName: form.fullName || null,
        username: form.username || null,
        platformRole: form.platformRole,
        group: form.group || null,
      } as any);

      return Astro.redirect("/platform/users");
    } catch (e) {
      error = e instanceof Error ? e.message : "Failed to create user";
      console.error("[platform/users/new] Create failed:", error);
    }
  }
}
---

<AppLayout title="Create User" eyebrow="Platform">
  <div class="page-container">
    <div class="page-header">
      <div>
        <h2>Create User</h2>
        <p>Add a user account to the platform</p>
      </div>
      <a href="/platform/users" class="button secondary">Cancel</a>
    </div>

    {error && (
      <div class="alert alert-error">
        <strong>Error:</strong> {error}
      </div>
    )}

    {loadError && (
      <div class="alert alert-warn">
        <strong>Heads up:</strong> workspaces could not be loaded ({loadError}). You can still
        create the user and assign a workspace afterwards.
      </div>
    )}

    <div class="form-container">
      <form method="POST" class="form">
        <section class="form-section">
          <h3>Account</h3>

          <div class="form-group">
            <label for="email">Email *</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="off"
              placeholder="user@example.com"
              value={form.email}
              autofocus
            />
            <small>Used to sign in. Stored lowercase.</small>
          </div>

          <div class="form-group">
            <label for="full_name">Full name</label>
            <input
              type="text"
              id="full_name"
              name="full_name"
              placeholder="Ada Lovelace"
              value={form.fullName}
            />
          </div>

          <div class="form-group">
            <label for="username">Username</label>
            <input
              type="text"
              id="username"
              name="username"
              autocomplete="off"
              placeholder="Defaults to the full name"
              value={form.username}
            />
            <small>Left blank, this falls back to the full name. Sign-in always uses the email.</small>
          </div>
        </section>

        <section class="form-section">
          <h3>Password</h3>

          <div class="form-group">
            <label for="password">Password *</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              minlength="8"
              autocomplete="new-password"
            />
            <small>At least 8 characters.</small>
          </div>

          <div class="form-group">
            <label for="password_confirm">Confirm password *</label>
            <input
              type="password"
              id="password_confirm"
              name="password_confirm"
              required
              minlength="8"
              autocomplete="new-password"
            />
          </div>
        </section>

        <section class="form-section">
          <h3>Access</h3>

          <div class="form-group">
            <label for="platform_role">Platform role</label>
            <select id="platform_role" name="platform_role">
              {platformRoles.map((role) => (
                <option value={role.value} selected={role.value === form.platformRole}>
                  {role.label}
                </option>
              ))}
            </select>
            <small>
              {platformRoles.map((r) => `${r.label}: ${r.hint}`).join(" · ")}
            </small>
          </div>

          <div class="form-group">
            <label for="group">Workspace</label>
            <select id="group" name="group">
              <option value="">No workspace</option>
              {workspaces.map((ws) => (
                <option value={ws.name} selected={ws.name === form.group}>{ws.name}</option>
              ))}
            </select>
            <small>The workspace this user starts in. Further memberships are granted per workspace.</small>
          </div>
        </section>

        <div class="form-actions">
          <button type="submit" class="button primary">Create user</button>
          <a href="/platform/users" class="button secondary">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</AppLayout>

<script>
  // Progressive enhancement only — the server re-checks both rules, since the form works
  // without JavaScript.
  const form = document.querySelector<HTMLFormElement>("form.form");
  const password = document.getElementById("password") as HTMLInputElement | null;
  const confirm = document.getElementById("password_confirm") as HTMLInputElement | null;

  function validate() {
    if (!password || !confirm) return;
    confirm.setCustomValidity(password.value === confirm.value ? "" : "Passwords do not match");
  }

  password?.addEventListener("input", validate);
  confirm?.addEventListener("input", validate);
  form?.addEventListener("submit", validate);
</script>

<style>
  .page-container {
    max-width: 800px;
  }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .page-header h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .page-header p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    font-size: 14px;
  }

  .alert-error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .alert-warn {
    background: rgba(234, 179, 8, 0.1);
    color: #a16207;
    border: 1px solid rgba(234, 179, 8, 0.3);
  }

  .form-container {
    max-width: 600px;
  }

  .form {
    display: grid;
    gap: 24px;
  }

  .form-section {
    display: grid;
    gap: 20px;
    padding: 24px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-section h3 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .form-group {
    display: grid;
    gap: 6px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 500;
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
    background: var(--bg);
    color: var(--text);
    font-family: inherit;
  }

  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--primary);
  }

  .form-group small {
    font-size: 12px;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 12px;
  }

  .button {
    padding: 10px 20px;
    border: none;
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .button.primary {
    background: var(--accent);
    color: white;
  }

  .button.primary:hover {
    background: #8f3f31;
  }

  .button.secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--line);
  }

  .button.secondary:hover {
    background: var(--panel-2);
  }
</style>
