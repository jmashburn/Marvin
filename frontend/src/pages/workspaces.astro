---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { listWorkspaces } from "@/lib/api/workspaces";

const authToken = getAuthToken(Astro.cookies);

let workspaces = [];
let error: string | null = null;

try {
  workspaces = await listWorkspaces(authToken);
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}
---

<AppLayout title="Workspaces">
  <div class="toolbar">
    <div>
      <h2 style="margin:0;font-size:20px;">Workspaces</h2>
      <p style="margin:4px 0 0;color:var(--muted);">Manage your workspace memberships.</p>
    </div>
    <a class="button" href="/workspace/new">Create Workspace</a>
  </div>

  {error ? (
    <div class="error-banner">{error}</div>
  ) : (
    <section class="grid">
      {workspaces.map(({ workspace, role, is_active }) => (
        <article class="card">
          <div class="card-body">
            <h2>{workspace.name}</h2>
            <div class="meta">
              <span class={`pill ${is_active ? 'published' : ''}`}>
                {is_active ? 'Active' : 'Inactive'}
              </span>
              <span class="pill">{role}</span>
            </div>
            {!is_active && (
              <form method="POST" action="/api/workspace/activate" style="margin-top:1rem;">
                <input type="hidden" name="workspace_id" value={workspace.id} />
                <button type="submit" class="button">Activate</button>
              </form>
            )}
          </div>
        </article>
      ))}
    </section>
  )}
</AppLayout>

<style>
  .error-banner {
    padding: 1rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    color: var(--color-error);
  }
</style>
