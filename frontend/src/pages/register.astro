---
import { register } from '@/lib/api/auth';
import type { UserRegistration } from '@/lib/api/auth';

// Get token from query params (supports both ?token= and ?invite=)
const token = Astro.url.searchParams.get('token') || Astro.url.searchParams.get('invite');

// Check if user is already logged in
const existingAuth = Astro.cookies.get('marvin_session');
if (existingAuth) {
  return Astro.redirect('/workspace');
}

let registrationError: string | null = null;
let registeredUsername: string | null = null;
let registeredPassword: string | null = null;

// Handle form submission (server-side)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();

    // Validate passwords match
    const password = formData.get('password') as string;
    const passwordConfirm = formData.get('password_confirm') as string;

    if (password !== passwordConfirm) {
      registrationError = 'Passwords do not match';
    } else {
      const data: UserRegistration = {
        full_name: formData.get('full_name') as string,
        email: formData.get('email') as string,
        username: formData.get('username') as string,
        password,
        password_confirm: passwordConfirm,
        group_token: (formData.get('group_token') as string) || null,
        group: null,
        advanced: false,
        private: false,
        seed_data: false,
      };

      await register(data);
      // Store credentials for auto-login
      registeredUsername = data.username;
      registeredPassword = password;
    }
  } catch (e) {
    registrationError = e instanceof Error ? e.message : 'Registration failed';
    console.error('[Register] Failed:', registrationError);
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register | Marvin</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="register-page">
    <div class="register-container">
      <div class="register-card">
        <div class="register-header">
          <div class="brand-logo">
            <strong>Marvin</strong>
            <span>Content engine</span>
          </div>
          <h1>Create Your Account</h1>
          {token ? (
            <p>You've been invited to join a workspace</p>
          ) : (
            <p>Sign up to get started</p>
          )}
        </div>

        {token && (
          <div class="invitation-badge">
            <span class="badge-label">🎟️ Invitation Token</span>
            <code class="token-preview">{token.substring(0, 20)}...</code>
          </div>
        )}

      <form id="register-form" method="POST" class="register-form">
        {token && (
          <input type="hidden" name="group_token" value={token} />
        )}

        <div class="form-group">
          <label for="full_name">Full Name *</label>
          <input
            type="text"
            id="full_name"
            name="full_name"
            required
            placeholder="John Doe"
            autocomplete="name"
          />
        </div>

        <div class="form-group">
          <label for="email">Email Address *</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="you@example.com"
            autocomplete="email"
          />
        </div>

        <div class="form-group">
          <label for="username">Username *</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            placeholder="johndoe"
            autocomplete="username"
            pattern="[a-zA-Z0-9_-]+"
            title="Letters, numbers, hyphens, and underscores only"
          />
          <small>Letters, numbers, hyphens, and underscores only</small>
        </div>

        <div class="form-group">
          <label for="password">Password *</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            minlength="8"
            placeholder="At least 8 characters"
            autocomplete="new-password"
          />
        </div>

        <div class="form-group">
          <label for="password_confirm">Confirm Password *</label>
          <input
            type="password"
            id="password_confirm"
            name="password_confirm"
            required
            minlength="8"
            placeholder="Re-enter your password"
            autocomplete="new-password"
          />
        </div>

        {registrationError && (
          <div id="error-message" class="error-message" style="display: block;">
            {registrationError}
          </div>
        )}

        {registeredUsername && registeredPassword && (
          <>
            <input type="hidden" id="registered-username" value={registeredUsername} />
            <input type="hidden" id="registered-password" value={registeredPassword} />
          </>
        )}

        <button type="submit" class="button primary full-width">
          Create Account
        </button>

        <div class="register-footer">
          <p class="help-text">
            Already have an account? <a href="/login">Sign in</a>
          </p>
        </div>
      </form>
    </div>
  </div>
  </body>
</html>

<script>
  // If registration was successful, auto-login
  const registeredUsername = document.getElementById('registered-username') as HTMLInputElement;
  const registeredPassword = document.getElementById('registered-password') as HTMLInputElement;

  if (registeredUsername && registeredPassword) {
    // Registration successful - now log in via form POST (sets cookies correctly)
    const loginForm = document.createElement('form');
    loginForm.method = 'POST';
    loginForm.action = '/api/auth/login?return=/workspace';
    loginForm.style.display = 'none';

    const usernameInput = document.createElement('input');
    usernameInput.name = 'username';
    usernameInput.value = registeredUsername.value;
    loginForm.appendChild(usernameInput);

    const passwordInput = document.createElement('input');
    passwordInput.name = 'password';
    passwordInput.value = registeredPassword.value;
    loginForm.appendChild(passwordInput);

    document.body.appendChild(loginForm);
    loginForm.submit();
  }
</script>

<style>
  .register-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #1e2725 0%, #2f4a47 100%);
    padding: 2rem;
  }

  .register-container {
    width: 100%;
    max-width: 28rem;
  }

  .register-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2.5rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .register-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .brand-logo {
    display: grid;
    gap: 4px;
    margin-bottom: 2rem;
  }

  .brand-logo strong {
    font-size: 32px;
    font-weight: 700;
    color: var(--ink);
  }

  .brand-logo span {
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .register-header h1 {
    margin: 0 0 0.5rem;
    font-size: 24px;
    font-weight: 600;
    color: var(--ink);
  }

  .register-header p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
  }

  .invitation-badge {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .badge-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
  }

  .token-preview {
    padding: 4px 8px;
    background: var(--panel-2);
    border: 1px solid var(--line);
    border-radius: 4px;
    font-family: 'SF Mono', Monaco, monospace;
    font-size: 11px;
    color: var(--good);
  }

  .register-form {
    display: grid;
    gap: 1.5rem;
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
  }

  .form-group input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg);
    font-size: 15px;
    transition: all 0.2s;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(169, 77, 63, 0.1);
  }

  .form-group small {
    font-size: 12px;
    color: var(--muted);
  }

  .error-message {
    padding: 1rem;
    margin-bottom: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: 8px;
    color: var(--color-error);
    font-size: 14px;
  }

  .button {
    padding: 0.875rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .button.primary {
    width: 100%;
    background: var(--accent);
    color: white;
  }

  .button.primary:hover:not(:disabled) {
    background: #8f3f31;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(169, 77, 63, 0.3);
  }

  .button.primary:active {
    transform: translateY(0);
  }

  .button.primary:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .register-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }

  .help-text {
    margin: 0;
    text-align: center;
    font-size: 13px;
    color: var(--muted);
  }

  .help-text a {
    color: var(--accent);
    text-decoration: none;
  }

  .help-text a:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .register-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
