---
// Ensure this page is server-rendered (not prerendered)
export const prerender = false;

let success = false;
let error: string | null = null;

// Handle form submission (server-side)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const email = formData.get('email') as string;

    // Call the forgot password API endpoint
    const response = await fetch(`${import.meta.env.MARVIN_API_URL || 'http://localhost:8080'}/api/users/forgot-password`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ email }),
    });

    if (response.ok) {
      success = true;
    } else {
      const errorData = await response.json();
      error = errorData.detail || 'Failed to send reset email';
    }
  } catch (e) {
    console.error('[ForgotPassword] Error:', e);
    error = 'An error occurred. Please try again.';
  }
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password | Marvin</title>
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="forgot-password-page">
    <div class="forgot-password-container">
      <div class="forgot-password-card">
        <div class="forgot-password-header">
          <div class="brand-logo">
            <strong>Marvin</strong>
            <span>Content engine</span>
          </div>
          <h1>Reset your password</h1>
          <p>Enter your email address and we'll send you a reset link</p>
        </div>

        {success ? (
          <div class="success-message">
            <strong>✓ Email sent</strong>
            <p>If an account exists with that email, you'll receive a password reset link shortly.</p>
            <a href="/login" class="button primary" style="margin-top:1.5rem;">Back to Login</a>
          </div>
        ) : (
          <>
            {error && (
              <div class="error-message">
                <strong>⚠ Error</strong>
                <p>{error}</p>
              </div>
            )}

            <form method="POST" class="forgot-password-form">
              <div class="form-group">
                <label for="email">Email Address</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autofocus
                  placeholder="you@example.com"
                />
              </div>

              <div class="form-actions">
                <button type="submit" class="button primary">Send Reset Link</button>
                <a href="/login" class="button secondary">Back to Login</a>
              </div>
            </form>
          </>
        )}
      </div>
    </div>
  </body>
</html>

<style>
  .forgot-password-page {
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #1e2725 0%, #2f4a47 100%);
    padding: 2rem;
  }

  .forgot-password-container {
    width: 100%;
    max-width: 24rem;
  }

  .forgot-password-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2.5rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .forgot-password-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .brand-logo {
    display: grid;
    gap: 4px;
    margin-bottom: 2rem;
  }

  .brand-logo strong {
    font-size: 32px;
    font-weight: 700;
    color: var(--ink);
  }

  .brand-logo span {
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .forgot-password-header h1 {
    margin: 0 0 0.5rem;
    font-size: 24px;
    font-weight: 600;
    color: var(--ink);
  }

  .forgot-password-header p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
  }

  .success-message {
    padding: 1.5rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    text-align: center;
  }

  .success-message strong {
    display: block;
    margin-bottom: 0.5rem;
    color: #22c55e;
    font-size: 16px;
  }

  .success-message p {
    margin: 0;
    color: var(--ink);
    font-size: 14px;
    line-height: 1.5;
  }

  .error-message {
    padding: 1rem;
    margin-bottom: 1.5rem;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 8px;
  }

  .error-message strong {
    display: block;
    margin-bottom: 0.25rem;
    color: #ef4444;
    font-size: 14px;
  }

  .error-message p {
    margin: 0;
    color: #ef4444;
    font-size: 13px;
  }

  .forgot-password-form {
    display: grid;
    gap: 1.25rem;
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-group label {
    font-weight: 600;
    font-size: 14px;
    color: var(--ink);
  }

  .form-group input {
    padding: 0.75rem 1rem;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--bg);
    font-size: 15px;
    transition: all 0.2s;
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(169, 77, 63, 0.1);
  }

  .form-actions {
    margin-top: 0.5rem;
    display: grid;
    gap: 0.75rem;
  }

  .button {
    width: 100%;
    padding: 0.875rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 15px;
    cursor: pointer;
    transition: all 0.2s;
    text-align: center;
    text-decoration: none;
    display: block;
  }

  .button.primary {
    background: var(--accent);
    color: white;
  }

  .button.primary:hover {
    background: #8f3f31;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(169, 77, 63, 0.3);
  }

  .button.secondary {
    background: transparent;
    color: var(--muted);
    border: 1px solid var(--line);
  }

  .button.secondary:hover {
    background: var(--panel-2);
    color: var(--ink);
  }

  @media (max-width: 480px) {
    .forgot-password-card {
      padding: 2rem 1.5rem;
    }
  }
</style>
