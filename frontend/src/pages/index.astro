---
import EntryCard from "@/components/EntryCard.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { getAssets, getEntries, getSiteClients } from "@/lib/api/platform";

const [entries, assets, siteClients] = await Promise.all([getEntries(), getAssets(), getSiteClients()]);
const published = entries.filter((entry) => entry.status === "published");
const review = entries.filter((entry) => entry.status === "review");
const featured = entries.find((entry) => entry.frontmatter?.featured === true) ?? entries[0];
---

<AppLayout title="Dashboard">
  <section class="stats" aria-label="Platform stats">
    <div class="stat"><span>Total entries</span><strong>{entries.length}</strong></div>
    <div class="stat"><span>Published</span><strong>{published.length}</strong></div>
    <div class="stat"><span>In review</span><strong>{review.length}</strong></div>
    <div class="stat"><span>Assets</span><strong>{assets.length}</strong></div>
  </section>

  <section class="toolbar">
    <div>
      <h2 style="margin:0;font-size:20px;">Workspace pulse</h2>
      <p style="margin:4px 0 0;color:var(--muted);">Entries, media, and publishing clients in one place.</p>
    </div>
    <a class="button" href="/entries">Open Entries</a>
  </section>

  <section class="grid">
    {featured && <EntryCard entry={featured} />}
    <article class="card">
      <div class="card-body">
        <h3>Publishing clients</h3>
        <p>{siteClients.length} site client{siteClients.length === 1 ? "" : "s"} configured for external publishing.</p>
        <div class="meta">
          {siteClients.map((client) => <span class={`pill ${client.is_active ? "published" : "draft"}`}>{client.slug}</span>)}
        </div>
      </div>
    </article>
    <article class="card">
      <div class="card-body">
        <h3>Media model</h3>
        <p>Featured media, support images, and file details ready for publishing.</p>
        <div class="meta">
          <span class="pill">asset metadata</span>
          <span class="pill">placement metadata</span>
        </div>
      </div>
    </article>
  </section>
</AppLayout>
