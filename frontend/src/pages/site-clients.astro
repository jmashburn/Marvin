---
import AppLayout from "@/layouts/AppLayout.astro";
import { getSiteClients } from "@/lib/api/platform";
import { getAuthToken } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);

let siteClients = [];
let error: string | null = null;

try {
  siteClients = await getSiteClients(authToken);
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
  console.error('[SiteClients] Failed to load:', error);
}
---

<AppLayout title="Site Clients">
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading site clients:</strong> {error}</p>
      <button onclick="location.reload()" class="button secondary">Retry</button>
    </div>
  ) : (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Publishing access</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Read-only identities for Astro and other external sites.</p>
        </div>
        <a class="button" href="/site-clients/new">New Client</a>
      </div>

      {siteClients.length === 0 ? (
        <div class="empty-state">
          <p class="empty-title">No site clients yet</p>
          <p class="empty-description">
            Create a site client to allow external sites to access published content.
          </p>
          <a href="/site-clients/new" class="button">New Client</a>
        </div>
      ) : (
        <table class="table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Slug</th>
              <th>Status</th>
              <th>Permissions</th>
              <th>Last used</th>
            </tr>
          </thead>
          <tbody>
            {siteClients.map((client) => (
              <tr>
                <td><strong>{client.name}</strong></td>
                <td>{client.slug}</td>
                <td><span class={`pill ${client.is_active ? "published" : "draft"}`}>{client.is_active ? "active" : "inactive"}</span></td>
                <td>
                  <div class="meta">{client.permissions.map((permission) => <span class="pill">{permission}</span>)}</div>
                </td>
                <td>{client.last_used_at ? new Date(client.last_used_at).toLocaleString() : "Never"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </>
  )}
</AppLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .empty-state {
    display: grid;
    place-items: center;
    gap: 1rem;
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-title {
    margin: 0;
    font-size: 1.5rem;
    font-weight: 600;
  }

  .empty-description {
    margin: 0;
    color: var(--muted);
    max-width: 32rem;
  }
</style>
