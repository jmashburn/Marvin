---
import AppLayout from "@/layouts/AppLayout.astro";
import { getEntryType } from "@/lib/api/entryTypes";

const { id } = Astro.params;

let entryType = null;
let error: string | null = null;

if (!id) {
  error = "Entry type ID is required";
} else {
  try {
    entryType = await getEntryType(id);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[EntryType] Failed to load:', error);
  }
}

const isSystem = entryType?.is_system ?? false;
---

<AppLayout title={entryType ? `Edit ${entryType.name}` : "Edit Entry Type"}>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading entry type:</strong> {error}</p>
      <a href="/entry-types" class="button secondary">Back to Entry Types</a>
    </div>
  ) : entryType ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">Edit Entry Type</h2>
          <p style="margin:4px 0 0;color:var(--muted);">
            {isSystem ? "System entry types have limited editing" : "Update entry type details"}
          </p>
        </div>
        <a class="button secondary" href="/entry-types">Back</a>
      </div>

      <section class="form-section">
        <form method="POST" action={`/api/entry-types/${id}/update`} class="form">
          <div class="form-group">
            <label for="name">Name *</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              value={entryType.name}
              disabled={isSystem}
            />
            <p class="form-help">Human-readable name for this entry type</p>
          </div>

          <div class="form-group">
            <label for="slug">Slug *</label>
            <input
              type="text"
              id="slug"
              name="slug"
              required
              value={entryType.slug}
              pattern="[a-z0-9-]+"
              disabled={isSystem}
            />
            <p class="form-help">URL-friendly identifier (lowercase, hyphens only)</p>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="icon">Icon</label>
              <input
                type="text"
                id="icon"
                name="icon"
                value={entryType.icon || ""}
                maxlength="4"
              />
              <p class="form-help">Emoji or symbol</p>
            </div>

            <div class="form-group">
              <label for="color">Color</label>
              <input
                type="color"
                id="color"
                name="color"
                value={entryType.color || "#a94d3f"}
              />
              <p class="form-help">Theme color</p>
            </div>
          </div>

          <div class="form-group">
            <label for="description">Description</label>
            <textarea
              id="description"
              name="description"
              rows="3"
            >{entryType.description || ""}</textarea>
          </div>

          <div class="form-group">
            <label for="sort_order">Sort Order</label>
            <input
              type="number"
              id="sort_order"
              name="sort_order"
              value={entryType.sort_order}
              min="0"
            />
            <p class="form-help">Lower numbers appear first</p>
          </div>

          {isSystem && (
            <div class="notice">
              <strong>⚠️ System Entry Type</strong>
              <p>Name and slug cannot be changed for system entry types. Only visual properties can be updated.</p>
            </div>
          )}

          <div class="form-actions">
            <button type="submit" class="button">Save Changes</button>
            <a href="/entry-types" class="button secondary">Cancel</a>
          </div>
        </form>
      </section>
    </>
  ) : null}
</AppLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="number"],
  input[type="color"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  input[type="color"] {
    height: 40px;
    cursor: pointer;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .notice {
    padding: 1rem;
    background: rgb(169 99 47 / 0.1);
    border: 1px solid var(--warn);
    border-radius: 6px;
  }

  .notice strong {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--warn);
  }

  .notice p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }
</style>
