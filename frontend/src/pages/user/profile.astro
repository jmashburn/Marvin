---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAuthToken } from "@/lib/api/client";
import { changePassword, getUserProfile, updateUserProfile } from "@/lib/api/users";

const authToken = getAuthToken(Astro.cookies);
if (!authToken) {
  return Astro.redirect("/login");
}

let error: string | null = null;
let success: string | null = null;

// Handle form submissions (server-side)
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action") as string;

    if (action === "update_profile") {
      const data = {
        username: (formData.get("username") as string) || undefined,
        email: (formData.get("email") as string) || undefined,
        fullName: (formData.get("full_name") as string) || null,
      };

      await updateUserProfile(data, authToken);
      success = "Profile updated successfully";
    } else if (action === "change_password") {
      const currentPassword = formData.get("current_password") as string;
      const newPassword = formData.get("new_password") as string;
      const confirmPassword = formData.get("confirm_password") as string;

      if (newPassword !== confirmPassword) {
        error = "New passwords do not match";
      } else if (newPassword.length < 8) {
        error = "Password must be at least 8 characters";
      } else {
        await changePassword({ currentPassword, newPassword }, authToken);
        success = "Password changed successfully";
      }
    }
  } catch (e) {
    error = e instanceof Error ? e.message : "Operation failed";
    console.error("[Profile] Error:", error);
  }
}

let userProfile = null;

try {
  userProfile = await getUserProfile(authToken);
} catch (e) {
  error = e instanceof Error ? e.message : "Failed to load profile";
  console.error("[Profile] Failed to load profile:", error);
}
---

<AppLayout title="Profile" eyebrow="Account">
  <div class="profile-container">
    <div class="page-header">
      <div>
        <h2>Your Profile</h2>
        <p>Manage your account settings and password</p>
      </div>
    </div>

    {error && (
      <div class="alert alert-error">
        <strong>Error:</strong> {error}
      </div>
    )}

    {success && (
      <div class="alert alert-success">
        {success}
      </div>
    )}

    {userProfile && (
      <div class="profile-sections">
        <!-- Profile Information -->
        <section class="profile-section">
          <div class="section-header">
            <h3>Profile Information</h3>
            <p>Update your account details</p>
          </div>

          <form method="POST" class="form">
            <input type="hidden" name="action" value="update_profile" />

            <div class="form-group">
              <label for="username">Username *</label>
              <input
                type="text"
                id="username"
                name="username"
                value={userProfile.username}
                required
                pattern="[a-zA-Z0-9_\-]+"
                title="Letters, numbers, hyphens, and underscores only"
              />
              <small>Letters, numbers, hyphens, and underscores only</small>
            </div>

            <div class="form-group">
              <label for="email">Email Address *</label>
              <input
                type="email"
                id="email"
                name="email"
                value={userProfile.email}
                required
              />
            </div>

            <div class="form-group">
              <label for="full_name">Full Name</label>
              <input
                type="text"
                id="full_name"
                name="full_name"
                value={userProfile.fullName || ''}
              />
            </div>

            <div class="form-actions">
              <button type="submit" class="button">Save Changes</button>
            </div>
          </form>
        </section>

        <!-- Change Password -->
        <section class="profile-section">
          <div class="section-header">
            <h3>Change Password</h3>
            <p>Update your password to keep your account secure</p>
          </div>

          <form method="POST" class="form">
            <input type="hidden" name="action" value="change_password" />

            <div class="form-group">
              <label for="current_password">Current Password *</label>
              <input
                type="password"
                id="current_password"
                name="current_password"
                required
                autocomplete="current-password"
              />
            </div>

            <div class="form-group">
              <label for="new_password">New Password *</label>
              <input
                type="password"
                id="new_password"
                name="new_password"
                required
                minlength="8"
                autocomplete="new-password"
              />
              <small>Must be at least 8 characters</small>
            </div>

            <div class="form-group">
              <label for="confirm_password">Confirm New Password *</label>
              <input
                type="password"
                id="confirm_password"
                name="confirm_password"
                required
                minlength="8"
                autocomplete="new-password"
              />
            </div>

            <div class="form-actions">
              <button type="submit" class="button">Change Password</button>
            </div>
          </form>
        </section>

        <!-- API Tokens -->
        <section class="profile-section">
          <div class="section-header">
            <div class="section-header-row">
              <div>
                <h3>API Tokens</h3>
                <p>Long-lived tokens for accessing the API programmatically</p>
              </div>
              <a href="/user/api-tokens" class="button secondary small">Manage Tokens</a>
            </div>
          </div>
          <p class="token-hint">Generate API tokens to authenticate CLI tools, scripts, and integrations without using your password.</p>
          <a href="/user/api-tokens/new" class="button small">Create API Token</a>
        </section>

        <!-- Account Info -->
        <section class="profile-section">
          <div class="section-header">
            <h3>Account Information</h3>
            <p>Read-only account details</p>
          </div>

          <div class="info-grid">
            <div class="info-item">
              <span class="info-label">User ID</span>
              <code class="info-value">{userProfile.id}</code>
            </div>
            <div class="info-item">
              <span class="info-label">Account Type</span>
              <span class="info-value">{userProfile.admin ? 'Administrator' : 'Standard User'}</span>
            </div>
          </div>
        </section>
      </div>
    )}
  </div>
</AppLayout>

<style>
  .profile-container {
    max-width: 800px;
  }

  .page-header {
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .page-header h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .page-header p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
    font-size: 14px;
  }

  .alert-error {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .alert-success {
    background: rgba(34, 197, 94, 0.1);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .profile-sections {
    display: grid;
    gap: 32px;
  }

  .profile-section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .section-header {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--line);
  }

  .section-header h3 {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
  }

  .section-header p {
    margin: 4px 0 0;
    color: var(--muted);
    font-size: 13px;
  }

  .form {
    display: grid;
    gap: 20px;
  }

  .form-group {
    display: grid;
    gap: 6px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 500;
  }

  .form-group input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
    background: var(--bg);
    color: var(--text);
  }

  .form-group input:focus {
    outline: none;
    border-color: var(--primary);
  }

  .form-group small {
    font-size: 12px;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

  .info-grid {
    display: grid;
    gap: 16px;
  }

  .info-item {
    display: grid;
    gap: 6px;
  }

  .info-label {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-value {
    font-size: 14px;
  }

  .section-header-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }

  .token-hint {
    font-size: 13px;
    color: var(--muted);
    margin: 0 0 16px;
  }

  .button.small {
    padding: 6px 14px;
    font-size: 13px;
  }

  .info-value code {
    background: var(--bg);
    padding: 4px 8px;
    border-radius: 4px;
    font-family: 'SF Mono', 'Monaco', monospace;
    font-size: 12px;
  }
</style>
