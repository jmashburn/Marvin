---
import AppLayout from "@/layouts/AppLayout.astro";
import { getCurrentWorkspace } from "@/lib/api/workspaces";

let workspace = null;
let error: string | null = null;

try {
  workspace = await getCurrentWorkspace();
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
}

const preferences = workspace?.preferences || {};
---

<AppLayout title="Workspace Settings">
  <div class="toolbar">
    <h2 style="margin:0;font-size:20px;">Workspace Settings</h2>
  </div>

  {error ? (
    <div class="error-banner">{error}</div>
  ) : workspace ? (
    <section style="max-width:42rem;">
      <form method="POST" action={`/api/workspaces/${workspace.id}/update`} class="form">
        <div class="form-group">
          <label for="name">Workspace Name</label>
          <input type="text" id="name" name="name" value={workspace.name} required />
        </div>

        <h3 style="margin:1.5rem 0 1rem;">Preferences</h3>

        <div class="form-group">
          <label>
            <input
              type="checkbox"
              name="private_group"
              checked={preferences.private_group}
            />
            Private Workspace
          </label>
          <p class="form-help">Restrict access to workspace members only</p>
        </div>

        <div class="form-group">
          <label for="first_day_of_week">First Day of Week</label>
          <select id="first_day_of_week" name="first_day_of_week">
            <option value="0" selected={preferences.first_day_of_week === 0}>Sunday</option>
            <option value="1" selected={preferences.first_day_of_week === 1}>Monday</option>
          </select>
        </div>

        <div class="form-actions">
          <button type="submit" class="button">Save Settings</button>
        </div>
      </form>
    </section>
  ) : null}
</AppLayout>

<style>
  .error-banner {
    padding: 1rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    color: var(--color-error);
  }
  .form {
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }
  .form-group {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  label {
    font-weight: 600;
    font-size: 0.875rem;
  }
  input[type="text"],
  select {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
  }
  input[type="checkbox"] {
    margin-right: 0.5rem;
  }
  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }
  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
</style>
