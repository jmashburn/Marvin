---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";

const authToken = getAuthToken(Astro.cookies);
const { id } = Astro.params;

let group = null;
let members = [];
let error: string | null = null;

if (!id) {
  error = "Group ID is required";
} else {
  try {
    // Get group details
    group = await fetchApi(`/api/admin/groups/${id}`, {}, authToken);

    // Get workspace members
    members = await fetchApi(`/api/admin/groups/${id}/members`, {}, authToken);
  } catch (e) {
    error = e instanceof Error ? e.message : String(e);
    console.error('[admin/groups] Failed to load:', error);
  }
}
---

<AdminLayout title={group ? `Manage ${group.name}` : "Manage Workspace"}>
  {error ? (
    <div class="error-banner">
      <p><strong>Error loading workspace:</strong> {error}</p>
      <a href="/admin/groups" class="button secondary">Back to Workspaces</a>
    </div>
  ) : group ? (
    <>
      <div class="toolbar">
        <div>
          <h2 style="margin:0;font-size:20px;">{group.name}</h2>
          <p style="margin:4px 0 0;color:var(--muted);">Manage workspace settings and members</p>
        </div>
        <a class="button secondary" href="/admin/groups">Back</a>
      </div>

      <div class="layout-grid">
        <section class="main-section">
          <div class="panel">
            <h3>Workspace Details</h3>
            <form method="POST" action={`/api/admin/groups/${id}/update`} class="form">
              <div class="form-group">
                <label for="name">Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  value={group.name}
                />
              </div>

              <div class="form-group">
                <label for="slug">Slug</label>
                <input
                  type="text"
                  id="slug"
                  name="slug"
                  value={group.slug || ""}
                  disabled
                  style="background: var(--panel-2); color: var(--muted);"
                />
                <p class="form-help">Auto-generated identifier</p>
              </div>

              <div class="form-actions">
                <button type="submit" class="button">Save Changes</button>
              </div>
            </form>
          </div>

          <div class="panel">
            <h3>Members ({members.length})</h3>
            {members.length === 0 ? (
              <p class="empty-message">No members in this workspace.</p>
            ) : (
              <table class="table">
                <thead>
                  <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {members.map((member: any) => (
                    <tr>
                      <td>
                        <strong>{member.user?.fullName || member.user?.username || 'Unknown'}</strong>
                      </td>
                      <td>{member.user?.email || '—'}</td>
                      <td><span class="role-badge">{member.workspaceRole}</span></td>
                      <td>
                        <form method="POST" action={`/api/admin/groups/${id}/members/${member.id}/delete`} style="display:inline;">
                          <button type="submit" class="button secondary small danger" onclick="return confirm('Remove this user from the workspace?')">
                            Remove
                          </button>
                        </form>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
          </div>
        </section>

        <aside class="sidebar">
          <div class="panel">
            <h3>Info</h3>
            <dl class="info-list">
              <dt>Workspace ID</dt>
              <dd><code>{group.id}</code></dd>

              {group.slug && (
                <>
                  <dt>Slug</dt>
                  <dd><code>{group.slug}</code></dd>
                </>
              )}

              <dt>Total Members</dt>
              <dd>{members.length}</dd>
            </dl>
          </div>

          <div class="panel">
            <h3>Quick Actions</h3>
            <a href={`/workspace/members`} class="button secondary" style="width:100%;margin-bottom:0.5rem;">
              View Members Page
            </a>
            <a href={`/workspace/invites`} class="button secondary" style="width:100%;">
              Manage Invites
            </a>
          </div>
        </aside>
      </div>
    </>
  ) : null}
</AdminLayout>

<style>
  .error-banner {
    padding: 1.5rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .error-banner p {
    margin: 0;
    color: var(--color-error);
  }

  .layout-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 20rem;
    gap: 1.5rem;
  }

  .main-section {
    display: grid;
    gap: 1.5rem;
  }

  .panel {
    padding: 1.5rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .panel h3 {
    margin: 0 0 1.5rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .form {
    display: grid;
    gap: 1.5rem;
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"] {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .form-actions {
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .empty-message {
    padding: 2rem;
    text-align: center;
    color: var(--muted);
    background: var(--panel-2);
    border-radius: 6px;
  }

  .role-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--panel-2);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .button.small {
    min-height: 32px;
    padding: 6px 10px;
    font-size: 0.875rem;
  }

  .button.danger {
    color: var(--color-error);
    border-color: var(--color-error);
  }

  .button.danger:hover {
    background: var(--color-error-bg);
  }

  .sidebar {
    display: grid;
    gap: 1.5rem;
    align-content: start;
  }

  .info-list {
    display: grid;
    gap: 0.75rem;
    margin: 0;
  }

  .info-list dt {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-list dd {
    margin: 0;
    font-size: 0.875rem;
  }

  @media (max-width: 1024px) {
    .layout-grid {
      grid-template-columns: 1fr;
    }

    .sidebar {
      order: -1;
    }
  }
</style>
