---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { getAuthToken, fetchApi } from "@/lib/api/client";
import { listEmailTemplates } from "@/lib/api/emailTemplates";

// Require admin authentication
const user = await requireAdmin(Astro.cookies, Astro.redirect, Astro.url.pathname);
const authToken = getAuthToken(Astro.cookies);

let smtpEnabled = false;
let smtpFeature: any = null;
let settings: any = null;

// Fetch all settings including SMTP configuration
try {
  settings = await fetchApi<any>('/api/admin/about/startup-info', {}, authToken);
  smtpEnabled = settings?.smtpEnabled || false;
  smtpFeature = settings?.smtpFeature || null;
} catch (e) {
  console.error('Could not fetch settings:', e);
}
---

<AdminLayout title="Email Settings">
  <div class="toolbar">
    <div>
      <h2>Email Configuration</h2>
      <p>Configure SMTP settings and test email delivery</p>
    </div>
    <div class="status-badge">
      <span class={`status-indicator ${smtpEnabled ? 'enabled' : 'disabled'}`}>
        {smtpEnabled ? '● Enabled' : '○ Disabled'}
      </span>
    </div>
  </div>

  {!smtpEnabled && smtpFeature?.description && (
    <div class="alert alert-warning">
      <strong>SMTP Not Configured</strong>
      <p>{smtpFeature.description}</p>
      <p class="config-hint">Configure SMTP by setting environment variables in your .env file</p>
    </div>
  )}

  <div class="page-container">
    <div class="email-grid">
      <!-- SMTP Configuration (Read-Only) -->
      <section class="card">
        <h3>SMTP Server Settings</h3>
        <p class="card-description">Current SMTP configuration from environment variables</p>

        <div class="settings-display">
          <div class="setting-item">
            <span class="setting-label">SMTP Host</span>
            <span class="setting-value">{settings?.smtpHost || '(not configured)'}</span>
          </div>

          <div class="setting-item">
            <span class="setting-label">SMTP Port</span>
            <span class="setting-value">{settings?.smtpPort || '587'}</span>
          </div>

          <div class="setting-item">
            <span class="setting-label">Auth Strategy</span>
            <span class="setting-value">{settings?.smtpAuthStrategy || 'TLS'}</span>
          </div>

          {settings?.smtpAuthStrategy !== 'NONE' && (
            <>
              <div class="setting-item">
                <span class="setting-label">Username</span>
                <span class="setting-value">{settings?.smtpUser || '(not configured)'}</span>
              </div>

              <div class="setting-item">
                <span class="setting-label">Password</span>
                <span class="setting-value">{settings?.smtpPassword ? '••••••••' : '(not configured)'}</span>
              </div>
            </>
          )}

          <div class="setting-item">
            <span class="setting-label">From Email</span>
            <span class="setting-value">{settings?.smtpFromEmail || '(not configured)'}</span>
          </div>

          <div class="setting-item">
            <span class="setting-label">From Name</span>
            <span class="setting-value">{settings?.smtpFromName || 'Marvin'}</span>
          </div>
        </div>

        <div class="config-info">
          <p><strong>To update SMTP settings:</strong></p>
          <p>Edit your <code>.env</code> file and set the following variables:</p>
          <ul>
            <li><code>SMTP_HOST</code> - SMTP server hostname</li>
            <li><code>SMTP_PORT</code> - SMTP server port (default: 587)</li>
            <li><code>SMTP_AUTH_STRATEGY</code> - Auth strategy: TLS, SSL, or NONE (default: TLS)</li>
            <li><code>SMTP_USER</code> - SMTP username (if auth required)</li>
            <li><code>SMTP_PASSWORD</code> - SMTP password (if auth required)</li>
            <li><code>SMTP_FROM_EMAIL</code> - From email address</li>
            <li><code>SMTP_FROM_NAME</code> - From name (default: Marvin)</li>
          </ul>
          <p class="restart-note">Restart the application after making changes.</p>
        </div>
      </section>

      <!-- Test Email -->
      {smtpEnabled && (
        <section class="card">
          <h3>Test Email Delivery</h3>
          <p class="card-description">Send a test email to verify SMTP configuration</p>

          <form id="test-email-form" class="test-form">
            <label class="form-field">
              <span class="label">Test Email Address *</span>
              <input
                type="email"
                name="test_email"
                placeholder="test@example.com"
                required
                class="input"
              />
            </label>

            <label class="form-field">
              <span class="label">Subject</span>
              <input
                type="text"
                name="subject"
                value="Marvin Platform - Test Email"
                class="input"
              />
            </label>

            <label class="form-field">
              <span class="label">Message</span>
              <textarea
                name="message"
                rows="4"
                class="input textarea"
              >This is a test email from Marvin Platform. If you received this, your SMTP configuration is working correctly.</textarea>
            </label>

            <div class="form-actions">
              <button type="submit" class="button">Send Test Email</button>
            </div>
          </form>

          <div id="test-result" class="test-result hidden"></div>
        </section>
      )}

      <!-- Email Templates (Future) -->
      <section class="card">
        <h3>Email Templates</h3>
        <p class="card-description">Customize email templates (coming soon)</p>
        <div class="coming-soon">
          <p>📧 Email template customization will be available here</p>
          <p class="hint">Configure templates for invitations, notifications, password resets, etc.</p>
        </div>
      </section>
    </div>
  </div>
</AdminLayout>

<script>
  const testForm = document.getElementById('test-email-form');
  const testResult = document.getElementById('test-result');

  testForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new FormData(e.target as HTMLFormElement);

    const payload = {
      to: formData.get('test_email'),
      subject: formData.get('subject'),
      message: formData.get('message'),
    };

    testResult?.classList.remove('hidden', 'success', 'error');
    testResult!.textContent = 'Sending test email...';
    testResult?.classList.add('info');

    // TODO: Replace with actual API endpoint when backend is ready
    setTimeout(() => {
      testResult?.classList.remove('info');
      testResult?.classList.add('success');
      testResult!.textContent = '✓ Test email sent successfully! (Mock response - backend API needed)';
    }, 1500);

    console.log('Test Email:', payload);

    // Actual implementation when backend is ready:
    // try {
    //   const response = await fetch('/api/admin/email/test', {
    //     method: 'POST',
    //     headers: { 'Content-Type': 'application/json' },
    //     credentials: 'include',
    //     body: JSON.stringify(payload),
    //   });
    //
    //   if (response.ok) {
    //     testResult?.classList.add('success');
    //     testResult!.textContent = '✓ Test email sent successfully!';
    //   } else {
    //     const error = await response.text();
    //     testResult?.classList.add('error');
    //     testResult!.textContent = `✗ Failed to send test email: ${error}`;
    //   }
    // } catch (error) {
    //   testResult?.classList.add('error');
    //   testResult!.textContent = '✗ Network error. Please try again.';
    // }
  });
</script>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .status-badge {
    display: flex;
    align-items: center;
  }

  .status-indicator {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
  }

  .status-indicator.enabled {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .status-indicator.disabled {
    background: var(--panel-2);
    color: var(--muted);
    border: 1px solid var(--line);
  }

  .alert {
    padding: 16px 20px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-warning {
    background: rgba(255, 193, 7, 0.1);
    border: 1px solid rgba(255, 193, 7, 0.3);
  }

  .alert strong {
    display: block;
    margin-bottom: 6px;
    font-size: 14px;
    font-weight: 600;
  }

  .alert p {
    margin: 0 0 8px;
    font-size: 13px;
    line-height: 1.5;
  }

  .alert p:last-child {
    margin-bottom: 0;
  }

  .config-hint {
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
  }

  .page-container {
    max-width: 900px;
  }

  .email-grid {
    display: grid;
    gap: 24px;
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .card h3 {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
  }

  .card-description {
    margin: 0 0 20px;
    font-size: 14px;
    color: var(--muted);
  }

  .settings-display {
    display: grid;
    gap: 12px;
    margin-bottom: 24px;
  }

  .setting-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 14px;
    background: var(--panel-2);
    border-radius: var(--radius);
  }

  .setting-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
  }

  .setting-value {
    font-size: 14px;
    font-family: ui-monospace, monospace;
    color: var(--text);
  }

  .config-info {
    margin-top: 24px;
    padding: 16px;
    background: var(--panel-2);
    border-radius: var(--radius);
    border-left: 3px solid var(--accent);
  }

  .config-info p {
    margin: 0 0 12px;
    font-size: 13px;
    line-height: 1.6;
  }

  .config-info p:last-child {
    margin-bottom: 0;
  }

  .config-info strong {
    font-weight: 600;
  }

  .config-info code {
    padding: 2px 6px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 3px;
    font-size: 12px;
    font-family: ui-monospace, monospace;
  }

  .config-info ul {
    margin: 12px 0;
    padding-left: 24px;
    font-size: 13px;
    line-height: 1.8;
  }

  .config-info li {
    margin: 4px 0;
  }

  .restart-note {
    margin-top: 12px;
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
  }

  .test-form {
    display: grid;
    gap: 16px;
  }

  .form-field {
    display: grid;
    gap: 6px;
  }

  .label {
    font-size: 14px;
    font-weight: 500;
  }

  .input {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
  }

  .textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-actions {
    display: flex;
    gap: 12px;
    margin-top: 8px;
  }

  .test-result {
    margin-top: 16px;
    padding: 12px 16px;
    border-radius: var(--radius);
    font-size: 14px;
  }

  .test-result.hidden {
    display: none;
  }

  .test-result.info {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .test-result.success {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .test-result.error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .coming-soon {
    padding: 40px 24px;
    text-align: center;
    background: var(--panel-2);
    border-radius: var(--radius);
  }

  .coming-soon p {
    margin: 0 0 8px;
    font-size: 16px;
  }

  .coming-soon .hint {
    font-size: 14px;
    color: var(--muted);
    max-width: 400px;
    margin: 0 auto;
  }
</style>
