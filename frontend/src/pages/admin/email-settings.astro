<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .status-badge {
    display: flex;
    align-items: center;
  }

  .status-indicator {
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 500;
  }

  .status-indicator.enabled {
    background: rgba(79, 156, 132, 0.1);
    color: var(--accent);
    border: 1px solid var(--accent);
  }

  .status-indicator.disabled {
    background: var(--panel-2);
    color: var(--muted);
    border: 1px solid var(--line);
  }

  .alert {
    padding: 16px 20px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-warning {
    background: rgba(255, 193, 7, 0.1);
    border: 1px solid rgba(255, 193, 7, 0.3);
  }

  .alert strong {
    display: block;
    margin-bottom: 6px;
    font-size: 14px;
    font-weight: 600;
  }

  .alert p {
    margin: 0 0 8px;
    font-size: 13px;
    line-height: 1.5;
  }

  .alert p:last-child {
    margin-bottom: 0;
  }

  .config-hint {
    font-size: 12px;
    color: var(--muted);
    font-style: italic;
  }

  .page-container {
    max-width: 900px;
  }

  .email-grid {
    display: grid;
    gap: 24px;
  }

  .card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .card h3 {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
  }

  .card-description {
    margin: 0 0 20px;
    font-size: 14px;
    color: var(--muted);
  }

  .settings-display {
    display: grid;
    gap: 12px;
    margin-bottom: 24px;
  }

  .setting-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 14px;
    background: var(--panel-2);
    border-radius: var(--radius);
  }

  .setting-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
  }

  .setting-value {
    font-size: 14px;
    font-family: ui-monospace, monospace;
    color: var(--text);
  }

  .config-info {
    margin-top: 24px;
    padding: 16px;
    background: var(--panel-2);
    border-radius: var(--radius);
    border-left: 3px solid var(--accent);
  }

  .config-info p {
    margin: 0 0 12px;
    font-size: 13px;
    line-height: 1.6;
  }

  .config-info p:last-child {
    margin-bottom: 0;
  }

  .config-info strong {
    font-weight: 600;
  }

  .config-info code {
    padding: 2px 6px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 3px;
    font-size: 12px;
    font-family: ui-monospace, monospace;
  }

  .config-info ul {
    margin: 12px 0;
    padding-left: 24px;
    font-size: 13px;
    line-height: 1.8;
  }

  .config-info li {
    margin: 4px 0;
  }

