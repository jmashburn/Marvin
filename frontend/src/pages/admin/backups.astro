---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";

await requireAdmin(Astro.cookies, Astro.redirect, Astro.url.pathname);
---

<AdminLayout title="Backups">
  <div class="toolbar">
    <div>
      <h2>Backups</h2>
      <p>Backup and restore platform data</p>
    </div>
    <button class="button" disabled>Create Backup</button>
  </div>

  <div class="page-container">
    <section class="backups-section">
      <h3>Database Backups</h3>
      <p class="section-description">Create and manage database backups</p>
      <div class="coming-soon">
        <p>🚧 Backup management coming soon</p>
        <p class="hint">This will allow creating database backups, scheduling automatic backups, and restoring from backups.</p>
      </div>
    </section>
  </div>
</AdminLayout>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .page-container {
    max-width: 900px;
  }

  .backups-section {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
  }

  .backups-section h3 {
    margin: 0 0 4px;
    font-size: 18px;
    font-weight: 600;
  }

  .section-description {
    margin: 0 0 20px;
    font-size: 14px;
    color: var(--muted);
  }

  .coming-soon {
    padding: 40px 24px;
    text-align: center;
    background: var(--panel-2);
    border-radius: var(--radius);
  }

  .coming-soon p {
    margin: 0 0 8px;
    font-size: 16px;
  }

  .coming-soon .hint {
    font-size: 14px;
    color: var(--muted);
    max-width: 400px;
    margin: 0 auto;
  }

  .button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
