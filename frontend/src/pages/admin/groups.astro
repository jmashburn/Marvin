---
// Groups and Workspaces are the same thing (a Group *is* a workspace). This page was a duplicate
// of /admin/workspaces (same /api/admin/groups source), so it now redirects there.
import { requireAdmin } from "@/lib/auth";

await requireAdmin(Astro.cookies, Astro.redirect, Astro.url.pathname);
return Astro.redirect("/admin/workspaces", 301);
