---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdmin } from "@/lib/auth";
import { getAuthToken, fetchApi } from "@/lib/api/client";

const currentUser = await requireAdmin(Astro.cookies, Astro.redirect, Astro.url.pathname);

const authToken = getAuthToken(Astro.cookies);
let groups: any[] = [];
let error: string | null = null;

try {
  const response = await fetchApi<any>('/api/admin/groups', {}, authToken);
  groups = response.items || [];
} catch (e) {
  console.error('[admin/groups] Error loading:', e);
  error = e instanceof Error ? e.message : String(e);
}
---

<AdminLayout title="Groups">
  <div class="toolbar">
    <div>
      <h2>Workspaces & Groups</h2>
      <p>Manage all platform workspaces</p>
    </div>
    <button class="button">Create Group</button>
  </div>

  <div class="page-container">
    {error ? (
      <div class="alert alert-error">
        <strong>Error:</strong> {error}
      </div>
    ) : groups.length === 0 ? (
      <div class="empty-state">
        <div class="empty-icon">◫</div>
        <p class="empty-title">No groups found</p>
        <p class="empty-description">Create a workspace to get started</p>
      </div>
    ) : (
      <div class="groups-list">
        {groups.map((group) => (
          <div class="group-card">
            <div class="group-info">
              <strong>{group.name}</strong>
              {group.slug && <code class="group-slug">{group.slug}</code>}
              <div class="group-meta">
                <span>ID: {group.id}</span>
                {group.users && <span>• {group.users.length} users</span>}
              </div>
            </div>
            <div class="group-actions">
              <a href={`/admin/groups/${group.id}`} class="button secondary small">Manage</a>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</AdminLayout>

<style>
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--line);
  }

  .toolbar h2 {
    margin: 0;
    font-size: 24px;
    font-weight: 600;
  }

  .toolbar p {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: 14px;
  }

  .page-container {
    max-width: 900px;
  }

  .alert {
    padding: 16px;
    margin-bottom: 24px;
    border-radius: var(--radius);
  }

  .alert-error {
    background: var(--color-error-bg);
    color: var(--color-error);
    border: 1px solid var(--color-error);
  }

  .empty-state {
    padding: 80px 24px;
    text-align: center;
  }

  .empty-icon {
    font-size: 64px;
    margin-bottom: 16px;
    opacity: 0.3;
  }

  .empty-title {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 600;
  }

  .empty-description {
    margin: 0 0 24px;
    color: var(--muted);
    font-size: 14px;
  }

  .groups-list {
    display: grid;
    gap: 16px;
  }

  .group-card {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    padding: 20px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .group-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .group-info strong {
    font-size: 15px;
    font-weight: 600;
  }

  .group-slug {
    font-size: 13px;
    font-family: ui-monospace, monospace;
    color: var(--muted);
  }

  .group-meta {
    font-size: 12px;
    color: var(--muted);
    display: flex;
    gap: 6px;
  }

  .group-actions {
    flex-shrink: 0;
  }

  .button.small {
    padding: 6px 14px;
    font-size: 13px;
  }
</style>
