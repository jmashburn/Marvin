---
import AppLayout from "@/layouts/AppLayout.astro";
import { getAssets } from "@/lib/api/platform";

const assets = await getAssets();
---

<AppLayout title="Assets">
  <div class="toolbar">
    <div>
      <h2 style="margin:0;font-size:20px;">Media library</h2>
      <p style="margin:4px 0 0;color:var(--muted);">{assets.length} reusable uploads available to entries.</p>
    </div>
    <a class="button" href="/assets/new">Upload Asset</a>
  </div>

  <section class="grid" aria-label="Assets">
    {assets.map((asset) => (
      <article class="card">
        <div class="media">
          {asset.url && <img src={asset.url} alt={asset.alt_text ?? asset.name} style={`object-position: ${asset.focal_point ?? "50% 50%"}`} />}
        </div>
        <div class="card-body">
          <h2>{asset.name}</h2>
          <p>{asset.alt_text}</p>
          <div class="meta">
            <span class="pill">{asset.mime_type}</span>
            {asset.role && <span class="pill">{asset.role}</span>}
            {asset.usage && <span class="pill">{asset.usage}</span>}
            {asset.focal_point && <span class="pill">{asset.focal_point}</span>}
          </div>
        </div>
      </article>
    ))}
  </section>
</AppLayout>
