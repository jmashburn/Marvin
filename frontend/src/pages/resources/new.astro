---
import AppLayout from "@/layouts/AppLayout.astro";
---

<AppLayout title="New Resource" eyebrow="Resources">
  <div class="toolbar">
    <div>
      <h2 style="margin:0;font-size:20px;">New Resource</h2>
      <p style="margin:4px 0 0;color:var(--muted);">Add an external reference, supplier, tool, or material</p>
    </div>
    <a href="/resources" class="button secondary">Cancel</a>
  </div>

  <section class="form-section">
    <form method="POST" action="/api/resources" class="form">
      <div class="form-group">
        <label for="name">Name *</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="e.g., Organic Cotton Supplier, Figma, GitHub Repo"
        />
      </div>

      <div class="form-group">
        <label for="slug">Slug</label>
        <input
          type="text"
          id="slug"
          name="slug"
          placeholder="Auto-generated from name"
          disabled
          style="background: var(--panel-2); color: var(--muted);"
        />
        <p class="form-help">Auto-generated from name</p>
      </div>

      <div class="form-group">
        <label for="resource_type">Type *</label>
        <input
          type="text"
          id="resource_type"
          name="resource_type"
          required
          placeholder="e.g., supplier, tool, fabric, documentation"
        />
        <p class="form-help">Category for this resource</p>
      </div>

      <div class="form-group">
        <label for="url">URL</label>
        <input
          type="url"
          id="url"
          name="url"
          placeholder="https://example.com"
        />
        <p class="form-help">External website or documentation</p>
      </div>

      <div class="form-group">
        <label for="external_id">External ID</label>
        <input
          type="text"
          id="external_id"
          name="external_id"
          placeholder="SKU, ISBN, or other identifier"
        />
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea
          id="description"
          name="description"
          rows="4"
          placeholder="What is this resource? How is it used?"
        ></textarea>
      </div>

      <div class="form-group">
        <label for="metadata_">Metadata (JSON)</label>
        <p class="form-help">Custom metadata fields for this resource</p>
        <textarea
          id="metadata_"
          name="metadata_"
          rows="6"
          placeholder='{"key": "value"}'
          class="metadata-editor"
        ></textarea>
        <small style="font-size: 11px; color: var(--muted);">
          Must be valid JSON. Example: {`{"supplier_code": "ABC123", "contact": "john@example.com"}`}
        </small>
      </div>

      <div class="form-actions">
        <button type="submit" class="button">Create Resource</button>
        <a href="/resources" class="button secondary">Cancel</a>
      </div>
    </form>
  </section>
</AppLayout>

<script>
  // Auto-generate slug from name
  const nameInput = document.getElementById('name');
  const slugInput = document.getElementById('slug');

  if (nameInput && slugInput) {
    nameInput.addEventListener('input', () => {
      const slug = nameInput.value
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
      slugInput.value = slug;
    });
  }

  // Validate metadata JSON on form submit
  const form = document.querySelector('form');
  const metadataField = document.getElementById('metadata_');

  if (form && metadataField) {
    metadataField.addEventListener('blur', () => {
      const value = metadataField.value.trim();
      if (!value) return;

      try {
        JSON.parse(value);
        metadataField.style.borderColor = 'var(--line)';
      } catch (error) {
        metadataField.style.borderColor = '#ef5350';
      }
    });

    form.addEventListener('submit', async (e) => {
      const metadataValue = metadataField.value.trim();

      if (metadataValue) {
        try {
          JSON.parse(metadataValue);
        } catch (error) {
          e.preventDefault();
          alert('Metadata must be valid JSON. Please check your syntax.');
          metadataField.focus();
          return;
        }
      }
    });
  }
</script>

<style>
  .form-section {
    max-width: 42rem;
  }

  .form {
    display: grid;
    gap: 2rem;
    padding: 2rem;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
  }

  .form-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  input[type="text"],
  input[type="url"],
  textarea {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
  }

  textarea {
    resize: vertical;
    font-family: inherit;
  }

  .form-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .metadata-editor {
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
    font-size: 12px;
    line-height: 1.5;
    background: var(--panel-2);
  }
</style>
