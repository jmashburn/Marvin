---
import { getAuthToken } from "@/lib/api/client";
import { getCurrentWorkspace, listWorkspaces } from "@/lib/api/workspaces";

const authToken = getAuthToken(Astro.cookies);

let currentWorkspace: any;
let workspaces: any;
let error: string | null = null;

try {
  if (!authToken) {
    throw new Error("Not authenticated");
  }
  currentWorkspace = await getCurrentWorkspace(authToken);
  workspaces = await listWorkspaces(authToken);
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
  console.error("[WorkspaceSwitcher] Failed to load workspaces:", error);
}
---

{error ? (
  <div class="workspace-switcher-error">
    <span class="error-icon">⚠</span>
    <span class="error-text">Workspace Error</span>
  </div>
) : currentWorkspace && workspaces ? (
  <div class="workspace-switcher">
    <button class="workspace-button" id="workspace-menu-trigger" type="button">
      <span class="workspace-name">{currentWorkspace.name}</span>
      <span class="dropdown-icon">▾</span>
    </button>

    <div class="workspace-menu" id="workspace-menu" hidden>
      <div class="menu-header">Switch Workspace</div>
      <ul class="workspace-list">
        {workspaces.map(({ workspace, role, isActive }) => (
          <li>
            <form method="POST" action="/api/workspace/activate">
              <input type="hidden" name="workspace_id" value={workspace.id} />
              <button
                type="submit"
                class:list={['workspace-item', { active: isActive }]}
                disabled={isActive}
              >
                <span class="workspace-name">{workspace.name}</span>
                {isActive && <span class="active-badge">Active</span>}
                <span class="workspace-role">{role}</span>
              </button>
            </form>
          </li>
        ))}
      </ul>
      <div class="menu-footer">
        <a href="/workspace/new" class="create-workspace-link">+ Create Workspace</a>
      </div>
    </div>
  </div>
) : null}

<script>
  // Client-side toggle for dropdown menu
  const trigger = document.getElementById('workspace-menu-trigger');
  const menu = document.getElementById('workspace-menu');

  trigger?.addEventListener('click', () => {
    menu?.toggleAttribute('hidden');
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!trigger?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      menu?.setAttribute('hidden', '');
    }
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      menu?.setAttribute('hidden', '');
    }
  });
</script>

<style>
  .workspace-switcher {
    position: relative;
    width: 100%;
  }

  .workspace-button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 10px 12px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.2s;
  }

  .workspace-button:hover {
    background: var(--panel-2);
    border-color: var(--muted);
  }

  .workspace-button .workspace-name {
    flex: 1;
    text-align: left;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .workspace-button .dropdown-icon {
    font-size: 12px;
    opacity: 0.6;
    margin-left: 8px;
  }

  .workspace-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    z-index: 50;
    overflow: hidden;
  }

  .workspace-menu[hidden] {
    display: none;
  }

  .menu-header {
    padding: 10px 14px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--muted);
    border-bottom: 1px solid var(--line);
  }

  .workspace-list {
    list-style: none;
    margin: 0;
    padding: 8px;
    max-height: 300px;
    overflow-y: auto;
  }

  .workspace-list li {
    margin: 0;
  }

  .workspace-list form {
    margin: 0;
  }

  .workspace-item {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 10px;
    background: transparent;
    border: none;
    border-radius: var(--radius);
    text-align: left;
    font-size: 14px;
    color: var(--ink);
    cursor: pointer;
    transition: all 0.2s;
  }

  .workspace-item:not(:disabled):hover {
    background: var(--panel-2);
    color: var(--ink);
  }

  .workspace-item.active {
    background: var(--color-primary-bg);
    color: var(--accent);
    font-weight: 600;
    cursor: default;
  }

  .workspace-item .workspace-name {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .active-badge {
    padding: 2px 8px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    background: var(--good);
    color: white;
    border-radius: 4px;
  }

  .workspace-role {
    font-size: 11px;
    color: var(--muted);
    text-transform: capitalize;
  }

  .menu-footer {
    padding: 8px 14px;
    border-top: 1px solid var(--line);
  }

  .create-workspace-link {
    display: block;
    padding: 8px 10px;
    font-size: 13px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    border-radius: var(--radius);
    transition: background 0.2s;
  }

  .create-workspace-link:hover {
    background: var(--color-primary-bg);
  }

  .workspace-switcher-error {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--color-error-bg);
    border: 1px solid var(--color-error);
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-error);
  }

  .error-icon {
    font-size: 1rem;
  }
</style>
