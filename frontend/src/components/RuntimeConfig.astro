---
// Hands the browser its runtime configuration. Values the browser needs — chiefly the API base
// URL — are resolved server-side here, from the live environment, and written into the page as a
// small global. Browser code reads window.__MARVIN_RUNTIME__ instead of a value inlined at build
// time, so one built image serves any deployment (see lib/api/config.ts).
//
// Only browser-safe values belong here. This global is visible to every visitor — never put a
// credential (e.g. the site-client token) in it.
import { getBrowserApiBaseUrl } from "@/lib/api/config";

const runtimeConfig = {
  apiBaseUrl: getBrowserApiBaseUrl(),
};
---
<script is:inline set:html={`window.__MARVIN_RUNTIME__=${JSON.stringify(runtimeConfig)}`}></script>
