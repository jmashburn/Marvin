---
/**
 * DateField Component
 * Renders a date picker field
 */
export interface Props {
  field: {
    key: string;
    label: string;
    type: "date";
    required?: boolean;
    defaultValue?: string;
    placeholder?: string;
    helpText?: string;
    readOnly?: boolean;
  };
  value?: string;
  error?: string;
}

const { field, value, error } = Astro.props;
const inputId = `field-${field.key}`;
---

<div class="field-group">
  <label for={inputId}>
    {field.label}
    {field.required && <span class="required">*</span>}
  </label>

  <input
    type="date"
    id={inputId}
    name={`dataJson.${field.key}`}
    value={value || field.defaultValue || ''}
    placeholder={field.placeholder}
    required={field.required}
    readonly={field.readOnly}
    class:list={['field-input', { error }]}
  />

  {field.helpText && <p class="field-help">{field.helpText}</p>}
  {error && <p class="field-error">{error}</p>}
</div>

<style>
  .field-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  .required {
    color: var(--color-error);
    margin-left: 2px;
  }

  .field-input {
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
    transition: border-color 0.2s;
  }

  .field-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-alpha);
  }

  .field-input:read-only {
    background: var(--muted-bg);
    cursor: not-allowed;
  }

  .field-input.error {
    border-color: var(--color-error);
  }

  .field-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .field-error {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-error);
  }
</style>
