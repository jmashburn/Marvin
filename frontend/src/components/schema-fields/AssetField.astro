---
/**
 * AssetField Component
 * Renders an asset picker for single asset selection
 * Currently simplified - shows UUID input (asset picker UI can be added later)
 */
export interface Props {
  field: {
    key: string;
    label: string;
    type: 'asset';
    required?: boolean;
    defaultValue?: string;
    placeholder?: string;
    helpText?: string;
    readOnly?: boolean;
  };
  value?: string;
  error?: string;
}

const { field, value, error } = Astro.props;
const inputId = `field-${field.key}`;
---

<div class="field-group">
  <label for={inputId}>
    {field.label}
    {field.required && <span class="required">*</span>}
  </label>

  <div class="asset-field">
    <input
      type="text"
      id={inputId}
      name={`dataJson.${field.key}`}
      value={value || field.defaultValue || ''}
      placeholder={field.placeholder || 'Asset UUID'}
      required={field.required}
      readonly={field.readOnly}
      class:list={['field-input', { error }]}
    />
    <button type="button" class="button secondary asset-picker-btn" disabled={field.readOnly}>
      Browse Assets
    </button>
  </div>

  {field.helpText && <p class="field-help">{field.helpText}</p>}
  {error && <p class="field-error">{error}</p>}

  <p class="field-note">
    <small><em>Asset picker UI coming soon. Enter asset UUID directly for now.</em></small>
  </p>
</div>

<style>
  .field-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  .required {
    color: var(--color-error);
    margin-left: 2px;
  }

  .asset-field {
    display: flex;
    gap: 0.5rem;
  }

  .field-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
    font-family: 'SF Mono', Monaco, monospace;
    transition: border-color 0.2s;
  }

  .field-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-alpha);
  }

  .field-input:read-only {
    background: var(--muted-bg);
    cursor: not-allowed;
  }

  .field-input.error {
    border-color: var(--color-error);
  }

  .asset-picker-btn {
    white-space: nowrap;
  }

  .field-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .field-error {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-error);
  }

  .field-note {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
    font-style: italic;
  }
</style>

<script>
  // Asset picker functionality (placeholder)
  document.querySelectorAll('.asset-picker-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      alert('Asset picker UI not yet implemented. Enter UUID directly for now.');
    });
  });
</script>
