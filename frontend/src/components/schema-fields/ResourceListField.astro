---
/**
 * ResourceListField Component
 * Renders a resource picker for multiple resource selection
 * Currently simplified - shows comma-separated UUID input
 */
export interface Props {
  field: {
    key: string;
    label: string;
    type: 'resource-list';
    required?: boolean;
    defaultValue?: string[];
    placeholder?: string;
    helpText?: string;
    readOnly?: boolean;
    minItems?: number;
    maxItems?: number;
  };
  value?: string[];
  error?: string;
}

const { field, value, error } = Astro.props;
const inputId = `field-${field.key}`;
const displayValue = Array.isArray(value) ? value.join(', ') : (value || '');
---

<div class="field-group">
  <label for={inputId}>
    {field.label}
    {field.required && <span class="required">*</span>}
    {field.minItems && field.maxItems && (
      <span class="count-hint">({field.minItems}-{field.maxItems} items)</span>
    )}
  </label>

  <div class="resource-list-field">
    <textarea
      id={inputId}
      name={`dataJson.${field.key}`}
      placeholder={field.placeholder || 'Resource UUIDs (comma-separated)'}
      required={field.required}
      readonly={field.readOnly}
      rows="3"
      class:list={['field-textarea', { error }]}
    >{displayValue}</textarea>
  </div>

  {field.helpText && <p class="field-help">{field.helpText}</p>}
  {error && <p class="field-error">{error}</p>}

  <p class="field-note">
    <small><em>Enter resource UUIDs separated by commas. Resource picker UI coming soon.</em></small>
  </p>
</div>

<style>
  .field-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  .required {
    color: var(--color-error);
    margin-left: 2px;
  }

  .count-hint {
    font-weight: normal;
    color: var(--muted);
    margin-left: 0.5rem;
  }

  .field-textarea {
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
    font-family: 'SF Mono', Monaco, monospace;
    line-height: 1.6;
    resize: vertical;
    transition: border-color 0.2s;
  }

  .field-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-alpha);
  }

  .field-textarea:read-only {
    background: var(--muted-bg);
    cursor: not-allowed;
  }

  .field-textarea.error {
    border-color: var(--color-error);
  }

  .field-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .field-error {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-error);
  }

  .field-note {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
    font-style: italic;
  }
</style>
