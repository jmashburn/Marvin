---
/**
 * TextareaField Component
 * Renders a multi-line plain text field
 */
export interface Props {
  field: {
    key: string;
    label: string;
    type: "textarea";
    required?: boolean;
    defaultValue?: string;
    placeholder?: string;
    helpText?: string;
    readOnly?: boolean;
    min?: number;
    max?: number;
    rows?: number;
  };
  value?: string;
  error?: string;
}

const { field, value, error } = Astro.props;
const inputId = `field-${field.key}`;
---

<div class="field-group">
  <label for={inputId}>
    {field.label}
    {field.required && <span class="required">*</span>}
  </label>

  <textarea
    id={inputId}
    name={`dataJson.${field.key}`}
    placeholder={field.placeholder}
    required={field.required}
    readonly={field.readOnly}
    minlength={field.min}
    maxlength={field.max}
    rows={field.rows || 4}
    class:list={['field-textarea', { error }]}
  >{value || field.defaultValue || ''}</textarea>

  {field.helpText && <p class="field-help">{field.helpText}</p>}
  {error && <p class="field-error">{error}</p>}
</div>

<style>
  .field-group {
    display: grid;
    gap: 0.5rem;
  }

  label {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--ink);
  }

  .required {
    color: var(--color-error);
    margin-left: 2px;
  }

  .field-textarea {
    padding: 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
    font-family: inherit;
    line-height: 1.6;
    resize: vertical;
    transition: border-color 0.2s;
  }

  .field-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--color-primary-alpha);
  }

  .field-textarea:read-only {
    background: var(--muted-bg);
    cursor: not-allowed;
  }

  .field-textarea.error {
    border-color: var(--color-error);
  }

  .field-help {
    margin: 0;
    font-size: 0.75rem;
    color: var(--muted);
  }

  .field-error {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-error);
  }
</style>
