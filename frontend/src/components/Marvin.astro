---
// Marvin — the (pluggable) workspace assistant bubble.
// Renders hidden; the client script reveals it only when AI is enabled for the workspace.
// Capabilities live in @/lib/marvin/capabilities — adding a skill needs no change here.
---

<div id="marvin-root" class="marvin" hidden>
  <button id="marvin-toggle" class="marvin-toggle" aria-label="Ask Marvin" title="Ask Marvin">🤖</button>

  <div id="marvin-panel" class="marvin-panel" role="dialog" aria-label="Ask Marvin">
    <div class="marvin-head">
      <div class="marvin-id">
        <span class="marvin-name">Marvin</span>
        <span id="marvin-sub" class="marvin-sub">here to help, allegedly</span>
      </div>
      <button id="marvin-clear" class="marvin-clear" aria-label="Clear conversation" title="Clear conversation" hidden>Clear</button>
      <button id="marvin-close" class="marvin-close" aria-label="Close">×</button>
    </div>
    <div id="marvin-context" class="marvin-context" hidden>
      <span class="marvin-context-what">Looking at</span>
      <span id="marvin-context-label" class="marvin-context-label"></span>
      <button id="marvin-context-clear" class="marvin-context-clear"
        aria-label="Ignore this page's context" title="Ignore this page's context">×</button>
    </div>
    <div id="marvin-log" class="marvin-log"></div>
    <form id="marvin-form" class="marvin-form">
      <input id="marvin-input" class="marvin-input" type="text" autocomplete="off"
        placeholder="Ask Marvin…  (try /help)" />
      <button type="submit" class="marvin-send" aria-label="Send">➤</button>
    </form>
  </div>
</div>

<script>
  import { fetchApi } from '@/lib/api/client';
  import { resolveCapability, helpHtml, esc, setPendingRegister } from '@/lib/marvin/capabilities';
  import { GREETINGS, TAGLINES, THINKING, EMOTES, ERRORS, pick } from '@/lib/marvin/persona';
  import { getPageContext, contextLabel, setContextSuppressed } from '@/lib/marvin/context';
  import { setHistory, clearHistory } from '@/lib/marvin/history';

  const root = document.getElementById('marvin-root');
  if (root) {
    // Gate: stay hidden until we confirm AI is enabled for this workspace.
    (async () => {
      try {
        const settings = await fetchApi<any>('/api/groups/ai-settings');
        if (settings?.enabled === false) { root.remove(); return; }
        root.removeAttribute('hidden');
      } catch {
        root.remove(); // no auth / no AI / error → no bubble
      }
    })();

    const toggle = document.getElementById('marvin-toggle')!;
    const close = document.getElementById('marvin-close')!;
    const panel = document.getElementById('marvin-panel')!;
    const log = document.getElementById('marvin-log')!;
    const form = document.getElementById('marvin-form') as HTMLFormElement;
    const input = document.getElementById('marvin-input') as HTMLInputElement;
    const sub = document.getElementById('marvin-sub')!;
    const clear = document.getElementById('marvin-clear')!;
    let greeted = false;
    let busy = false;
    let taglineTimer: number | undefined;

    // ── Session memory: keep the transcript across page navigations (per-tab) ──
    // sessionStorage, so the conversation follows you as you move around the workspace but doesn't
    // linger forever or leak between tabs. Only committed turns are stored — never the transient
    // "thinking…" placeholder, which is replaced in place by the final answer.
    const MEM_KEY = 'marvin.transcript';
    const MEM_CAP = 60; // keep the last N turns; guards both quota and scrollback bloat
    // `text` is the plain-text form replayed to the model as memory (see @/lib/marvin/history).
    // It's optional so transcripts saved before this existed still rehydrate.
    type Turn = { who: 'user' | 'marvin'; html: string; text?: string };
    let transcript: Turn[] = [];
    try {
      const saved = JSON.parse(sessionStorage.getItem(MEM_KEY) || '[]');
      if (Array.isArray(saved)) transcript = saved;
    } catch { /* ignore corrupt transcript */ }

    function saveTranscript() {
      try {
        transcript = transcript.slice(-MEM_CAP);
        sessionStorage.setItem(MEM_KEY, JSON.stringify(transcript));
      } catch { /* quota or disabled storage — degrade to in-memory only */ }
      clear.toggleAttribute('hidden', transcript.length === 0);
    }

    function appendNode(who: 'user' | 'marvin', html: string): HTMLElement {
      const div = document.createElement('div');
      div.className = `mv-msg mv-${who}`;
      div.innerHTML = html;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      return div;
    }

    // Add a message to the log. Committed turns persist; pass persist=false for the transient
    // "thinking…" placeholder (its final answer is committed via commitReply once it resolves).
    function addMsg(who: 'user' | 'marvin', html: string, persist = true, text?: string): HTMLElement {
      const div = appendNode(who, html);
      if (persist) { transcript.push({ who, html, text: text ?? div.textContent ?? '' }); saveTranscript(); }
      return div;
    }

    // Commit a marvin reply that replaced a "thinking…" node in place.
    function commitReply(node: HTMLElement, html: string, text?: string) {
      node.innerHTML = html;
      transcript.push({ who: 'marvin', html, text: text ?? node.textContent ?? '' });
      saveTranscript();
    }

    /** Plain-text view of the conversation so far, for replay as agent memory. */
    function historySnapshot() {
      return transcript
        .map((t) => ({ role: (t.who === 'user' ? 'user' : 'assistant') as 'user' | 'assistant',
                       content: (t.text ?? '').trim() }))
        .filter((t) => t.content);
    }

    function clearTranscript() {
      transcript = [];
      clearHistory(); // "Clear" must also drop the model's memory, not just the visible log
      try { sessionStorage.removeItem(MEM_KEY); } catch { /* ignore */ }
      log.innerHTML = '';
      clear.setAttribute('hidden', '');
      greeted = false;
      if (panel.classList.contains('open')) { greeted = true; addMsg('marvin', esc(pick(GREETINGS)), false); }
    }

    // Rehydrate a stored conversation on page load (before any greeting).
    if (transcript.length) {
      for (const t of transcript) appendNode(t.who, t.html);
      greeted = true; // don't greet over a restored conversation
      clear.removeAttribute('hidden');
    }

    // ── Page context chip: show what Marvin is grounded in, and let it be dismissed ──
    // The chip is honest UI, not decoration: if it's showing, that entity is being sent with
    // every ask. Dismissing suppresses it for this page load (a navigation resets it).
    const contextBar = document.getElementById('marvin-context')!;
    const contextLabelEl = document.getElementById('marvin-context-label')!;
    const contextClear = document.getElementById('marvin-context-clear')!;

    function renderContext() {
      const label = contextLabel(getPageContext());
      if (!label) { contextBar.setAttribute('hidden', ''); return; }
      contextLabelEl.textContent = label;
      contextBar.removeAttribute('hidden');
    }

    contextClear.addEventListener('click', () => {
      setContextSuppressed(true);
      contextBar.setAttribute('hidden', '');
      addMsg('marvin', "Fine — I'll ignore this page and answer about the whole workspace.", false);
    });

    renderContext();

    function rotateTagline() { sub.textContent = pick(TAGLINES); }

    // Open the panel on the side of the button with the most room (he may be dragged anywhere).
    function placePanel() {
      const r = toggle.getBoundingClientRect();
      const below = r.top < window.innerHeight / 2;
      const leftSide = r.left < window.innerWidth / 2;
      panel.style.top = below ? '64px' : 'auto';
      panel.style.bottom = below ? 'auto' : '64px';
      panel.style.left = leftSide ? '0' : 'auto';
      panel.style.right = leftSide ? 'auto' : '0';
    }

    function openPanel() {
      placePanel();
      panel.classList.add('open');
      rotateTagline();
      taglineTimer = window.setInterval(rotateTagline, 7000); // cycle like a login fortune
      if (!greeted) {
        greeted = true;
        addMsg('marvin', esc(pick(GREETINGS)), false); // flavor line, not part of the saved transcript
      }
      input.focus();
    }
    function closePanel() {
      panel.classList.remove('open');
      if (taglineTimer) { clearInterval(taglineTimer); taglineTimer = undefined; }
    }

    // ── Drag the bubble around (pointer events; click vs drag disambiguated) ──
    const POS_KEY = 'marvin.pos';
    let dragging = false, moved = false, sx = 0, sy = 0, ox = 0, oy = 0;

    try {
      const saved = JSON.parse(localStorage.getItem(POS_KEY) || 'null');
      if (saved && typeof saved.left === 'number') {
        root.style.left = saved.left + 'px';
        root.style.top = saved.top + 'px';
        root.style.right = 'auto';
        root.style.bottom = 'auto';
      }
    } catch { /* ignore bad stored position */ }

    toggle.addEventListener('pointerdown', (e) => {
      dragging = true; moved = false;
      const r = root.getBoundingClientRect();
      ox = r.left; oy = r.top; sx = e.clientX; sy = e.clientY;
      toggle.setPointerCapture(e.pointerId);
    });
    toggle.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - sx, dy = e.clientY - sy;
      if (!moved && Math.abs(dx) + Math.abs(dy) > 4) moved = true;
      if (!moved) return;
      const left = Math.min(Math.max(8, ox + dx), window.innerWidth - toggle.offsetWidth - 8);
      const top = Math.min(Math.max(8, oy + dy), window.innerHeight - toggle.offsetHeight - 8);
      root.style.left = left + 'px'; root.style.top = top + 'px';
      root.style.right = 'auto'; root.style.bottom = 'auto';
      if (panel.classList.contains('open')) placePanel();
    });
    toggle.addEventListener('pointerup', (e) => {
      if (!dragging) return;
      dragging = false;
      toggle.releasePointerCapture(e.pointerId);
      if (moved) {
        const r = root.getBoundingClientRect();
        localStorage.setItem(POS_KEY, JSON.stringify({ left: r.left, top: r.top }));
      }
    });

    toggle.addEventListener('click', () => {
      if (moved) { moved = false; return; } // it was a drag, not a click
      panel.classList.contains('open') ? closePanel() : openPanel();
    });
    // Public hook: any page can drive the bubble without reaching into it or needing a global —
    //   document.dispatchEvent(new CustomEvent('marvin:ask', { detail: { text: 'review this' } }))
    // Opens the panel and submits, so the ask flows through the normal capability dispatch
    // (and therefore picks up page context + history like anything the user typed).
    // `detail.register` lets the caller ask for a tone register — e.g. the entry editor's
    // "Review & suggest" sends 'professional' so the findings come back plain and actionable
    // rather than in character. Cleared after the run so typed messages aren't affected.
    document.addEventListener('marvin:ask', (e) => {
      const detail = (e as CustomEvent).detail ?? {};
      const text = String(detail.text ?? '').trim();
      if (!text || busy) return;
      if (detail.register) setPendingRegister(detail.register);
      if (!panel.classList.contains('open')) openPanel();
      input.value = text;
      form.requestSubmit();
    });

    close.addEventListener('click', closePanel);
    clear.addEventListener('click', clearTranscript);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePanel(); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || busy) return;
      // Snapshot the conversation BEFORE appending this turn, so `history` is exactly
      // "what came before this message" — otherwise the question would be sent twice.
      setHistory(historySnapshot());
      addMsg('user', esc(text), true, text);
      input.value = '';

      const { cap, arg, help } = resolveCapability(text);
      if (help) { addMsg('marvin', helpHtml()); return; }
      if (!cap) {
        addMsg('marvin', "I don't know that command. Try <code>/help</code> — not that it'll lift the mood.");
        return;
      }
      if (!arg && !cap.noArg) { addMsg('marvin', "You'll have to give me something to work with."); return; }

      busy = true;
      const thinking = addMsg('marvin', `<span class="mv-thinking">${esc(pick(EMOTES) + ' ' + pick(THINKING))}</span>`, false);
      try {
        const res = await cap.run(arg);
        commitReply(thinking, res.html, res.text);
      } catch (err: any) {
        commitReply(thinking, `<span class="mv-error">${esc(pick(ERRORS))} (${esc(err?.message || 'error')})</span>`);
      } finally {
        busy = false;
        log.scrollTop = log.scrollHeight;
      }
    });
  }
</script>

<style>
  .marvin { position: fixed; right: 20px; bottom: 20px; z-index: 1000; }

  .marvin-toggle {
    width: 52px; height: 52px; border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--accent); color: #fff;
    font-size: 24px; line-height: 1; cursor: grab;
    box-shadow: 0 6px 20px rgb(0 0 0 / 0.18);
    transition: box-shadow 0.15s;
    touch-action: none; user-select: none;
  }
  .marvin-toggle:active { cursor: grabbing; }
  .marvin-toggle:hover { box-shadow: 0 10px 26px rgb(0 0 0 / 0.24); }

  .marvin-panel {
    position: absolute; right: 0; bottom: 64px;
    width: 360px; max-width: calc(100vw - 40px);
    height: 520px; max-height: calc(100vh - 120px);
    display: none; flex-direction: column;
    background: var(--panel); border: 1px solid var(--line);
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 12px 40px rgb(0 0 0 / 0.22);
  }
  .marvin-panel.open { display: flex; }

  .marvin-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px; border-bottom: 1px solid var(--line); background: var(--bg);
  }
  .marvin-id { display: flex; flex-direction: column; }
  .marvin-name { font-weight: 600; font-size: 15px; color: var(--ink); }
  .marvin-sub { font-size: 11px; color: var(--muted); }
  .marvin-clear {
    margin-left: auto; margin-right: 4px;
    background: none; border: none; cursor: pointer;
    font-size: 11px; line-height: 1; color: var(--muted); padding: 2px 4px;
  }
  .marvin-clear:hover { color: var(--ink); }
  .marvin-close {
    background: none; border: none; cursor: pointer;
    font-size: 22px; line-height: 1; color: var(--muted); padding: 0 4px;
  }
  .marvin-close:hover { color: var(--ink); }

  /* Context chip — static markup, so plain scoped styles reach it. */
  .marvin-context {
    display: flex; align-items: center; gap: 6px;
    padding: 7px 14px; border-bottom: 1px solid var(--line);
    background: var(--bg); font-size: 11px; color: var(--muted);
  }
  .marvin-context[hidden] { display: none; }
  .marvin-context-what { flex: none; }
  .marvin-context-label {
    flex: 1; min-width: 0; font-weight: 600; color: var(--ink);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .marvin-context-clear {
    flex: none; background: none; border: none; cursor: pointer;
    font-size: 15px; line-height: 1; color: var(--muted); padding: 0 2px;
  }
  .marvin-context-clear:hover { color: var(--ink); }

  .marvin-log { flex: 1; overflow-y: auto; padding: 14px; display: flex; flex-direction: column; gap: 10px; }

  .marvin-form { display: flex; gap: 8px; padding: 12px; border-top: 1px solid var(--line); background: var(--bg); }
  .marvin-input {
    flex: 1; padding: 9px 12px; font-size: 14px;
    border: 1px solid var(--line); border-radius: 999px;
    background: var(--panel); color: var(--ink);
  }
  .marvin-input:focus { border-color: var(--accent); outline: none; }
  .marvin-send {
    width: 38px; border: none; border-radius: 50%;
    background: var(--accent); color: #fff; cursor: pointer; font-size: 14px;
  }
  .marvin-send:hover { filter: brightness(1.05); }

  /* Messages are built in JS, so their styles must be :global() to apply. */
  .marvin-log :global(.mv-msg) {
    font-size: 14px; line-height: 1.5; padding: 9px 12px;
    border-radius: 12px; max-width: 85%; word-wrap: break-word;
  }
  .marvin-log :global(.mv-user) {
    align-self: flex-end; background: var(--accent); color: #fff; border-bottom-right-radius: 4px;
  }
  .marvin-log :global(.mv-marvin) {
    align-self: flex-start; background: var(--bg); color: var(--ink);
    border: 1px solid var(--line); border-bottom-left-radius: 4px;
  }
  /* Rendered markdown: tighten default block spacing so the bubble stays compact. */
  .marvin-log :global(.mv-answer > :first-child) { margin-top: 0; }
  .marvin-log :global(.mv-answer > :last-child) { margin-bottom: 0; }
  .marvin-log :global(.mv-answer p) { margin: 6px 0; }
  .marvin-log :global(.mv-answer ul), .marvin-log :global(.mv-answer ol) { margin: 6px 0; padding-left: 20px; }
  .marvin-log :global(.mv-answer li) { margin: 2px 0; }
  .marvin-log :global(.mv-answer h1), .marvin-log :global(.mv-answer h2),
  .marvin-log :global(.mv-answer h3), .marvin-log :global(.mv-answer h4) {
    margin: 10px 0 4px; font-size: 14px; font-weight: 650; line-height: 1.3;
  }
  .marvin-log :global(.mv-answer pre) {
    margin: 6px 0; padding: 8px 10px; background: var(--panel); border: 1px solid var(--line);
    border-radius: 6px; overflow-x: auto; font-size: 12px;
  }
  .marvin-log :global(.mv-answer pre code) { background: none; border: 0; padding: 0; }
  .marvin-log :global(.mv-answer img) { max-width: 100%; height: auto; border-radius: 6px; }
  .marvin-log :global(.mv-answer blockquote) {
    margin: 6px 0; padding-left: 10px; border-left: 3px solid var(--line); color: var(--muted);
  }
  /* Deterministic thumbnail strip from tool image assets. */
  .marvin-log :global(.mv-thumbs) {
    margin-top: 8px; display: flex; flex-wrap: wrap; gap: 6px;
  }
  .marvin-log :global(.mv-thumb) {
    display: block; width: 64px; height: 64px; border-radius: 8px; overflow: hidden;
    border: 1px solid var(--line); background: var(--panel); flex: 0 0 auto;
  }
  .marvin-log :global(.mv-thumb img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  .marvin-log :global(a.mv-thumb:hover) { border-color: var(--accent); }
  .marvin-log :global(.mv-sources) {
    margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--line);
    font-size: 12px; color: var(--muted);
  }
  .marvin-log :global(.mv-sources a), .marvin-log :global(.mv-answer a) { color: var(--accent); text-decoration: none; }
  .marvin-log :global(.mv-sources a:hover) { text-decoration: underline; }
  .marvin-log :global(.mv-help ul) { margin: 8px 0; padding-left: 18px; display: flex; flex-direction: column; gap: 4px; }
  .marvin-log :global(.mv-help code), .marvin-log :global(.mv-marvin code) {
    font-size: 12px; background: var(--panel); border: 1px solid var(--line);
    border-radius: 4px; padding: 1px 5px; font-family: ui-monospace, monospace;
  }
  .marvin-log :global(.mv-tools-group) { margin: 8px 0; }
  .marvin-log :global(.mv-tools-head) {
    display: block; font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.04em; color: var(--muted); margin-bottom: 2px;
  }
  .marvin-log :global(.mv-tools ul) { margin: 0; padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 3px; }
  .marvin-log :global(.mv-tools li) { display: flex; gap: 6px; align-items: baseline; font-size: 12px; }
  .marvin-log :global(.mv-tools li span) { color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .marvin-log :global(.mv-tools code) {
    font-size: 12px; background: var(--panel); border: 1px solid var(--line);
    border-radius: 4px; padding: 1px 5px; font-family: ui-monospace, monospace; flex: none;
  }
  .marvin-log :global(.mv-thinking) { color: var(--muted); font-style: italic; }
  .marvin-log :global(.mv-error) { color: var(--color-error); }
</style>
