---

<div class="emoji-picker-container">
  <input
    type="text"
    id={inputId}
    name="icon"
    value={value}
    maxlength="4"
    placeholder="Click to pick emoji..."
    readonly
    class="emoji-input"
  />
  <button type="button" class="emoji-trigger" data-emoji-trigger={inputId}>
    {value || '😀'}
  </button>

  <div class="emoji-picker" data-emoji-picker={inputId} hidden>
    <div class="emoji-picker-header">
      <span>Pick an emoji</span>
      <button type="button" class="emoji-close" data-emoji-close={inputId}>×</button>
    </div>
    <div class="emoji-picker-content">
      {emojiGroups.map(group => (
        <div class="emoji-group">
          <div class="emoji-group-name">{group.name}</div>
          <div class="emoji-grid">
            {group.emojis.map(emoji => (
              <button
                type="button"
                class="emoji-option"
                data-emoji={emoji}
                data-target={inputId}
              >
                {emoji}
              </button>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  function initEmojiPicker(triggerId: string) {
    const trigger = document.querySelector(`[data-emoji-trigger="${triggerId}"]`) as HTMLButtonElement;
    const picker = document.querySelector(`[data-emoji-picker="${triggerId}"]`) as HTMLElement;
    const close = document.querySelector(`[data-emoji-close="${triggerId}"]`) as HTMLButtonElement;
    const input = document.getElementById(triggerId) as HTMLInputElement;

    if (!trigger || !picker || !close || !input) return;

    // Open picker
    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      picker.toggleAttribute('hidden');
    });

    // Close picker
    close.addEventListener('click', (e) => {
      e.preventDefault();
      picker.setAttribute('hidden', '');
    });

    // Select emoji
    picker.querySelectorAll('.emoji-option').forEach(button => {
      button.addEventListener('click', (e) => {
        e.preventDefault();
        const btn = e.target as HTMLButtonElement;
        const emoji = btn.dataset.emoji!;
        input.value = emoji;
        trigger.textContent = emoji;
        picker.setAttribute('hidden', '');
      });
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      if (!trigger.contains(e.target as Node) && !picker.contains(e.target as Node)) {
        picker.setAttribute('hidden', '');
      }
    });
  }

  // Initialize all emoji pickers on the page
  document.querySelectorAll('[data-emoji-trigger]').forEach((trigger) => {
    const inputId = trigger.getAttribute('data-emoji-trigger');
    if (inputId) initEmojiPicker(inputId);
  });
</script>

<style>
  .emoji-picker-container {
    position: relative;
    display: flex;
    gap: 0.5rem;
    align-items: stretch;
  }

  .emoji-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.875rem;
    cursor: pointer;
  }

  .emoji-input:focus {
    outline: none;
    border-color: var(--accent);
  }

  .emoji-trigger {
    width: 48px;
    height: 48px;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--bg);
    font-size: 1.5rem;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .emoji-trigger:hover {
    background: var(--panel-2);
    border-color: var(--accent);
  }

  .emoji-picker {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    width: 320px;
    max-height: 400px;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    z-index: 100;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .emoji-picker[hidden] {
    display: none;
  }

  .emoji-picker-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--line);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .emoji-close {
    width: 24px;
    height: 24px;
    padding: 0;
    border: none;
    background: none;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    color: var(--muted);
    transition: color 0.2s;
  }

  .emoji-close:hover {
    color: var(--ink);
  }

  .emoji-picker-content {
    overflow-y: auto;
    padding: 0.5rem;
  }

  .emoji-group {
    margin-bottom: 1rem;
  }

  .emoji-group:last-child {
    margin-bottom: 0;
  }

  .emoji-group-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 0.5rem 0.5rem 0.25rem;
  }

  .emoji-grid {
    display: grid;
    grid-template-columns: repeat(9, 1fr);
    gap: 2px;
  }

  .emoji-option {
    width: 100%;
    aspect-ratio: 1;
    padding: 0.25rem;
    border: none;
    background: transparent;
    font-size: 1.25rem;
    cursor: pointer;
    border-radius: 4px;
    transition: background 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .emoji-option:hover {
    background: var(--panel-2);
  }
</style>
