---
import type { EntryRead } from "@/lib/api/types";

interface Props {
  entry: EntryRead;
}

const { entry } = Astro.props;
const asset = entry.assets?.find((item) => item.role === "featured" || item.role === "hero") ?? entry.assets?.[0];
---

<article class="card">
  <div class="media">
    {asset?.url ? <img src={asset.url} alt={asset.altText ?? entry.title} style={`object-position: ${asset.focalPoint ?? "50% 50%"}`} /> : null}
  </div>
  <div class="card-body">
    <a href={`/workspace/entries/${entry.id}`} class="card-title-link">
      <h2>{entry.title}</h2>
    </a>
    <p>{entry.summary}</p>
    <div class="meta">
      <span class={`pill ${entry.status}`}>{entry.status}</span>
      {entry.resources && entry.resources.length > 0 && (
        <span class="pill">{entry.resources.length} resource{entry.resources.length === 1 ? '' : 's'}</span>
      )}
    </div>
  </div>
</article>
