---
import "../styles/global.css";
import Marvin from "@/components/Marvin.astro";
import ThemeSwitcher from "@/components/ThemeSwitcher.astro";
import WorkspaceSwitcher from "@/components/WorkspaceSwitcher.astro";
import { getAuthToken } from "@/lib/api/client";
import { createSdkClient } from "@/lib/sdk";

interface Props {
  title: string;
  eyebrow?: string;
  /**
   * Optional page grounding for the Marvin bubble — what entity this page is rendering.
   * Detail pages declare it; it's stamped onto <body> as data-entity-* and read back by
   * @/lib/marvin/context. Grounding only: it does not widen permissions.
   */
  /**
   * Only declare a type the agent can actually resolve with a tool (get_entry, get_asset,
   * get_resource, get_collection, get_entry_type). Grounding a page whose entity the agent
   * cannot fetch invites hallucination rather than preventing it.
   */
  entityType?: "entry" | "asset" | "resource" | "collection" | "entry_type";
  entityId?: string;
  entityLabel?: string;
}

const { title, eyebrow = "Marvin Platform", entityType, entityId, entityLabel } = Astro.props;
const path = Astro.url.pathname;

// Check if user is admin and get platform role
const authToken = getAuthToken(Astro.cookies);
const sdk = createSdkClient(authToken);
let isAdmin = false;
let isSuperAdmin = false;
try {
  const currentUser = (await sdk.user.getProfile()) as any;
  isAdmin = currentUser?.admin === true;
  isSuperAdmin = currentUser?.platformRole === "SUPER_ADMIN";

  if (import.meta.env.DEV) {
    console.log("[AppLayout] User role check:", {
      admin: isAdmin,
      superAdmin: isSuperAdmin,
      platformRole: currentUser?.platformRole,
      workspaceMemberships: currentUser?.workspaceMemberships,
    });
    console.log("[AppLayout] Full user object:", currentUser);
  }
} catch (e) {
  // Not logged in or error
}

// Simplified navigation following 80% rule
// Primary sidebar contains only daily-use features
const navGroups = [
  {
    label: null,
    items: [{ href: "/", label: "Dashboard", icon: "⌂" }],
  },
  {
    label: "Content",
    items: [
      { href: "/workspace/entries", label: "Entries", icon: "📝" },
      { href: "/workspace/collections", label: "Collections", icon: "📚" },
      { href: "/workspace/assets", label: "Assets", icon: "🖼" },
      { href: "/workspace/resources", label: "Resources", icon: "🔗" },
    ],
  },
  {
    label: "Workspace",
    items: [
      // Lands on the workspace dashboard (/workspace); its tab banner navigates into each settings section.
      { href: "/workspace", label: "Settings", icon: "⚙" },
    ],
  },
];

const finalNavGroups = [
  ...navGroups,
  {
    label: null,
    items: [{ href: "/user/profile", label: "Profile", icon: "👤" }],
  },
];

// Admin settings link - only for super admins (platform-wide)
// Added at the very end with a separator label for visual distinction
if (isSuperAdmin) {
  finalNavGroups.push({
    label: "Administration",
    items: [{ href: "/admin", label: "Admin Settings", icon: "⚙" }],
  });
}

// Helper to check if path is active (exact or starts with for nested routes)
function isActive(itemPath: string, currentPath: string): boolean {
  if (itemPath === "/") {
    return currentPath === "/";
  }
  // The Workspace "Settings" item lands on /workspace (dashboard) and owns the settings
  // sections, but NOT sibling content routes like /workspace/entries or /workspace/assets.
  if (itemPath === "/workspace") {
    return currentPath === "/workspace" || currentPath.startsWith("/workspace/settings");
  }
  return currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Marvin platform admin frontend" />
    <title>{title} | Marvin</title>
  </head>
  <body
    data-entity-type={entityType}
    data-entity-id={entityId}
    data-entity-label={entityLabel}
  >
    <div class="app-shell">
      <aside class="sidebar">
        <div class="sidebar-header">
          <WorkspaceSwitcher />
        </div>
        {finalNavGroups.map((group, groupIndex) => (
          <div class:list={["nav-group", { "nav-group-admin": group.label === "Administration" }]}>
            {group.label && (
              <div class="nav-group-label">{group.label}</div>
            )}
            <nav class="nav" aria-label={group.label || "Primary"}>
              {group.items.map((item) => (
                <a href={item.href} aria-current={isActive(item.href, path) ? "page" : undefined}>
                  <span aria-hidden="true">{item.icon}</span>
                  <span>{item.label}</span>
                </a>
              ))}
            </nav>
          </div>
        ))}
      </aside>
      <main class="main">
        <header class="topbar">
          <div class="topbar-left">
            <div class="topbar-title">
              <p>{eyebrow}</p>
              <h1>{title}</h1>
            </div>
          </div>
          <div class="topbar-actions">
            <a class="button secondary" href="/workspace/entries?status=needs_review,approved">Review Queue</a>
            <form method="POST" action="/api/auth/logout" style="display:inline;">
              <button type="submit" class="button secondary">Logout</button>
            </form>
          </div>
        </header>
        <section class="content">
          <slot />
        </section>
      </main>
      <ThemeSwitcher />
      <Marvin />
    </div>
  </body>
</html>
