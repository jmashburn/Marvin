---
import "../styles/global.css";
import WorkspaceSwitcher from "@/components/WorkspaceSwitcher.astro";
import { getAuthToken, fetchApi } from "@/lib/api/client";

interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow = "Marvin Platform" } = Astro.props;
const path = Astro.url.pathname;

// Check if user is admin
const authToken = getAuthToken(Astro.cookies);
let isAdmin = false;
try {
  const currentUser = await fetchApi<any>('/api/self', {}, authToken);
  isAdmin = currentUser?.admin === true;
} catch (e) {
  // Not logged in or error
}

// Grouped navigation structure for workflow-oriented UX
const navGroups = [
  {
    label: null, // No label for top-level items
    items: [
      { href: "/", label: "Dashboard", icon: "⌂" },
    ]
  },
  {
    label: "Content",
    items: [
      { href: "/entries", label: "Entries", icon: "▤" },
      { href: "/collections", label: "Collections", icon: "☰" },
    ]
  },
  {
    label: "Structure",
    items: [
      { href: "/entry-types", label: "Entry Types", icon: "◈" },
    ]
  },
  {
    label: "Publishing",
    items: [
      { href: "/publishing/site", label: "Site", icon: "◉" },
      { href: "/publishing/clients", label: "Clients", icon: "⚡" },
      { href: "/assets", label: "Assets", icon: "◫" },
    ]
  },
  {
    label: "Workspace",
    items: [
      { href: "/workspace/members", label: "Members", icon: "👥" },
      { href: "/workspace/webhooks", label: "Webhooks", icon: "🔗" },
      { href: "/workspace/settings", label: "Settings", icon: "⚙" },
    ]
  },
  {
    label: "User",
    items: [
      { href: "/user/profile", label: "Profile", icon: "👤" },
      { href: "/user/api-tokens", label: "API Tokens", icon: "🔑" },
    ]
  },
];

// Add admin link if user is admin
if (isAdmin) {
  navGroups.push({
    label: "Administration",
    items: [
      { href: "/admin", label: "Admin Panel", icon: "⚡" },
    ]
  });
}

// Helper to check if path is active (exact or starts with for nested routes)
function isActive(itemPath: string, currentPath: string): boolean {
  if (itemPath === "/") {
    return currentPath === "/";
  }
  return currentPath === itemPath || currentPath.startsWith(itemPath + "/");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Marvin platform admin frontend" />
    <title>{title} | Marvin</title>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href="/">
          <strong>Marvin</strong>
          <span>Content engine</span>
        </a>
        {navGroups.map((group, groupIndex) => (
          <div class="nav-group">
            {group.label && (
              <div class="nav-group-label">{group.label}</div>
            )}
            <nav class="nav" aria-label={group.label || "Primary"}>
              {group.items.map((item) => (
                <a href={item.href} aria-current={isActive(item.href, path) ? "page" : undefined}>
                  <span aria-hidden="true">{item.icon}</span>
                  <span>{item.label}</span>
                </a>
              ))}
            </nav>
          </div>
        ))}
      </aside>
      <main class="main">
        <header class="topbar">
          <div class="topbar-left">
            <WorkspaceSwitcher />
            <div class="topbar-title">
              <p>{eyebrow}</p>
              <h1>{title}</h1>
            </div>
          </div>
          <div class="topbar-actions">
            <a class="button secondary" href="/entries">Review Queue</a>
            <form method="POST" action="/api/auth/logout" style="display:inline;">
              <button type="submit" class="button secondary">Logout</button>
            </form>
          </div>
        </header>
        <section class="content">
          <slot />
        </section>
      </main>
    </div>
  </body>
</html>
