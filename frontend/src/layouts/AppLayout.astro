---
import "../styles/global.css";

interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow = "Marvin Platform" } = Astro.props;
const path = Astro.url.pathname;

const nav = [
  { href: "/", label: "Dashboard", icon: "⌂" },
  { href: "/entries", label: "Entries", icon: "▤" },
  { href: "/assets", label: "Assets", icon: "◫" },
  { href: "/site-clients", label: "Site Clients", icon: "◉" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Marvin platform admin frontend" />
    <title>{title} | Marvin</title>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href="/">
          <strong>Marvin</strong>
          <span>Content engine</span>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} aria-current={path === item.href ? "page" : undefined}>
              <span aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </a>
          ))}
        </nav>
      </aside>
      <main class="main">
        <header class="topbar">
          <div>
            <p>{eyebrow}</p>
            <h1>{title}</h1>
          </div>
          <a class="button secondary" href="/entries">Review Queue</a>
        </header>
        <section class="content">
          <slot />
        </section>
      </main>
    </div>
  </body>
</html>
