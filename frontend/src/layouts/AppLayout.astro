---
import "../styles/global.css";
import WorkspaceSwitcher from "@/components/WorkspaceSwitcher.astro";

interface Props {
  title: string;
  eyebrow?: string;
}

const { title, eyebrow = "Marvin Platform" } = Astro.props;
const path = Astro.url.pathname;

const nav = [
  { href: "/", label: "Dashboard", icon: "⌂" },
  { href: "/entries", label: "Entries", icon: "▤" },
  { href: "/entry-types", label: "Entry Types", icon: "◈" },
  { href: "/collections", label: "Collections", icon: "☰" },
  { href: "/assets", label: "Assets", icon: "◫" },
  { href: "/site-clients", label: "Publishing", icon: "◉" },
];

const settingsNav = [
  { href: "/settings/workspace", label: "Workspace", icon: "⚙" },
  { href: "/workspaces", label: "Workspaces", icon: "◱" },
];

// Helper to check if path is active (exact or starts with for nested routes)
function isActive(itemPath: string, currentPath: string): boolean {
  if (itemPath === "/") {
    return currentPath === "/";
  }
  return currentPath === itemPath || currentPath.startsWith(itemPath + "/");
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Marvin platform admin frontend" />
    <title>{title} | Marvin</title>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar">
        <a class="brand" href="/">
          <strong>Marvin</strong>
          <span>Content engine</span>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href, path) ? "page" : undefined}>
              <span aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </a>
          ))}
        </nav>
        <div class="nav-divider"></div>
        <div class="nav-section">Settings</div>
        <nav class="nav" aria-label="Settings">
          {settingsNav.map((item) => (
            <a href={item.href} aria-current={isActive(item.href, path) ? "page" : undefined}>
              <span aria-hidden="true">{item.icon}</span>
              <span>{item.label}</span>
            </a>
          ))}
        </nav>
      </aside>
      <main class="main">
        <header class="topbar">
          <div class="topbar-left">
            <WorkspaceSwitcher />
            <div class="topbar-title">
              <p>{eyebrow}</p>
              <h1>{title}</h1>
            </div>
          </div>
          <div class="topbar-actions">
            <a class="button secondary" href="/entries">Review Queue</a>
            <form method="POST" action="/api/auth/logout" style="display:inline;">
              <button type="submit" class="button secondary">Logout</button>
            </form>
          </div>
        </header>
        <section class="content">
          <slot />
        </section>
      </main>
    </div>
  </body>
</html>
