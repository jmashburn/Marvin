{
    "name": "Python 3",
    "build": {
        "dockerfile": "Dockerfile",
        "context": "..",
        "args": {
            "VARIANT": "3.12-bookworm",
            "APT_PROXY": "none"
        }
    },
    "mounts":[
        "source=marvin-bashhistory,target=/home/vscode/commandhistory,type=volume",
        "source=${localEnv:HOME}/.password-store,target=/home/vscode/.password-store,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python",
                "python.formatting.autopep8Path": "/usr/local/py-utils/bin/autopep8",
                "python.formatting.blackPath": "/usr/local/py-utils/bin/black",
                "python.formatting.yapfPath": "/usr/local/py-utils/bin/yapf",
                "editor.rulers": [
                    {
                        "column": 120
                    }
                ],
                "git.allowForcePush": true
            },
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.pylint",
                "matangover.mypy",
                "ms-python.black-formatter",
                "ms-azuretools.vscode-docker"
            ]
        }
    },
    "postCreateCommand": "bash -t .devcontainer/post-create.sh",
    "waitFor": "postCreateCommand",
    "features": {
        "ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {
            "version": "latest"
        },
        "ghcr.io/eitsupi/devcontainer-features/go-task:1": {
            "version": "latest"
        },
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "moby": true,
            "azureDnsAutoDetection": true,
            "installDockerBuildx": true,
            "version": "latest",
            "dockerDashComposeVersion": "none"
        },
        "ghcr.io/devcontainers-extra/features/claude-code:1": {
            "version": "latest"
        }
    },
    "forwardPorts": [
        3000,
        9000,
        9091,
        25678
    ],
    "onCreateCommand": "task setup"
}
