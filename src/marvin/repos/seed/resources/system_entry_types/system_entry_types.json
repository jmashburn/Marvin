[
  {
    "name": "Page",
    "slug": "page",
    "icon": "\ud83d\udcc4",
    "color": "#2563EB",
    "description": "A standard content page with markdown body content.",
    "sort_order": 100,
    "is_system": true,
    "isRendered": true,
    "schema_json": {
      "fields": [
        {
          "key": "body",
          "label": "Body",
          "type": "markdown",
          "required": true,
          "placeholder": "Write page content..."
        }
      ]
    },
    "renderingJson": {
      "renderer": "page",
      "package": "@inneropen/marvin-renderers-core",
      "version": "^1.0.0"
    },
    "capabilitiesJson": {
      "publishable": true,
      "submittable": false,
      "routable": true
    },
    "recipeJson": {
      "assets": {
        "min": 0,
        "max": 5,
        "roles": [
          {
            "role": "hero",
            "max": 1,
            "derive": [
              "thumbnail",
              "palette"
            ]
          },
          {
            "role": "gallery",
            "max": 4
          }
        ]
      },
      "resources": {
        "extract": [
          {
            "type": "supplier",
            "source": "body",
            "capture": [
              "name",
              "url"
            ]
          },
          {
            "type": "tool",
            "source": "body",
            "capture": [
              "name"
            ]
          }
        ]
      }
    }
  },
