{
  "version": 1,
  "disable_existing_loggers": false,
  "handlers": {
    "rich": {
      "class": "rich.logging.RichHandler"
    }
  },
  "loggers": {
    "root": {
      "level": "DEBUG",
      "handlers": [
        "rich"
      ]
    },
    "httpx": { "level": "WARNING" },
    "httpcore": { "level": "WARNING" },
    "openai": { "level": "WARNING" }
  }
}
